<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Icons -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">

  <!-- Admin Premium Styles -->
  <link rel="stylesheet" href="/admin/css/admin-style.css">

  <style>
    /* Specific overrides for Dashboard charts and mobile layout */
    .main-content {
      margin-left: var(--sidebar-w);
      padding: 40px;
      transition: var(--transition);
    }

    .sidebar {
      width: var(--sidebar-w);
      height: 100vh;
      position: fixed;
      background: var(--bg-dark);
      border-right: 1px solid var(--border);
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        z-index: 1050;
      }
      .sidebar.open {
        transform: translateX(0);
      }
      .main-content {
        margin-left: 0;
        padding: 20px;
      }
    }
  </style>
</head>

<body>

  <!-- Sidebar -->
  <div class="sidebar reveal-init">
    <div class="p-4 mb-4 font-heading">
      <div class="logo-box">
        <span class="material-symbols-outlined text-primary text-2xl font-bold">smartphone</span>
        <span class="logo-text">Starzo</span>
      </div>
    </div>

    <nav class="flex-column px-2">
      <a href="/admin/dashboard" class="sidebar-link active">
        <span class="material-symbols-outlined">dashboard</span>Dashboard
      </a>
      <a href="/admin/product/productManagement" class="sidebar-link">
        <span class="material-symbols-outlined">inventory_2</span>Products
      </a>
      <a href="/admin/category/categories" class="sidebar-link">
        <span class="material-symbols-outlined">category</span>Categories
      </a>
      <a href="/admin/management" class="sidebar-link">
        <span class="material-symbols-outlined">people</span>Customers
      </a>
    </nav>

    <div class="mt-auto pt-3 border-top border-light">
      <small class="text-dim">Mohammad Anshad</small><br>
      <small class="text-muted">Admin Account</small>
    </div>
  </div>

  <!-- Main -->
  <div class="main-content">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 stagger-1">
      <div class="d-flex align-items-center gap-3">
        <button class="mobile-nav-toggle d-md-none border-0 bg-transparent text-main"
          onclick="document.querySelector('.sidebar').classList.toggle('open')">
          <span class="material-icons-outlined">menu</span>
        </button>
        <div>
          <h3 class="fw-bold mb-0">Admin Dashboard</h3>
          <small class="text-dim">Welcome back, here's what's happening today.</small>
        </div>
      </div>

      <button class="btn-premium">
        <span class="material-icons-outlined">assessment</span>
        View Sales Report
      </button>
    </div>


    <div class="row g-4 mb-4 stagger-2">
      <div class="col-md-3">
        <div class="admin-card p-4">
          <small class="text-muted">Total Revenue</small>
          <h4 class="fw-bold mt-2">$45,231.89</h4>
          <small class="text-success">+20% this month</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="admin-card p-4">
          <small class="text-muted">Total Orders</small>
          <h4 class="fw-bold mt-2">2,350</h4>
          <small class="text-success">+15%</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="admin-card p-4">
          <small class="text-muted">Pending Orders</small>
          <h4 class="fw-bold mt-2">48</h4>
          <small class="text-warning">Needs Attention</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="admin-card p-4">
          <small class="text-muted">Active Users</small>
          <h4 class="fw-bold mt-2">12,234</h4>
          <small class="text-success">+7%</small>
        </div>
      </div>
    </div>

    <!-- Revenue Chart -->
    <div class="row g-4 mb-4 stagger-3">
      <div class="col-lg-8">
        <div class="admin-card p-4">
          <h5 class="fw-bold mb-3">Revenue Overview</h5>
          <canvas id="revenueChart" height="120"></canvas>
        </div>
      </div>

      <!-- Recent Sales -->
      <div class="col-lg-4">
        <div class="admin-card p-4">
          <h5 class="fw-bold mb-3">Recent Sales</h5>

          <div class="d-flex justify-content-between mb-3">
            <span>Olivia Martin</span>
            <strong class="text-main">$1,999</strong>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <span>Jackson Lee</span>
            <strong class="text-main">$39</strong>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <span>Isabella Nguyen</span>
            <strong class="text-main">$299</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span>William Chen</span>
            <strong class="text-main">$1,999</strong>
          </div>

        </div>
      </div>
    </div>

    <!-- Products + Categories -->
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="admin-card p-4">
          <h5 class="fw-bold mb-3">Top Trending Products</h5>

          <div class="table-responsive">
            <table class="premium-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Category</th>
                  <th class="text-end">Sales</th>
                  <th class="text-end">Revenue</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Galaxy S23 Ultra</td>
                  <td>Samsung</td>
                  <td class="text-end">342</td>
                  <td class="text-end">$1,995,390</td>
                </tr>
                <tr>
                  <td>iPhone 17 Pro</td>
                  <td>Apple</td>
                  <td class="text-end">288</td>
                  <td class="text-end">$999,988</td>
                </tr>
                <tr>
                  <td>Redmi Note 13 Pro</td>
                  <td>Xiaomi</td>
                  <td class="text-end">245</td>
                  <td class="text-end">$1,290,999</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Categories -->
      <div class="col-lg-4">
        <div class="admin-card p-4">
          <h5 class="fw-bold mb-3">Top Categories</h5>

          <p class="mb-1 text-dim">Samsung 45%</p>
          <div class="progress mb-3" style="background: var(--border-light); height: 8px;">
            <div class="progress-bar" style="width:45%; background: var(--primary);"></div>
          </div>

          <p class="mb-1 text-dim">Xiaomi 28%</p>
          <div class="progress mb-3" style="background: rgba(238, 238, 238, 0.05); height: 8px;">
            <div class="progress-bar" style="width:28%; background: var(--primary);"></div>
          </div>

          <p class="mb-1 text-dim">Apple 15%</p>
          <div class="progress mb-3" style="background: rgba(238, 238, 238, 0.05); height: 8px;">
            <div class="progress-bar" style="width:15%; background: var(--primary);"></div>
          </div>

          <p class="mb-1 text-dim">Others 12%</p>
          <div class="progress" style="background: rgba(238, 238, 238, 0.05); height: 8px;">
            <div class="progress-bar" style="width:12%; background: var(--primary);"></div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <!-- Chart Script -->
  <script>
    const ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
        datasets: [{
          label: 'Revenue',
          data: [200, 180, 190, 140, 145, 90, 80, 30, 20],
          borderColor: '#50C878',
          backgroundColor: 'rgba(80,200,120,.2)',
          tension: .4,
          fill: true
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(0,0,0,0.02)' } },
          y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(0,0,0,0.02)' } }
        }
      }
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Query Path params -->
  <% if (typeof msg !=='undefined' ) { %>
    <script>
      Swal.fire({
        title: "<%=msg%>",
        text: "Success!",
        icon: "<%=icon%>",
        background: '#ffffff',
        color: '#0f172a',
      });

      const url = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.replaceState({ path: url }, '', url);

    </script>
    <% } %>

</body>

</html>