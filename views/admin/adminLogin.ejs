<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"> 
    
    <!-- Admin Premium Styles -->
    <link rel="stylesheet" href="/admin/css/admin-style.css">

    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script> 
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
        }

        .logo-box {
            width: 64px;
            height: 64px;
            background: var(--primary);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            box-shadow: 0 0 30px var(--primary-glow);
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
            z-index: 10;
        }

        .admin-input {
            padding-left: 45px;
        }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--text-muted);
            z-index: 10;
        }

        .error-text {
            color: var(--danger);
            font-size: 0.8rem;
            margin-top: 4px;
            font-weight: 500;
        }

        .footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: var(--transition);
        }

        .footer-links a:hover {
            color: var(--primary);
        }
    </style>
</head>


<body>


    <main class="login-container">


        <div class="text-center mb-5 stagger-1">

            <div class="logo-box reveal-init">
                <span class="material-icons-outlined text-dark fs-3">shield</span>
            </div>

            <h2 class="fw-bold reveal-init stagger-2">Admin Portal</h2>

            <small class="text-dim reveal-init stagger-3">Starzo E-commerce Management</small>

        </div>



        <div class="admin-card reveal-init stagger-4">


            <form id="adminLoginForm" action="/admin/auth/login" method="POST" novalidate>



                <div class="mb-4">

                    <label class="form-label small text-dim">Admin Email</label>

                    <div class="position-relative">
                        <span class="material-icons-outlined input-icon">person</span>

                        <input type="email" id="email" name="email" class="admin-input"
                            placeholder="Enter admin email">
                    </div>

                    <div id="emailError" class="error-text"></div>

                </div>



                <div class="mb-4">

                    <div class="d-flex justify-content-between mb-2">

                        <label class="form-label small text-dim">Password</label>

                        <a href="#" class="small text-primary text-decoration-none">Forgot Password</a>

                    </div>

                    <div class="position-relative">
                        <span class="material-icons-outlined input-icon">lock</span>

                        <input type="password" name="password" id="password" class="admin-input pe-5"
                            placeholder="••••••••">

                        <span class="material-icons-outlined password-toggle" id="togglePassword">visibility</span>
                    </div>

                    <div id="passwordError" class="error-text"></div>

                </div>



                <div class="form-check mb-4">

                    <input class="form-check-input" type="checkbox" id="trustDevice">

                    <label class="form-check-label text-muted small" for="trustDevice">
                        Trust this device for 30 days
                    </label>

                </div>



                <button type="submit" class="btn-premium w-100 justify-content-center">

                    <span class="material-icons-outlined">verified_user</span>

                    Secure Login

                </button>

            </form>



            <div class="text-center mt-4 pt-4 border-top border-light">

                <small class="text-muted text-uppercase" style="letter-spacing:2px; font-size:10px; opacity: 0.5;">
                    Protected by 256-bit encryption
                </small>

            </div>

        </div>



        <div class="footer-links text-center mt-4 small">

            <a href="#">Help Center</a>

            <span class="mx-2">•</span>

            <a href="#">Privacy Policy</a>

            <span class="mx-2">•</span>

            <a href="#">Terms of Service</a>

        </div>

    </main>



    <script>

        const form = document.getElementById("adminLoginForm");

        const email = document.getElementById("email");
        const password = document.getElementById("password");

        const emailError = document.getElementById("emailError");
        const passwordError = document.getElementById("passwordError");


        /* REGEX PATTERNS */

        const emailRegex = /^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.[A-Za-z]{2,}$/;

        const passwordRegex =
            /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/;



        /* EMAIL VALIDATION */

        email.addEventListener("input", () => {

            const value = email.value.trim();

            if (value === "") {
                emailError.textContent = "Email is required";
                return;
            }

            if (!emailRegex.test(value)) {
                emailError.textContent = "Enter a valid email (example: admin@starzo.com)";
            } else {
                emailError.textContent = "";
            }

        });



        /* PASSWORD VALIDATION */

        password.addEventListener("input", () => {

            const value = password.value;

            if (value === "") {
                passwordError.textContent = "Password is required";
                return;
            }

            if (!passwordRegex.test(value)) {
                passwordError.textContent =
                    "Password must contain 8+ characters, uppercase, lowercase, number and special character";
            } else {
                passwordError.textContent = "";
            }

        });



        /* FORM SUBMIT VALIDATION */

        form.addEventListener("submit", (e) => {

            let valid = true;

            const emailValue = email.value.trim();
            const passwordValue = password.value;



            if (!emailRegex.test(emailValue)) {

                emailError.textContent =
                    "Enter a valid email address";

                valid = false;

            }



            if (!passwordRegex.test(passwordValue)) {

                passwordError.textContent =
                    "Password must contain uppercase, lowercase, number and special character";

                valid = false;

            }



            if (!valid) {
                e.preventDefault();
            }

        });


        document.addEventListener("DOMContentLoaded", function () {

            const togglePassword = document.getElementById("togglePassword");
            const password = document.getElementById("password");

            togglePassword.addEventListener("click", function () {

                if (password.type === "password") {
                    password.type = "text";
                    togglePassword.textContent = "visibility_off";
                } else {
                    password.type = "password";
                    togglePassword.textContent = "visibility";
                }

            });

        });


<% if (error) { %>

Toastify({
  text: "<%= error %>",
  duration: 3000,
  gravity: "top",
  position: "right",
  backgroundColor: "#ef4444",
  stopOnFocus: true
}).showToast();

<% } %>


    </script>


</body>

</html>