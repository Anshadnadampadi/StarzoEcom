<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    
    <!-- Admin Premium Styles -->
    <link rel="stylesheet" href="/admin/css/admin-style.css">

    <style>
        .sidebar {
            height: 100vh;
            background: var(--bg-dark);
            position: fixed;
            width: var(--sidebar-w);
            border-right: 1px solid var(--border);
            z-index: 100;
        }

        .main-content {
            margin-left: var(--sidebar-w);
            padding: 40px;
            transition: var(--transition);
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid var(--border-light);
            object-fit: cover;
        }

        .avatar-letter {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--primary-glow);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }

        .btn-action {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-light);
            background: var(--bg-surface);
            color: var(--text-dim);
            transition: var(--transition);
        }

        .btn-action:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-glow);
        }

        .btn-delete:hover {
            border-color: var(--danger);
            color: var(--danger);
            background: rgba(224, 90, 90, 0.1);
        }

        .badge-active {
            background: var(--primary-glow);
            color: var(--primary);
        }

        .badge-blocked {
            background: rgba(224, 90, 90, 0.1);
            color: var(--danger);
        }

        .pagination .page-link {
            background: var(--bg-surface);
            color: var(--text-main);
            border: 1px solid var(--border-light);
            border-radius: 8px;
            margin: 0 4px;
        }

        .pagination .page-item.active .page-link {
            background: var(--primary);
            border-color: var(--primary);
            color: var(--bg-dark);
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
                padding: 20px;
            }
        }
    </style>
</head>

<body>

    <aside class="sidebar reveal-init">
        <div class="p-4 mb-4 font-heading">
            <div class="logo-box">
                <span class="material-symbols-outlined text-primary text-2xl font-bold">smartphone</span>
                <span class="logo-text">Starzo</span>
            </div>
        </div>

        <nav class="flex-column px-2 mb-auto">
            <a href="/admin/dashboard" class="sidebar-link">
                <span class="material-symbols-outlined">dashboard</span>Dashboard
            </a>
            <a href="/admin/product/productManagement" class="sidebar-link">
                <span class="material-symbols-outlined">inventory_2</span>Products
            </a>
            <a href="/admin/category/categories" class="sidebar-link">
                <span class="material-symbols-outlined">category</span>Categories
            </a>
            <a href="/admin/management" class="sidebar-link active">
                <span class="material-symbols-outlined">people</span>Customers
            </a>
        </nav>

        <a href="/admin/auth/logout" class="sidebar-link mt-auto text-danger">
            <i class="fas fa-sign-out-alt"></i>Logout
        </a>

    </div>


    <div class="main-content stagger-1">

        <h2 class="fw-bold mb-1">
            <button class="mobile-nav-toggle d-md-none btn btn-link p-0 me-2"
                onclick="document.querySelector('.sidebar').classList.toggle('open')"
                style="font-size:24px; color:var(--text-muted);">
                <i class="fas fa-bars"></i>
            </button>
            User Management
        </h2>
        <p class="text-dim mb-4">Manage system users</p>


        <div class="admin-card stagger-2">


            <form class="d-flex align-items-center gap-2 mb-4" method="get">

                <input type="text" name="search" class="admin-input rounded-pill"
                    placeholder="Search users..." value="<%= search || '' %>" style="width:220px">
                <input type="hidden" name="page" value="1">
                <input type="hidden" name="limit" value="<%= limit %>">

                <select name="status" class="admin-input" style="width:160px">

                    <option value="">All Users</option>

                    <option value="active" <%=status==='active' ? 'selected' : '' %>>
                        Active
                    </option>

                    <option value="blocked" <%=status==='blocked' ? 'selected' : '' %>>
                        Blocked
                    </option>

                </select>

                <button class="btn-premium rounded-pill px-3"> Filter
                    <i class="fas fa-search"></i>
                </button>
                <% if (search && search.trim().length> 0) { %>
                    <a href="<%= clearSearchUrl %>" class="btn btn-outline-primary rounded-pill px-3">Clear</a>
                    <% } %>

            </form>



            <div class="table-responsive">
                <table class="premium-table">

                    <thead>

                        <tr>

                            <th>User</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th class="text-right">Actions</th>

                        </tr>

                    </thead>


                <tbody>

                    <% if(currUser.length<=0){ %>

                        <tr>
                            <td colspan="4">No users found</td>
                        </tr>

                        <% } else { %>

                            <% currUser.forEach(user=>{ %>
                                <% const isUserBlocked=user.status===0 || user.isBlocked===true; %>

                                    <tr>

                                        <td>

                                            <div class="d-flex align-items-center">
                                                <% if (user && (user.profileImage || user.avatar)) { %>

                                                    <img src="<%= user.profileImage || user.avatar %>" alt="User"
                                                        class="avatar" title="My Profile" />

                                                    <% } else { %>

                                                        <div class="avatar-letter">
                                                            <%= user && user.name ? user.name.charAt(0).toUpperCase()
                                                                : 'U' %>
                                                        </div>

                                                        <% } %>
                                                                 <div>

                                                                <div class="fw-bold text-main">
                                                                    <%=user.name%>
                                                                </div>

                                                                <div class="text-muted small">ID: <%=user._id%>
                                                                </div>

                                                            </div>

                                            </div>

                                        </td>

                                        <td class="text-dim">
                                            <%=user.email%>
                                        </td>

                                        <% if(!isUserBlocked){ %>

                                            <td>
                                                <span class="badge badge-active px-3 py-1 rounded-pill">
                                                    Active
                                                </span>
                                            </td>

                                            <% } else { %>

                                                <td>
                                                    <span class="badge badge-blocked px-3 py-1 rounded-pill">
                                                        Blocked
                                                    </span>
                                                </td>

                                                <% } %>


                                                    <td class="text-right">

                                                        <div class="d-flex justify-content-end gap-2">

                                                            <% if(!isUserBlocked){ %>

                                                                <form action="/admin/block/<%=user._id%>" method="post"
                                                                    class="blockForm">

                                                                    <button class="btn-action btn-block">
                                                                        <i class="fas fa-ban"></i>
                                                                    </button>

                                                                </form>

                                                                <% } else { %>

                                                                    <form action="/admin/unblock/<%=user._id%>"
                                                                        method="post" class="unblockForm">

                                                                        <button class="btn-action btn-block">
                                                                            <i class="fas fa-unlock"></i>
                                                                        </button>

                                                                    </form>

                                                                    <% } %>


                                                                        <form action="/admin/delete/<%=user._id%>"
                                                                            method="post" class="deleteForm">

                                                                            <button class="btn-action btn-delete">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>

                                                                        </form>

                                                        </div>

                                                    </td>

                                    </tr>

                                    <% }) %>

                                        <% } %>

                </tbody>

            </table>

            <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
                <nav aria-label="Users pagination" class="mt-4">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                            <a class="page-link"
                                href="?search=<%= encodeURIComponent(search || '') %>&status=<%= encodeURIComponent(status || '') %>&page=<%= page - 1 %>&limit=<%= limit %>">
                                Previous
                            </a>
                        </li>

                        <% for(let i=1; i <=totalPages; i++) { %>
                            <li class="page-item <%= page === i ? 'active' : '' %>">
                                <a class="page-link"
                                    href="?search=<%= encodeURIComponent(search || '') %>&status=<%= encodeURIComponent(status || '') %>&page=<%= i %>&limit=<%= limit %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>

                                <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="?search=<%= encodeURIComponent(search || '') %>&status=<%= encodeURIComponent(status || '') %>&page=<%= page + 1 %>&limit=<%= limit %>">
                                        Next
                                    </a>
                                </li>
                    </ul>
                </nav>
                <% } %>

        </div>

    </div>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <script>

        document.querySelectorAll(".blockForm").forEach(form => {
            form.addEventListener("submit", function (e) {

                e.preventDefault()

                Swal.fire({
                    title: "Block this user?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes"
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit()
                    }
                })

            })
        })


        document.querySelectorAll(".unblockForm").forEach(form => {
            form.addEventListener("submit", function (e) {

                e.preventDefault()

                Swal.fire({
                    title: "Unblock this user?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes"
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit()
                    }
                })

            })
        })


        document.querySelectorAll(".deleteForm").forEach(form => {
            form.addEventListener("submit", function (e) {

                e.preventDefault()

                Swal.fire({
                    title: "Delete this user?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes"
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit()
                    }
                })

            })
        })
    





    </script>

</body>

</html>