<%- contentFor('body') %>

<style>
    .report-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    .report-card:hover {
        border-color: rgba(255, 106, 0, 0.2);
    }
    .stat-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.3);
    }
    .filter-btn {
        padding: 6px 16px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 20px;
        transition: all 0.3s ease;
        color: rgba(255, 255, 255, 0.4);
    }
    .filter-btn.active {
        background: #ff6a00;
        color: #000;
    }
    .table-header {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.2);
        padding: 16px 24px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .growth-indicator {
        font-size: 10px;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 4px;
    }
</style>

<div class="space-y-8" x-data="{ 
    filter: '<%= filter %>',
    showCustom: <%= filter === 'custom' %>,
    updateFilter(val) {
        if(val === 'custom') {
            this.showCustom = true;
        } else {
            window.location.href = `/admin/sales-report?filter=${val}`;
        }
    }
}">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Sales Report</h1>
            <p class="text-white/40 text-xs font-bold uppercase tracking-widest mt-1">
                Performance overview • <%= period.start ? period.start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '...' %> → <%= period.end ? period.end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '...' %>
            </p>
        </div>
        
        <div class="flex items-center gap-4">
            <!-- Period Filters -->
            <div class="bg-white/5 p-1 rounded-full flex gap-1">
                <button @click="updateFilter('daily')" :class="filter === 'daily' ? 'active' : ''" class="filter-btn">Day</button>
                <button @click="updateFilter('weekly')" :class="filter === 'weekly' ? 'active' : ''" class="filter-btn">Week</button>
                <button @click="updateFilter('monthly')" :class="filter === 'monthly' ? 'active' : ''" class="filter-btn">Month</button>
                <button @click="updateFilter('yearly')" :class="filter === 'yearly' ? 'active' : ''" class="filter-btn">Year</button>
                <button @click="showCustom = !showCustom" :class="filter === 'custom' ? 'active' : ''" class="filter-btn">Custom</button>
            </div>

            <!-- Export Dropdown -->
            <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" class="flex items-center gap-3 px-6 py-2.5 bg-status-success text-black text-[11px] font-black uppercase tracking-widest rounded-sm hover:bg-white transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Export
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </button>
                <div x-show="open" @click.away="open = false" class="absolute right-0 mt-2 w-48 bg-[#111] border border-white/10 rounded-sm shadow-2xl z-50 overflow-hidden">
                    <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=pdf" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">PDF Report</a>
                    <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=excel" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">Excel Sheet</a>
                    <a href="/admin/sales-report/download?filter=<%= filter %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=ledger" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">Ledger Book</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Custom Date Range Form (Hidden by default) -->
    <div x-show="showCustom" x-collapse class="bg-white/5 border border-white/5 p-6 rounded-lg">
        <form action="/admin/sales-report" method="GET" class="flex flex-wrap gap-6 items-end">
            <input type="hidden" name="filter" value="custom">
            <div class="space-y-2">
                <label class="stat-label">Start Date</label>
                <input type="date" name="startDate" value="<%= startDate %>" class="block bg-black border border-white/10 text-white text-xs px-4 py-2 focus:border-accent outline-none rounded-sm">
            </div>
            <div class="space-y-2">
                <label class="stat-label">End Date</label>
                <input type="date" name="endDate" value="<%= endDate %>" class="block bg-black border border-white/10 text-white text-xs px-4 py-2 focus:border-accent outline-none rounded-sm">
            </div>
            <button type="submit" class="px-8 py-2 bg-white text-black text-[11px] font-bold uppercase tracking-widest hover:bg-accent hover:text-white transition-all rounded-sm">Generate Report</button>
        </form>
    </div>

    <!-- Top Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="report-card p-8 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <svg class="w-12 h-12 text-status-success" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"></path><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="stat-label mb-6">Total Revenue</p>
            <p class="text-3xl font-bold text-white mb-2">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
            <% const growth = previousRevenue > 0 ? ((stats.totalRevenue - previousRevenue) / previousRevenue * 100).toFixed(1) : 100; %>
            <div class="flex items-center gap-2">
                <span class="growth-indicator <%= growth >= 0 ? 'bg-status-success/10 text-status-success' : 'bg-status-danger/10 text-status-danger' %>">
                    <%= growth >= 0 ? '+' : '' %><%= growth %>%
                </span>
                <span class="text-[9px] font-bold text-white/20 uppercase tracking-widest">vs prev. period</span>
            </div>
        </div>

        <div class="report-card p-8">
            <p class="stat-label mb-6">Total Orders</p>
            <p class="text-3xl font-bold text-white mb-2"><%= stats.totalSales %></p>
            <p class="text-[10px] font-bold text-white/20 uppercase tracking-widest">Delivered orders</p>
        </div>

        <div class="report-card p-8">
            <p class="stat-label mb-6">Products Sold</p>
            <p class="text-3xl font-bold text-white mb-2"><%= stats.totalProductsSold %></p>
            <p class="text-[10px] font-bold text-white/20 uppercase tracking-widest">Total units dispatched</p>
        </div>
    </div>

    <!-- Analysis Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Revenue Chart -->
        <div class="lg:col-span-2 report-card p-8">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h3 class="text-white font-bold">Revenue Overview</h3>
                    <p class="stat-label mt-1">Daily sales trend</p>
                </div>
                <div class="text-right">
                    <p class="text-xl font-bold text-white">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
                    <span class="text-[10px] font-bold text-status-success">+<%= growth %>%</span>
                </div>
            </div>
            <div class="h-[300px]">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <!-- Growth Comparison -->
        <div class="report-card p-8">
            <div class="flex justify-between items-center mb-10">
                <h3 class="text-white font-bold">Growth Comparison</h3>
                <span class="text-[10px] font-bold text-status-success">+<%= growth %>%</span>
            </div>
            <div class="h-[250px] mb-6">
                <canvas id="growthChart"></canvas>
            </div>
            <p class="text-[9px] font-bold text-white/20 uppercase tracking-[0.2em] text-center">Current vs Previous Period</p>
        </div>
    </div>

    <!-- Tables Row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Coupon Usage Details -->
        <div class="report-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h3 class="text-white font-bold">Coupon Usage Details</h3>
                <p class="stat-label mt-1">Top performing promotions</p>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.01]">
                            <th class="table-header">Coupon Code</th>
                            <th class="table-header text-center">Times Used</th>
                            <th class="table-header text-right">Total Discount</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (couponUsage.length > 0) { %>
                            <% couponUsage.forEach(coupon => { %>
                                <tr class="hover:bg-white/[0.02] transition-colors">
                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 bg-accent/10 text-accent text-[10px] font-black rounded-full uppercase tracking-widest"><%= coupon._id %></span>
                                    </td>
                                    <td class="px-6 py-4 text-center text-xs font-bold text-white"><%= coupon.timesUsed %>x</td>
                                    <td class="px-6 py-4 text-right text-xs font-bold text-white">₹<%= coupon.totalDiscount.toLocaleString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="px-6 py-10 text-center text-white/20 text-[10px] uppercase font-bold">No coupon data</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Order Discount Breakdown -->
        <div class="report-card overflow-hidden">
            <div class="p-8 border-b border-white/5 flex justify-between items-center">
                <div>
                    <h3 class="text-white font-bold">Order Discount Breakdown</h3>
                    <p class="stat-label mt-1">Coupon deductions per order</p>
                </div>
                <span class="px-4 py-1.5 bg-accent text-black text-[10px] font-black rounded-full uppercase tracking-widest">Saved: ₹<%= stats.totalDiscount.toLocaleString() %></span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.01]">
                            <th class="table-header">Order #</th>
                            <th class="table-header">Date</th>
                            <th class="table-header text-right">Discount</th>
                            <th class="table-header text-right">Final</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% orders.filter(o => o.discount > 0).slice(0, 5).forEach(order => { %>
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4 text-[10px] font-mono text-white/40">#<%= order.orderId %></td>
                                <td class="px-6 py-4 text-[10px] font-bold text-white/60 uppercase"><%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                                <td class="px-6 py-4 text-right text-[10px] font-bold text-status-danger">-₹<%= order.discount %></td>
                                <td class="px-6 py-4 text-right text-xs font-bold text-white">₹<%= order.totalAmount.toLocaleString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Detailed Table (Existing Pagination) -->
    <div class="report-card overflow-hidden mt-12">
        <div class="p-8 border-b border-white/5">
            <h3 class="text-white font-bold">Detailed Transaction Log</h3>
            <p class="stat-label mt-1">Full delivery history for selected period</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[0.01]">
                        <th class="table-header">Order ID</th>
                        <th class="table-header">Customer</th>
                        <th class="table-header text-right">Amount</th>
                        <th class="table-header text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% orders.forEach(order => { %>
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-6 py-5">
                                <div class="flex flex-col">
                                    <span class="text-xs font-mono text-white/80">#<%= order.orderId %></span>
                                    <span class="text-[9px] text-white/30 uppercase font-bold"><%= new Date(order.createdAt).toLocaleString() %></span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex flex-col">
                                    <span class="text-xs font-bold text-white uppercase"><%= order.user?.firstName %> <%= order.user?.lastName %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-tighter"><%= order.user?.email %></span>
                                </div>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <span class="text-xs font-bold text-white">₹<%= order.totalAmount.toLocaleString() %></span>
                            </td>
                            <td class="px-6 py-5 text-center">
                                <span class="px-3 py-1 bg-status-success/10 text-status-success text-[9px] font-bold uppercase tracking-widest border border-status-success/10 rounded-full">
                                    <%= order.orderStatus %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <div class="p-8 border-t border-white/5">
            <%- include('../../partials/pagination') %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Revenue Chart
        const revCtx = document.getElementById('revenueChart').getContext('2d');
        const gradient = revCtx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(255, 106, 0, 0.1)');
        gradient.addColorStop(1, 'rgba(255, 106, 0, 0)');

        new Chart(revCtx, {
            type: 'line',
            data: {
                labels: <%- JSON.stringify(orders.reverse().map(o => new Date(o.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }))) %>,
                datasets: [{
                    label: 'Revenue',
                    data: <%- JSON.stringify(orders.map(o => o.totalAmount)) %>,
                    borderColor: '#ff6a00',
                    borderWidth: 3,
                    tension: 0.4,
                    pointRadius: 0,
                    fill: true,
                    backgroundColor: gradient
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { grid: { color: 'rgba(255,255,255,0.03)' }, ticks: { color: 'rgba(255,255,255,0.2)', font: { size: 9 } } },
                    x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.2)', font: { size: 9 } } }
                },
                plugins: { legend: { display: false } }
            }
        });

        // Growth Comparison Chart
        const growthCtx = document.getElementById('growthChart').getContext('2d');
        new Chart(growthCtx, {
            type: 'bar',
            data: {
                labels: ['Previous', 'Current'],
                datasets: [{
                    data: [<%= previousRevenue %>, <%= stats.totalRevenue %>],
                    backgroundColor: ['rgba(255,255,255,0.05)', '#ff6a00'],
                    borderRadius: 8,
                    barThickness: 40
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { display: false },
                    x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, weight: 'bold' } } }
                },
                plugins: { legend: { display: false } }
            }
        });
    });
</script>

