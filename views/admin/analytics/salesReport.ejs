<%- contentFor('body') %>

<style>
    .report-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        transition: all 0.3s ease;
    }
    .report-card:hover {
        border-color: rgba(255, 106, 0, 0.2);
    }
    .stat-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.3);
    }
    .filter-btn {
        padding: 6px 16px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 20px;
        transition: all 0.3s ease;
        color: rgba(255, 255, 255, 0.4);
    }
    .filter-btn.active {
        background: #ff6a00;
        color: #000;
    }
    .table-header {
        font-size: 9px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: rgba(255, 255, 255, 0.2);
        padding: 16px 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .growth-indicator {
        font-size: 10px;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 4px;
    }
</style>

<div class="space-y-8" x-data="{ 
    filter: '<%= filter %>',
    showCustom: <%= filter === 'custom' %>,
    dateErrors: { start: '', end: '' },
    today: '',
    init() {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        this.today = `${year}-${month}-${day}`;

        // Default empty custom inputs to today for better UX
        const startInput = document.getElementsByName('startDate')[0];
        const endInput = document.getElementsByName('endDate')[0];
        if (startInput && !startInput.value) startInput.value = this.today;
        if (endInput && !endInput.value) endInput.value = this.today;
    },
    updateFilter(val) {
        if(val === 'custom') {
            this.showCustom = true;
        } else {
            window.location.href = `/admin/sales-report?filter=${val}`;
        }
    },
    validateDates() {
        this.dateErrors = { start: '', end: '' };
        let isValid = true;
        const start = document.getElementsByName('startDate')[0].value;
        const end = document.getElementsByName('endDate')[0].value;

        if (!start) {
            this.dateErrors.start = 'Start date is required';
            isValid = false;
        }
        if (!end) {
            this.dateErrors.end = 'End date is required';
            isValid = false;
        }
        if (start && end && start > end) {
            this.dateErrors.start = 'Start must be before End';
            isValid = false;
        }
        if (end && end > this.today) {
            this.dateErrors.end = 'Cannot be in the future';
            isValid = false;
        }
        return isValid;
    },
    handleCustomSubmit(e) {
        if (!this.validateDates()) {
            e.preventDefault();
            return false;
        }
    }
}">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Sales Report</h1>
            <p class="text-white/40 text-xs font-bold uppercase tracking-widest mt-1">
                Performance overview • <%= period.start ? period.start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '...' %> → <%= period.end ? period.end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '...' %>
            </p>
        </div>
        
        <div class="flex flex-wrap items-center gap-4">
            <!-- Inventory Shortcut -->
            <a href="/admin/productManagement" class="flex items-center gap-2 px-6 py-2.5 bg-white/5 text-white/40 text-[10px] font-black uppercase tracking-widest rounded-sm border border-white/5 hover:text-white transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                Inventory
            </a>

            <!-- Status Filter -->
            <div class="bg-white/5 p-1 rounded-full flex gap-1 border border-white/5">
                <select @change="window.location.href = `/admin/sales-report?filter=${filter}&status=${$el.value}&startDate=<%= startDate %>&endDate=<%= endDate %>`" 
                        style="background-color: #0d0d0d; color: white;"
                        class="bg-transparent text-[10px] font-black uppercase tracking-widest text-white/60 px-4 py-1.5 outline-none cursor-pointer hover:text-white transition-colors">
                    <option value="Delivered" style="background-color: #0d0d0d; color: white;" <%= status === 'Delivered' ? 'selected' : '' %>>Delivered Only</option>
                    <option value="exclude_cancelled" style="background-color: #0d0d0d; color: white;" <%= status === 'exclude_cancelled' ? 'selected' : '' %>>Exclude Cancelled</option>
                    <option value="all" style="background-color: #0d0d0d; color: white;" <%= status === 'all' ? 'selected' : '' %>>All Orders</option>
                </select>
            </div>

            <!-- Period Filters -->
            <div class="bg-white/5 p-1 rounded-full flex gap-1 border border-white/5">
                <button @click="updateFilter('daily')" :class="(filter === 'daily' && !showCustom) ? 'active' : ''" class="filter-btn">Day</button>
                <button @click="updateFilter('weekly')" :class="(filter === 'weekly' && !showCustom) ? 'active' : ''" class="filter-btn">Week</button>
                <button @click="updateFilter('monthly')" :class="(filter === 'monthly' && !showCustom) ? 'active' : ''" class="filter-btn">Month</button>
                <button @click="updateFilter('yearly')" :class="(filter === 'yearly' && !showCustom) ? 'active' : ''" class="filter-btn">Year</button>
                <button @click="showCustom = !showCustom" :class="(filter === 'custom' || showCustom) ? 'active' : ''" class="filter-btn">Custom</button>
            </div>

            <!-- Export Dropdown -->
            <div class="relative" x-data="{ open: false }">
                <button @click="open = !open" class="flex items-center gap-3 px-6 py-2.5 bg-status-success text-black text-[11px] font-black uppercase tracking-widest rounded-sm hover:bg-white transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    Export
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </button>
                <div x-show="open" @click.away="open = false" class="absolute right-0 mt-2 w-48 bg-[#111] border border-white/10 rounded-sm shadow-2xl z-50 overflow-hidden">
                    <a href="/admin/sales-report/download?filter=<%= filter %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=pdf" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">PDF Report</a>
                    <a href="/admin/sales-report/download?filter=<%= filter %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=excel" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">Excel Sheet</a>
                    <a href="/admin/sales-report/download?filter=<%= filter %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>&format=ledger" class="block px-6 py-3 text-[10px] font-bold text-white/60 hover:text-white hover:bg-white/5 uppercase tracking-widest transition-colors">Ledger Book</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Custom Date Range Form (Hidden by default) -->
    <div x-show="showCustom" x-collapse class="bg-white/5 border border-white/5 p-6 rounded-lg">
        <form action="/admin/sales-report" method="GET" @submit="handleCustomSubmit" class="flex flex-wrap gap-6 items-end">
            <input type="hidden" name="filter" value="custom">
            <div class="space-y-2">
                <label class="stat-label">Start Date</label>
                <input type="date" name="startDate" value="<%= startDate %>" 
                       :max="today"
                       :class="dateErrors.start ? 'border-status-danger' : 'border-white/10'"
                       class="block bg-black border text-white text-xs px-4 py-2 focus:border-accent outline-none rounded-sm">
                <p x-show="dateErrors.start" x-text="dateErrors.start" class="text-[9px] text-status-danger font-bold uppercase tracking-widest mt-1"></p>
            </div>
            <div class="space-y-2">
                <label class="stat-label">End Date</label>
                <input type="date" name="endDate" value="<%= endDate %>" 
                       :max="today"
                       :class="dateErrors.end ? 'border-status-danger' : 'border-white/10'"
                       class="block bg-black border text-white text-xs px-4 py-2 focus:border-accent outline-none rounded-sm">
                <p x-show="dateErrors.end" x-text="dateErrors.end" class="text-[9px] text-status-danger font-bold uppercase tracking-widest mt-1"></p>
            </div>
            <button type="submit" class="px-8 py-2 bg-white text-black text-[11px] font-bold uppercase tracking-widest hover:bg-accent hover:text-white transition-all rounded-sm mb-[2px]">Generate Report</button>
        </form>
    </div>

    <!-- Top Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="report-card p-8 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <svg class="w-12 h-12 text-status-success" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"></path><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="stat-label mb-6">Total Revenue</p>
            <p class="text-3xl font-bold text-white mb-2">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
            <% const growth = previousRevenue > 0 ? ((stats.totalRevenue - previousRevenue) / previousRevenue * 100).toFixed(1) : 100; %>
            <div class="flex items-center gap-2">
                <span class="growth-indicator <%= growth >= 0 ? 'bg-status-success/10 text-status-success' : 'bg-status-danger/10 text-status-danger' %>">
                    <%= growth >= 0 ? '+' : '' %><%= growth %>%
                </span>
                <span class="text-[9px] font-bold text-white/20 uppercase tracking-widest">vs prev. period</span>
            </div>
        </div>

        <div class="report-card p-8">
            <p class="stat-label mb-6">Total Orders</p>
            <p class="text-3xl font-bold text-white mb-2"><%= stats.totalSales %></p>
            <p class="text-[10px] font-bold text-white/20 uppercase tracking-widest">Delivered orders</p>
        </div>

        <div class="report-card p-8">
            <p class="stat-label mb-6">Products Sold</p>
            <p class="text-3xl font-bold text-white mb-2"><%= stats.totalProductsSold %></p>
            <p class="text-[10px] font-bold text-white/20 uppercase tracking-widest">Total units dispatched</p>
        </div>
    </div>

    <!-- Analysis Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Revenue Chart -->
        <div class="lg:col-span-2 report-card p-8">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h3 class="text-white font-bold">Revenue Overview</h3>
                    <p class="stat-label mt-1">Daily sales trend</p>
                </div>
                <div class="text-right">
                    <p class="text-xl font-bold text-white">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
                    <span class="text-[10px] font-bold text-status-success">+<%= growth %>%</span>
                </div>
            </div>
            <div class="h-[300px]">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <!-- Growth Comparison -->
        <div class="report-card p-8">
            <div class="flex justify-between items-center mb-10">
                <h3 class="text-white font-bold">Growth Comparison</h3>
                <span class="text-[10px] font-bold text-status-success">+<%= growth %>%</span>
            </div>
            <div class="h-[250px] mb-6">
                <canvas id="growthChart"></canvas>
            </div>
            <p class="text-[9px] font-bold text-white/20 uppercase tracking-[0.2em] text-center">Current vs Previous Period</p>
        </div>
    </div>

    <!-- Tables Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Coupon Usage Details -->
        <div class="report-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h3 class="text-white font-bold text-sm">Coupon Usage</h3>
                <p class="stat-label mt-1">Top performing promotions</p>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.01]">
                            <th class="table-header">Code</th>
                            <th class="table-header text-center">Used</th>
                            <th class="table-header text-right">Saved</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (couponUsage.length > 0) { %>
                            <% couponUsage.forEach(coupon => { %>
                                <tr class="hover:bg-white/[0.02] transition-colors">
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-0.5 bg-accent/10 text-accent text-[9px] font-black rounded-full uppercase tracking-widest"><%= coupon._id %></span>
                                    </td>
                                    <td class="px-6 py-4 text-center text-[11px] font-bold text-white"><%= coupon.timesUsed %>x</td>
                                    <td class="px-6 py-4 text-right text-[11px] font-bold text-white">₹<%= coupon.totalDiscount.toLocaleString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="px-6 py-10 text-center text-white/20 text-[9px] uppercase font-bold">No data</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top Selling Brands -->
        <div class="report-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h3 class="text-white font-bold text-sm">Top Brands</h3>
                <p class="stat-label mt-1">Units & Revenue mix</p>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.01]">
                            <th class="table-header">Brand</th>
                            <th class="table-header text-center">Sold</th>
                            <th class="table-header text-right">Revenue</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (topBrands && topBrands.length > 0) { %>
                            <% topBrands.forEach(brand => { %>
                                <tr class="hover:bg-white/[0.02] transition-colors">
                                    <td class="px-6 py-4">
                                        <span class="text-[11px] font-bold text-white uppercase"><%= brand._id %></span>
                                    </td>
                                    <td class="px-6 py-4 text-center text-[11px] font-bold text-white"><%= brand.totalSold %>u</td>
                                    <td class="px-6 py-4 text-right text-[11px] font-bold text-status-success">₹<%= brand.revenue.toLocaleString() %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="px-6 py-10 text-center text-white/20 text-[9px] uppercase font-bold">No data</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Order Discount Breakdown -->
        <div class="report-card overflow-hidden">
            <div class="p-8 border-b border-white/5">
                <h3 class="text-white font-bold text-sm">Recent Savings</h3>
                <p class="stat-label mt-1">Deductions per order</p>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.01]">
                            <th class="table-header">Order #</th>
                            <th class="table-header text-right">Disc.</th>
                            <th class="table-header text-right">Final</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% orders.filter(o => o.discount > 0).slice(0, 5).forEach(order => { %>
                            <tr class="hover:bg-white/[0.02] transition-colors">
                                <td class="px-6 py-4 text-[9px] font-mono text-white/40">#<%= order.orderId %></td>
                                <td class="px-6 py-4 text-right text-[10px] font-bold text-status-danger">-₹<%= order.discount %></td>
                                <td class="px-6 py-4 text-right text-[11px] font-bold text-white">₹<%= order.totalAmount.toLocaleString() %></td>
                            </tr>
                        <% }) %>
                        <% if (orders.filter(o => o.discount > 0).length === 0) { %>
                            <tr><td colspan="3" class="px-6 py-10 text-center text-white/20 text-[9px] uppercase font-bold">No discounts</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Detailed Table (Existing Pagination) -->
    <div class="report-card overflow-hidden mt-12">
        <div class="p-8 border-b border-white/5">
            <h3 class="text-white font-bold">Detailed Transaction Log</h3>
            <p class="stat-label mt-1">Full delivery history for selected period</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[0.01]">
                        <th class="table-header">Order ID / Date</th>
                        <th class="table-header">Customer</th>
                        <th class="table-header text-center">Qty</th>
                        <th class="table-header text-right">Amount</th>
                        <th class="table-header text-center">Method</th>
                        <th class="table-header text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% orders.forEach(order => { %>
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-3 py-5">
                                <div class="flex flex-col">
                                    <span class="text-xs font-mono text-white/80">#<%= order.orderId %></span>
                                    <span class="text-[9px] text-white/30 uppercase font-bold"><%= new Date(order.createdAt).toLocaleDateString() %></span>
                                </div>
                            </td>
                            <td class="px-3 py-5">
                                <div class="flex flex-col max-w-[150px]">
                                    <span class="text-xs font-bold text-white uppercase truncate"><%= order.user?.firstName %> <%= order.user?.lastName %></span>
                                    <span class="text-[9px] text-white/30 uppercase tracking-tighter truncate"><%= order.user?.email %></span>
                                </div>
                            </td>
                            <td class="px-3 py-5 text-center">
                                <span class="text-xs font-bold text-white"><%= order.items.reduce((sum, i) => sum + i.qty, 0) %></span>
                            </td>
                            <td class="px-3 py-5 text-right">
                                <span class="text-xs font-bold text-white">₹<%= order.totalAmount.toLocaleString() %></span>
                            </td>
                            <td class="px-3 py-5 text-center">
                                <% 
                                    const methodMap = {
                                        'CASH ON DELIVERY': 'COD',
                                        'ONLINE PAYMENT': 'ONLINE',
                                        'RAZORPAY': 'ONLINE',
                                        'WALLET': 'WALLET'
                                    };
                                    const shortMethod = methodMap[order.paymentMethod] || order.paymentMethod;
                                %>
                                <span class="px-2 py-0.5 bg-white/5 text-white/60 text-[9px] font-bold uppercase tracking-widest border border-white/5 rounded-sm whitespace-nowrap">
                                    <%= shortMethod %>
                                </span>
                            </td>
                            <td class="px-3 py-5 text-center">
                                <span class="px-3 py-1 bg-status-success/10 text-status-success text-[9px] font-bold uppercase tracking-widest border border-status-success/10 rounded-full">
                                    <%= order.orderStatus %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <div class="p-8 border-t border-white/5">
            <%- include('../../partials/pagination') %>
        </div>
    </div>
</div>


<script>
    window.initSalesReport = () => {
        // Revenue Chart
        const revCanvas = document.getElementById('revenueChart');
        if (!revCanvas) return;
        
        const revCtx = revCanvas.getContext('2d');
        const gradient = revCtx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(255, 106, 0, 0.1)');
        gradient.addColorStop(1, 'rgba(255, 106, 0, 0)');
        
        if (window.revenueChartInstance instanceof Chart) window.revenueChartInstance.destroy();
        
        window.revenueChartInstance = new Chart(revCtx, {
            type: 'line',
            data: {
                labels: <%- JSON.stringify(chartData.labels) %>,
                datasets: [{
                    label: 'Revenue',
                    data: <%- JSON.stringify(chartData.data) %>,
                    borderColor: '#ff6a00',
                    borderWidth: 3,
                    tension: 0.4,
                    pointRadius: 0,
                    fill: true,
                    backgroundColor: gradient
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { grid: { color: 'rgba(255,255,255,0.03)' }, ticks: { color: 'rgba(255,255,255,0.2)', font: { size: 9 } } },
                    x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.2)', font: { size: 9 } } }
                },
                plugins: { legend: { display: false } }
            }
        });

        // Growth Comparison Chart
        const growthCanvas = document.getElementById('growthChart');
        if (!growthCanvas) return;
        
        const growthCtx = growthCanvas.getContext('2d');
        
        if (window.growthChartInstance instanceof Chart) window.growthChartInstance.destroy();
        
        window.growthChartInstance = new Chart(growthCtx, {
            type: 'bar',
            data: {
                labels: ['Previous', 'Current'],
                datasets: [{
                    data: [<%= previousRevenue %>, <%= stats.totalRevenue %>],
                    backgroundColor: ['rgba(255,255,255,0.05)', '#ff6a00'],
                    borderRadius: 8,
                    barThickness: 40
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { display: false },
                    x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, weight: 'bold' } } }
                },
                plugins: { legend: { display: false } }
            }
        });
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', window.initSalesReport);
    } else {
        window.initSalesReport();
    }
</script>

