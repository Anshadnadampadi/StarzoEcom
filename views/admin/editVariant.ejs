<%- contentFor('body') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css">
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>

<div class="space-y-10" x-data="variantManager">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <a href="/admin/products/details/<%= product._id %>" class="text-white/20 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <h1 class="text-3xl font-bold tracking-tight uppercase text-white">EDIT VARIANT.</h1>
            </div>
            <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Modify specifications for <%= product.name %></p>
        </div>
    </div>

    <div class="max-w-4xl">
        <form @submit.prevent="submitForm()" data-no-spa="true" novalidate class="bg-black-surface border border-white/5 p-10 space-y-12">
            <!-- Specifications -->
            <div class="space-y-8">
                <div class="border-l-2 border-accent pl-6">
                    <h3 class="text-xs font-bold text-white uppercase tracking-widest">Configuration Protocol</h3>
                    <p class="text-[9px] text-white/30 uppercase mt-1">Review hardware and aesthetic parameters</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="space-y-2">
                        <label class="text-[9px] font-bold uppercase tracking-widest text-white/40">Color / Finish</label>
                        <input type="text" x-model="form.color" placeholder="e.g., Titanium Gray"
                            class="w-full bg-black border border-white/5 py-4 px-6 text-xs text-white focus:outline-none focus:border-accent transition-colors placeholder:text-white/10 uppercase font-bold">
                        <p x-show="errors.color" x-text="errors.color" class="text-red-500 text-xs mt-1" style="color:#ef4444; font-size:12px; margin-top:4px; font-weight:500;"></p>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-bold uppercase tracking-widest text-white/40">RAM Capacity</label>
                        <input type="text" x-model="form.ram" placeholder="e.g., 12GB"
                            class="w-full bg-black border border-white/5 py-4 px-6 text-xs text-white focus:outline-none focus:border-accent transition-colors placeholder:text-white/10 uppercase font-bold">
                        <p x-show="errors.ram" x-text="errors.ram" class="text-red-500 text-xs mt-1" style="color:#ef4444; font-size:12px; margin-top:4px; font-weight:500;"></p>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-bold uppercase tracking-widest text-white/40">Storage Volume</label>
                        <input type="text" x-model="form.storage" placeholder="e.g., 256GB"
                            class="w-full bg-black border border-white/5 py-4 px-6 text-xs text-white focus:outline-none focus:border-accent transition-colors placeholder:text-white/10 uppercase font-bold">
                        <p x-show="errors.storage" x-text="errors.storage" class="text-red-500 text-xs mt-1" style="color:#ef4444; font-size:12px; margin-top:4px; font-weight:500;"></p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-2">
                        <label class="text-[9px] font-bold uppercase tracking-widest text-white/40">Pricing (INR)</label>
                        <input type="number" x-model="form.price" onwheel="this.blur()"
                            class="w-full bg-black border border-white/5 py-4 px-6 text-xs text-white focus:outline-none focus:border-accent transition-colors placeholder:text-white/10 font-mono">
                        <p x-show="errors.price" x-text="errors.price" class="text-red-500 text-xs mt-1" style="color:#ef4444; font-size:12px; margin-top:4px; font-weight:500;"></p>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[9px] font-bold uppercase tracking-widest text-white/40">Inventory Level</label>
                        <input type="number" x-model="form.stock" onwheel="this.blur()"
                            class="w-full bg-black border border-white/5 py-4 px-6 text-xs text-white focus:outline-none focus:border-accent transition-colors placeholder:text-white/10 font-mono">
                        <p x-show="errors.stock" x-text="errors.stock" class="text-red-500 text-xs mt-1" style="color:#ef4444; font-size:12px; margin-top:4px; font-weight:500;"></p>
                    </div>
                </div>
            </div>

            <!-- Image Asset Deployment -->
            <div class="space-y-8">
                <div class="border-l-2 border-accent pl-6">
                    <h3 class="text-xs font-bold text-white uppercase tracking-widest">Asset Management</h3>
                    <p class="text-[9px] text-white/30 uppercase mt-1">Direct modification. Selectively delete or replace assets.</p>
                </div>

                <div class="space-y-4">
                    <label class="text-[9px] font-bold uppercase tracking-[0.2em] text-white/30 block">Active Assets Configuration</label>
                    <div class="flex flex-row overflow-x-auto gap-3 pb-2 custom-scrollbar">
                        <% variant.images.forEach((img, imgIndex) => { %>
                            <div class="w-16 h-16 bg-black border border-white/10 p-1 flex-shrink-0 relative group">
                                <img src="<%= img %>" class="w-full h-full object-contain">
                                <button type="button" @click="deleteExistingAsset(<%= imgIndex %>)"
                                    class="absolute -top-1 -right-1 w-4 h-4 bg-status-danger text-white text-[8px] flex items-center justify-center rounded-full opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="space-y-6">
                     <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Upload New Assets</label>
                    <div class="flex flex-wrap gap-6">
                        <template x-for="(preview, index) in previews" :key="index">
                            <div class="bg-black border border-white/5 relative group overflow-hidden flex-shrink-0" style="width: 120px; height: 120px;">
                                <img :src="preview.url" class="w-full h-full object-cover">
                                <button type="button" @click="removeFile(index)"
                                    class="absolute top-2 right-2 w-6 h-6 bg-status-danger text-white text-[10px] flex items-center justify-center rounded-full opacity-0 group-hover:opacity-100 transition-opacity">✕</button>
                            </div>
                        </template>
                        
                        <button x-show="previews.length + existingImageCount < 5" type="button" @click="$refs.imageInput.click()"
                            class="border border-dashed border-white/10 flex flex-col items-center justify-center hover:border-white/30 transition-all gap-2 group flex-shrink-0" style="width: 120px; height: 120px;">
                            <span class="text-2xl text-white/10 group-hover:text-white/40 transition-colors">+</span>
                            <span class="text-[9px] font-bold text-white/10 group-hover:text-white/40 uppercase tracking-widest">Add Asset</span>
                        </button>
                    </div>
                    <input type="file" x-ref="imageInput" @change="handleFileChange" accept="image/*" multiple class="hidden">
                    <p class="text-[8px] text-white/20 uppercase tracking-widest">Note: New assets will be added to the existing collection (Max 5 total).</p>
                    <p x-show="errors.images" x-text="errors.images" class="text-red-500 text-[10px] mt-1 font-bold uppercase tracking-wider ml-1"></p>
                </div>
            </div>

            <div class="pt-10">
                <button type="submit" :disabled="isSubmitting"
                    class="w-full bg-white text-black font-bold py-5 text-[10px] tracking-widest uppercase hover:bg-accent disabled:opacity-50 disabled:cursor-not-allowed transition-all btn-press">
                    <span x-show="!isSubmitting">Update Variant Parameters</span>
                    <span x-show="isSubmitting">Processing Catalog Synchronization...</span>
                </button>
            </div>
        </form>
    </div>

    <!-- Crop Modal - Premium Design -->
    <div x-show="showCropModal" 
         class="fixed inset-0 z-[1000] flex items-center justify-center p-6 select-none" 
         x-cloak
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">
        
        <div class="absolute inset-0 bg-black/60 backdrop-blur-md" @click="cancelCrop()"></div>
        
        <div class="premium-modal-card-large flex flex-col items-center text-center !max-w-md" 
             style="max-height: 90vh;"
             x-show="showCropModal"
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0 scale-95 translate-y-8"
             x-transition:enter-end="opacity-100 scale-100 translate-y-0">
            
            <div class="premium-modal-header w-full !p-6">
                <div class="text-left">
                    <h2 class="premium-modal-title-text !text-lg">Align Asset</h2>
                    <p class="premium-modal-subtitle-text !text-[10px]">Optimize for catalog synchronization</p>
                </div>
            </div>
            
            <div class="p-6 w-full flex flex-col items-center flex-1 overflow-hidden">
                <div class="w-full max-h-[50vh] aspect-square bg-black rounded-2xl overflow-hidden border border-white/10 mb-6 shadow-inner flex items-center justify-center">
                    <img x-ref="cropImage" src="" class="max-h-full max-w-full object-contain">
                </div>

                <div class="grid grid-cols-2 gap-4 w-full mt-auto">
                    <button @click="cancelCrop()" class="py-3 rounded-xl bg-white/5 text-white/60 text-[10px] font-bold tracking-widest uppercase hover:bg-white/10 transition-all border-none cursor-pointer">Abort</button>
                    <button @click="confirmCrop()" class="py-3 rounded-xl bg-accent text-black text-[10px] font-bold tracking-widest uppercase hover:scale-105 transition-transform border-none cursor-pointer">Optimize</button>
                </div>
            </div>
        </div>
    </div>
v>

</div>


    <script>
        (() => {
            const register = () => {
                if (Alpine.data('variantManager')) return;
                const existingData = <%- JSON.stringify(variant) %>;
                Alpine.data('variantManager', () => ({
                    productId: '<%= product._id %>',
                    variantIndex: '<%= variantIndex %>',
                    existingVariants: <%- JSON.stringify(product.variants.filter(v => !v.isDeleted)) %>,
                    showCropModal: false,
                    isSubmitting: false,
                    cropper: null,
                    previews: [],
                    fileQueue: [],
                    existingImageCount: (existingData.images || []).length,
                    errors: { color: '', ram: '', storage: '', price: '', stock: '', images: '' },
                    form: {
                        color: existingData.color,
                        ram: existingData.ram,
                        storage: existingData.storage,
                        price: existingData.price,
                        stock: existingData.stock
                    },

                    handleFileChange(e) {
                        const files = Array.from(e.target.files);
                        if (files.length === 0) return;
                        if (this.previews.length + this.existingImageCount + files.length > 5) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Maximum 5 assets total allowed.', type: 'error' } }));
                            return;
                        }
                        this.fileQueue = [...files];
                        this.processNextInQueue();
                        e.target.value = '';
                    },

                    processNextInQueue() {
                        if (this.fileQueue.length === 0) return;
                        const file = this.fileQueue.shift();
                        const reader = new FileReader();
                        reader.onload = (event) => {
                            this.showCropModal = true;
                            setTimeout(() => {
                                this.$refs.cropImage.src = event.target.result;
                                if (this.cropper) this.cropper.destroy();
                                this.cropper = new Cropper(this.$refs.cropImage, { viewMode: 1, autoCropArea: 1, background: false, zoomable: true });
                            }, 100);
                        };
                        reader.readAsDataURL(file);
                    },

                    confirmCrop() {
                        if (!this.cropper) return;
                        this.cropper.getCroppedCanvas({ width: 600, height: 600 }).toBlob((blob) => {
                            this.previews.push({ file: blob, url: URL.createObjectURL(blob) });
                            this.closeCropModal();
                            if (this.fileQueue.length > 0) setTimeout(() => this.processNextInQueue(), 300);
                        }, 'image/jpeg', 0.9);
                    },

                    cancelCrop() { this.closeCropModal(); this.fileQueue = []; },
                    closeCropModal() {
                        if (this.cropper) { this.cropper.destroy(); this.cropper = null; }
                        this.showCropModal = false;
                    },
                    removeFile(index) {
                        URL.revokeObjectURL(this.previews[index].url);
                        this.previews.splice(index, 1);
                    },

                    async deleteExistingAsset(imgIndex) {
                        const confirmed = await window.confirmAction({ title: 'PURGE ASSET?', message: 'Image will be removed.', type: 'danger' });
                        if (confirmed) {
                            try {
                                const res = await fetch(`/admin/products/variant/delete-asset/${this.productId}/${this.variantIndex}/${imgIndex}`, { method: 'DELETE' });
                                const data = await res.json();
                                if (data.success) {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Asset purged.', type: 'success' } }));
                                    setTimeout(() => window.location.reload(), 1000);
                                } else { throw new Error(data.message); }
                            } catch (error) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Error deleting asset', type: 'error' } }));
                            }
                        }
                    },

                    validate() {
                        Object.keys(this.errors).forEach(key => this.errors[key] = '');
                        let isValid = true;
                        
                        const colorVal = this.form.color ? this.form.color.trim() : '';
                        if (!colorVal || colorVal.length < 3) {
                            this.errors.color = 'Color must be at least 3 characters.';
                            isValid = false;
                        } else if (!/[a-zA-Z]/.test(colorVal)) {
                            this.errors.color = 'Color must contain letters.';
                            isValid = false;
                        }
                        
                        const ramVal = this.form.ram ? this.form.ram.trim() : '';
                        if (!ramVal) {
                            this.errors.ram = 'RAM is required.';
                            isValid = false;
                        } else if (!/[0-9]/.test(ramVal)) {
                            this.errors.ram = 'RAM must contain a numeric value (e.g., 12GB).';
                            isValid = false;
                        }

                        const storageVal = this.form.storage ? this.form.storage.trim() : '';
                        if (!storageVal) {
                            this.errors.storage = 'Storage is required.';
                            isValid = false;
                        } else if (!/[0-9]/.test(storageVal)) {
                            this.errors.storage = 'Storage must contain a numeric value (e.g., 256GB).';
                            isValid = false;
                        }

                        if (!this.form.price || parseFloat(this.form.price) <= 0) { this.errors.price = 'Price must be positive.'; isValid = false; }
                        if (this.form.stock === '' || parseInt(this.form.stock) < 0) { this.errors.stock = 'Stock must be non-negative.'; isValid = false; }

                        // Duplicate Variant Check (Excluding self)
                        if (isValid) {
                            const isDuplicate = this.existingVariants.some((v, idx) => 
                                idx !== parseInt(this.variantIndex) &&
                                v.color.toLowerCase() === colorVal.toLowerCase() &&
                                v.ram.toLowerCase() === ramVal.toLowerCase() &&
                                v.storage.toLowerCase() === storageVal.toLowerCase()
                            );
                            if (isDuplicate) {
                                this.errors.color = 'Another variant with this combination already exists.';
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Duplicate variant combination.', type: 'warning' } }));
                                isValid = false;
                            }
                        }

                        if (this.existingImageCount + this.previews.length < 3) {
                            this.errors.images = 'A variant must have at least 3 images total.';
                            isValid = false;
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Please provide at least 3 images.', type: 'warning' } }));
                        }

                        return isValid;
                    },

                    async submitForm() {
                        if (this.isSubmitting) return;
                        if (!this.validate()) return;
                        
                        this.isSubmitting = true;
                        const formData = new FormData();
                        Object.keys(this.form).forEach(key => formData.append(key, this.form[key]));
                        this.previews.forEach((p, i) => formData.append('images', p.file, `update-${Date.now()}-${i}.jpg`));
                        try {
                            const res = await fetch(`/admin/products/variant/update/${this.productId}/${this.variantIndex}`, { method: 'PATCH', body: formData });
                            const result = await res.json();
                            if (result.success) {
                                this.isSubmitting = false; 
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Variant updated.', type: 'success' } }));
                                setTimeout(() => { window.location.href = `/admin/products/details/${this.productId}`; }, 1500);
                            } else { 
                                if (result.message.toLowerCase().includes('already exists')) {
                                    this.errors.color = result.message;
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: result.message, type: 'error' } }));
                                } else {
                                    throw new Error(result.message); 
                                }
                            }
                        } catch (error) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: error.message || 'Error occurred.', type: 'error' } }));
                        } finally { this.isSubmitting = false; }
                    }
                }));
            };

            if (window.Alpine) {
                register();
            } else {
                document.addEventListener('alpine:init', register);
            }
        })();
    </script>

<style>
    /* Premium Modal Standard CSS */
    .premium-modal-card-large {
        background-color: #0a0a0a;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        width: 100%;
        max-width: 32rem;
        overflow: hidden;
        position: relative;
    }

    .premium-modal-header {
        padding: 2rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #000000;
    }

    .premium-modal-title-text {
        font-family: 'Syne', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        color: #ffffff;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .premium-modal-subtitle-text {
        font-size: 0.75rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.4);
        margin-top: 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    /* Added missing Label and Input styles for consistency */
    .premium-modal-label {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #374151;
        display: block;
        margin-bottom: 0.75rem;
        margin-left: 0.25rem;
    }

    .premium-modal-input {
        width: 100%;
        background-color: #ffffff;
        border: 2px solid #f3f4f6;
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        font-size: 0.875rem;
        color: #111827;
        font-weight: 500;
        transition: all 0.2s;
    }

    .cropper-view-box, .cropper-face { border-radius: 0; }
    .cropper-line, .cropper-point { background-color: #ffffff; }
    .cropper-bg { background-image: none; background-color: #000; }
</style>
