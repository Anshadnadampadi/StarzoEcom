<!-- views/admin/marketing/coupons.ejs -->
<%- contentFor('body') %>

    <div class="space-y-10" x-data="couponManager">
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">MARKETING OFFERS.</h1>
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Configure promotional coupons
                    and discounts</p>
            </div>
            <button @click="openCreateModal()"
                class="px-8 py-4 bg-white text-black text-[10px] font-bold tracking-widest uppercase hover:bg-accent transition-all btn-press shadow-[0_0_15px_rgba(255,255,255,0.1)]">Create
                Coupon</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% coupons.forEach(coupon=> { %>
                <div
                    class="bg-black-surface border border-white/5 p-8 relative overflow-hidden group hover:border-accent/30 transition-all">
                    <div class="flex justify-between items-start mb-8">
                        <div
                            class="bg-accent/10 border border-accent/20 px-3 py-1 font-mono text-accent text-sm font-bold tracking-widest uppercase">
                            <%= coupon.code %>
                        </div>
                        <%- include('../../partials/status-badge', { status: coupon.isActive ? 'active' : 'inactive' })
                            %>
                    </div>

                    <div class="mb-10">
                        <h3 class="text-white text-2xl font-black tracking-tight mb-2">
                            <%= coupon.discountType==='percentage' ? coupon.discountValue + '%' : '₹' +
                                coupon.discountValue.toLocaleString() %> OFF
                        </h3>
                        <p class="text-white/40 text-[10px] font-bold tracking-widest uppercase">Min. Purchase: ₹<%=
                                (coupon.minAmount || 0).toLocaleString() %>
                        </p>
                    </div>

                    <div class="pt-8 border-t border-white/5 flex justify-between items-center">
                        <div>
                            <p class="text-white/20 text-[8px] uppercase tracking-widest mb-1">Expires On</p>
                            <p class="text-white text-[10px] font-bold uppercase">
                                <%= new Date(coupon.expiryDate).toLocaleDateString() %>
                            </p>
                        </div>
                        <div>
                            <p class="text-white/20 text-[8px] uppercase tracking-widest mb-1">Usage Count</p>
                            <p class="text-white text-[10px] font-bold uppercase">
                                <%= coupon.usedBy ? coupon.usedBy.length : 0 %> / <%= coupon.usageLimit || 1 %>
                            </p>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 mt-6 pt-6 border-t border-white/5">
                        <button
                            @click="openEditModal('<%= coupon._id %>', '<%= coupon.code %>', '<%= coupon.discountType %>', <%= coupon.discountValue %>, <%= coupon.minAmount || 0 %>, <%= coupon.maxDiscount || 0 %>, '<%= coupon.expiryDate ? new Date(coupon.expiryDate).toISOString().split(`T`)[0] : `` %>', <%= coupon.usageLimit || 1 %>)"
                            class="flex-1 py-3 bg-white/5 text-white/70 hover:bg-white hover:text-black text-[10px] font-bold tracking-widest uppercase transition-all">
                            Edit
                        </button>
                        <button @click="toggleStatus('<%= coupon._id %>')"
                            class="flex-1 py-3 bg-white/5 text-white/70 text-[10px] font-bold tracking-widest uppercase transition-all <%= coupon.isActive ? 'hover:bg-status-danger/20 hover:text-status-danger' : 'hover:bg-status-success/20 hover:text-status-success' %>">
                            <%= coupon.isActive ? 'Disable' : 'Enable' %>
                        </button>
                        <button @click="deleteCoupon('<%= coupon._id %>')"
                            class="flex-1 py-3 bg-white/5 text-white/70 hover:bg-status-danger/20 hover:text-status-danger text-[10px] font-bold tracking-widest uppercase transition-all">
                            Delete
                        </button>
                    </div>
                </div>
                <% }) %>
        </div>

        <!-- Create/Edit Coupon Modal -->
        <div x-show="showModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm px-4"
            style="display: none;" x-transition.opacity>

            <div class="bg-black-surface border border-white/10 w-full max-w-lg p-6 relative shadow-2xl"
                @click.away="closeModal()" x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-8" x-transition:enter-end="opacity-100 translate-y-0">

                <button @click="closeModal()" type="button"
                    class="absolute top-6 left-6 text-white/40 hover:text-white transition-colors z-10">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>

                <h2 class="text-xl font-bold tracking-tight uppercase text-white mb-5 pl-10"
                    x-text="isEditing ? 'Edit Coupon' : 'Create Coupon'"></h2>

                <form @submit.prevent="submitForm()" data-no-spa="true" class="space-y-5">
                    <div class="grid grid-cols-2 gap-x-4 gap-y-4">
                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Coupon
                                Code</label>
                            <input type="text" x-model="formData.code"
                                @input="formData.code = formData.code.toUpperCase(); validateField('code')"
                                @blur="validateField('code')"
                                :class="formErrors.code ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-3 py-2 text-white text-xs border">

                            <p x-show="formErrors.code" class="text-status-danger text-[10px] mt-1" x-text="formErrors.code"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount
                                Type</label>
                            <select x-model="formData.discountType"
                                class="w-full bg-black border border-white/10 px-3 py-2 text-white text-xs focus:border-accent focus:outline-none transition-colors">
                                <option value="percentage">Percentage (%)</option>
                                <option value="fixed">Fixed Amount (₹)</option>
                            </select>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount
                                Value</label>
                            <input type="number" x-model="formData.discountValue"
                                @input="validateField('discountValue')" @blur="validateField('discountValue')"
                                :class="formErrors.discountValue ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-3 py-2 text-white text-xs border">

                            <p x-show="formErrors.discountValue" class="text-status-danger text-[10px] mt-1"
                                x-text="formErrors.discountValue"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Min.
                                Purchase (₹)</label>
                            <input type="number" x-model="formData.minAmount" @input="validateField('minAmount')"
                                @blur="validateField('minAmount')" :class="[
        'w-full bg-black px-3 py-2 text-white text-xs border',
        formErrors.minAmount ? 'border-status-danger' : 'border-white/10'
    ]" min="0" placeholder="0">

                            <p x-show="formErrors.minAmount" class="text-status-danger text-[10px] mt-1"
                                x-text="formErrors.minAmount"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Max.
                                Discount (₹)</label>
                            <input type="number" x-model="formData.maxDiscount" @input="validateField('maxDiscount')"
                                @blur="validateField('maxDiscount')" :class="[
        'w-full bg-black px-3 py-2 text-white text-xs border',
        formErrors.maxDiscount ? 'border-status-danger' : 'border-white/10'
    ]" min="0" placeholder="Optional">

                            <p x-show="formErrors.maxDiscount" class="text-status-danger text-[10px] mt-1"
                                x-text="formErrors.maxDiscount"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Expiry
                                Date</label>
                            <input type="date" x-model="formData.expiryDate" @change="validateField('expiryDate')"
                                @blur="validateField('expiryDate')" :class="[
        'w-full bg-black px-3 py-2 text-white text-xs border',
        formErrors.expiryDate ? 'border-status-danger' : 'border-white/10'
    ]">

                            <p x-show="formErrors.expiryDate" class="text-status-danger text-[10px] mt-1"
                                x-text="formErrors.expiryDate"></p>
                        </div>

                        <div class="space-y-1 col-span-2">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Usage Limit
                                (Per User)</label>
                            <input type="number" x-model="formData.usageLimit" @input="validateField('usageLimit')"
                                @blur="validateField('usageLimit')" :class="[
        'w-full bg-black px-3 py-2 text-white text-xs border',
        formErrors.usageLimit ? 'border-status-danger' : 'border-white/10'
    ]" min="1" placeholder="1">

                            <p x-show="formErrors.usageLimit" class="text-status-danger text-[10px] mt-1"
                                x-text="formErrors.usageLimit"></p>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 pt-5 border-t border-white/5">
                        <button type="button" @click="closeModal()" :disabled="isSubmitting"
                            class="flex-1 py-3 border border-white/10 text-white text-[10px] font-bold tracking-widest uppercase hover:bg-white/5 disabled:opacity-50 transition-all">Cancel</button>
                        <button type="submit" :disabled="isSubmitting"
                            class="flex-1 py-3 bg-accent text-black text-[10px] font-bold tracking-widest uppercase hover:bg-white disabled:opacity-50 transition-all btn-press shadow-[0_0_15px_rgba(255,106,0,0.3)]">
                            <span x-show="!isSubmitting">Save Coupon</span>
                            <span x-show="isSubmitting" class="flex items-center justify-center gap-2">
                                <svg class="animate-spin h-3 w-3 text-black" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                Processing...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const register = () => {
                if (Alpine.data('couponManager')) return;
                Alpine.data('couponManager', () => ({
                    showModal: false,
                    isEditing: false,
                    isSubmitting: false,
                    currentId: null,
                    formData: {
                        code: '',
                        discountType: 'percentage',
                        discountValue: '',
                        minAmount: 0,
                        maxDiscount: '',
                        expiryDate: '',
                        usageLimit: 1
                    },
                    formErrors: {
                        code: '',
                        discountValue: '',
                        minAmount: '',
                        maxDiscount: '',
                        expiryDate: '',
                        usageLimit: ''
                    },
                    openCreateModal() {
                        this.isEditing = false;
                        this.isSubmitting = false;
                        this.currentId = null;
                        this.formData = {
                            code: '',
                            discountType: 'percentage',
                            discountValue: '',
                            minAmount: 0,
                            maxDiscount: '',
                            expiryDate: '',
                            usageLimit: 1
                        };
                        Object.keys(this.formErrors).forEach(k => this.formErrors[k] = '');
                        this.showModal = true;
                    },
                    openEditModal(id, code, type, val, minAmt, maxDisc, expiry, limit) {
                        this.isEditing = true;
                        this.currentId = id;
                        this.formData = {
                            code: code,
                            discountType: type,
                            discountValue: val,
                            minAmount: minAmt || 0,
                            maxDiscount: maxDisc || '',
                            expiryDate: expiry || '',
                            usageLimit: limit || 1
                        };
                        Object.keys(this.formErrors).forEach(k => this.formErrors[k] = '');
                        this.showModal = true;
                    },
                    async toggleStatus(id) {
                        try {
                            const res = await fetch(`/admin/marketing/coupons/${id}/status`, { method: 'PATCH' });
                            const data = await res.json();
                            if (data.success || data.succes) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon status updated', type: 'success' } }));
                                setTimeout(() => window.location.reload(), 1000);
                            } else {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to update status', type: 'error' } }));
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Unexpected error occurred', type: 'error' } }));
                        }
                    },
                    async deleteCoupon(id) {
                        if (!await window.confirmAction({ title: 'Delete Coupon?', message: 'Are you sure you want to permanently delete this coupon?', confirmText: 'Delete', type: 'danger' })) return;
                        
                        try {
                            const res = await fetch(`/admin/marketing/coupons/${id}`, { method: 'DELETE' });
                            const data = await res.json();
                            if (data.success || data.succes) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon deleted successfully', type: 'success' } }));
                                setTimeout(() => window.location.reload(), 1000);
                            } else {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to delete coupon', type: 'error' } }));
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Unexpected error occurred', type: 'error' } }));
                        }
                    },
                    closeModal() {
                        this.showModal = false;
                    },
                    validateField(field) {
                        const v = this.formData;
                        this.formErrors[field] = '';

                        if (field === "code") {
                            if (!v.code) {
                                this.formErrors.code = "Required";
                            } else if (!/^[A-Z0-9]{4,15}$/.test(v.code)) {
                                this.formErrors.code = "4–15 uppercase letters only";
                            }
                        }

                        if (field === "discountValue") {
                            if (!v.discountValue || v.discountValue <= 0) {
                                this.formErrors.discountValue = "Must be > 0";
                            } else if (v.discountType === "percentage" && v.discountValue > 100) {
                                this.formErrors.discountValue = "Max 100%";
                            }
                        }

                        if (field === "minAmount" && v.minAmount < 0) {
                            this.formErrors.minAmount = "Cannot be negative";
                        }

                        if (field === "maxDiscount" && v.maxDiscount && v.maxDiscount < 0) {
                            this.formErrors.maxDiscount = "Invalid amount";
                        }

                        if (field === "expiryDate") {
                            if (!v.expiryDate) {
                                this.formErrors.expiryDate = "Required";
                            } else {
                                const selected = new Date(v.expiryDate);
                                const today = new Date();
                                today.setHours(0, 0, 0, 0);

                                if (selected < today) {
                                    this.formErrors.expiryDate = "Cannot be a past date";
                                }
                            }
                        }

                        if (field === "usageLimit") {
                            if (!v.usageLimit || v.usageLimit < 1) {
                                this.formErrors.usageLimit = "Minimum 1 required";
                            }

                            if (v.usageLimit > 10000) {
                                this.formErrors.usageLimit = "Too large";
                            }
                        }
                        if (field === "maxDiscount") {
                            if (v.maxDiscount && v.maxDiscount < 0) {
                                this.formErrors.maxDiscount = "Cannot be negative";
                            }


                            if (v.discountType === "percentage" && !v.maxDiscount) {
                                this.formErrors.maxDiscount = "Required for % coupons";
                            }
                        }
                    },

                    validateAll() {
                        const fields = ["code", "discountValue", "minAmount", "maxDiscount", "expiryDate", "usageLimit"];
                        fields.forEach(f => this.validateField(f));
                        return Object.values(this.formErrors).every(e => !e);
                    },
                    async submitForm() {
                        if (this.isSubmitting) return;
                        if (!this.validateAll()) {
                            const firstError = Object.values(this.formErrors).find(e => e !== '');
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: firstError || 'Please fix the validation errors.', type: 'error' } }));
                            return;
                        }

                        this.isSubmitting = true;
                        this.formData.code = this.formData.code.trim().toUpperCase();

                        try {
                            const url = this.isEditing
                                ? `/admin/marketing/coupons/${this.currentId}`
                                : '/admin/marketing/coupons';

                            const method = this.isEditing ? 'PUT' : 'POST';

                            const res = await fetch(url, {
                                method,
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.formData)
                            });

                            const data = await res.json();

                            if (data.success) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon saved successfully!', type: 'success' } }));
                                this.closeModal();
                                if (window.SpaNavigation) {
                                    window.SpaNavigation.loadPage(window.location.href, false);
                                } else {
                                    setTimeout(() => window.location.reload(), 1000);
                                }
                            } else {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to save coupon', type: 'error' } }));
                            }
                        } catch (err) {
                            console.error(err);
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Unexpected error occurred', type: 'error' } }));
                        } finally {
                            this.isSubmitting = false;
                        }
                    }
                }));
            };

            if (window.Alpine) {
                register();
            } else {
                document.addEventListener('alpine:init', register);
            }
        })();
    </script>