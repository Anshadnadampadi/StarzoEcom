<!-- views/admin/marketing/coupons.ejs -->
<%- contentFor('body') %>

    <%- include('../../partials/toast') %>
    <div class="space-y-10" x-data="couponManager">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">PROMOTIONAL VOUCHERS.</h1>
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Configure and monitor customer discount codes</p>
            </div>
            <button @click="openCreateModal()"
                class="px-8 py-4 bg-white text-black text-[10px] font-bold tracking-widest uppercase hover:bg-accent transition-all btn-press shadow-[0_0_20px_rgba(255,255,255,0.1)] flex items-center gap-3">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path></svg>
                Create New Coupon
            </button>
        </div>

        <!-- Filters & Tabs -->
        <div class="space-y-6">
            <div class="flex items-center gap-8 border-b border-white/5">
                <button @click="currentTab = 'live'" 
                    :class="currentTab === 'live' ? 'text-accent border-accent' : 'text-white/40 border-transparent hover:text-white'"
                    class="pb-4 text-[10px] font-bold tracking-[0.2em] uppercase border-b-2 transition-all">Live Coupons <span class="ml-2 w-1.5 h-1.5 rounded-full bg-status-success inline-block"></span></button>
                <button @click="currentTab = 'archived'"
                    :class="currentTab === 'archived' ? 'text-accent border-accent' : 'text-white/40 border-transparent hover:text-white'"
                    class="pb-4 text-[10px] font-bold tracking-[0.2em] uppercase border-b-2 transition-all">Archived / Expired</button>
            </div>

            <div class="bg-black-surface border border-white/5 p-6 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="relative group w-full md:w-96">
                    <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-white/20">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input type="text" x-model="search" placeholder="Search by coupon code..." 
                           class="w-full bg-black border border-white/10 px-10 py-3 text-[10px] text-white placeholder:text-white/20 focus:border-accent focus:outline-none transition-all uppercase tracking-widest font-mono">
                </div>
                <div class="flex items-center gap-4 text-white/20 text-[10px] font-bold uppercase tracking-widest">
                    Total Results: <span class="text-white"><%= typeof totalCoupons !== 'undefined' ? totalCoupons : coupons.length %></span>
                </div>
            </div>
        </div>

        <!-- Table View -->
        <div class="bg-black-surface border border-white/5 overflow-hidden shadow-2xl">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[0.02] border-b border-white/5">
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Coupon Code</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Discount</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Usage Intensity</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Timeline</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30">Status</th>
                        <th class="px-8 py-6 text-[9px] font-black tracking-[0.2em] uppercase text-white/30 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <% coupons.forEach(coupon => { %>
                        <% 
                            const isExpired = new Date(coupon.expiryDate) < new Date();
                            const usedCount = coupon.usedBy ? coupon.usedBy.length : 0;
                            const limit = coupon.usageLimit || 1;
                            const usagePercent = Math.min(100, (usedCount / limit) * 100);
                        %>
                        <tr x-data="{ 
                            active: <%= coupon.isActive %>,
                            async toggle() {
                                try {
                                    const res = await fetch(`/admin/marketing/coupons/<%= coupon._id %>/status`, { method: 'PATCH' });
                                    const data = await res.json();
                                    if (!data.success) {
                                        this.active = !this.active;
                                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to update', type: 'error' } }));
                                    } else {
                                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Status updated', type: 'success' } }));
                                    }
                                } catch (e) { 
                                    this.active = !this.active;
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Network error', type: 'error' } }));
                                }
                            }
                        }" class="hover:bg-white/[0.01] group"
                            x-show="((currentTab === 'live' && !<%= isExpired %>) || (currentTab === 'archived' && <%= isExpired %>)) && ('<%= coupon.code %>'.toLowerCase().includes(search.toLowerCase()))">
                            <td class="px-8 py-8">
                                <div class="bg-accent/10 border border-accent/20 px-3 py-1.5 font-mono text-accent text-xs font-bold tracking-widest uppercase inline-block rounded-sm">
                                    <%= coupon.code %>
                                </div>
                            </td>
                            <td class="px-8 py-8">
                                <p class="text-white text-sm font-bold uppercase mb-1">
                                    <%= coupon.discountType === 'percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue.toLocaleString() %> Off
                                </p>
                                <p class="text-white/30 text-[9px] tracking-widest uppercase">Min Order: ₹<%= (coupon.minAmount || 0).toLocaleString() %></p>
                            </td>
                            <td class="px-8 py-8">
                                <div class="w-48">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-[8px] font-bold uppercase tracking-widest text-white/40">Usage</span>
                                        <span class="text-[9px] font-mono font-bold text-white"><%= usedCount %> / <%= limit %></span>
                                    </div>
                                    <div class="h-1 bg-white/5 rounded-full overflow-hidden">
                                        <div class="h-full bg-accent transition-all duration-1000" style="width: <%= usagePercent %>%"></div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-8 py-8">
                                <div class="flex flex-col">
                                    <span class="text-white text-[10px] font-bold uppercase tracking-widest"><%= new Date(coupon.expiryDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                                    <span class="text-white/20 text-[8px] uppercase tracking-tighter mt-1">Expiry Date</span>
                                </div>
                            </td>
                            <td class="px-8 py-8">
                                <% if (isExpired) { %>
                                    <span class="px-3 py-1 bg-status-danger/10 text-status-danger text-[8px] font-bold uppercase tracking-widest border border-status-danger/20 rounded-full">Expired</span>
                                <% } else { %>
                                    <span x-show="!active" class="px-3 py-1 bg-white/5 text-white/40 text-[8px] font-bold uppercase tracking-widest border border-white/10 rounded-full">Inactive</span>
                                    <span x-show="active" class="px-3 py-1 bg-status-success/10 text-status-success text-[8px] font-bold uppercase tracking-widest border border-status-success/20 rounded-full">Active</span>
                                <% } %>
                            </td>
                            <td class="px-8 py-8 text-center align-middle">
                                <div class="flex items-center justify-center gap-6">
                                    <!-- Premium Toggle (Icon Movement Focused) -->
                                    <label class="relative inline-flex items-center cursor-pointer group">
                                        <input type="checkbox" class="absolute opacity-0" x-model="active" @change="toggle()">
                                        <div class="w-10 h-5 bg-white/5 rounded-full relative border border-white/10 transition-colors duration-300">
                                            <div class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full transition-transform duration-500 ease-in-out shadow-[0_0_10px_rgba(0,0,0,0.5)]"
                                                 :class="active ? 'bg-accent' : 'bg-white/20'"
                                                 :style="{ transform: active ? 'translateX(20px)' : 'translateX(0)' }"></div>
                                        </div>
                                    </label>

                                    <button type="button" @click.prevent.stop="openEditModal('<%= coupon._id %>', '<%= coupon.code %>', '<%= coupon.discountType %>', <%= coupon.discountValue %>, <%= coupon.minAmount || 0 %>, <%= coupon.maxDiscount || 0 %>, '<%= coupon.expiryDate ? new Date(coupon.expiryDate).toISOString().split(`T`)[0] : `` %>', <%= coupon.usageLimit || 1 %>)"
                                        class="text-white/40 hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </button>
                                    
                                    <button type="button" @click.prevent.stop="confirmDelete('<%= coupon._id %>', '<%= coupon.code %>')"
                                        class="text-white/20 hover:text-status-danger transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <% 
            let paginationQuery = '';
            if (typeof query !== 'undefined') {
                paginationQuery = Object.entries(query)
                    .filter(([k, v]) => k !== 'page' && v)
                    .map(([k, v]) => `${k}=${encodeURIComponent(v)}`)
                    .join('&');
            }
        %>
        <%- include('../../partials/pagination', { currentPage, totalPages, query: paginationQuery }) %>

        <!-- Create/Edit Coupon Modal -->
        <div x-show="showModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm px-4"
            style="display: none;" x-transition.opacity>
            <div class="bg-black-surface border border-white/10 w-full max-w-lg p-8 relative shadow-[0_0_50px_rgba(0,0,0,0.5)]"
                @click.away="closeModal()" x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-8" x-transition:enter-end="opacity-100 translate-y-0">

                <div class="flex items-center gap-4 mb-8">
                    <button @click="closeModal()" type="button"
                        class="text-white hover:bg-accent hover:text-black transition-all border border-accent w-8 h-8 flex items-center justify-center rounded-sm bg-accent/5 shadow-[0_0_10px_rgba(255,106,0,0.2)] group">
                        <svg class="w-4 h-4 transform group-hover:rotate-90 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                    <h2 class="text-xl font-bold tracking-tight uppercase text-white"
                        x-text="isEditing ? 'Edit Coupon' : 'Create Coupon'"></h2>
                </div>

                <form @submit.prevent="submitForm()" data-no-spa="true" class="space-y-6">
                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Coupon Code</label>
                            <input type="text" x-model="formData.code"
                                @input="formData.code = formData.code.toUpperCase(); validateField('code')"
                                @blur="validateField('code')"
                                :class="formErrors.code ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all font-mono">
                            <p x-show="formErrors.code" class="text-status-danger text-[10px] mt-1" x-text="formErrors.code"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount Type</label>
                            <select x-model="formData.discountType"
                                class="w-full bg-black border border-white/10 px-4 py-3 text-white text-xs focus:border-accent focus:outline-none transition-colors">
                                <option value="percentage">Percentage (%)</option>
                                <option value="fixed">Fixed Amount (₹)</option>
                            </select>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Discount Value</label>
                            <input type="number" x-model="formData.discountValue"
                                @input="validateField('discountValue')" @blur="validateField('discountValue')"
                                :class="formErrors.discountValue ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.discountValue" class="text-status-danger text-[10px] mt-1" x-text="formErrors.discountValue"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Min. Purchase (₹)</label>
                            <input type="number" x-model="formData.minAmount" @input="validateField('minAmount')"
                                @blur="validateField('minAmount')" :class="formErrors.minAmount ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.minAmount" class="text-status-danger text-[10px] mt-1" x-text="formErrors.minAmount"></p>
                        </div>

                        <div class="space-y-1" x-show="formData.discountType === 'percentage'">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Max. Discount (₹)</label>
                            <input type="number" x-model="formData.maxDiscount" @input="validateField('maxDiscount')"
                                @blur="validateField('maxDiscount')" :class="formErrors.maxDiscount ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.maxDiscount" class="text-status-danger text-[10px] mt-1" x-text="formErrors.maxDiscount"></p>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Expiry Date</label>
                            <input type="date" x-model="formData.expiryDate" @change="validateField('expiryDate')"
                                @blur="validateField('expiryDate')" :class="formErrors.expiryDate ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.expiryDate" class="text-status-danger text-[10px] mt-1" x-text="formErrors.expiryDate"></p>
                        </div>

                        <div class="space-y-1 col-span-2">
                            <label class="text-[9px] font-bold tracking-widest uppercase text-white/40">Usage Limit (Per User)</label>
                            <input type="number" x-model="formData.usageLimit" @input="validateField('usageLimit')"
                                @blur="validateField('usageLimit')" :class="formErrors.usageLimit ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black px-4 py-3 text-white text-xs border focus:border-accent outline-none transition-all">
                            <p x-show="formErrors.usageLimit" class="text-status-danger text-[10px] mt-1" x-text="formErrors.usageLimit"></p>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 pt-6 border-t border-white/5">
                        <button type="button" @click="closeModal()" :disabled="isSubmitting"
                            class="flex-1 py-4 border border-white/10 text-white text-[10px] font-bold tracking-widest uppercase hover:bg-white/5 transition-all">Cancel</button>
                        <button type="submit" :disabled="isSubmitting"
                            class="flex-1 py-4 bg-accent text-black text-[10px] font-bold tracking-widest uppercase hover:bg-white disabled:opacity-50 transition-all btn-press shadow-[0_0_20px_rgba(255,106,0,0.3)]">
                            <span x-show="!isSubmitting">Save Coupon</span>
                            <span x-show="isSubmitting" class="flex items-center justify-center gap-2">Processing...</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const register = () => {
                if (Alpine.data('couponManager')) return;
                Alpine.data('couponManager', () => ({
                    showModal: false,
                    isEditing: false,
                    isSubmitting: false,
                    currentId: null,
                    currentTab: 'live',
                    search: '',
                    formData: {
                        code: '',
                        discountType: 'percentage',
                        discountValue: '',
                        minAmount: 0,
                        maxDiscount: '',
                        expiryDate: '',
                        usageLimit: 1
                    },
                    formErrors: {
                        code: '',
                        discountValue: '',
                        minAmount: '',
                        maxDiscount: '',
                        expiryDate: '',
                        usageLimit: ''
                    },
                    openCreateModal() {
                        this.isEditing = false;
                        this.isSubmitting = false;
                        this.currentId = null;
                        this.formData = {
                            code: '',
                            discountType: 'percentage',
                            discountValue: '',
                            minAmount: 0,
                            maxDiscount: '',
                            expiryDate: '',
                            usageLimit: 1
                        };
                        Object.keys(this.formErrors).forEach(k => this.formErrors[k] = '');
                        this.showModal = true;
                    },
                    async confirmDelete(id, name) {
                        const confirmed = await window.confirmAction({ 
                            title: 'DELETE COUPON?', 
                            message: `Are you sure you want to remove <span class='text-white font-black'>${name}</span>? This action is permanent and cannot be undone.`, 
                            type: 'error',
                            confirmText: 'Delete Permanently'
                        });
                        
                        if (confirmed) {
                            try {
                                const res = await fetch(`/admin/marketing/coupons/${id}`, { method: 'DELETE' });
                                const data = await res.json();
                                if (data.success) {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon deleted successfully', type: 'success' } }));
                                    if (window.SpaNavigation) {
                                        setTimeout(() => window.SpaNavigation.loadPage(window.location.href), 800);
                                    } else {
                                        setTimeout(() => window.location.reload(), 800);
                                    }
                                } else {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Delete failed', type: 'error' } }));
                                }
                            } catch (err) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Network error occurred', type: 'error' } }));
                            }
                        }
                    },
                    closeModal() { this.showModal = false; },
                    openEditModal(id, code, type, val, minAmt, maxDisc, expiry, limit) {
                        this.isEditing = true;
                        this.currentId = id;
                        this.formData = { code, discountType: type, discountValue: val, minAmount: minAmt || 0, maxDiscount: maxDisc || '', expiryDate: expiry || '', usageLimit: limit || 1 };
                        Object.keys(this.formErrors).forEach(k => this.formErrors[k] = '');
                        this.showModal = true;
                    },
                    validateField(field) {
                        const v = this.formData;
                        this.formErrors[field] = '';
                        if (field === "code" && !/^[A-Z0-9]{4,15}$/.test(v.code)) this.formErrors.code = "4-15 Alphanumeric";
                        if (field === "discountValue") {
                            if (!v.discountValue || v.discountValue <= 0) this.formErrors.discountValue = "Invalid value";
                            else if (v.discountType === 'percentage' && v.discountValue > 90) this.formErrors.discountValue = "Offer percentage too high";
                        }
                        if (field === "minAmount" && (v.discountType === "fixed" && Number(v.discountValue) >= Number(v.minAmount))) {
                            this.formErrors.minAmount = "Must be > Discount";
                        }
                        if (field === "expiryDate" && (!v.expiryDate || new Date(v.expiryDate) < new Date().setHours(0,0,0,0))) {
                            this.formErrors.expiryDate = "Invalid date";
                        }
                    },
                    validateAll() {
                        ["code", "discountValue", "minAmount", "expiryDate"].forEach(f => this.validateField(f));
                        return !Object.values(this.formErrors).some(e => e !== '');
                    },
                    async submitForm() {
                        if (this.isSubmitting || !this.validateAll()) return;
                        this.isSubmitting = true;
                        try {
                            const url = this.isEditing ? `/admin/marketing/coupons/${this.currentId}` : '/admin/marketing/coupons';
                            const res = await fetch(url, {
                                method: this.isEditing ? 'PUT' : 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.formData)
                            });
                            const data = await res.json();
                            if (data.success) {
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon saved!', type: 'success' } }));
                                if (window.SpaNavigation) {
                                    setTimeout(() => window.SpaNavigation.loadPage(window.location.href), 800);
                                } else {
                                    setTimeout(() => window.location.reload(), 800);
                                }
                            } else {
                                throw new Error(data.message);
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: err.message, type: 'error' } }));
                        } finally { this.isSubmitting = false; }
                    }
                }));
            };
            if (window.Alpine) register(); else document.addEventListener('alpine:init', register);
        })();
    </script>