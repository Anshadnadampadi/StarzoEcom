<!-- views/admin/orders/show.ejs -->
<%- contentFor('body') %>

<div class="max-w-6xl mx-auto space-y-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-12">
        <div>
            <a href="/admin/orders" class="text-accent text-[9px] font-bold tracking-widest uppercase hover:underline mb-8 inline-block">← Back to logistics</a>
            <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">ORDER #<%= order.orderId %>.</h1>
            <div class="flex gap-4 items-center">
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Placed on <%= new Date(order.createdAt).toLocaleString() %></p>
                <span class="w-1.5 h-1.5 rounded-full bg-white/10"></span>
                <%- include('../../partials/status-badge', { status: order.status }) %>
            </div>
        </div>
        
        <div class="flex gap-4">
            <select name="status" class="bg-black border border-white/10 px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-white focus:outline-none focus:border-accent transition-all">
                <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Update: Pending</option>
                <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Update: Confirmed</option>
                <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Update: Processing</option>
                <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Update: Shipped</option>
                <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Update: Delivered</option>
                <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Update: Cancelled</option>
            </select>
            <button class="bg-accent text-black font-bold px-8 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all btn-press">UPDATE STATUS</button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Order Items -->
        <div class="lg:col-span-2 space-y-10">
            <div class="bg-black-surface border border-white/5 overflow-hidden">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase px-10 py-6 border-b border-white/5">Purchased Items</h3>
                <div class="divide-y divide-white/5">
                    <% order.items.forEach(item => { %>
                        <div class="px-10 py-8 flex justify-between items-center gap-8">
                            <div class="flex items-center gap-8">
                                <div class="w-20 h-20 bg-black p-4 border border-white/5 flex-shrink-0">
                                    <img src="<%= item.product.images[0].url %>" class="w-full h-full object-contain">
                                </div>
                                <div>
                                    <p class="text-white text-sm font-bold uppercase"><%= item.product.title %></p>
                                    <p class="text-white/30 text-[10px] tracking-widest uppercase mt-2"><%= (typeof item.variant === 'object' && item.variant !== null) ? [item.variant.storage, item.variant.color, item.variant.ram].filter(Boolean).join(' ') : item.variant %> · SKU: <%= item._id %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-white font-mono text-sm font-bold">₹<%= item.product.price.toLocaleString() %> × <%= item.qty %></p>
                                <p class="text-accent font-mono text-base font-bold mt-2">₹<%= (item.product.price * item.qty).toLocaleString() %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <div class="px-10 py-8 bg-white/[0.02] border-t border-white/5 text-right">
                    <div class="space-y-2 mb-6">
                        <div class="flex justify-end gap-12 text-white/40 text-[10px] font-bold tracking-widest uppercase">
                            <span>Subtotal</span>
                            <span class="text-white font-mono min-w-[100px]">₹<%= order.totalAmount.toLocaleString() %></span>
                        </div>
                        <div class="flex justify-end gap-12 text-white/40 text-[10px] font-bold tracking-widest uppercase text-status-success">
                            <span>Shipping</span>
                            <span class="font-mono min-w-[100px]">₹0.00</span>
                        </div>
                    </div>
                    <div class="flex justify-end gap-12 items-baseline">
                        <span class="text-white text-[11px] font-bold tracking-widest uppercase">Grand Total</span>
                        <span class="text-white text-3xl font-mono font-bold">₹<%= order.totalAmount.toLocaleString() %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="space-y-10">
            <!-- Customer Info -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-8 border-b border-white/5 pb-4">Customer Base</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-white text-sm font-bold uppercase">
                            <%= (order.user.firstName || order.user.name || order.user.email.split('@')[0]) %> 
                            <%= (order.user.lastName || '') %>
                        </p>
                    </div>
                    <div>
                        <p class="text-white/30 text-[9px] font-bold tracking-widest uppercase mb-1">Email</p>
                        <p class="text-white text-sm"><%= order.user.email %></p>
                    </div>
                </div>
            </div>

            <!-- Shipping Info -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-8 border-b border-white/5 pb-4">Dispatch Logic</h3>
                <div class="text-white/60 text-sm leading-relaxed space-y-1 mb-8">
                    <p class="font-bold text-white mb-2"><%= order.address.name %></p>
                    <p><%= order.address.street %></p>
                    <p><%= order.address.city %>, <%= order.address.state %> - <%= order.address.pincode %></p>
                    <p class="text-[10px] font-mono mt-4 text-white/40">+91 <%= order.address.phone %></p>
                </div>
                <button class="w-full py-4 border border-white/10 text-white text-[10px] font-bold tracking-widest uppercase hover:bg-white/5 transition-all">Print Packing Slip</button>
            </div>

            <!-- Payment Info -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-8 border-b border-white/5 pb-4">Financial Status</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-white/40 text-[10px] uppercase font-bold">Method</span>
                        <span class="text-white text-xs font-bold uppercase"><%= order.paymentMethod %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-white/40 text-[10px] uppercase font-bold">Status</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest <%= order.paymentStatus === 'paid' ? 'text-status-success' : 'text-status-warning' %>"><%= order.paymentStatus %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
