<!-- views/admin/orders/show.ejs -->
<%- contentFor('body') %>

<div class="max-w-6xl mx-auto space-y-10">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-12">
        <div>
            <a href="/admin/orders" class="text-accent text-[9px] font-bold tracking-widest uppercase hover:underline mb-8 inline-block">← Back to Orders</a>
            <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">ORDER #<%= order.orderId %>.</h1>
            <div class="flex gap-4 items-center">
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Placed on <%= new Date(order.createdAt).toLocaleString() %></p>
                <span class="w-1.5 h-1.5 rounded-full bg-white/10"></span>
                <%- include('../partials/status-badge.ejs', { status: order.orderStatus }) %>
            </div>
        </div>

        <!-- Status Update & Return Management -->
        <div class="flex gap-4 items-center">
            <% 
                const returnableItems = order.items.filter(i => !['Cancelled', 'Returned'].includes(i.status));
                const requestedItems = returnableItems.filter(i => i.status === 'Return Requested');
                const isPartialReturn = requestedItems.length > 0 && requestedItems.length < returnableItems.length;
                const isFullReturn = requestedItems.length > 0 && requestedItems.length === returnableItems.length;
            %>

            <% if (order.orderStatus === 'Return Requested') { %>
                <% if (isFullReturn) { %>
                    <button onclick="updateStatus('Return Approved')" class="bg-status-success text-black font-bold px-8 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all">APPROVE RETURN</button>
                    <button onclick="updateStatus('Delivered')" class="bg-status-danger text-white font-bold px-8 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-status-danger/80 transition-all">REJECT RETURN</button>
                <% } else { %>
                    <div class="bg-status-warning/10 border border-status-warning/20 px-6 py-4 rounded-sm flex flex-col items-end">
                        <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-status-warning">Partial Return Requested</p>
                        <p class="text-[8px] text-white/40 mt-1 uppercase tracking-widest">Manage individual items below</p>
                    </div>
                <% } %>
            <% } else if (order.orderStatus === 'Return Approved') { %>
                <button onclick="updateStatus('Return Picked')" class="bg-accent text-black font-bold px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all">MARK AS PICKED</button>
            <% } else if (order.orderStatus === 'Return Picked') { %>
                <button onclick="updateStatus('Returned')" class="bg-status-success text-black font-bold px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all shadow-[0_0_20px_rgba(22,163,74,0.3)]">PROCESS REFUND & CLOSE</button>
            <% } else if (['Cancelled', 'Returned', 'Partially Returned', 'Return Rejected'].includes(order.orderStatus)) { %>
                <div class="bg-white/5 border border-white/10 px-6 py-4 rounded-sm flex items-center gap-4">
                    <p class="text-[10px] font-bold tracking-[0.2em] uppercase text-white/40">Status: <%= order.orderStatus %></p>
                    <% if (order.orderStatus === 'Partially Returned' || order.orderStatus === 'Return Rejected') { %>
                        <span class="text-white/20 text-[9px] uppercase tracking-widest border-l border-white/10 pl-4">Delivery Finalized</span>
                    <% } %>
                </div>
            <% } else { %>
                <% 
                    const hierarchy = ['Pending', 'Confirmed', 'Processing', 'Shipped', 'Delivered', 'Cancelled'];
                    const currentIndex = Math.max(0, hierarchy.indexOf(order.orderStatus));
                %>
                <select id="statusSelect" class="bg-black border border-white/10 px-6 py-4 text-[10px] font-bold tracking-widest uppercase text-white focus:outline-none focus:border-accent transition-all">
                    <% hierarchy.forEach((s, idx) => { %>
                        <% if (idx >= currentIndex || s === 'Cancelled') { %>
                            <option value="<%= s %>" <%= order.orderStatus === s ? 'selected' : '' %>>
                                <%= order.orderStatus === s ? 'Current: ' : 'Update to: ' %><%= s %>
                            </option>
                        <% } %>
                    <% }) %>
                </select>
                <button id="update-status-btn" class="bg-accent text-black font-bold px-8 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all font-display tracking-widest">UPDATE STATUS</button>
            <% } %>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Left: Order Items/Alerts -->
        <div class="lg:col-span-2 space-y-10">
            <% 
                const hasGlobalReason = (order.orderStatus === 'Cancelled' && order.cancellationReason) || 
                                       (['Return Requested', 'Returned', 'Return Approved', 'Partially Returned'].includes(order.orderStatus) && order.returnReason);
            %>

            <% if (hasGlobalReason) { %>
                <div class="bg-black-surface border border-l-4 <%= order.orderStatus === 'Cancelled' ? 'border-status-danger' : 'border-status-warning' %> p-8">
                    <h4 class="text-white text-[11px] font-bold tracking-widest uppercase mb-4">
                        <%= order.orderStatus %> Details
                    </h4>
                    <p class="text-white/60 text-xs italic leading-relaxed">
                        "<%= order.returnReason || order.cancellationReason %>"
                    </p>
                </div>
            <% } %>

            <div class="bg-black-surface border border-white/5 overflow-hidden">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase px-10 py-6 border-b border-white/5">Purchased Items</h3>
                <div class="divide-y divide-white/5">
                    <% order.items.forEach(item => { %>
                        <%
                            const pName = (item.product && item.product.name) ? item.product.name : 'Product Unavailable';
                            let pImg = '/images/placeholder.png';
                            if (item.product && item.product.variants && item.product.variants.length > 0) {
                                const tv = item.variant || {};
                                const mv = item.product.variants.find(v =>
                                    (!tv.color   || v.color   === tv.color) &&
                                    (!tv.storage || v.storage === tv.storage) &&
                                    (!tv.ram     || v.ram     === tv.ram)
                                ) || item.product.variants[0];
                                if (mv && mv.images && mv.images.length > 0) pImg = mv.images[0];
                            }
                            const variantStr = (typeof item.variant === 'object' && item.variant !== null)
                                ? [item.variant.storage, item.variant.color, item.variant.ram].filter(Boolean).join(' · ')
                                : (item.variant || 'Standard');
                            const itemPrice = item.price || (item.product ? item.product.price : 0) || 0;
                        %>
                        <div class="px-10 py-8 flex justify-between items-center gap-8">
                            <div class="flex items-center gap-8">
                                <div class="w-20 h-20 bg-black p-3 border border-white/5 flex-shrink-0">
                                    <img src="<%= pImg %>" class="w-full h-full object-contain" alt="<%= pName %>">
                                </div>
                                <div>
                                    <p class="text-white text-sm font-bold uppercase mb-1"><%= pName %></p>
                                    <p class="text-white/30 text-[10px] tracking-widest uppercase"><%= variantStr %></p>
                                    <p class="text-white/20 text-[9px] mt-1">Qty: <%= item.qty %></p>
                                    <% if (item.status === 'Cancelled') { %>
                                        <span class="text-status-danger text-[8px] font-bold uppercase tracking-widest border border-status-danger/30 px-2 py-0.5 bg-status-danger/5 mt-1 inline-block">Cancelled</span>
                                    <% } else if (item.status === 'Return Requested') { %>
                                        <div class="space-y-2 mt-2">
                                            <span class="text-status-warning text-[8px] font-bold uppercase tracking-widest border border-status-warning/30 px-2 py-0.5 bg-status-warning/5 inline-block">Return Requested</span>
                                            <p class="text-white/40 text-[9px] italic">Reason: <%= item.returnReason %></p>
                                            <div class="flex gap-2">
                                                <button onclick="updateItemReturn('<%= item._id %>', 'Return Approved')" class="text-[8px] font-bold uppercase tracking-widest bg-status-success/20 text-status-success border border-status-success/30 px-2 py-1 hover:bg-status-success hover:text-black transition-all">Approve</button>
                                                <button onclick="updateItemReturn('<%= item._id %>', 'Return Rejected')" class="text-[8px] font-bold uppercase tracking-widest bg-status-danger/20 text-status-danger border border-status-danger/30 px-2 py-1 hover:bg-status-danger hover:text-white transition-all">Reject</button>
                                            </div>
                                        </div>
                                    <% } else if (item.status === 'Return Approved') { %>
                                        <div class="space-y-2 mt-2">
                                            <span class="text-status-warning text-[8px] font-bold uppercase tracking-widest border border-status-warning/30 px-2 py-0.5 bg-status-warning/5 inline-block">Return Approved</span>
                                            <button onclick="updateItemReturn('<%= item._id %>', 'Return Picked')" class="block text-[8px] font-bold uppercase tracking-widest bg-accent/20 text-accent border border-accent/30 px-2 py-1 hover:bg-accent hover:text-black transition-all">Mark as Picked</button>
                                        </div>
                                    <% } else if (item.status === 'Return Picked') { %>
                                        <div class="space-y-2 mt-2">
                                            <span class="text-status-warning text-[8px] font-bold uppercase tracking-widest border border-status-warning/30 px-2 py-0.5 bg-status-warning/5 inline-block">Item Picked</span>
                                            <button onclick="updateItemReturn('<%= item._id %>', 'Returned')" class="block text-[8px] font-bold uppercase tracking-widest bg-status-success/20 text-status-success border border-status-success/30 px-2 py-1 hover:bg-status-success hover:text-black transition-all">Process Refund</button>
                                        </div>
                                    <% } else if (item.status === 'Returned') { %>
                                        <span class="text-status-success text-[8px] font-bold uppercase tracking-widest border border-status-success/30 px-2 py-0.5 bg-status-success/5 mt-1 inline-block">Returned & Refunded</span>
                                    <% } else if (item.status === 'Return Rejected') { %>
                                        <span class="text-status-danger text-[8px] font-bold uppercase tracking-widest border border-status-danger/30 px-2 py-0.5 bg-status-danger/5 mt-1 inline-block">Return Rejected</span>
                                    <% } %>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="<%= item.status === 'Cancelled' ? 'text-white/10 line-through' : 'text-white/50' %> font-mono text-xs mb-1">₹<%= itemPrice.toLocaleString() %> × <%= item.qty %></p>
                                <p class="<%= item.status === 'Cancelled' ? 'text-white/10 line-through' : 'text-accent' %> font-mono text-base font-bold">₹<%= (itemPrice * item.qty).toLocaleString() %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Totals -->
                <div class="px-10 py-8 bg-white/[0.02] border-t border-white/5">
                    <div class="space-y-3 mb-6">
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-white/40">
                            <span>Subtotal</span>
                            <span class="font-mono text-white/60">₹<%= order.subtotal.toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-white/40">
                            <span>Tax (18% GST)</span>
                            <span class="font-mono text-white/60">₹<%= (order.tax || 0).toLocaleString() %></span>
                        </div>
                        <% if (order.discount && order.discount > 0) { %>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-status-success">
                            <span>Discount</span>
                            <span class="font-mono">− ₹<%= order.discount.toLocaleString() %></span>
                        </div>
                        <% } %>
                        <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-white/40">
                            <span>Shipping</span>
                            <span class="font-mono text-status-success"><%= (!order.shippingFee || order.shippingFee === 0) ? 'FREE' : '₹' + order.shippingFee.toLocaleString() %></span>
                        </div>
                    </div>
                    <div class="flex justify-between items-baseline border-t border-white/5 pt-4">
                        <span class="text-white text-[11px] font-bold tracking-widest uppercase">Grand Total</span>
                        <span class="text-white text-3xl font-mono font-bold">₹<%= order.totalAmount.toLocaleString() %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Sidebar -->
        <div class="space-y-8">

            <!-- Customer -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-6 border-b border-white/5 pb-4">Customer</h3>
                <div class="space-y-4">
                    <p class="text-white font-bold uppercase text-sm">
                        <%= (order.user.firstName || order.user.name || order.user.email.split('@')[0]) %>
                        <%= (order.user.lastName || '') %>
                    </p>
                    <div>
                        <p class="text-white/30 text-[9px] uppercase tracking-widest mb-1">Email</p>
                        <p class="text-white text-sm break-all"><%= order.user.email %></p>
                    </div>
                </div>
            </div>

            <!-- Shipping Address -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-6 border-b border-white/5 pb-4">Shipping Address</h3>
                <% if (order.shippingAddress) { %>
                <div class="text-white/60 text-sm leading-relaxed space-y-1">
                    <p class="font-bold text-white mb-2"><%= order.shippingAddress.fullName %></p>
                    <p><%= order.shippingAddress.streetAddress %></p>
                    <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> − <%= order.shippingAddress.pinCode %></p>
                    <p class="text-[10px] font-mono mt-3 text-white/40">+91 <%= order.shippingAddress.phone %></p>
                </div>
                <% } else { %>
                <p class="text-white/30 text-xs">No address on record.</p>
                <% } %>
            </div>

            <!-- Payment -->
            <div class="bg-black-surface border border-white/5 p-8">
                <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-6 border-b border-white/5 pb-4">Payment</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-white/40 text-[10px] uppercase font-bold">Method</span>
                        <span class="text-white text-xs font-bold uppercase"><%= order.paymentMethod %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-white/40 text-[10px] uppercase font-bold">Status</span>
                        <span class="text-[10px] font-bold uppercase tracking-widest <%= order.paymentStatus === 'Paid' ? 'text-status-success' : 'text-status-warning' %>">
                            <%= order.paymentStatus %>
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    async function updateStatus(status) {
        const orderId = '<%= order._id %>';
        const confirmed = await window.confirmAction({
            title: `Update to ${status}?`,
            message: `Execution of this operation will transition the order status to: ${status}`,
            type: 'warning'
        });

        if (confirmed) {
            try {
                const response = await fetch('/admin/orders/status', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, status })
                });
                const data = await response.json();

                if (data.success) {
                    window.dispatchEvent(new CustomEvent('show-toast', { 
                        detail: { message: `Order status synchronized to ${status} successfully.`, type: 'success' } 
                    }));
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                window.dispatchEvent(new CustomEvent('show-toast', { 
                    detail: { message: error.message || 'Transmission failed. System unable to update status.', type: 'error' } 
                }));
            }
        }
    }

    const updateBtn = document.getElementById('update-status-btn');
    if (updateBtn) {
        updateBtn.addEventListener('click', () => {
            const status = document.getElementById('statusSelect').value;
            updateStatus(status);
        });
    }

    async function updateItemReturn(itemId, status) {
        const orderId = '<%= order._id %>';
        const action = status === 'Return Approved' ? 'APPROVE' : 
                       (status === 'Return Picked' ? 'MARK AS PICKED' : 
                       (status === 'Returned' ? 'PROCESS REFUND FOR' : 'REJECT'));
        
        const confirmed = await window.confirmAction({
            title: `AUTHORIZE ACTION?`,
            message: `Confirm you wish to ${action} this specific item return request. This action is logged.`,
            type: 'question'
        });

        if (confirmed) {
            try {
                const response = await fetch('/admin/orders/item-return', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, itemId, status })
                });
                const data = await response.json();

                if (data.success) {
                    window.dispatchEvent(new CustomEvent('show-toast', { 
                        detail: { message: data.message || 'Item return protocol executed successfully.', type: 'success' } 
                    }));
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                window.dispatchEvent(new CustomEvent('show-toast', { 
                    detail: { message: error.message || 'Protocol failure. Item return status update aborted.', type: 'error' } 
                }));
            }
        }
    }
</script>