<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Starzo - Product Management</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <!-- Admin Premium Styles -->
    <link rel="stylesheet" href="/admin/css/admin-style.css">

    <style>
        .glass-card {
            background: var(--bg-surface) !important;
            border-color: var(--border) !important;
        }
        .status-unlisted { opacity: 0.5; filter: grayscale(0.8); }
    </style>
</head>
<body class="flex min-h-screen">

    <aside class="sidebar reveal-init">
        <div class="p-8 font-heading">
            <div class="logo-box">
                <span class="material-symbols-outlined text-primary text-2xl font-bold">smartphone</span>
                <span class="logo-text">Starzo</span>
            </div>
        </div>

        <nav class="flex-1 px-6 space-y-2 mt-4">
            <a href="/admin/dashboard" class="sidebar-link">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a href="/admin/category/categories" class="sidebar-link">
                <span class="material-symbols-outlined">category</span>
                <span>Categories</span>
            </a>
            <a href="/admin/product/productManagement" class="sidebar-link active">
                <span class="material-symbols-outlined">inventory_2</span>
                <span>Products</span>
            </a>
            <a href="/admin/management" class="sidebar-link">
                <span class="material-symbols-outlined">people</span>
                <span>Customers</span>
            </a>
        </nav>
    </aside>

    <main class="flex-1 flex flex-col relative px-12">
        <header class="py-12 flex justify-between items-center stagger-1">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-slate-900">Product Management</h1>
                <p class="text-slate-500 text-sm">Manage your premium product catalog</p>
            </div>
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 rounded-xl bg-slate-100 border border-slate-200 text-slate-500 flex items-center justify-center">
                    <span class="material-symbols-outlined text-sm">notifications</span>
                </button>
                <button onclick="window.location.href='/admin/product/addProduct'" class="btn-premium px-6 py-3 rounded-2xl">
                    <span class="material-symbols-outlined">add_box</span>
                    <span class="font-bold">Add Product</span>
                </button>
            </div>
        </header>

        <div class="stagger-2">
            <div class="flex flex-col md:flex-row gap-4 mb-10">
                <div class="relative flex-grow">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary/40 text-xl pointer-events-none">search</span>
                    <input class="admin-input pl-12 rounded-2xl" placeholder="Search products by name, brand, or SKU..." type="text" id="searchInput" onkeyup="searchTable()"/>
                </div>
                <select class="admin-input rounded-2xl w-full md:w-64" id="categoryFilter" onchange="filterByCategory()">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.name %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="admin-card !p-0 overflow-hidden stagger-3 mb-12">
                <div class="table-responsive">
                    <table class="premium-table mb-0">
                        <thead>
                            <tr>
                                <th class="pl-8">Product Details</th>
                                <th>Category</th>
                                <th>Listing Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                                <th class="text-right pr-8">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach(product=> { %>
                                <tr class="<%= product.isDeleted ? 'status-unlisted' : '' %>">
                                    <td class="pl-8">
                                        <div class="flex items-center gap-4">
                                            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 overflow-hidden">
                                                <img src="/uploads/product-images/<%= product.productImage[0] %>" 
                                                     class="w-full h-full object-cover" alt="">
                                            </div>
                                            <div>
                                                <div class="font-bold text-slate-900"><%= product.productName %></div>
                                                <div class="text-[10px] text-primary uppercase tracking-tighter">SKU: <%= product._id.toString().slice(-6) %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-slate-500"><%= product.category.name %></td>
                                    <td class="font-mono text-slate-900 font-bold">₹<%= product.salePrice %></td>
                                    <td>
                                        <span class="px-2 py-1 rounded-md text-[10px] font-bold <%= product.quantity < 10 ? 'bg-red-500/10 text-red-500' : 'bg-primary/10 text-primary' %>">
                                            <%= product.quantity %> In Stock
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-[10px] font-black uppercase tracking-widest <%= product.isDeleted ? 'text-red-500' : 'text-primary' %>">
                                            <%= product.isBlocked ? 'Blocked' : (product.isDeleted ? 'Unlisted' : 'Listed') %>
                                        </span>
                                    </td>
                                    <td class="pr-8 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a href="/admin/product/editProduct?id=<%= product._id %>" 
                                               class="p-2 bg-slate-100 hover:bg-primary/10 text-slate-400 hover:text-primary rounded-xl transition-all border border-slate-200">
                                                <span class="material-symbols-outlined text-sm">edit</span>
                                            </a>
                                            <button onclick="handleBlock('<%= product._id %>', <%= !!product.isBlocked %>)"
                                                    class="p-2 bg-slate-100 hover:bg-yellow-500/10 text-slate-400 hover:text-yellow-600 rounded-xl transition-all border border-slate-200">
                                                <span class="material-symbols-outlined text-sm"><%= product.isBlocked ? 'lock_open' : 'lock' %></span>
                                            </button>
                                            <button onclick="handleDelete('<%= product._id %>')"
                                                    class="p-2 bg-slate-100 hover:bg-red-500/10 text-slate-400 hover:text-red-600 rounded-xl transition-all border border-slate-200">
                                                <span class="material-symbols-outlined text-sm">delete</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div id="productModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-6 bg-black/80 backdrop-blur-sm">
        <div class="admin-card w-full max-w-5xl max-h-[90vh] overflow-hidden flex flex-col relative !p-0 !bg-white">
            <div class="p-8 flex justify-between items-center border-b border-slate-100">
                <h2 id="modalTitle" class="text-2xl font-bold text-slate-900">Product Details</h2>
                <button onclick="closeModal('productModal')" class="text-slate-400 hover:text-slate-900 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-8 custom-scrollbar">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
                    <!-- Left Column: Primary Info & Media -->
                    <div class="lg:col-span-7 space-y-8">
                        <section>
                            <div class="mb-4">
                                <label class="text-[10px] text-primary uppercase font-bold tracking-widest ml-1">Product Name</label>
                                <input type="text" id="pName" placeholder="e.g. Flagship Pro Titanium" class="admin-input rounded-2xl">
                            </div>
                            <div class="mb-6">
                                <label class="text-[10px] text-primary uppercase font-bold tracking-widest ml-1">Description</label>
                                <textarea id="pDesc" rows="4" placeholder="Describe the premium features..." class="admin-input rounded-2xl resize-none"></textarea>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-[10px] text-primary uppercase font-bold tracking-widest ml-1">Category</label>
                                    <select id="pCat" class="admin-input rounded-2xl">
                                        <option>Smartphones</option>
                                        <option>Laptops</option>
                                        <option>Audio</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="text-[10px] text-primary uppercase font-bold tracking-widest ml-1">Stock Unit</label>
                                    <input type="number" id="pStock" placeholder="150" class="admin-input rounded-2xl">
                                </div>
                            </div>
                        </section>

                        <section>
                             <div class="flex items-center gap-2 text-primary text-[10px] uppercase font-bold tracking-[0.2em] mb-4">
                                <span>Media Suite</span>
                            </div>
                            <div class="grid grid-cols-3 gap-4" id="mediaSuite">
                                <div class="relative group aspect-square bg-slate-50 border border-dashed border-slate-200 rounded-2xl flex flex-col items-center justify-center cursor-pointer hover:border-primary transition-all overflow-hidden">
                                    <input type="file" class="absolute inset-0 opacity-0 cursor-pointer img-input" data-idx="0">
                                    <img class="absolute inset-0 w-full h-full object-cover hidden" id="prev0">
                                    <div class="text-center group-hover:scale-110 transition-all">
                                        <span class="material-symbols-outlined text-slate-300 text-2xl">add_photo_alternate</span>
                                        <p class="text-[8px] text-slate-400 mt-2 font-bold uppercase">Primary</p>
                                    </div>
                                    <button onclick="removeImg(0)" class="absolute top-2 right-2 bg-red-500/80 text-white p-1 rounded-lg hidden" id="rm0">
                                        <span class="material-symbols-outlined text-xs">delete</span>
                                    </button>
                                </div>
                                <div class="relative group aspect-square bg-slate-50 border border-dashed border-slate-200 rounded-2xl flex flex-col items-center justify-center cursor-pointer hover:border-primary transition-all overflow-hidden">
                                    <input type="file" class="absolute inset-0 opacity-0 cursor-pointer img-input" data-idx="1">
                                    <img class="absolute inset-0 w-full h-full object-cover hidden" id="prev1">
                                    <div class="text-center group-hover:scale-110 transition-all">
                                        <span class="material-symbols-outlined text-slate-300 text-2xl">add_photo_alternate</span>
                                        <p class="text-[8px] text-slate-400 mt-2 font-bold uppercase">Side View</p>
                                    </div>
                                    <button onclick="removeImg(1)" class="absolute top-2 right-2 bg-red-500/80 text-white p-1 rounded-lg hidden" id="rm1">
                                        <span class="material-symbols-outlined text-xs">delete</span>
                                    </button>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Right Column: Config & Meta -->
                    <div class="lg:col-span-5 space-y-8">
                        <section class="admin-card bg-white/[0.02] border-white/5 p-6 rounded-2xl !shadow-none">
                             <div class="flex items-center gap-2 text-primary text-[10px] uppercase font-bold tracking-[0.2em] mb-6">
                                <span class="material-symbols-outlined text-sm">settings</span>
                                <span>Configuration</span>
                            </div>
                            <div class="space-y-6">
                                <div>
                                    <label class="text-[10px] text-white/40 uppercase font-bold mb-3 block">Price (₹)</label>
                                    <input type="number" id="pPrice" placeholder="999.00" class="admin-input rounded-2xl">
                                </div>
                                <div class="flex justify-between items-center bg-slate-50 p-4 rounded-2xl border border-slate-100">
                                    <span class="text-xs font-bold text-white/60">Product Status</span>
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" id="pStatusToggle" class="sr-only peer" checked>
                                        <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#00ADB5]"></div>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>
                </div>
            </div>

            <div class="p-8 border-t border-slate-100 flex justify-end gap-4 bg-slate-50">
                <button onclick="closeModal('productModal')" class="px-8 py-3 rounded-2xl text-slate-400 font-bold text-xs hover:text-slate-900 transition-all uppercase tracking-widest">Discard Changes</button>
                <button id="saveProductBtn" onclick="saveProduct()" class="btn-premium px-10 py-3 rounded-2xl font-bold text-xs uppercase tracking-widest shadow-lg">Update Product</button>
            </div>
        </div>
    </div>

    <div id="deleteModal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-6 bg-slate-900/40 backdrop-blur-xl">
        <div class="admin-card max-w-sm w-full p-10 text-center relative border-slate-100 !bg-white">
            <div class="w-20 h-20 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">
                <span class="material-symbols-outlined text-4xl">delete_forever</span>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2">Delete Product?</h2>
            <p class="text-slate-500 text-sm mb-8 leading-relaxed">This action is permanent and will remove the item from the store and inventory logs.</p>
            <div class="space-y-3">
                <button onclick="closeModal('deleteModal')" class="btn-premium w-full py-4 rounded-2xl font-bold text-sm shadow-lg">KEEP PRODUCT</button>
                <button onclick="executeDelete()" class="w-full py-3 text-red-600/60 font-bold text-xs uppercase tracking-widest hover:text-red-600 transition-colors">Yes, Delete Permanently</button>
            </div>
        </div>
    </div>

    <canvas id="cropCanvas" class="hidden"></canvas>

    <script>
        // State
        let products = [
            { id: 1, name: "Galaxy S23 Ultra", sku: "SKU-S23-ULT", price: 9899.00, cat: "Samsung", stock: 12, status: "listed", img: "https://images.unsplash.com/photo-1678911820864-e2c567c655d7?auto=format&fit=crop&w=100&q=80" },
            { id: 2, name: "Redmi Note 13 Pro", sku: "SKU-RN13-PR", price: 149.50, cat: "Xiaomi", stock: 10, status: "unlisted", img: "https://images.unsplash.com/photo-1598327105666-5b89351aff97?auto=format&fit=crop&w=100&q=80" },
            { id: 3, name: "iPhone 17 Pro", sku: "SKU-IP15-PR", price: 9999.00, cat: "Apple", stock: 5, status: "listed", img: "https://images.unsplash.com/photo-1696446701796-da61225697cc?auto=format&fit=crop&w=100&q=80" }
        ];
        let editId = null;
        let deleteId = null;

        // Init
        window.onload = () => {
            renderTable();
            initImageUploads();
        };

        function renderTable() {
            const tbody = document.getElementById('productTableBody');
            const search = document.getElementById('searchInput').value.toLowerCase();
            const filtered = products.filter(p => p.name.toLowerCase().includes(search));

            tbody.innerHTML = filtered.map((p, i) => `
                <tr class="${p.status !== 'listed' ? 'status-unlisted' : ''}">
                    <td class="pl-8">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 overflow-hidden">
                                <img src="${p.img}" class="w-full h-full object-cover">
                            </div>
                            <div>
                                <div class="font-bold text-slate-900">${p.name}</div>
                                <div class="text-[10px] text-primary uppercase tracking-tighter">${p.sku}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-slate-500">${p.cat}</td>
                    <td class="font-mono text-slate-900 font-bold">₹${p.price.toFixed(2)}</td>
                    <td>
                        <span class="px-2 py-1 rounded-md text-[10px] font-bold ${p.stock < 10 ? 'bg-red-500/10 text-red-400' : 'bg-[#00ADB5]/10 text-[#00ADB5]'}">
                            ${p.stock} In Stock
                        </span>
                    </td>
                    <td>
                        <span class="text-[10px] font-black uppercase tracking-widest ${p.status !== 'listed' ? 'text-red-400' : 'text-[#00ADB5]'}">
                            ${p.status === 'listed' ? 'Listed' : 'Unlisted'}
                        </span>
                    </td>
                    <td class="pr-8 text-right">
                        <div class="flex justify-end gap-2">
                            <button onclick="openProductModal('edit', ${p.id})" class="p-2 bg-slate-100 hover:bg-primary/10 text-slate-400 hover:text-primary rounded-xl transition-all border border-slate-200">
                                <span class="material-symbols-outlined text-sm">edit</span>
                            </button>
                            <button onclick="toggleStatus(${p.id})" class="p-2 bg-slate-100 hover:bg-yellow-500/10 text-slate-400 hover:text-yellow-600 rounded-xl transition-all border border-slate-200">
                                <span class="material-symbols-outlined text-sm">${p.status === 'listed' ? 'lock' : 'lock_open'}</span>
                            </button>
                            <button onclick="askDelete(${p.id})" class="p-2 bg-slate-100 hover:bg-red-500/10 text-slate-400 hover:text-red-600 rounded-xl transition-all border border-slate-200">
                                <span class="material-symbols-outlined text-sm">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');

            const countDisplay = document.getElementById('countDisplay');
            if (countDisplay) countDisplay.innerText = filtered.length;
        }

        function openProductModal(type, id = null) {
            const m = document.getElementById('productModal');
            const inner = m.querySelector('.modal-scale');
            m.classList.remove('hidden');
            setTimeout(() => inner.classList.add('active'), 10);

            if (type === 'edit') {
                editId = id;
                const p = products.find(x => x.id === id);
                document.getElementById('modalTitle').innerText = "Edit Product Details";
                document.getElementById('saveProductBtn').innerText = "UPDATE PRODUCT";
                document.getElementById('pName').value = p.name;
                document.getElementById('pPrice').value = p.price;
                document.getElementById('pStock').value = p.stock;
            } else {
                editId = null;
                document.getElementById('modalTitle').innerText = "Add Elite Product";
                document.getElementById('saveProductBtn').innerText = "SAVE PRODUCT";
                resetForm();
            }
        }

        function closeModal(id) {
            const m = document.getElementById(id);
            const inner = m.querySelector('.modal-scale');
            inner.classList.remove('active');
            setTimeout(() => m.classList.add('hidden'), 300);
        }

        function saveProduct() {
            const name = document.getElementById('pName').value;
            if (!name) return alert("Product name is mandatory.");

            const data = {
                name: name,
                price: parseFloat(document.getElementById('pPrice').value || 0),
                stock: parseInt(document.getElementById('pStock').value || 0),
                cat: document.getElementById('pCat').value,
                status: document.getElementById('pStatusToggle').checked ? 'listed' : 'unlisted',
                sku: 'SKU-' + Math.random().toString(36).substr(2, 5).toUpperCase(),
                img: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=100&q=80"
            };

            if (editId) {
                const idx = products.findIndex(p => p.id === editId);
                products[idx] = { ...products[idx], ...data };
            } else {
                data.id = Date.now();
                products.push(data);
            }

            renderTable();
            // Requirement: Stay open after save
            const btn = document.getElementById('saveProductBtn');
            btn.innerText = "SUCCESSFULLY SAVED!";
            setTimeout(() => btn.innerText = editId ? "UPDATE PRODUCT" : "SAVE PRODUCT", 2000);
        }

        function toggleStatus(id) {
            const p = products.find(x => x.id === id);
            p.status = p.status === 'listed' ? 'unlisted' : 'listed';
            renderTable();
        }

        function askDelete(id) {
            deleteId = id;
            const m = document.getElementById('deleteModal');
            m.classList.remove('hidden');
            setTimeout(() => m.querySelector('.modal-scale').classList.add('active'), 10);
        }

        function executeDelete() {
            products = products.filter(p => p.id !== deleteId);
            renderTable();
            closeModal('deleteModal');
        }

        function resetForm() {
            ['pName', 'pDesc', 'pBrand', 'pPrice', 'pStock'].forEach(id => document.getElementById(id).value = '');
            [0, 1].forEach(i => removeImg(i));
        }

        // Image Handling with Auto-Crop
        function initImageUploads() {
            document.querySelectorAll('.img-input').forEach(input => {
                input.addEventListener('change', function(e) {
                    const idx = this.dataset.idx;
                    const file = e.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = (re) => {
                            const img = new Image();
                            img.onload = () => {
                                const canvas = document.getElementById('cropCanvas');
                                const ctx = canvas.getContext('2d');
                                const size = Math.min(img.width, img.height);
                                canvas.width = 400; canvas.height = 400;
                                ctx.drawImage(img, (img.width-size)/2, (img.height-size)/2, size, size, 0, 0, 400, 400);
                                
                                const preview = document.getElementById(`prev${idx}`);
                                preview.src = canvas.toDataURL();
                                preview.classList.remove('hidden');
                                document.getElementById(`rm${idx}`).classList.remove('hidden');
                            };
                            img.src = re.target.result;
                        };
                        reader.readAsDataURL(file);
                    }
                });
            });
        }

        function removeImg(idx) {
            const preview = document.getElementById(`prev${idx}`);
            preview.src = '';
            preview.classList.add('hidden');
            document.getElementById(`rm${idx}`).classList.add('hidden');
        }

        document.getElementById('searchInput').addEventListener('input', renderTable);
    </script>
</body>
</html>