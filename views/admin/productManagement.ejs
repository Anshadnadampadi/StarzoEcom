<%- contentFor('body') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.css">
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.5.13/dist/cropper.min.js"></script>

    <div class="space-y-10" x-data="productManager">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <h1 class="text-3xl font-bold tracking-tight uppercase text-white mb-2">INVENTORY CONTROL.</h1>
                <p class="text-white/40 text-[10px] tracking-[0.2em] font-bold uppercase">Manage your product
                    catalog and listings</p>
            </div>
            <div class="flex gap-4">
                <button
                    class="px-6 py-4 bg-white/5 border border-white/10 text-white text-[10px] font-bold tracking-widest uppercase hover:bg-white/10 transition-colors">Export
                    CSV</button>
                <a href="/admin/products/add"
                    class="px-8 py-4 bg-white text-black text-[10px] font-bold tracking-widest uppercase hover:bg-accent transition-all btn-press shadow-[0_0_15px_rgba(255,255,255,0.1)] inline-block">Add
                    Product</a>
            </div>
        </div>

        <!-- Filters & Search -->
        <form action="/admin/productManagement" method="GET"
            class="bg-black-surface border border-white/5 p-6 flex flex-wrap items-center justify-between gap-6"
            x-ref="filterForm">
            <div class="flex items-center gap-6">
                <div class="relative">
                    <input type="text" name="search"
                        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                        placeholder="Search products..."
                        class="bg-black border border-white/10 px-6 py-3 text-xs text-white focus:outline-none focus:border-accent w-80 placeholder:text-white/10">
                </div>
                <select name="sortBy" @change="$refs.filterForm.submit()"
                    class="bg-black border border-white/10 px-4 py-3 text-[10px] font-bold tracking-widest uppercase text-white/60 focus:outline-none">
                    <option value="newest" <%=typeof sortBy !=='undefined' && sortBy==='newest' ? 'selected' : '' %>
                        >Latest</option>
                    <option value="stock_low" <%=typeof sortBy !=='undefined' && sortBy==='stock_low' ? 'selected' : ''
                        %>>Stock: Low to High</option>
                    <option value="stock_high" <%=typeof sortBy !=='undefined' && sortBy==='stock_high' ? 'selected'
                        : '' %>>Stock: High to Low</option>
                    <option value="A-Z" <%=typeof sortBy !=='undefined' && sortBy==='A-Z' ? 'selected' : '' %>>Name: A
                        to Z</option>
                    <option value="Z-A" <%=typeof sortBy !=='undefined' && sortBy==='Z-A' ? 'selected' : '' %>>Name: Z
                        to A</option>

                </select>
            </div>
            <div class="flex items-center gap-4">
                <a href="/admin/productManagement"
                    class="text-[10px] text-white/20 hover:text-white font-bold uppercase transition-all">Clear</a>
                <button type="submit"
                    class="px-6 py-3 bg-white text-black text-[10px] font-bold tracking-widest uppercase hover:bg-accent transition-all">Filter</button>
            </div>
        </form>

        <!-- Table -->
        <div class="bg-black-surface border border-white/5 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/[0.02] border-b border-white/5">
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30">Product
                            Details</th>
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30">Category
                        </th>
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30">Brand
                        </th>
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30">Stock
                        </th>
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30">Status
                        </th>
                        <th class="px-8 py-6 text-[10px] font-bold tracking-widest uppercase text-white/30 text-right">
                            Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5 text-xs">
                    <% if (products && products.length> 0) { %>
                        <% products.forEach(product=> { %>
                            <tr class="hover:bg-white/[0.01] transition-colors group">
                                <td class="px-8 py-6">
                                    <div>
                                        <p class="text-white text-xs font-bold uppercase mb-1">
                                            <%= product.name %>
                                        </p>

                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-white/60 text-[10px] font-bold uppercase tracking-widest">
                                        <%= product.category?.name %>
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-white/40 text-[10px] font-bold uppercase tracking-widest">
                                        <%= product.brand %>
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-2">
                                        <div class="w-16 h-1 bg-white/10 rounded-full overflow-hidden">
                                            <div class="h-full <%= product.stock < 10 ? 'bg-status-danger' : 'bg-status-success' %>"
                                                style="width: <%= Math.min(product.stock, 100) %>%"></div>
                                        </div>
                                        <span
                                            class="text-[10px] font-mono font-bold <%= product.stock < 10 ? 'text-status-danger' : 'text-white/40' %>">
                                            <%= product.stock %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="flex items-center gap-2">
                                        <span
                                            class="w-1.5 h-1.5 rounded-full <%= !product.isBlocked && product.isListed ? 'bg-status-success' : 'bg-status-danger' %>"></span>
                                        <span class="text-[9px] font-bold uppercase tracking-widest text-white/60">
                                            <%= (!product.isBlocked && product.isListed) ? 'Active' : 'Hidden' %>
                                        </span>
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <div
                                        class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a href="/admin/products/details/<%= product._id %>"
                                            class="w-8 h-8 flex items-center justify-center border border-white/10 text-white/40 hover:text-white hover:border-white transition-all"
                                            title="View Details">👁️</a>
                                        <button @click="toggleStatus('<%= product._id %>')"
                                            class="w-8 h-8 flex items-center justify-center border border-white/10 text-white/40 hover:text-white hover:border-white transition-all"
                                            title="<%= product.isListed ? 'Unlist Product' : 'List Product' %>">
                                            <%= product.isListed ? '🔓' : '🔒' %>
                                        </button>
                                        <button @click="openEdit('<%= product._id %>')"
                                            class="w-8 h-8 flex items-center justify-center border border-white/10 text-white/40 hover:text-white hover:border-white transition-all"
                                            title="Edit Product">✎</button>
                                        <button @click="deleteProduct('<%= product._id %>')"
                                            class="w-8 h-8 flex items-center justify-center border border-white/10 text-white/40 hover:text-status-danger hover:border-status-danger transition-all"
                                            title="<%= product.isBlocked ? 'Restore Product' : 'Delete Product' %>">
                                            <%= product.isBlocked ? '🔄' : '✕' %>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="px-8 py-20 text-center">
                                            <p
                                                class="text-white/20 text-xs font-bold uppercase tracking-widest font-mono">
                                                No products found matching your criteria.</p>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <% let query=typeof searchQuery !=='undefined' && searchQuery ? `search=${searchQuery}` : '' %>
            <%- include('../partials/pagination', { currentPage, totalPages, query }) %>


                <!-- Edit Product Modal - iOS Styled -->
                <div x-show="showEditModal" class="fixed inset-0 z-[1000] flex items-center justify-center p-6 select-none" x-cloak>
                    <div class="absolute inset-0 bg-black/40 backdrop-blur-[15px]"
                         @click="showEditModal = false"></div>
                    
                    <div class="ios-alert-container !max-w-xl !w-full"
                         style="width: 500px; max-width: 95vw;">
                        
                        <div class="ios-alert-content !p-0">
                            <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
                                <div class="text-left">
                                    <h2 class="ios-title !text-left">Update Inventory</h2>
                                    <p class="ios-message !text-left">Catalog Synchronization Protocol</p>
                                </div>
                                <button @click="showEditModal = false" class="text-white/20 hover:text-white transition-colors">✕</button>
                            </div>

                            <form @submit.prevent="submitForm(true)" data-no-spa="true" class="p-8 space-y-6 text-left">
                                <div class="grid grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Product Name</label>
                                        <input type="text" x-model="form.name" @input="errors.name = ''"
                                            class="w-full bg-black/40 border border-white/10 rounded-lg py-3 px-4 text-xs text-white focus:outline-none focus:border-accent transition-colors">
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Brand</label>
                                        <input type="text" x-model="form.brand" @input="errors.brand = ''"
                                            class="w-full bg-black/40 border border-white/10 rounded-lg py-3 px-4 text-xs text-white focus:outline-none focus:border-accent transition-colors"
                                            list="brand-list" placeholder="Enter or select brand">
                                        <datalist id="brand-list">
                                            <% if (typeof brands !=='undefined' ) { %>
                                                <% brands.forEach(brand=> { %>
                                                    <option value="<%= brand %>"></option>
                                                <% }) %>
                                            <% } %>
                                        </datalist>
                                    </div>
                                </div>

                                <div class="grid grid-cols-3 gap-6">
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Category</label>
                                        <select x-model="form.category"
                                            class="w-full bg-black/40 border border-white/10 rounded-lg py-3 px-4 text-xs text-white focus:outline-none focus:border-accent appearance-none">
                                            <option value="">Select Category</option>
                                            <% if (typeof categories !=='undefined' ) { %>
                                                <% categories.forEach(cat=> { %>
                                                    <option value="<%= cat._id %>"><%= cat.name %></option>
                                                <% }) %>
                                            <% } %>
                                        </select>
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Price (INR)</label>
                                        <input type="number" x-model="form.price" onwheel="this.blur()"
                                            class="w-full bg-black/40 border border-white/10 rounded-lg py-3 px-4 text-xs text-white focus:outline-none focus:border-accent">
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[10px] font-bold uppercase tracking-widest text-white/40 block">Stock Level</label>
                                        <input type="number" x-model="form.stock" onwheel="this.blur()"
                                            class="w-full bg-black/40 border border-white/10 rounded-lg py-3 px-4 text-xs text-white focus:outline-none focus:border-accent">
                                    </div>
                                </div>

                                <div class="pt-4">
                                    <button type="submit" :disabled="isSubmitting"
                                        class="w-full bg-white text-black font-bold py-4 rounded-xl text-[11px] tracking-widest uppercase hover:bg-accent disabled:opacity-50 transition-all btn-press">
                                        <span x-show="!isSubmitting">Apply Modifications</span>
                                        <span x-show="isSubmitting">Updating...</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>


                <!-- Crop Modal - iOS Styled -->
                <div x-show="showCropModal" class="fixed inset-0 z-[1100] flex items-center justify-center p-6 select-none" x-cloak>
                    <div class="absolute inset-0 bg-black/40 backdrop-blur-[15px]" @click="cancelCrop()"></div>
                    
                    <div class="ios-alert-container !max-w-md !w-full" style="width: 400px; max-width: 90vw;">
                        <div class="ios-alert-content">
                            <h2 class="ios-title">Align Asset</h2>
                            <p class="ios-message">Optimize the asset for high-fidelity catalog display.</p>
                            
                            <div class="mt-6 w-full aspect-square bg-black/40 rounded-lg overflow-hidden border border-white/5">
                                <img x-ref="cropImage" src="" class="max-w-full">
                            </div>
                        </div>

                        <div class="ios-button-grid two-buttons">
                            <button type="button" @click="cancelCrop()" class="ios-button cancel-btn">Abort</button>
                            <button type="button" @click="confirmCrop()" class="ios-button confirm-btn">Optimize</button>
                        </div>
                    </div>
                </div>

    </div>

    <style>
        /* Custom Scrollbar for Modals */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Cropper Custom Styles */
        .cropper-view-box,
        .cropper-face {
            border-radius: 0;
        }

        .cropper-line {
            background-color: #ffffff;
        }

        .cropper-point {
            background-color: #ffffff;
        }

        .cropper-bg {
            background-image: none;
        }
    </style>


    <script>
        (() => {
            const register = () => {
                if (Alpine.data('productManager')) return;
                Alpine.data('productManager', () => ({
                    showEditModal: false,
                    isSubmitting: false,
                    showCropModal: false,
                    cropper: null,
                    fileQueue: [],
                    isEditMode: false,
                    form: { id: '', name: '', brand: '', category: '', price: '', stock: '' },
                    errors: { name: '', brand: '', category: '', price: '', stock: '' },

                    async openEdit(id) {
                        this.isEditMode = true;
                        this.errors = { name: '', brand: '', category: '', price: '', stock: '' };
                        try {
                            const res = await fetch(`/admin/products/json/${id}`);
                            const result = await res.json();
                            if (result.success) {
                                const prod = result.product;
                                this.form = {
                                    id: prod._id,
                                    name: prod.name,
                                    brand: prod.brand?._id || prod.brand || "",
                                    category: prod.category?._id || prod.category || "",
                                    price: prod.price,
                                    stock: prod.stock
                                };
                                this.showEditModal = true;
                            } else {
                                this.showError(result.message || 'Could not fetch product details.');
                            }
                        } catch (error) {
                            this.showError('Could not fetch product details.');
                        }
                    },

                    validate() {
                        Object.keys(this.errors).forEach(key => this.errors[key] = '');
                        let isValid = true;
                        
                        const nameVal = this.form.name ? this.form.name.trim() : '';
                        if (!nameVal || nameVal.length < 3) {
                            this.errors.name = 'Name must be at least 3 characters.';
                            isValid = false;
                        } else if (!/[a-zA-Z]/.test(nameVal)) {
                            this.errors.name = 'Name must contain letters.';
                            isValid = false;
                        }
                        
                        if (!this.form.brand) {
                            this.errors.brand = 'Brand required.';
                            isValid = false;
                        }

                        if (!this.form.category) { this.errors.category = 'Category required.'; isValid = false; }
                        if (!this.form.price || parseFloat(this.form.price) <= 0) { this.errors.price = 'Price must be positive.'; isValid = false; }
                        if (this.form.stock === '' || parseInt(this.form.stock) < 0) { this.errors.stock = 'Stock must be non-negative.'; isValid = false; }
                        return isValid;
                    },

                    async submitForm(isEdit = false) {
                        if (this.isSubmitting) return;
                        if (!this.validate()) {
                            const firstError = Object.values(this.errors).find(e => e !== '');
                            this.showError(firstError || "Validation failed.");
                            return;
                        }

                        this.isSubmitting = true;
                        const formData = new FormData();
                        Object.keys(this.form).forEach(key => formData.append(key, this.form[key]));

                        try {
                            const url = isEdit ? "/admin/products/update/" + this.form.id : "/admin/products/add";
                            const method = isEdit ? 'PATCH' : 'POST';
                            const res = await fetch(url, { method, body: formData });
                            const result = await res.json();

                            if (result.success) {
                                this.showSuccess(result.message);
                            } else {
                                this.showError(result.message);
                            }
                        } catch (err) {
                            this.showError("Synchronization error.");
                        } finally {
                            this.isSubmitting = false;
                        }
                    },

                    async toggleStatus(id) {
                        const confirmed = await window.confirmAction({ title: 'TOGGLE VISIBILITY?', message: 'Update product visibility?', type: 'warning' });
                        if (confirmed) {
                            try {
                                const res = await fetch(`/admin/products/toggle-status/${id}`, { method: 'PATCH' });
                                const result = await res.json();
                                if (result.success) { this.showSuccess(result.message); }
                                else { this.showError(result.message); }
                            } catch (error) { this.showError('Status toggle failed.'); }
                        }
                    },

                    async deleteProduct(id) {
                        const confirmed = await window.confirmAction({ title: 'TOGGLE PRODUCT ACCESS?', message: 'Update product availability?', type: 'danger' });
                        if (confirmed) {
                            try {
                                const res = await fetch(`/admin/products/delete/${id}`, { method: 'DELETE' });
                                const resData = await res.json();
                                if (resData.success) { this.showSuccess(resData.message); }
                                else { this.showError(resData.message); }
                            } catch (error) { this.showError('Deletion failed.'); }
                        }
                    },

                    showSuccess(message) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message, type: 'success' } }));
                        setTimeout(() => window.location.reload(), 1000);
                    },

                    showError(message) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message, type: 'error' } }));
                    }
                }));
            };

            if (window.Alpine) {
                register();
            } else {
                document.addEventListener('alpine:init', register);
            }
        })();
    </script>