<%- contentFor('body') %>

<div class="min-h-screen bg-black flex items-center justify-center px-6 py-24">
    <div class="max-w-md w-full text-center">
        <!-- Error Code/Icon -->
        <div class="mb-12 flex justify-center">
            <div class="w-24 h-24 bg-black-surface border border-black-border flex items-center justify-center relative">
                <div class="absolute inset-0 bg-status-danger opacity-10 animate-pulse"></div>
                <svg class="w-12 h-12 text-status-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
            </div>
        </div>

        <h1 class="text-white text-display font-bold tracking-tight uppercase font-display mb-4">Something went wrong</h1>
        
        <p class="text-text-secondary mb-12 text-sm leading-relaxed">
            <%= message || "We encountered an unexpected error while processing your request. Please try again later or return to home." %>
        </p>

        <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV !== 'production') { %>
            <div class="bg-black-elevated border border-black-border p-6 mb-12 text-left overflow-auto max-h-60">
                <h3 class="text-status-danger text-[10px] font-bold uppercase tracking-widest mb-4">Stack Trace</h3>
                <pre class="text-text-muted text-[10px] font-mono whitespace-pre"><%= error.stack %></pre>
            </div>
        <% } %>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/" class="bg-white text-black font-bold px-8 py-4 text-xs tracking-[0.2em] uppercase hover:bg-accent transition-all btn-press">
                BACK TO HOME
            </a>
            <button onclick="window.history.back()" class="border border-black-border text-white font-bold px-8 py-4 text-xs tracking-[0.2em] uppercase hover:bg-black-elevated transition-all btn-press">
                GO BACK
            </button>
        </div>
    </div>
</div>
