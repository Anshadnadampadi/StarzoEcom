<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | MOBIVERSE Admin' : 'Admin Dashboard | MOBIVERSE' %></title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

    <!-- Scripts -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ── PAGE LOADER ── */
        #page-loader {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 24px;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        #page-loader.fade-out {
            opacity: 0;
            visibility: hidden;
        }
        .loader-brand {
            font-family: 'Inter', sans-serif;
            font-weight: 800;
            font-size: 18px;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: #fff;
        }
        .loader-brand span { color: #ff6a00; }
        .loader-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
        }
        .loader-bar-track {
            width: 140px;
            height: 1px;
            background: rgba(255,255,255,0.06);
            overflow: hidden;
            position: relative;
        }
        .loader-bar-fill {
            position: absolute;
            left: -60%;
            top: 0; bottom: 0;
            width: 60%;
            background: linear-gradient(90deg, transparent, #ff6a00, transparent);
            animation: loader-slide 1s ease-in-out infinite;
        }
        @keyframes loader-slide {
            0%   { left: -60%; }
            100% { left: 110%; }
        }

        /* ── GLOBAL NUMBER INPUT UX ── */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none;
            margin: 0; 
        }
        input[type=number] {
            -moz-appearance: textfield;
        }

        /* ── CUSTOM SCROLLBAR ── */
        .custom-scrollbar {
            scrollbar-width: thin;
            scrollbar-color: rgba(255, 106, 0, 0.4) transparent;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 106, 0, 0.2);
            border-radius: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #ff6a00;
        }
    </style>
</head>
<body class="flex min-h-screen bg-black text-text-primary overflow-x-hidden">

    <!-- Page Loader -->
    <div id="page-loader" aria-hidden="true">
        <div class="loader-brand">STAR<span>ZO</span></div>
        <div class="loader-bar-track"><div class="loader-bar-fill"></div></div>
        <div class="loader-label">Admin Panel</div>
    </div>
    
    <!-- Sidebar -->
    <aside class="w-64 border-r border-black-border flex flex-col h-screen sticky top-0 bg-black">
        <div class="h-16 flex items-center px-6 border-b border-black-border">
            <span class="text-white font-bold tracking-widest text-lg">Starzo<span class="text-accent text-[10px] ml-1 uppercase">Admin</span></span>
        </div>
        
        <nav class="flex-1 overflow-y-auto py-6">
            <div class="px-6 mb-4">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Management</p>
                <div class="space-y-1">
                    <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">📊</span>
                        Dashboard
                    </a>
                    
                    <!-- Catalog Dropdown -->
                    <div x-data="{ open: <%= typeof title !== 'undefined' && ['Product Management', 'Category Management', 'Brand Management'].includes(title) ? 'true' : 'false' %> }">
                        <button @click="open = !open" 
                                class="w-full flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm transition-colors group">
                            <div class="flex items-center gap-3">
                                <span class="w-4 h-4 opacity-50">📦</span>
                                <span>Catalog</span>
                            </div>
                            <svg class="w-3 h-3 transition-transform duration-300 opacity-30 group-hover:opacity-100" 
                                 :class="open ? 'rotate-180' : ''" 
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        
                        <div x-show="open" 
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 -translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="mt-1 ml-4 pl-4 border-l border-white/5 space-y-1">
                            <a href="/admin/productManagement" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Product Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Products
                            </a>
                            <a href="/admin/categories" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Category Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Categories
                            </a>
                            <a href="/admin/brands" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Brand Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Brands
                            </a>
                        </div>
                    </div>

                    <a href="/admin/orders" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Orders' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">🛒</span>
                        Orders
                    </a>
                    <a href="/admin/customers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Customers' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">👤</span>
                        Customers
                    </a>
                </div>
            </div>

            <div class="px-6 mb-4">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Marketing</p>
                <div class="space-y-1">
                    <a href="/admin/marketing/coupons" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">🎟️</span>
                        Coupons
                    </a>
                    <a href="/admin/marketing/banners" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">🖼️</span>
                        Banners
                    </a>
                    <a href="/admin/marketing/offers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Offer Management' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">🏷️</span>
                        Offers
                    </a>
                </div>
            </div>

            <div class="px-6">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">System</p>
                <div class="space-y-1">
                    <a href="/admin/settings/general" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">⚙️</span>
                        Settings
                    </a>
                    <a href="/admin/support" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">💬</span>
                        Support
                    </a>
                </div>
            </div>
        </nav>

        <div class="p-6 border-t border-white/5" x-data="{}">
            <a href="/admin/logout" 
               @click.prevent="if(await window.confirmAction({ title: 'Logout Admin?', message: 'Are you sure you want to terminate the secure admin session?', confirmText: 'Logout', cancelText: 'Stay', type: 'danger' })) window.location.href='/admin/logout'"
               class="flex items-center gap-3 px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">
                🚪 Logout
            </a>
        </div>

    </aside>

    <!-- Content -->
    <div class="flex-1 flex flex-col min-h-screen relative">
        <header class="h-16 border-b border-black-border flex items-center justify-between px-8 sticky top-0 bg-black/80 backdrop-blur-md z-10 font-display">
            <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/40">
                System <span class="text-accent ml-2">Active</span>
            </div>
            <div class="flex items-center gap-6">
                <div class="relative" x-data="{ 
                    open: false, 
                    notifications: [], 
                    unreadCount: 0,
                    async fetchNotifications() {
                        try {
                            const res = await fetch('/admin/api/notifications');
                            const data = await res.json();
                            if (data.success) {
                                this.notifications = data.notifications;
                                this.unreadCount = data.unreadCount;
                            }
                        } catch (err) { console.error('Fetch error:', err); }
                    },
                    async markAsRead(id) {
                        try {
                            const res = await fetch(`/admin/api/notifications/${id}/read`, { method: 'PATCH' });
                            if ((await res.json()).success) {
                                this.notifications = this.notifications.map(n => n._id === id ? { ...n, isRead: true } : n);
                                this.unreadCount = Math.max(0, this.unreadCount - 1);
                            }
                        } catch (err) { console.error('Mark read error:', err); }
                    },
                    async markAllRead() {
                        try {
                            const res = await fetch('/admin/api/notifications/read-all', { method: 'PATCH' });
                            const data = await res.json();
                            if (data.success) {
                                this.notifications = this.notifications.map(n => ({ ...n, isRead: true }));
                                this.unreadCount = 0;
                                window.dispatchEvent(new CustomEvent('show-toast', { 
                                    detail: { message: 'All protocols marked as read.', type: 'success' } 
                                }));
                            }
                        } catch (err) { 
                            console.error('Mark all read error:', err);
                            window.dispatchEvent(new CustomEvent('show-toast', { 
                                detail: { message: 'Failed to update protocols.', type: 'error' } 
                            }));
                        }
                    },
                    async clearAll() {
                        if (!await window.confirmAction({ 
                            title: 'Clear Protocols?', 
                            message: 'This will permanently delete all system logs. Continue?', 
                            confirmText: 'Clear All', 
                            type: 'danger' 
                        })) return;

                        try {
                            const res = await fetch('/admin/api/notifications/clear-all', { method: 'DELETE' });
                            const data = await res.json();
                            if (data.success) {
                                this.notifications = [];
                                this.unreadCount = 0;
                                window.dispatchEvent(new CustomEvent('show-toast', { 
                                    detail: { message: 'All protocols cleared.', type: 'success' } 
                                }));
                            }
                        } catch (err) { 
                            console.error('Clear all error:', err);
                            window.dispatchEvent(new CustomEvent('show-toast', { 
                                detail: { message: 'Failed to clear protocols.', type: 'error' } 
                            }));
                        }
                    },
                    getIcon(type) {
                        switch(type) {
                            case 'order_placed': return '🛒';
                            case 'return_requested': return '🔄';
                            case 'order_cancelled': return '✕';
                            default: return '🔔';
                        }
                    }
                }" x-init="fetchNotifications(); window.addEventListener('new-notification', (e) => { 
                    notifications.unshift(e.detail); 
                    if(!e.detail.isRead) unreadCount++;
                })">
                    
                    <!-- Notification Bell -->
                    <button @click="open = !open" class="w-10 h-10 flex items-center justify-center rounded-sm hover:bg-white/5 transition-all relative group">
                        <svg class="w-5 h-5 text-white/40 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                        <template x-if="unreadCount > 0">
                            <span class="absolute top-1 right-1 w-4 h-4 bg-accent text-[8px] text-black font-black flex items-center justify-center rounded-full border-2 border-black shadow-xl animate-pulse" x-text="unreadCount"></span>
                        </template>
                    </button>


                    <!-- Dropdown -->
                    <div x-show="open" 
                         @click.away="open = false"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 translate-y-4"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         class="absolute right-0 mt-4 w-80 bg-black-surface border border-white/10 shadow-2xl z-50 overflow-hidden" 
                         style="display: none;">
                        
                        <div class="px-6 py-4 border-b border-white/5 flex justify-between items-center">
                            <h4 class="text-[10px] font-bold tracking-widest uppercase text-white/40">Notifications</h4>
                            <button @click="markAllRead()" class="text-[9px] font-bold uppercase text-accent hover:text-white transition-colors">Mark all as read</button>
                        </div>

                        <div style="max-height: 320px; overflow-y: auto;" class="custom-scrollbar">
                            <template x-if="notifications.length === 0">
                                <div class="px-6 py-10 text-center">
                                    <p class="text-[10px] text-white/20 uppercase font-bold tracking-widest leading-relaxed">System logs are clear.<br>No recent alerts.</p>
                                </div>
                            </template>
                            
                            <template x-for="n in notifications" :key="n._id">
                                <div @click="markAsRead(n._id)" 
                                     class="px-6 py-4 border-b border-white/5 hover:bg-white/[0.02] transition-colors cursor-pointer group"
                                     :class="!n.isRead ? 'bg-accent/5' : ''">
                                    <div class="flex gap-4">
                                        <div class="w-8 h-8 bg-black border border-white/5 rounded-full flex items-center justify-center text-xs flex-shrink-0" x-text="getIcon(n.type)"></div>
                                        <div class="flex-1 min-w-0">
                                            <div class="flex justify-between items-start mb-1">
                                                <h5 class="text-[10px] font-bold text-white uppercase truncate pr-2" x-text="n.title"></h5>
                                                <span class="text-[8px] text-white/20 uppercase whitespace-nowrap" x-text="new Date(n.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })"></span>
                                            </div>
                                            <p class="text-[10px] text-white/40 leading-relaxed line-clamp-2" x-text="n.message"></p>
                                        </div>
                                    </div>
                                </div>
                            </template>
                        </div>

                        <div class="px-6 py-4 bg-white/[0.02] flex justify-between items-center border-t border-white/5">
                            <a href="/admin/notifications" class="text-[9px] font-bold uppercase text-white/20 hover:text-white transition-colors tracking-widest">Entire Protocol</a>
                            <button @click="clearAll()" class="text-[9px] font-bold uppercase text-status-danger/40 hover:text-status-danger transition-colors tracking-widest">Clear All</button>
                        </div>
                    </div>
                </div>

                <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-black font-bold text-xs uppercase">
                    <%= typeof admin !== 'undefined' && admin ? admin.email[0] : 'A' %>
                </div>
            </div>
        </header>


        <%- include('../partials/breadcrumbs', { isAdmin: true }) %>

        <main class="flex-1 p-8">
            <%- body %>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        window.USER_ID = "<%= typeof admin !== 'undefined' && admin ? admin._id : '' %>";
    </script>
    <script src="/socket.io/socket.io.js"></script>

    <script src="/js/main.js"></script>
    <script src="/js/socket-client.js"></script>
    <script src="/js/spa-navigation.js"></script>
    <%- include('../partials/toast') %>
    <%- include('../partials/ios-alert') %>

    <script>
        window.addEventListener('load', () => {
            const loader = document.getElementById('page-loader');
            if (loader) {
                loader.classList.add('fade-out');
                setTimeout(() => {
                    loader.style.opacity = '0';
                    loader.style.visibility = 'hidden';
                }, 450);
            }
        });

        // Prevent number input value changes on scroll
        document.addEventListener("wheel", (event) => {
            if (document.activeElement.type === "number") {
                document.activeElement.blur();
            }
        });
    </script>
</body>
</html>

