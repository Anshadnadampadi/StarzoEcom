<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | MOBIVERSE Admin' : 'Admin Dashboard | MOBIVERSE' %></title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">

    <!-- Scripts -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>
<body class="flex min-h-screen bg-black text-text-primary overflow-x-hidden">
    
    <!-- Sidebar -->
    <aside class="w-64 border-r border-black-border flex flex-col h-screen sticky top-0 bg-black">
        <div class="h-16 flex items-center px-6 border-b border-black-border">
            <span class="text-white font-bold tracking-widest text-lg">Starzo<span class="text-accent text-[10px] ml-1 uppercase">Admin</span></span>
        </div>
        
        <nav class="flex-1 overflow-y-auto py-6">
            <div class="px-6 mb-4">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Management</p>
                <div class="space-y-1">
                    <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">📊</span>
                        Dashboard
                    </a>
                    
                    <!-- Catalog Dropdown -->
                    <div x-data="{ open: <%= typeof title !== 'undefined' && ['Product Management', 'Category Management', 'Brand Management'].includes(title) ? 'true' : 'false' %> }">
                        <button @click="open = !open" 
                                class="w-full flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm transition-colors group">
                            <div class="flex items-center gap-3">
                                <span class="w-4 h-4 opacity-50">📦</span>
                                <span>Catalog</span>
                            </div>
                            <svg class="w-3 h-3 transition-transform duration-300 opacity-30 group-hover:opacity-100" 
                                 :class="open ? 'rotate-180' : ''" 
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        
                        <div x-show="open" 
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 -translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="mt-1 ml-4 pl-4 border-l border-white/5 space-y-1">
                            <a href="/admin/productManagement" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Product Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Products
                            </a>
                            <a href="/admin/categories" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Category Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Categories
                            </a>
                            <a href="/admin/brands" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Brand Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                                Brands
                            </a>
                        </div>
                    </div>

                    <a href="/admin/orders" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Orders' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">🛒</span>
                        Orders
                    </a>
                    <a href="/admin/customers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Customers' ? 'bg-white/10 text-white' : '' %>">
                        <span class="w-4 h-4 opacity-50">👤</span>
                        Customers
                    </a>
                </div>
            </div>

            <div class="px-6 mb-4">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Marketing</p>
                <div class="space-y-1">
                    <a href="/admin/marketing/coupons" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">🎟️</span>
                        Coupons
                    </a>
                    <a href="/admin/marketing/banners" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">🖼️</span>
                        Banners
                    </a>
                </div>
            </div>

            <div class="px-6">
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">System</p>
                <div class="space-y-1">
                    <a href="/admin/settings/general" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">⚙️</span>
                        Settings
                    </a>
                    <a href="/admin/support" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm">
                        <span class="w-4 h-4 opacity-50">💬</span>
                        Support
                    </a>
                </div>
            </div>
        </nav>

        <div class="p-6 border-t border-white/5">
            <a href="/admin/logout" class="flex items-center gap-3 px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">
                🚪 Logout
            </a>
        </div>
    </aside>

    <!-- Content -->
    <div class="flex-1 flex flex-col min-h-screen relative">
        <header class="h-16 border-b border-black-border flex items-center justify-between px-8 sticky top-0 bg-black/80 backdrop-blur-md z-10 font-display">
            <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/40">
                System <span class="text-accent ml-2">Active</span>
            </div>
            <div class="flex items-center gap-4">
                <button class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/5 transition-colors">
                    🔔
                </button>
                <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-black font-bold text-xs">
                    A
                </div>
            </div>
        </header>

        <%- include('../partials/breadcrumbs', { isAdmin: true }) %>

        <main class="flex-1 p-8">
            <%- body %>
        </main>
    </div>

    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <%- include('../partials/toast') %>
    <%- include('../partials/confirm-modal') %>
</body>
</html>
