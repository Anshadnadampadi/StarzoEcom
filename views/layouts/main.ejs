<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | MOBIVERSE' : 'MOBIVERSE — Full-Stack Mobile E-Commerce' %></title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/output.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        [x-cloak] { display: none !important; }

        /* ── PAGE LOADER ── */
        #page-loader {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 28px;
            transition: opacity 0.45s ease, visibility 0.45s ease;
        }
        #page-loader.fade-out {
            opacity: 0;
            visibility: hidden;
        }
        .loader-brand {
            font-family: 'Outfit', sans-serif;
            font-weight: 900;
            font-size: 22px;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #fff;
        }
        .loader-brand span {
            color: #ff6a00;
        }
        .loader-bar-track {
            width: 160px;
            height: 2px;
            background: rgba(255,255,255,0.06);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }
        .loader-bar-fill {
            position: absolute;
            left: -60%;
            top: 0;
            bottom: 0;
            width: 60%;
            background: linear-gradient(90deg, transparent, #ff6a00, transparent);
            border-radius: 4px;
            animation: loader-slide 1.1s ease-in-out infinite;
        }
        @keyframes loader-slide {
            0%   { left: -60%; }
            100% { left: 110%; }
        }
    </style>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Razorpay -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    
    
</head>
<body class="bg-black text-white overflow-x-hidden">
    <%- include('../partials/toast') %>
    <%- include('../partials/ios-alert') %>

    <!-- Page Loader -->
    <div id="page-loader" aria-hidden="true">
        <div class="loader-brand">STAR<span>ZO</span></div>
        <div class="loader-bar-track"><div class="loader-bar-fill"></div></div>
    </div>
    
    <%- include('../partials/announcement-bar') %>
    <%- include('../partials/nav') %>
    <%- include('../partials/breadcrumbs', { isAdmin: false }) %>

    <main class="min-h-[70vh]">
        <%- body %>
    </main>

    <%- include('../partials/footer') %>

    <!-- Wallet Top-Up Modal (global — persists across SPA navigations) -->
    <div id="wallet-topup-modal"
         x-data="topupModal()"
         x-cloak
         @open-topup-modal.window="openModal()"
         :style="{ display: showModal ? 'flex' : 'none' }"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="wallet-modal-overlay"
         @click.self="if(!isProcessing) closeModal()">

        <div x-show="showModal"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 scale-95 translate-y-4"
             x-transition:enter-end="opacity-100 scale-100 translate-y-0"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95"
             style="background:#0d0d0d;width:100%;max-width:400px;padding:2.5rem;position:relative;box-shadow:0 30px 80px rgba(0,0,0,0.8);border:1px solid rgba(255,255,255,0.08);">

            <button @click="closeModal()" :disabled="isProcessing"
                    style="position:absolute;top:1rem;right:1rem;width:2rem;height:2rem;border-radius:50%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);cursor:pointer;font-size:0.9rem;color:rgba(255,255,255,0.4);display:flex;align-items:center;justify-content:center;">&#10005;</button>

            <div style="margin-bottom:2rem;">
                <h2 style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:900;text-transform:uppercase;color:#fff;line-height:1.1;margin:0 0 0.4rem 0;">Add Money To <span style="color:#ff6a00;font-style:italic;">Wallet.</span></h2>
                <p style="font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:rgba(255,255,255,0.3);margin:0;">Funds available instantly after payment</p>
            </div>

            <div style="margin-bottom:1.25rem;">
                <label style="display:block;font-size:0.6rem;font-weight:800;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.4);margin-bottom:0.5rem;">Enter Amount (&#8377;)</label>
                <input type="number" x-model="topupAmount"
                       min="100" max="50000"
                       style="width:100%;border:1px solid rgba(255,255,255,0.1);padding:0.85rem 1rem;font-size:1.4rem;color:#fff;background:rgba(255,255,255,0.04);outline:none;box-sizing:border-box;font-weight:500;transition:border-color 0.15s;font-family:'Outfit',sans-serif;"
                       placeholder="0.00"
                       @focus="$el.style.borderColor='#ff6a00'" @blur="$el.style.borderColor='rgba(255,255,255,0.1)'">
            </div>

            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;margin-bottom:1.5rem;">
                <template x-for="amt in [500, 1000, 2000]" :key="amt">
                    <button @click="topupAmount = amt"
                            :style="`border:1px solid ${topupAmount==amt?'#ff6a00':'rgba(255,255,255,0.1)'};background:${topupAmount==amt?'rgba(255,106,0,0.15)':'transparent'};color:${topupAmount==amt?'#ff6a00':'rgba(255,255,255,0.5)'};padding:0.6rem 0.5rem;font-size:0.72rem;font-weight:700;cursor:pointer;transition:all 0.15s;`"
                            x-text="'\u20b9' + amt"></button>
                </template>
            </div>

            <button @click="initiateTopup()" 
                    :disabled="isProcessing || topupAmount < 100 || topupAmount > 50000"
                    class="btn-proceed-pay">
                <span x-show="!isProcessing">Proceed To Pay</span>
                <span x-show="isProcessing" style="display:flex;align-items:center;gap:0.5rem;">
                    <svg style="animation:spin 1s linear infinite;width:1rem;height:1rem;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" opacity="0.25"></circle><path fill="currentColor" opacity="0.75" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    Processing...
                </span>
            </button>
        </div>
    </div>

    <style>
        .wallet-modal-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.78);
            backdrop-filter: blur(6px);
        }
        .btn-proceed-pay {
            width: 100%;
            background: #ff6a00;
            color: #000 !important;
            border: none;
            padding: 1rem;
            font-size: 0.68rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            transition: all 0.2s ease;
            font-family: 'Outfit', sans-serif;
        }
        .btn-proceed-pay:hover:not(:disabled) {
            background: #fff;
            color: #000 !important;
        }
        .btn-proceed-pay:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <script>
        function topupModal() {
            return {
                showModal: false,
                topupAmount: '',
                isProcessing: false,
                get razorpayKey() { return window.__RZPKEY__ || ''; },

                openModal() {
                    // Try to pre-fill from URL if we are on a failure page
                    const urlParams = new URLSearchParams(window.location.search);
                    const urlAmount = urlParams.get('amount');
                    
                    this.topupAmount = urlAmount || '';
                    this.isProcessing = false;
                    this.isSuccess = false; // Reset success flag
                    this.showModal = true;
                    document.body.style.overflow = 'hidden';
                },

                closeModal() {
                    this.showModal = false;
                    document.body.style.overflow = '';
                },

                async initiateTopup() {
                    const amount = parseFloat(this.topupAmount);
                    
                    if (isNaN(amount) || amount < 100) {
                        window.dispatchEvent(new CustomEvent('show-toast', { 
                            detail: { message: 'Minimum sequence of \u20b9100 required.', type: 'error' } 
                        }));
                        return;
                    }
                    
                    if (amount > 50000) {
                        window.dispatchEvent(new CustomEvent('show-toast', { 
                            detail: { message: 'Maximum sequence limit of \u20b950,000 exceeded.', type: 'error' } 
                        }));
                        return;
                    }

                    this.isProcessing = true;
                    try {
                        const res = await fetch('/account/wallet/topup/create', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ amount: amount })
                        });
                        const data = await res.json();
                        if (data.success) { 
                            this.openRazorpay(data.razorpayOrder); 
                        } else { 
                            throw new Error(data.message || 'Transmission error'); 
                        }
                    } catch(err) {
                        window.dispatchEvent(new CustomEvent('show-toast', { 
                            detail: { message: err.message, type: 'error' } 
                        }));
                        this.isProcessing = false;
                    }
                },

                openRazorpay(order) {
                    const options = {
                        key: this.razorpayKey,
                        amount: order.amount, currency: order.currency,
                        name: 'STARZO MOBILES', description: 'Wallet Top-Up',
                        order_id: order.id,
                        handler: async (r) => { 
                            this.isSuccess = true; 
                            await this.verifyTopup(r); 
                        },
                        modal: { ondismiss: () => { this.isProcessing = false; } },
                        theme: { color: '#ff6a00' }
                    };
                    this.closeModal();
                    const rzp = new Razorpay(options);
                    rzp.on('payment.failed', (response) => {
                        // Prevent redirecting to failure if verification is already in progress or succeeded
                        if (this.isSuccess) return;
                        
                        this.isProcessing = false;
                        window.location.href = `/account/wallet/topup/failure?amount=${this.topupAmount}&error=${encodeURIComponent(response.error.description)}`;
                    });
                    rzp.open();
                },

                async verifyTopup(r) {
                    this.isSuccess = true; // Mark early to block failure redirects
                    try {
                        const res = await fetch('/account/wallet/topup/verify', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ ...r, amount: this.topupAmount })
                        });
                        const data = await res.json();
                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('wallet-topup-success'));
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Wallet topped up successfully!', type: 'success' } }));
                            setTimeout(() => window.location.href = '/account/wallet', 800);
                        } else { throw new Error(data.message); }
                    } catch(err) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: err.message, type: 'error' } }));
                        this.isProcessing = false;
                    }
                }
            }
        }
    </script>



    <% if (!locals.hideAiChat) { %>
    <!-- AI Chatbot Widget -->
    <div id="ai-chatbot"
         x-data="aiChatbot()"
         class="fixed bottom-6 right-6 z-[9999]"
         x-cloak>
         
         <!-- Chat Bubble Button -->
         <button @click="toggle()"
                 class="w-14 h-14 bg-accent rounded-full flex items-center justify-center shadow-2xl hover:scale-105 transition-transform relative group">
             <!-- Icon -->
             <svg x-show="!isOpen" class="w-7 h-7 text-black" viewBox="0 0 24 24" fill="currentColor">
                 <path d="M12.0001 1.66699L13.5684 8.4319L20.3334 10.0003L13.5684 11.5687L12.0001 18.3337L10.4317 11.5687L3.66675 10.0003L10.4317 8.4319L12.0001 1.66699ZM20.3334 15.0003L19.5492 18.3844L16.1651 19.1687L19.5492 19.9529L20.3334 23.337L21.1175 19.9529L24.5017 19.1687L21.1175 18.3844L20.3334 15.0003Z"/>
             </svg>
             <svg x-show="isOpen" class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
         </button>

         <!-- Chat Window -->
         <div x-show="isOpen"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 translate-y-4 scale-95"
              x-transition:enter-end="opacity-100 translate-y-0 scale-100"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 translate-y-0 scale-100"
              x-transition:leave-end="opacity-0 translate-y-4 scale-95"
              class="absolute bottom-20 right-0 w-[350px] bg-[#0d0d0d] border border-white/10 rounded-xl shadow-2xl overflow-hidden flex flex-col"
              style="height: 500px; max-height: 80vh;">
              
              <!-- Header -->
              <div class="p-4 border-b border-white/5 bg-black/50 backdrop-blur-md flex items-center justify-between">
                  <div class="flex items-center gap-3">
                      <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center">
                          <svg class="w-4 h-4 text-black" viewBox="0 0 24 24" fill="currentColor">
                              <path d="M12.0001 1.66699L13.5684 8.4319L20.3334 10.0003L13.5684 11.5687L12.0001 18.3337L10.4317 11.5687L3.66675 10.0003L10.4317 8.4319L12.0001 1.66699ZM20.3334 15.0003L19.5492 18.3844L16.1651 19.1687L19.5492 19.9529L20.3334 23.337L21.1175 19.9529L24.5017 19.1687L21.1175 18.3844L20.3334 15.0003Z"/>
                          </svg>
                      </div>
                      <div>
                          <h3 class="text-white font-bold text-sm tracking-widest uppercase">Starzo AI</h3>
                          <p class="text-accent/60 text-[9px] uppercase font-black tracking-widest">Online</p>
                      </div>
                  </div>
                  <button @click="toggle()" class="text-white/40 hover:text-white transition-colors">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  </button>
              </div>

              <!-- Messages Area -->
              <div class="flex-1 overflow-y-auto p-4 space-y-4 custom-scrollbar bg-[#050505]" id="chat-messages" x-ref="messagesContainer">
                  <template x-for="(msg, index) in messages" :key="index">
                      <div class="flex flex-col max-w-[85%]" :class="msg.sender === 'user' ? 'ml-auto items-end' : 'mr-auto items-start'">
                          <div class="px-4 py-3 rounded-2xl text-sm"
                               :class="msg.sender === 'user' ? 'bg-accent text-black rounded-br-sm' : 'bg-white/5 text-white/80 rounded-bl-sm border border-white/5 whitespace-pre-wrap leading-relaxed'"
                               x-text="msg.text"></div>
                          <span class="text-[8px] text-white/20 uppercase tracking-widest mt-1 font-bold" x-text="msg.time"></span>
                      </div>
                  </template>
                  
                  <div x-show="isLoading" class="flex flex-col max-w-[85%] mr-auto items-start">
                      <div class="px-4 py-3 bg-white/5 rounded-2xl rounded-bl-sm border border-white/5 flex items-center gap-2">
                          <span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce"></span>
                          <span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                          <span class="w-1.5 h-1.5 bg-accent rounded-full animate-bounce" style="animation-delay: 0.4s"></span>
                      </div>
                  </div>
              </div>

              <!-- Input Area -->
              <div class="p-4 border-t border-white/5 bg-black/50 backdrop-blur-md">
                  <form @submit.prevent="sendMessage" data-no-spa="true" class="flex items-center gap-2 relative">
                      <input type="text" x-model="input" placeholder="Ask Starzo AI..." 
                             class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-full focus:outline-none focus:border-accent transition-colors"
                             :disabled="isLoading">
                      <button type="submit" 
                              class="absolute right-1.5 w-8 h-8 rounded-full bg-accent flex items-center justify-center disabled:opacity-50 transition-opacity"
                              :disabled="!input.trim() || isLoading">
                          <svg class="w-4 h-4 text-black transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                      </button>
                  </form>
              </div>
         </div>
    </div>

    <script>
        function aiChatbot() {
            return {
                isOpen: false,
                isLoading: false,
                input: '',
                messages: [
                    { sender: 'ai', text: 'Hello! I am Starzo AI. How can I help you today?', time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) }
                ],
                toggle() {
                    this.isOpen = !this.isOpen;
                    if (this.isOpen) {
                        setTimeout(() => this.scrollToBottom(), 100);
                    }
                },
                scrollToBottom() {
                    const container = this.$refs.messagesContainer;
                    if (container) {
                        container.scrollTop = container.scrollHeight;
                    }
                },
                async sendMessage() {
                    const text = this.input.trim();
                    if (!text) return;
                    
                    this.messages.push({
                        sender: 'user',
                        text: text,
                        time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
                    });
                    
                    this.input = '';
                    this.isLoading = true;
                    this.scrollToBottom();
                    
                    try {
                        const res = await fetch('/api/ai/generate', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ prompt: text })
                        });
                        
                        const data = await res.json();
                        
                        this.messages.push({
                            sender: 'ai',
                            text: data.response || 'Sorry, I could not generate a response.',
                            time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
                        });
                    } catch (err) {
                        console.error('AI Chat Error:', err);
                        this.messages.push({
                            sender: 'ai',
                            text: 'An error occurred while connecting to the AI.',
                            time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})
                        });
                    } finally {
                        this.isLoading = false;
                        this.scrollToBottom();
                    }
                }
            }
        }
    </script>
    <% } %>

    <!-- Global Scripts -->
    <script>
        window.USER_ID = "<%= typeof user !== 'undefined' ? user : '' %>";
    </script>
    <script src="/socket.io/socket.io.js"></script>

    <script src="/js/user-common.js"></script>
    <script src="/js/socket-client.js"></script>
    <script src="/js/spa-navigation.js"></script>
    <script>
        window.addEventListener('load', () => {
            const loader = document.getElementById('page-loader');
            if (loader) {
                loader.classList.add('fade-out');
                setTimeout(() => {
                    loader.style.opacity = '0';
                    loader.style.visibility = 'hidden';
                }, 500);
            }
        });
    </script>
</body>
</html>

