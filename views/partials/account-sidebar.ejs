<!-- views/partials/account-sidebar.ejs -->
<% 
  if (typeof activeTab === 'undefined') { activeTab = ''; }
  const tabs = [
    { id: 'dashboard', label: 'Dashboard', href: '/account' },
    { id: 'profile', label: 'Profile', href: '/profile' },
    { id: 'orders', label: 'My Orders', href: '/account/orders' },
    { id: 'wishlist', label: 'Wishlist', href: '/wishlist' },
    { id: 'address', label: 'Address Book', href: '/account/address' },
    { id: 'wallet', label: 'My Wallet', href: '/account/wallet' }
  ];
%>
<aside class="flex flex-row overflow-x-auto lg:flex-col gap-1 pb-4 lg:pb-0 scrollbar-hide lg:sticky lg:top-24 h-fit" style="scrollbar-width: none; -ms-overflow-style: none;">
    <style>
        aside::-webkit-scrollbar { display: none; }
    </style>
    <% tabs.forEach(tab => { %>
        <a href="<%= tab.href %>" 
           class="flex-shrink-0 px-6 py-4 border transition-all text-[10px] font-black uppercase tracking-[0.2em] relative group
                  <%= activeTab === tab.id 
                    ? 'bg-white/[0.03] text-accent border-white/10' 
                    : 'border-transparent text-white/40 hover:text-white hover:bg-white/[0.02]' %>">
            
            <!-- Active/Hover Indicator -->
            <div class="absolute left-0 top-0 bottom-0 w-[2px] transition-all duration-300
                        <%= activeTab === tab.id ? 'bg-accent' : 'bg-transparent group-hover:bg-white/20' %>"></div>
            
            <span class="relative z-10"><%= tab.label %></span>
        </a>
    <% }) %>
</aside>
