<!-- views/partials/admin-nav-links.ejs -->
<div x-data="{ 
    counts: { orders: 0, returns: 0, support: 0 },
    async fetchCounts() {
        try {
            const res = await fetch('/admin/api/sidebar-counts');
            const data = await res.json();
            if (data.success) this.counts = data.counts;
        } catch (err) { console.error('Sidebar counts error:', err); }
    }
}" x-init="fetchCounts(); window.addEventListener('new-notification', () => fetchCounts())">
    <style>
        @keyframes pulse-badge {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 106, 0, 0.4); }
            70% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(255, 106, 0, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 106, 0, 0); }
        }
        .badge-pulse { animation: pulse-badge 2s infinite; }
    </style>
    <div class="px-6 mb-4">
        <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Management</p>
        <div class="space-y-1">
            <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">🏠</span>
                Dashboard
            </a>
            
            <div x-data="{ open: <%= typeof title !== 'undefined' && ['Product Management', 'Category Management', 'Brand Management'].includes(title) ? 'true' : 'false' %> }">
                <button @click="open = !open" 
                        class="w-full flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm transition-colors group">
                    <div class="flex items-center gap-3">
                        <span class="w-4 h-4 opacity-50">📦</span>
                        <span class="text-white/40 group-hover:text-white">Catalog</span>
                    </div>
                    <svg class="w-3 h-3 transition-transform duration-300 opacity-30 group-hover:opacity-100 text-white" 
                         :class="open ? 'rotate-180' : ''" 
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
                
                <div x-show="open" 
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="mt-1 ml-4 pl-4 border-l border-white/5 space-y-1">
                    <a href="/admin/productManagement" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Product Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                        Products
                    </a>
                    <a href="/admin/categories" class="block px-4 py-2 text-[11px] font-medium transition-all <%= typeof title !== 'undefined' && title === 'Category Management' ? 'text-white border-l-2 border-accent -ml-[17px] pl-[15px]' : 'text-white/40 hover:text-white' %>">
                        Categories
                    </a>
                </div>
            </div>

            <a href="/admin/orders" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group <%= typeof title !== 'undefined' && title === 'Orders' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <span class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity">🛒</span>
                    <span>Orders</span>
                </div>
                <template x-if="counts.orders > 0">
                    <span class="w-5 h-5 rounded-full bg-accent text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,106,0,0.4)] ring-2 ring-black badge-pulse" x-text="counts.orders"></span>
                </template>
            </a>

            <a href="/admin/returns" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group <%= typeof title !== 'undefined' && title === 'Return Management' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <span class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity">🔄</span>
                    <span>Returns</span>
                </div>
                <template x-if="counts.returns > 0">
                    <span class="w-5 h-5 rounded-full bg-status-warning text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,193,7,0.4)] ring-2 ring-black badge-pulse" x-text="counts.returns"></span>
                </template>
            </a>

            <a href="/admin/customers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Customers' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">👤</span>
                Customers
            </a>
            <a href="/admin/sales-report" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Sales Report' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">📈</span>
                Sales Report
            </a>
        </div>
    </div>

    <div class="px-6 mb-4">
        <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">Marketing</p>
        <div class="space-y-1">
            <a href="/admin/marketing/coupons" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Coupons' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">🎟️</span>
                Coupons
            </a>
            <a href="/admin/marketing/banners" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Banners' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">🖼️</span>
                Banners
            </a>
            <a href="/admin/marketing/offers" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Offer Management' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">🏷️</span>
                Offers
            </a>
        </div>
    </div>

    <div class="px-6">
        <p class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-4">System</p>
        <div class="space-y-1">
            <a href="/admin/settings/general" class="flex items-center gap-3 px-4 py-2.5 text-sm nav-item rounded-sm <%= typeof title !== 'undefined' && title === 'Settings' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <span class="w-4 h-4 opacity-50">⚙️</span>
                Settings
            </a>
            <a href="/admin/support" class="flex items-center justify-between px-4 py-2.5 text-sm nav-item rounded-sm group <%= typeof title !== 'undefined' && title === 'Support' ? 'bg-white/10 text-white' : 'text-white/40 hover:text-white' %>">
                <div class="flex items-center gap-3">
                    <span class="w-4 h-4 opacity-50 group-hover:opacity-100 transition-opacity">💬</span>
                    <span>Support</span>
                </div>
                <template x-if="counts.support > 0">
                    <span class="w-5 h-5 rounded-full bg-accent text-black text-[10px] font-black flex items-center justify-center shadow-[0_0_15px_rgba(255,106,0,0.4)] ring-2 ring-black badge-pulse" x-text="counts.support"></span>
                </template>
            </a>
        </div>
    </div>
</div>
