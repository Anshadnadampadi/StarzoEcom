<!-- views/partials/breadcrumbs.ejs -->
<% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>
<div class="<%= typeof isAdmin !== 'undefined' && isAdmin ? 'px-8 mt-4 sticky top-16 z-10' : 'px-4 py-6 max-w-7xl mx-auto w-full' %>">
    <nav aria-label="Breadcrumb" style="display:flex;overflow-x:auto;padding-bottom:0.5rem;">
        <ol style="display:inline-flex;align-items:center;gap:0.5rem;white-space:nowrap;list-style:none;margin:0;padding:0;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;font-family:'JetBrains Mono',monospace;">
            <li style="display:inline-flex;align-items:center;">
                <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/admin/dashboard" class="text-white/30 hover:text-accent transition-colors" style="display:inline-flex;align-items:center;gap:0.5rem;">
                        <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        <span>HOME</span>
                    </a>
                <% } else { %>
                    <a href="/" class="text-white/40 hover:text-white transition-colors" style="display:inline-flex;align-items:center;gap:0.5rem;">
                        <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        <span>HOME</span>
                    </a>
                <% } %>
            </li>
            
            <% breadcrumbs.forEach((crumb, index) => { %>
            <li style="display:inline-flex;align-items:center;gap:0.5rem;">
                <span class="text-white/10" style="font-weight:400;font-size:12px;user-select:none;">/</span>
                <% if (index === breadcrumbs.length - 1) { %>
                    <span class="text-white" style="user-select:none;position:relative;">
                        <%= crumb.label %>
                        <span style="position:absolute;bottom:-2px;left:0;width:100%;height:1px;background:rgba(255,255,255,0.2);"></span>
                    </span>
                <% } else { %>
                    <a href="<%= crumb.url %>" class="text-white/40 hover:text-white transition-colors">
                        <%= crumb.label %>
                    </a>
                <% } %>
            </li>
            <% }) %>
        </ol>
    </nav>
</div>
<% } %>
