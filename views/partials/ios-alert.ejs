<!-- views/partials/ios-alert.ejs -->
<style>
    .starzo-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background-color: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    .starzo-modal-card {
        background-color: #0d0d0d;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 1);
        max-width: 24rem;
        width: 100%;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .starzo-modal-icon {
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 50%;
        border: 2px solid #ff6a00;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        color: #ff6a00;
    }

    .starzo-modal-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
        text-transform: capitalize;
    }

    .starzo-modal-message {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
        margin-bottom: 2rem;
        font-weight: 500;
    }

    .starzo-modal-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
    }

    @media (min-width: 640px) {
        .starzo-modal-buttons {
            flex-direction: row-reverse;
        }
        .starzo-modal-buttons button {
            flex: 1;
        }
    }

    .starzo-btn {
        padding: 1rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .starzo-btn-primary {
        background-color: #ef4444;
        color: #ffffff;
    }

    .starzo-btn-primary:hover {
        background-color: #dc2626;
        transform: translateY(-1px);
    }

    .starzo-btn-secondary {
        background-color: #1a1a1a;
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .starzo-btn-secondary:hover {
        background-color: #262626;
    }

    /* Type Specific Colors */
    .icon-danger { border-color: #ef4444; color: #ef4444; }
    .btn-danger { background-color: #ef4444; }
    
    .icon-warning { border-color: #ff6a00; color: #ff6a00; }
    .btn-warning { background-color: #ff6a00; }
    
    .icon-success { border-color: #22c55e; color: #22c55e; }
    .btn-success { background-color: #22c55e; }
</style>

<div x-data="starzoAlertComponent()" 
     x-show="show" 
     class="starzo-modal-overlay"
     x-cloak
     style="display: none;"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0">
    
    <div class="starzo-modal-card"
         x-show="show"
         x-transition:enter="transition ease-out duration-500"
         x-transition:enter-start="opacity-0 scale-90 translate-y-8"
         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
         x-transition:leave="transition ease-in duration-300"
         x-transition:leave-start="opacity-100 scale-100"
         x-transition:leave-end="opacity-0 scale-95 translate-y-4">
        
        <!-- Icon -->
        <div class="starzo-modal-icon"
             :class="{
                'icon-danger': type === 'danger' || type === 'error',
                'icon-warning': type === 'warning',
                'icon-success': type === 'success'
             }">
            <template x-if="type === 'danger' || type === 'error'">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
            </template>
            <template x-if="type === 'warning'">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </template>
            <template x-if="type === 'success'">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
            </template>
        </div>

        <h3 class="starzo-modal-title" x-text="title"></h3>
        <p class="starzo-modal-message" x-html="message"></p>

        <!-- Optional Input Field -->
        <div x-show="hasInput" class="w-full mb-6 text-left" x-cloak>
            <label x-show="inputLabel" class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1 mb-2 block" x-text="inputLabel"></label>
            <textarea x-model="inputValue" 
                      class="w-full bg-black border border-white/10 rounded-lg p-4 text-white text-sm focus:border-accent outline-none transition-all placeholder-white/10"
                      :placeholder="inputPlaceholder"
                      :rows="inputRows"></textarea>
            <p x-show="inputError" class="text-status-danger text-[10px] mt-1 font-bold uppercase ml-1" x-text="inputError"></p>
        </div>

        <div class="starzo-modal-buttons">
            <button @click="confirm()" 
                    class="starzo-btn" 
                    :class="{
                        'btn-danger': type === 'danger' || type === 'error',
                        'btn-warning': type === 'warning',
                        'btn-success': type === 'success'
                    }"
                    x-text="confirmText"></button>
            <button @click="cancel()" class="starzo-btn starzo-btn-secondary" x-text="cancelText"></button>
        </div>
    </div>
</div>

<script>
    function starzoAlertComponent() {
        return {
            show: false,
            title: '',
            message: '',
            type: 'warning',
            confirmText: 'Confirm',
            cancelText: 'Cancel',
            resolve: null,

            // Input Support
            hasInput: false,
            inputValue: '',
            inputLabel: '',
            inputPlaceholder: '',
            inputRows: 3,
            inputError: '',
            inputValidator: null,

            init() {
                window.confirmAction = (config) => {
                    return new Promise((resolve) => {
                        this.title = config.title || 'Are you sure?';
                        this.message = config.message || '';
                        this.type = config.type || 'warning';
                        this.confirmText = config.confirmText || 'Confirm';
                        this.cancelText = config.cancelText || 'Cancel';
                        
                        // Reset/Set Input
                        this.hasInput = config.hasInput || false;
                        this.inputValue = config.inputValue || '';
                        this.inputLabel = config.inputLabel || '';
                        this.inputPlaceholder = config.inputPlaceholder || 'Type here...';
                        this.inputRows = config.inputRows || 3;
                        this.inputError = '';
                        this.inputValidator = config.inputValidator || null;

                        this.resolve = resolve;
                        this.show = true;
                    });
                };
            },

            async confirm() {
                if (this.hasInput && this.inputValidator) {
                    const error = this.inputValidator(this.inputValue);
                    if (error) {
                        this.inputError = error;
                        return;
                    }
                }
                
                this.show = false;
                if (this.resolve) {
                    if (this.hasInput) {
                        this.resolve(this.inputValue);
                    } else {
                        this.resolve(true);
                    }
                }
            },

            cancel() {
                this.show = false;
                if (this.resolve) this.resolve(false);
            }
        }
    }
</script>
