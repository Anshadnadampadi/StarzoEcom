<!-- views/partials/nav-guest.ejs -->
<nav x-data="{ mobileMenu: false }" class="h-20 glass border-b border-black-border sticky top-0 z-40 flex items-center justify-between px-6 lg:px-12">
    <!-- Logo & Mobile Toggle -->
    <div class="flex items-center gap-4 lg:gap-8">
        <!-- Modern Mobile Toggle -->
        <button @click="mobileMenu = true" 
                class="lg:hidden w-10 h-10 flex items-center justify-center rounded-sm text-white/60 hover:text-white transition-all active:scale-95">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

        <a href="/" class="text-white font-bold tracking-widest text-xl">STARZO</a>

        <!-- Desktop Menu -->
        <div class="hidden lg:flex items-center gap-8">
            <a href="/products"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">All
                Phones</a>
            
            <a href="/deals"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Deals</a>
            <a href="/support"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Support</a>
        </div>
    </div>



    <!-- Actions -->
    <div class="flex items-center gap-6">


        <!-- Search -->
        <div class="relative group hidden md:block">
            <form action="/products" method="GET">
                <input type="text" name="search" placeholder="Search..."
                    class="bg-white/5 border border-white/10 rounded-sm px-4 py-2 text-xs text-white focus:outline-none focus:border-accent/50 w-48 transition-all focus:w-64">
            </form>
        </div>

        <!-- Tools -->
        <div class="hidden sm:flex items-center gap-6">
            <a href="/wishlist" class="text-white/60 hover:text-white transition-colors relative" title="Wishlist">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                    </path>
                </svg>
                <span id="wishlist-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    0
                </span>
            </a>

            <a href="/cart" class="text-white/60 hover:text-white transition-colors relative" title="Cart">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                <span id="cart-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    0
                </span>
            </a>
        </div>

        <!-- Guest Actions -->
        <div class="hidden lg:flex items-center gap-4">
            <a href="/auth/login"
                class="text-[11px] font-bold tracking-[0.2em] text-white/60 hover:text-white transition-colors uppercase">Login</a>
            <a href="/auth/register"
                class="bg-white text-black text-[10px] font-bold tracking-[0.2em] px-6 py-2.5 uppercase hover:bg-accent transition-all btn-press">
                Register
            </a>
        </div>


    </div>

    <!-- Modern Flipkart-Style Mobile Menu Drawer (Guest) -->
    <div x-show="mobileMenu" 
         x-cloak
         class="fixed inset-0 z-[100] lg:hidden">
        
        <!-- Backdrop -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @click="mobileMenu = false"
             class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        
        <!-- Drawer (Left Aligned) -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-300 cubic-bezier(0, 0, 0.2, 1)"
             x-transition:enter-start="-translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-250 cubic-bezier(0.4, 0, 1, 1)"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="-translate-x-full"
             class="absolute left-0 top-0 bottom-0 w-[280px] bg-[#0d0d0d] flex flex-col shadow-2xl">
            
            <!-- Flipkart-Style Header (Guest) -->
            <div class="bg-white/5 px-6 py-8 flex items-center gap-4 border-b border-white/10">
                <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center border border-accent/30">
                    <i class="fas fa-user-secret text-accent text-xl"></i>
                </div>
                <div>
                    <p class="text-white/40 text-[10px] font-black uppercase tracking-widest mb-0.5">Welcome Guest,</p>
                    <a href="/auth/login" class="text-accent font-black text-xs uppercase tracking-widest hover:underline">Login or Join Now</a>
                </div>
                <button @click="mobileMenu = false" class="ml-auto text-white/20 hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto py-4">
                <div class="px-6 py-4">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30 mb-6">Discovery</p>
                    <nav class="space-y-6">
                        <a href="/" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-house w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Home</span>
                        </a>
                        <a href="/products" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-mobile-screen w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">All Phones</span>
                        </a>
                        <a href="/deals" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-bolt w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Deals</span>
                        </a>
                        <a href="/support" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-circle-info w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Help Center</span>
                        </a>
                    </nav>
                </div>
            </div>

            <div class="mt-auto p-6 space-y-3 border-t border-white/5">
                <a href="/auth/login" class="block w-full bg-white text-black text-center py-3.5 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-accent transition-all">Sign In</a>
                <a href="/auth/register" class="block w-full border border-white/20 text-white text-center py-3.5 text-[10px] font-black uppercase tracking-[0.2em] hover:border-white transition-all">Create Account</a>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile Search Bar (Flipkart Style) -->
<div class="lg:hidden bg-black px-6 pb-4 border-b border-white/5">
    <form action="/products" method="GET" class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-white/40">
            <i class="fas fa-search text-xs"></i>
        </span>
        <input type="text" name="search" placeholder="Search for phones, brands and more" 
               class="w-full bg-white/5 border border-white/10 rounded-sm py-2.5 pl-10 pr-4 text-xs text-white focus:outline-none focus:border-accent/50 transition-all">
    </form>
</div>