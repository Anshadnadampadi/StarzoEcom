<!-- views/partials/nav-user.ejs -->
<nav x-data="{ mobileMenu: false }" class="h-20 glass border-b border-black-border sticky top-0 z-40 flex items-center justify-between px-6 lg:px-12">

    <!-- Logo & Mobile Toggle -->
    <div class="flex items-center gap-4 lg:gap-8">
        <!-- Modern Mobile Toggle -->
        <button @click="mobileMenu = true" 
                class="lg:hidden w-10 h-10 flex items-center justify-center rounded-sm text-white/60 hover:text-white transition-all active:scale-95">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>

        <a href="/" class="text-white font-bold tracking-widest text-xl">STARZO</a>

        <!-- Desktop Menu -->
        <div class="hidden lg:flex items-center gap-8">
            <a href="/products"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">All
                Phones</a>
           
            <a href="/deals"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Deals</a>
            <a href="/support"
                class="text-[11px] font-semibold tracking-widest text-text-secondary hover:text-white transition-colors uppercase">Support</a>
        </div>
    </div>


    <!-- Actions -->
    <div class="flex items-center gap-6">


        <!-- Search -->
        <div class="relative group hidden md:block">
            <form action="/search" method="GET">
                <input type="text" name="q" placeholder="Search..."
                    class="bg-white/5 border border-white/10 rounded-sm px-4 py-2 text-xs text-white focus:outline-none focus:border-accent/50 w-48 transition-all focus:w-64">
            </form>
        </div>

        <!-- User Actions -->
        <div class="hidden sm:flex items-center gap-6">
            <a href="/wishlist" class="text-white/60 hover:text-white transition-colors relative" title="Wishlist">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                    </path>
                </svg>
                <span id="wishlist-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    <%= typeof wishlistCount !== 'undefined' ? wishlistCount : 0 %>
                </span>
            </a>

            <a href="/cart" class="text-white/60 hover:text-white transition-colors relative" title="Cart">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                <span id="cart-badge"
                    class="absolute -top-2 -right-2 bg-accent text-black text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center">
                    <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
                </span>
            </a>
        </div>

        <!-- Account Dropdown -->
        <div x-data="{ open: false }" @click.away="open = false" class="relative hidden sm:block">
            <button @click="open = !open" class="flex items-center gap-2 focus:outline-none group">
                <% if (locals.user && locals.user.profileImage) { %>
                    <div class="w-8 h-8 rounded-sm overflow-hidden border border-white/10 group-hover:border-accent transition-colors">
                        <img src="<%= locals.user.profileImage %>" class="w-full h-full object-cover">
                    </div>
                <% } else { %>
                    <div class="text-white/60 group-hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                <% } %>
                <i class="fas fa-chevron-down text-[8px] text-white/40 group-hover:text-accent transition-transform duration-300" :class="{ 'rotate-180': open }"></i>
            </button>

            <!-- Dropdown Menu -->
            <div x-show="open" 
                 x-cloak
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0 scale-95 translate-y-2"
                 x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                 x-transition:leave="transition ease-in duration-150"
                 x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                 x-transition:leave-end="opacity-0 scale-95 translate-y-2"
                 class="absolute right-0 mt-3 w-48 bg-black/80 backdrop-blur-xl border border-white/10 rounded-sm py-2 shadow-2xl z-50">
                
                <div class="px-4 py-2 border-b border-white/5 mb-2">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30">Account Services</p>
                </div>

                <a href="/profile" class="flex items-center gap-3 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-white/60 hover:text-accent hover:bg-white/5 transition-all">
                    <i class="fas fa-user-circle w-4"></i> Profile
                </a>
                <a href="/account/orders" class="flex items-center gap-3 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-white/60 hover:text-accent hover:bg-white/5 transition-all">
                    <i class="fas fa-box w-4"></i> My Orders
                </a>
                <a href="/account/wallet" class="flex items-center gap-3 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-white/60 hover:text-accent hover:bg-white/5 transition-all">
                    <i class="fas fa-wallet w-4"></i> Wallet
                </a>
                
                <div class="h-px bg-white/5 my-2"></div>
                
                <a href="/auth/logout" 
                   @click.prevent="window.confirmAction({ title: 'Logout?', message: 'Are you sure you want to end your session?', confirmText: 'Logout', cancelText: 'Cancel', type: 'danger' }).then(confirmed => { if(confirmed) window.location.href='/auth/logout' })"
                   class="flex items-center gap-3 px-4 py-2 text-[10px] font-bold uppercase tracking-widest text-status-danger hover:bg-status-danger/10 transition-all">
                    <i class="fas fa-sign-out-alt w-4"></i> Logout
                </a>
            </div>
        </div>


    </div>

    <!-- Modern Flipkart-Style Mobile Menu Drawer -->
    <div x-show="mobileMenu" 
         x-cloak
         class="fixed inset-0 z-[100] lg:hidden">
        
        <!-- Backdrop -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             @click="mobileMenu = false"
             class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        
        <!-- Drawer (Left Aligned) -->
        <div x-show="mobileMenu"
             x-transition:enter="transition ease-out duration-300 cubic-bezier(0, 0, 0.2, 1)"
             x-transition:enter-start="-translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-250 cubic-bezier(0.4, 0, 1, 1)"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="-translate-x-full"
             class="absolute left-0 top-0 bottom-0 w-[280px] bg-[#0d0d0d] flex flex-col shadow-2xl">
            
            <!-- Flipkart-Style Blue Header -->
            <div class="bg-accent px-6 py-8 flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center border border-white/30 overflow-hidden">
                    <% if (locals.user && locals.user.profileImage) { %>
                        <img src="<%= locals.user.profileImage %>" class="w-full h-full object-cover">
                    <% } else { %>
                        <i class="fas fa-user text-white text-xl"></i>
                    <% } %>
                </div>
                <div>
                    <p class="text-black/60 text-[10px] font-black uppercase tracking-widest mb-0.5">Welcome,</p>
                    <p class="text-black font-black text-sm uppercase tracking-tight">
                        <%= (locals.user && (locals.user.firstName || locals.user.name)) ? (locals.user.firstName || locals.user.name) : 'Explorer' %>
                    </p>
                </div>
                <button @click="mobileMenu = false" class="ml-auto text-black/40 hover:text-black">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto py-4">
                <!-- Navigation Sections -->
                <div class="px-6 py-4 border-b border-white/5">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30 mb-6">Main Marketplace</p>
                    <nav class="space-y-6">
                        <a href="/" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-house w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Home</span>
                        </a>
                        <a href="/products" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-mobile-screen w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">All Phones</span>
                        </a>
                        <a href="/deals" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-tags w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Hot Deals</span>
                        </a>
                    </nav>
                </div>

                <div class="px-6 py-6 border-b border-white/5">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30 mb-6">Personal Vault</p>
                    <nav class="space-y-6">
                        <a href="/profile" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-user-gear w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">My Profile</span>
                        </a>
                        <a href="/account/orders" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-box-archive w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">My Orders</span>
                        </a>
                        <a href="/account/wallet" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-wallet w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Wallet Balance</span>
                        </a>
                        <a href="/wishlist" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-heart w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Wishlist</span>
                        </a>
                    </nav>
                </div>

                <div class="px-6 py-6">
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/30 mb-6">Assistance</p>
                    <nav class="space-y-6">
                        <a href="/support" @click="mobileMenu = false" class="flex items-center gap-4 text-white/80 hover:text-accent transition-colors">
                            <i class="fas fa-headset w-5 text-sm"></i>
                            <span class="text-xs font-bold uppercase tracking-widest">Customer Support</span>
                        </a>
                    </nav>
                </div>
            </div>

            <div class="mt-auto p-6 border-t border-white/5">
                <a href="/auth/logout"
                   @click.prevent="window.confirmAction({ title: 'Logout?', message: 'Are you sure you want to end your session?', confirmText: 'Logout', cancelText: 'Cancel', type: 'danger' }).then(confirmed => { if(confirmed) window.location.href='/auth/logout' })"
                   class="flex items-center gap-4 text-status-danger group">
                    <i class="fas fa-power-off text-sm"></i>
                    <span class="text-[10px] font-black uppercase tracking-[0.2em]">Logout System</span>
                </a>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile Search Bar (Flipkart Style) -->
<div class="lg:hidden bg-black px-6 pb-4 border-b border-white/5">
    <form action="/search" method="GET" class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-white/40">
            <i class="fas fa-search text-xs"></i>
        </span>
        <input type="text" name="q" placeholder="Search for phones, brands and more" 
               class="w-full bg-white/5 border border-white/10 rounded-sm py-2.5 pl-10 pr-4 text-xs text-white focus:outline-none focus:border-accent/50 transition-all">
    </form>
</div>