<!-- views/partials/product-card.ejs -->
<% 
  // Standardize product properties
  const pName = product.name || product.title || "Unknown Product";
  const pId = product._id;
  const pPrice = product.price || 0;
  const pDiscountedPrice = product.discountedPrice || pPrice;
  const hasOffer = product.hasOffer || false;
  const isWishlistCard = typeof isWishlist !== 'undefined' ? isWishlist : false;
  
  // Extract variant if passed
  const vColor = product.variant?.color || '';
  const vStorage = product.variant?.storage || '';
  const vRam = product.variant?.ram || '';

  const pImg = (isWishlistCard && product.image) 
                ? product.image 
                : ((product.variants && product.variants[0] && product.variants[0].images && product.variants[0].images[0]) 
                    ? product.variants[0].images[0] 
                    : (product.image || '/images/placeholder.jpg'));

  const pBrand = (typeof product.brand === 'object') ? product.brand.name : product.brand;
  const pSlug = product.slug || pId;

  const pStock = typeof product.stock !== 'undefined' ? product.stock : (product.variants?.[0]?.stock || 0);
  const isOutOfStock = pStock <= 0;

  // Flag from wishlist service: true if the saved variant was soft-deleted by admin
  const isVariantUnavailable = typeof product.isVariantUnavailable !== 'undefined' ? product.isVariantUnavailable : false;

  // Determine which variant info to use for wishlist checks
  const currentV = (isWishlistCard && product.variant) ? product.variant : (product.variants?.[0] || {});
  const normalize = (val) => String(val || '').toLowerCase().replace(/\s+/g, "").replace(/gb$/i, "").trim();
  const wishlistKey = `${pId}_${normalize(currentV.color)}_${normalize(currentV.storage)}_${normalize(currentV.ram)}`;
  
  const wishlistedIdsList = typeof wishlistedIds !== 'undefined' ? wishlistedIds : [];
  const isWishlisted = wishlistedIdsList.includes(wishlistKey);
%>

<div class="bg-black-card group relative overflow-hidden transition-all duration-300 border border-transparent hover:border-white/5 h-full flex flex-col">
    <!-- Image block -->
    <div class="aspect-square bg-black overflow-hidden relative cursor-pointer" onclick="window.location.href='/products/<%= pId %>'">
        <img src="<%= pImg %>" alt="<%= pName %>"
            class="w-full h-full object-contain p-8 lg:p-12 block transition-transform duration-500 group-hover:scale-110" loading="lazy">
        
        <!-- Badges -->
        <div class="absolute top-4 left-4 flex flex-col gap-2">
            <% if (product.isNew) { %>
                <span class="bg-accent text-black text-[9px] font-black px-2 py-0.5 tracking-widest uppercase">NEW</span>
            <% } %>
            <% if (hasOffer) { %>
                <span class="bg-status-success text-black text-[9px] font-black px-2 py-0.5 tracking-widest uppercase">OFFER</span>
            <% } %>
        </div>

        <!-- Quick actions (hover overlay) -->
        <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-10">
            <% if (isWishlistCard) { %>
                <div class="flex border-t border-white/10 w-full">
                    <button type="button"
                        class="flex-1 bg-black/90 backdrop-blur text-white font-black py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-status-danger transition-colors border-r border-white/10"
                        onclick="event.stopPropagation(); removeFromWishlistUI('<%= pId %>', '<%= vColor %>', '<%= vStorage %>', '<%= vRam %>', this)">
                        REMOVE
                    </button>
                     <% if (isVariantUnavailable) { %>
                        <button type="button" disabled
                            class="flex-2 w-full bg-status-danger/20 text-status-danger font-black py-4 text-[10px] tracking-[0.2em] uppercase cursor-not-allowed"
                            title="This variant is no longer available">
                            UNAVAILABLE
                        </button>
                    <% } else if (isOutOfStock) { %>
                        <button type="button" disabled
                            class="flex-2 w-full bg-white/20 text-white/50 font-black py-4 text-[10px] tracking-[0.2em] uppercase cursor-not-allowed">
                            OUT OF STOCK
                        </button>
                    <% } else { %>
                        <button type="button"
                            class="flex-2 w-full bg-accent text-black font-black py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-colors"
                            onclick="event.stopPropagation(); moveToCart('<%= pId %>', '<%= vColor %>', '<%= vStorage %>', '<%= vRam %>', this)">
                            MOVE TO CART
                        </button>
                    <% } %>
                </div>
            <% } else { %>
                <% if (isOutOfStock) { %>
                    <button type="button" disabled
                        class="w-full bg-white/20 text-white/50 font-black py-4 text-[10px] tracking-[0.2em] uppercase cursor-not-allowed">
                        OUT OF STOCK
                    </button>
                <% } else { %>
                    <button type="button"
                        class="w-full bg-accent text-black font-black py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-colors"
                        onclick="event.stopPropagation(); addToCartFromCard('<%= pId %>', '<%= pName %>')">
                        QUICK ADD
                    </button>
                <% } %>
            <% } %>
        </div>

        <!-- Wishlist Toggle -->
        <% if (isWishlistCard) { %>
            <button
                class="absolute top-4 right-4 opacity-100 transition-opacity duration-300 text-status-danger p-2 hover:scale-110"
                onclick="event.stopPropagation(); removeFromWishlistUI('<%= pId %>', '<%= vColor %>', '<%= vStorage %>', '<%= vRam %>', this)">
                <svg class="w-5 h-5 drop-shadow-md" fill="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                    </path>
                </svg>
            </button>
        <% } else { %>
            <button
                class="absolute top-4 right-4 <%= isWishlisted ? 'opacity-100 text-status-danger' : 'opacity-0 group-hover:opacity-100 text-white/50' %> transition-all duration-300 hover:text-white p-2"
                onclick="event.stopPropagation(); toggleWishlist('<%= pId %>', { 
                    button: this,
                    color: '<%= currentV.color || "" %>',
                    storage: '<%= currentV.storage || "" %>',
                    ram: '<%= currentV.ram || "" %>'
                })">
                <svg class="w-5 h-5 drop-shadow-md" fill="<%= isWishlisted ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z">
                    </path>
                </svg>
            </button>
        <% } %>
    </div>

    <!-- Details -->
    <div class="p-6 flex-grow flex flex-col">
        <p class="text-white/30 text-[9px] uppercase font-black tracking-[0.2em] mb-2">
            <%= pBrand %>
        </p>
        <h3 class="text-white font-bold text-sm leading-snug mb-3 line-clamp-2 h-10 group-hover:text-accent transition-colors">
            <a href="/products/<%= pId %>">
                <%= pName %>
            </a>
        </h3>
        
        <!-- Ratings -->
        <div class="flex items-center gap-1 mb-4">
            <div class="flex items-center">
                <% for(let i=1; i<=5; i++) { %>
                    <svg class="w-2.5 h-2.5 <%= i <= 4 ? 'text-accent' : 'text-white/10' %>" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                <% } %>
            </div>
            <span class="text-white/20 text-[9px] font-bold ml-1 tracking-wider">(24)</span>
        </div>

        <% if (isWishlistCard && (vColor || vStorage || vRam)) { %>
            <div class="mb-3 flex flex-wrap gap-1">
                <% if (vColor) { %><span class="text-[9px] font-bold tracking-widest uppercase bg-white/10 text-white/80 px-2 py-0.5"><%= vColor %></span><% } %>
                <% if (vStorage) { %><span class="text-[9px] font-bold tracking-widest uppercase bg-white/10 text-white/80 px-2 py-0.5"><%= vStorage %></span><% } %>
                <% if (vRam) { %><span class="text-[9px] font-bold tracking-widest uppercase bg-white/10 text-white/80 px-2 py-0.5"><%= vRam %> RAM</span><% } %>
                <% if (isVariantUnavailable) { %>
                    <span class="text-[9px] font-bold tracking-widest uppercase bg-status-danger/10 text-status-danger px-2 py-0.5 border border-status-danger/20">
                        ● UNAVAILABLE
                    </span>
                <% } %>
            </div>
        <% } %>

        <div class="mt-auto flex items-center justify-between">
            <div class="flex flex-col">
                <% if (hasOffer) { %>
                    <span class="text-white/30 text-[10px] line-through font-mono">₹<%= pPrice.toLocaleString() %></span>
                    <span class="text-white font-mono font-black text-base italic">₹<%= pDiscountedPrice.toLocaleString() %></span>
                <% } else { %>
                    <span class="text-white font-mono font-black text-base italic">₹<%= pPrice.toLocaleString() %></span>
                <% } %>
            </div>
            <% if (isOutOfStock) { %>
                <span class="text-status-danger text-[8px] font-black uppercase tracking-widest">Out of Stock</span>
            <% } %>
        </div>
    </div>
</div>