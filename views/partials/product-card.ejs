<!-- views/partials/product-card.ejs -->
<div class="bg-black-card group relative overflow-hidden transition-all duration-300 border border-transparent hover:border-white/5">
    <!-- Image block -->
    <div class="aspect-square bg-black overflow-hidden relative img-zoom">
        <a href="/phones/<%= product.brand.slug %>/<%= product.slug %>">
            <img src="<%= product.images[0].url %>" alt="<%= product.title %>"
                 class="w-full h-full object-contain p-8 lg:p-12 block" loading="lazy">
        </a>
        
        <!-- Badges -->
        <div class="absolute top-4 left-4 flex flex-col gap-2">
            <% if (product.badges && product.badges.isNew) { %>
                <span class="bg-accent text-black text-[9px] font-bold px-2 py-0.5 tracking-widest uppercase">NEW</span>
            <% } %>
            <% if (product.badges && product.badges.isHotDeal) { %>
                <span class="bg-status-danger text-white text-[9px] font-bold px-2 py-0.5 tracking-widest uppercase">HOT DEAL</span>
            <% } %>
        </div>

        <!-- Quick actions (hover overlay) -->
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
        
        <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-expo-out z-10">
            <button type="button" 
                    class="w-full bg-accent text-black font-bold py-4 text-[11px] tracking-[0.2em] uppercase hover:bg-white transition-colors btn-press"
                    onclick="addToCartFromCard('<%= product._id %>', '<%= product.title %>')">
                ADD TO CART
            </button>
        </div>

        <!-- Wishlist -->
        <button class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white/50 hover:text-white" onclick="toggleWishlist('<%= product._id %>')">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
        </button>
    </div>

    <!-- Info Info -->
    <div class="p-6">
        <p class="text-white/30 text-[9px] uppercase tracking-[0.2em] mb-2">
            <%= product.brand.name %>
        </p>
        <h3 class="text-white font-medium text-sm leading-snug mb-3 line-clamp-2 h-10">
            <a href="/phones/<%= product.brand.slug %>/<%= product.slug %>" class="hover:text-accent transition-colors">
                <%= product.title %>
            </a>
        </h3>
        
        <div class="flex items-center gap-3">
            <span class="text-white font-mono font-bold text-base">₹<%= product.price.toLocaleString() %></span>
            <% if (product.mrp > product.price) { %>
                <span class="text-white/20 text-xs line-through font-mono">₹<%= product.mrp.toLocaleString() %></span>
                <span class="text-accent text-[10px] font-bold">
                    <%= Math.round((product.mrp - product.price) / product.mrp * 100) %>% OFF
                </span>
            <% } %>
        </div>
    </div>
</div>
