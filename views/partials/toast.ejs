<!-- views/partials/toast.ejs -->
<div x-data="toastComponent()" 
     x-show="show" 
     style="position: fixed; top: 2rem; right: 2rem; z-index: 100000; min-width: 360px; pointer-events: none; display: none;"
     :style="{ display: show ? 'block' : 'none' }"
     x-transition:enter="transition ease-out duration-500"
     x-transition:enter-start="opacity-0 transform translate-x-12 scale-95"
     x-transition:enter-end="opacity-100 transform translate-x-0 scale-100"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="opacity-100 transform translate-x-0"
     x-transition:leave-end="opacity-0 transform translate-x-12">
    
    <div class="relative overflow-hidden"
         :style="{
             backgroundColor: 'rgba(10, 10, 10, 0.9)',
             backdropFilter: 'blur(20px)',
             border: '1px solid ' + (type === 'success' ? 'rgba(34, 197, 94, 0.2)' : (type === 'error' || type === 'danger' ? 'rgba(239, 68, 68, 0.2)' : 'rgba(255, 106, 0, 0.2)')),
             boxShadow: '0 30px 60px -12px rgba(0, 0, 0, 0.8)',
             borderRadius: '2px'
         }" 
         style="padding: 1.5rem 1.75rem; display: flex; align-items: flex-start; gap: 1.25rem; pointer-events: auto;">
        
        <!-- Animated Progress Accent (Timer) -->
        <div class="absolute bottom-0 left-0 h-[3px] bg-accent" 
             :style="{ width: show ? '100%' : '0%', transition: show ? 'width 5000ms linear' : 'none' }"></div>

        <!-- Dynamic Icon -->
        <div class="flex-shrink-0 mt-0.5">
            <template x-if="type === 'success'">
                <div class="w-9 h-9 border border-status-success/20 flex items-center justify-center text-status-success bg-status-success/5 rounded-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                </div>
            </template>
            <template x-if="type === 'error' || type === 'danger'">
                <div class="w-9 h-9 border border-status-danger/20 flex items-center justify-center text-status-danger bg-status-danger/5 rounded-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </div>
            </template>
            <template x-if="type !== 'success' && type !== 'error' && type !== 'danger'">
                <div class="w-9 h-9 border border-accent/20 flex items-center justify-center text-accent bg-accent/5 rounded-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </template>
        </div>

        <!-- Content -->
        <div class="flex-1 pt-0.5">
            <div class="flex items-center justify-between mb-1">
                <h4 class="text-[9px] font-bold tracking-[0.25em] uppercase m-0 leading-none" 
                    :style="{ color: type === 'success' ? '#22C55E' : (type === 'error' || type === 'danger' ? '#EF4444' : '#FF6A00') }"
                    x-text="type === 'error' || type === 'danger' ? 'SYSTEM ALERT' : (type === 'success' ? 'SUCCESS' : 'SYSTEM UPDATE')"></h4>
                <button @click="show = false" class="text-white/10 hover:text-white transition-colors duration-200 ml-4 -mt-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <p class="text-white/70 text-[11px] font-medium leading-relaxed m-0" x-text="message"></p>
        </div>
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('toastComponent', () => ({
        show: false,
        message: '',
        type: 'success',
        statusCode: null,
        timeout: null,

        init() {
            // 1. Check EJS Locals
            const localMsg = <%- JSON.stringify((typeof msg !== 'undefined' && msg) ? msg : ((typeof message !== 'undefined' && message) ? message : '')) %>;
            const localError = <%- JSON.stringify((typeof error !== 'undefined' && error) ? error : '') %>;
            const localIcon = <%- JSON.stringify((typeof icon !== 'undefined' && icon) ? icon : '') %>;
            
            if (localError) {
                this.showToast(localError, 'error');
            } else if (localMsg) {
                this.showToast(localMsg, localIcon || 'success');
            }

            // 2. Check URL Params
            const urlParams = new URLSearchParams(window.location.search);
            const urlMsg = urlParams.get('msg') || urlParams.get('message') || urlParams.get('error');
            if (urlMsg) {
                const urlIcon = urlParams.get('icon') || (urlParams.get('error') ? 'error' : 'success');
                const urlStatus = urlParams.get('status');
                this.showToast(urlMsg, urlIcon, urlStatus ? Number(urlStatus) : null);
                window.history.replaceState({}, '', window.location.pathname);
            }

            // 3. Global Event Listener
            window.addEventListener('show-toast', (e) => {
                const { message, msg, type, icon, status } = e.detail || {};
                this.showToast(message || msg, type || icon || 'success', status || null);
            });
        },

        showToast(msg, type, statusCode = null) {
            if (!msg) return;
            this.message = msg;
            this.type = type || 'success';
            this.statusCode = statusCode;
            this.show = true;
            
            clearTimeout(this.timeout);
            this.timeout = setTimeout(() => {
                this.show = false;
            }, 5000);
        }
    }));
});
</script>
