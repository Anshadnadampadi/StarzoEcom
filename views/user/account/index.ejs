<!-- views/user/account/index.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-24">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
            <div class="fade-up">
                <span class="text-accent text-label font-bold uppercase mb-4 block">Welcome Back</span>
                <h1 class="text-white text-display font-bold tracking-tight uppercase font-display"><%= (user.firstName || user.name || user.email.split('@')[0]) %>'s Account.</h1>
            </div>
            <a href="/auth/logout" class="text-text-muted hover:text-white text-label font-bold uppercase border-b border-black-border pb-1 transition-all">Sign Out</a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            <!-- Sidebar Nav -->
            <%- include('../../partials/account-sidebar', { activeTab: 'dashboard' }) %>

            <!-- Main Panel -->
            <div class="lg:col-span-3 space-y-12">
                <!-- Stats / Quick Look -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-black-card border border-black-border p-8">
                        <h4 class="text-text-muted text-[9px] font-bold tracking-widest uppercase mb-4">Total Orders</h4>
                        <p class="text-white text-4xl font-mono font-bold"><%= typeof orderCount !== 'undefined' ? orderCount : 0 %></p>
                    </div>
                    <div class="bg-black-card border border-black-border p-8">
                        <h4 class="text-text-muted text-[9px] font-bold tracking-widest uppercase mb-4">In Wishlist</h4>
                        <p class="text-white text-4xl font-mono font-bold"><%= typeof wishlistCount !== 'undefined' ? wishlistCount : 0 %></p>
                    </div>
                    <div class="bg-black-card border border-black-border p-8">
                        <h4 class="text-text-muted text-[9px] font-bold tracking-widest uppercase mb-4">Member Since</h4>
                        <p class="text-white text-sm font-bold uppercase tracking-widest mt-2"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) %></p>
                    </div>
                </div>

                <!-- Recent Order -->
                <div class="bg-black-card border border-black-border overflow-hidden">
                    <div class="px-8 py-6 border-b border-black-border flex justify-between items-center">
                        <h3 class="text-white text-label font-bold uppercase">Latest Order</h3>
                        <a href="/account/orders" class="text-accent text-[9px] font-bold uppercase hover:underline">View All</a>
                    </div>
                    <div class="p-8">
                        <% if (typeof latestOrder !== 'undefined' && latestOrder) { %>
                            <div class="flex flex-col md:flex-row justify-between items-center gap-12">
                                <div class="flex gap-6 items-center">
                                    <div class="w-16 h-16 bg-black p-2 border border-white/5">
                                        <img src="<%= latestOrder.items[0].product.images[0].url %>" class="w-full h-full object-contain">
                                    </div>
                                    <div>
                                        <p class="text-white text-xs font-bold uppercase"><%= latestOrder.items[0].product.title %></p>
                                        <p class="text-white/30 text-[10px] mt-1 tracking-wider uppercase"><%= latestOrder.orderId %> · <%= new Date(latestOrder.createdAt).toLocaleDateString() %></p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <%- include('../../partials/status-badge', { status: latestOrder.status }) %>
                                    <p class="text-white font-mono font-bold text-lg mt-3">₹<%= latestOrder.totalAmount.toLocaleString() %></p>
                                </div>
                            </div>
                        <% } else { %>
                            <p class="text-white/20 text-xs italic py-4">No recent orders found.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Profile Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div class="space-y-6">
                        <h3 class="text-white text-label font-bold uppercase border-b border-black-border pb-4">Personal Details</h3>
                        <div class="space-y-4">
                            <div>
                                <p class="text-text-muted text-[9px] font-bold uppercase mb-1">Name</p>
                                <p class="text-white text-sm"><%= (user.firstName || user.name || user.email.split('@')[0]) %> <%= (user.lastName || '') %></p>
                            </div>
                            <div>
                                <p class="text-text-muted text-[9px] font-bold uppercase mb-1">Email</p>
                                <p class="text-white text-sm"><%= user.email %></p>
                            </div>
                        </div>
                        <button class="text-accent text-label font-bold uppercase border border-accent/20 px-4 py-2 hover:bg-black-elevated transition-all">Edit Profile</button>
                    </div>

                    <div class="space-y-6">
                        <h3 class="text-white text-label font-bold uppercase border-b border-black-border pb-4">Default Address</h3>
                        <% if (typeof defaultAddress !== 'undefined' && defaultAddress) { %>
                            <div class="text-text-secondary text-sm leading-relaxed">
                                <p class="font-bold text-white mb-2"><%= defaultAddress.name %></p>
                                <p><%= defaultAddress.street %></p>
                                <p><%= defaultAddress.city %>, <%= defaultAddress.state %> - <%= defaultAddress.pincode %></p>
                                <p class="mt-2 text-text-muted text-xs underline">Default Shipping Address</p>
                            </div>
                        <% } else { %>
                            <p class="text-text-muted text-xs italic">No address saved yet.</p>
                        <% } %>
                        <button class="text-accent text-label font-bold uppercase border border-accent/20 px-4 py-2 hover:bg-black-elevated transition-all">Add Address</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
