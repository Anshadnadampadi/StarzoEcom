<!-- views/user/account/order-details.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-24" id="order-container">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
        <div class="mb-16 flex items-end justify-between gap-8 fade-up">
            <div>
                <a href="/account/orders" class="text-accent text-[10px] font-bold tracking-widest uppercase mb-8 inline-block hover:underline">← Back to orders</a>
                <h1 class="text-white text-display font-bold tracking-tight uppercase font-display">ORDER #<%= order.orderId %>.</h1>
                <p class="text-text-muted text-label font-bold uppercase mt-2">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
            </div>
            <div class="flex flex-wrap gap-4 justify-end">
                <% 
                   const allowedInvoiceStatuses = ['Confirmed', 'Processing', 'Shipped', 'Delivered', 'Partially Returned', 'Return Requested', 'Return Approved', 'Return Picked', 'Returned'];
                   const hasReturnedItems = order.items.some(i => i.status === 'Returned');
                %>

                <% if (allowedInvoiceStatuses.includes(order.orderStatus)) { %>
                    <a href="/account/orders/<%= order._id %>/invoice" class="bg-white text-black text-[10px] font-bold tracking-widest uppercase px-8 py-4 hover:bg-accent transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Download Invoice
                    </a>
                <% } %>

                <% if (hasReturnedItems) { %>
                    <a href="/account/orders/<%= order._id %>/credit-note" class="bg-status-success/10 text-status-success text-[10px] font-bold tracking-widest uppercase border border-status-success/30 px-8 py-4 hover:bg-status-success hover:text-black transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 15v4a2 2 0 01-2 2H4a2 2 0 01-2-2V7a2 2 0 012-2h3m4 3l5 5m0 0l-5 5m5-5H8"></path></svg>
                        Download Credit Note
                    </a>
                <% } %>

                <% if (['Pending', 'Confirmed', 'Processing'].includes(order.orderStatus)) { %>
                    <button onclick="confirmCancel('<%= order._id %>')" class="text-status-danger text-[10px] font-bold tracking-widest uppercase border border-status-danger/30 px-8 py-4 hover:bg-status-danger hover:text-white transition-all">Cancel Order</button>
                <% } %>

                <% if (order.orderStatus === 'Delivered') { %>
                    <button onclick="confirmReturn('<%= order._id %>')" class="text-status-warning text-[10px] font-bold tracking-widest uppercase border border-status-warning/30 px-8 py-4 hover:bg-status-warning hover:text-white transition-all">Return Order</button>
                <% } %>

                <% if ((order.orderStatus === 'Pending' || order.orderStatus === 'Confirmed') && (order.paymentStatus === 'Pending' || order.paymentStatus === 'Failed') && order.paymentMethod === 'ONLINE PAYMENT') { %>
                    <button onclick="retryPayment('<%= order.orderId %>')" 
                        class="bg-accent text-black text-[10px] font-bold tracking-widest uppercase px-10 py-4 hover:bg-white transition-all shadow-[0_0_20px_rgba(255,106,0,0.2)]">
                        Retry Payment
                    </button>
                <% } %>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <!-- Order Status Tracker -->
            <div class="lg:col-span-2 space-y-12">
                <div class="bg-[#0a0a0a] border border-white/5 p-8 rounded-xl shadow-inner">
                    <div class="flex justify-between items-center mb-10 pb-4 border-b border-white/5">
                        <h3 class="text-white text-xs font-bold tracking-[0.2em] uppercase">Tracking Status</h3>
                        <%- include('../../partials/status-badge', { status: order.orderStatus }) %>
                    </div>
                    
                    <div class="relative pt-4 pb-8">
                        <% if (!['Cancelled', 'Return Requested', 'Return Approved', 'Return Picked', 'Returned', 'Partially Returned', 'Return Rejected'].includes(order.orderStatus)) { %>
                            <% 
                            const stages = [
                                { name: 'Confirmed', desc: 'Order received', date: order.createdAt, active: true },
                                { name: 'Processing', desc: 'Being packed', date: ['Processing', 'Shipped', 'Delivered'].includes(order.orderStatus) ? order.updatedAt : null, active: ['Processing', 'Shipped', 'Delivered'].includes(order.orderStatus) },
                                { name: 'Shipped', desc: 'Out for delivery', date: ['Shipped', 'Delivered'].includes(order.orderStatus) ? order.updatedAt : null, active: ['Shipped', 'Delivered'].includes(order.orderStatus) },
                                { name: 'Delivered', desc: 'Order arrived', date: order.orderStatus === 'Delivered' ? order.updatedAt : null, active: order.orderStatus === 'Delivered' }
                            ];
                            %>
                            <%- include('../../partials/tracker-render', { stages: stages, order: order }) %>
                        <% } else if (['Return Requested', 'Return Approved', 'Return Picked', 'Returned', 'Partially Returned', 'Return Rejected'].includes(order.orderStatus)) { %>
                            <% 
                            const stages = [
                                { name: 'Delivered', desc: 'Initial Delivery', date: order.createdAt, active: true },
                                { name: 'Requested', desc: 'Return initiated', date: order.updatedAt, active: true },
                                { name: 'Processing', desc: 'Reviewing request', date: ['Return Approved', 'Return Picked', 'Returned'].includes(order.orderStatus) ? order.updatedAt : null, active: ['Return Approved', 'Return Picked', 'Returned'].includes(order.orderStatus) },
                                { name: 'Picked', desc: 'Item collected', date: ['Return Picked', 'Returned'].includes(order.orderStatus) ? order.updatedAt : null, active: ['Return Picked', 'Returned'].includes(order.orderStatus) },
                                { name: 'Returned', desc: 'Refund complete', date: order.orderStatus === 'Returned' ? order.updatedAt : null, active: order.orderStatus === 'Returned' }
                            ];
                
                            if (order.orderStatus === 'Return Rejected') {
                                stages[2] = { name: 'Rejected', desc: 'Return declined', date: order.updatedAt, active: true, color: 'text-status-danger' };
                            }
                            %>
                            <%- include('../../partials/tracker-render', { stages: stages, order: order }) %>
                        <% } else { %>
                            <!-- Cancelled State -->
                            <div class="flex items-center justify-center py-6">
                                <div class="text-center">
                                    <div class="w-20 h-20 rounded-full border-[4px] border-[#0a0a0a] bg-status-danger/10 flex items-center justify-center mx-auto mb-6 shadow-[0_0_30px_rgba(239,68,68,0.2)]" style="box-shadow: inset 0 0 20px rgba(239,68,68,0.2), 0 0 30px rgba(239,68,68,0.3);">
                                        <svg class="w-10 h-10 text-status-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                                    </div>
                                    <p class="text-status-danger text-lg font-black uppercase tracking-[0.2em] mb-2">Order Arrested</p>
                                    <p class="text-white/50 text-sm font-medium">Termination Reason: <span class="text-white/80"><%= order.cancellationReason || 'Not specified' %></span></p>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Product Table -->
                <div class="bg-black-card border border-black-border overflow-hidden">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-white/5 border-b border-black-border">
                                <th class="px-8 py-5 text-[10px] font-bold tracking-widest uppercase text-white/30">Item Details</th>
                                <th class="px-8 py-5 text-[10px] font-bold tracking-widest uppercase text-white/30">Quantity</th>
                                <th class="px-8 py-5 text-[10px] font-bold tracking-widest uppercase text-white/30">Status</th>
                                <th class="px-8 py-5 text-[10px] font-bold tracking-widest uppercase text-white/30 text-right">Price</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-black-border">
                            <% order.items.forEach(item => { %>
                                <tr>
                                    <td class="px-8 py-8">
                                        <div class="flex items-center gap-6">
                                            <% 
                                                const productTitle = (item.product && item.product.name) ? item.product.name : 'Product Unavailable';
                                                let productImg = '/images/placeholder.png';
                                                if (item.product && item.product.variants && item.product.variants.length > 0) {
                                                    const targetVar = item.variant || {};
                                                    const matchedVariant = item.product.variants.find(v => 
                                                        (!targetVar.color || v.color === targetVar.color) && 
                                                        (!targetVar.storage || v.storage === targetVar.storage) && 
                                                        (!targetVar.ram || v.ram === targetVar.ram)
                                                    ) || item.product.variants[0];
                                                    
                                                    if (matchedVariant && matchedVariant.images && matchedVariant.images.length > 0) {
                                                        productImg = matchedVariant.images[0];
                                                    }
                                                }
                                            %>
                                            <div class="w-16 h-16 bg-black p-3 border border-white/5 flex-shrink-0">
                                                <img src="<%= productImg %>" class="w-full h-full object-contain" alt="Product Image">
                                            </div>
                                            <div>
                                                <p class="text-white text-[11px] font-bold uppercase"><%= productTitle %></p>
                                                <p class="text-white/30 text-[9px] tracking-widest uppercase mt-1"><%= (typeof item.variant === 'object' && item.variant !== null) ? [item.variant.storage, item.variant.color, item.variant.ram].filter(Boolean).join(' ') : (item.variant || 'Standard') %></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-8">
                                        <span class="text-white font-mono text-xs font-bold">× <%= item.qty %></span>
                                    </td>
                                    <td class="px-8 py-8">
                                        <div class="flex flex-col gap-2">
                                            <% if (item.status === 'Cancelled') { %>
                                                <span class="text-status-danger text-[9px] font-bold uppercase tracking-widest border border-status-danger/30 px-3 py-1 bg-status-danger/5 inline-block w-fit">Cancelled</span>
                                            <% } else if (['Return Requested', 'Return Approved', 'Returned', 'Return Rejected'].includes(item.status)) { %>
                                                <span class="text-status-warning text-[9px] font-bold uppercase tracking-widest border border-status-warning/30 px-3 py-1 bg-status-warning/5 inline-block w-fit"><%= item.status %></span>
                                            <% } else { %>
                                                <span class="text-status-success text-[9px] font-bold uppercase tracking-widest border border-status-success/30 px-3 py-1 bg-status-success/5 inline-block w-fit"><%= item.status || 'Ordered' %></span>
                                                
                                                <div class="flex flex-col gap-1 mt-1">
                                                    <% if (['Pending', 'Confirmed', 'Processing'].includes(order.orderStatus)) { %>
                                                        <button onclick="confirmCancelItem('<%= order._id %>', '<%= item._id %>', '<%= productTitle %>')" 
                                                            class="text-[9px] font-bold text-accent uppercase tracking-[0.2em] hover:underline transition-all flex items-center gap-1">
                                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                            Cancel Item
                                                        </button>
                                                    <% } %>

                                                    <% if (order.orderStatus === 'Delivered' || order.orderStatus === 'Partially Returned') { %>
                                                        <% if (item.status === 'Delivered') { %>
                                                            <button onclick="confirmReturnItem('<%= order._id %>', '<%= item._id %>', '<%= productTitle %>')" 
                                                                class="text-[9px] font-bold text-status-warning uppercase tracking-[0.2em] hover:underline transition-all flex items-center gap-1">
                                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 15v4a2 2 0 01-2 2H4a2 2 0 01-2-2V7a2 2 0 012-2h3m4 3l5 5m0 0l-5 5m5-5H8"></path></svg>
                                                                Return Item
                                                            </button>
                                                        <% } %>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="px-8 py-8 text-right">
                                        <span class="text-white font-mono text-sm font-bold">₹<%= (item.price * item.qty).toLocaleString() %></span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                        <tfoot>
                            <tr class="bg-white/[0.02] border-t border-white/5">
                                <td colspan="2" class="px-8 py-5 text-right text-white/30 text-[9px] font-bold tracking-widest uppercase">Subtotal</td>
                                <td class="px-8 py-5 text-right text-white/60 font-mono text-xs font-bold">₹<%= order.subtotal.toLocaleString() %></td>
                            </tr>
                            <tr class="bg-white/[0.02]">
                                <td colspan="2" class="px-8 py-3 text-right text-white/30 text-[9px] font-bold tracking-widest uppercase">Tax (18% GST)</td>
                                <td class="px-8 py-3 text-right text-white/60 font-mono text-xs font-bold">₹<%= (order.tax || 0).toLocaleString() %></td>
                            </tr>
                            <tr class="bg-white/[0.02]">
                                <td colspan="2" class="px-8 py-3 text-right text-white/30 text-[9px] font-bold tracking-widest uppercase">Shipping</td>
                                <td class="px-8 py-3 text-right text-status-success font-mono text-xs font-bold">₹<%= order.shippingFee === 0 ? 'FREE' : order.shippingFee.toLocaleString() %></td>
                            </tr>
                            <% if (order.discount > 0) { %>
                                <tr class="bg-white/[0.02]">
                                    <td colspan="2" class="px-8 py-3 text-right text-status-success text-[9px] font-bold tracking-widest uppercase">Discount Applied</td>
                                    <td class="px-8 py-3 text-right text-status-success font-mono text-xs font-bold">- ₹<%= order.discount.toLocaleString() %></td>
                                </tr>
                            <% } %>
                            <tr class="bg-white/[0.05] border-t-2 border-accent/20">
                                <td colspan="2" class="px-8 py-8 text-right text-white text-[11px] font-black tracking-widest uppercase">Grand Total</td>
                                <td class="px-8 py-8 text-right text-accent font-mono text-3xl font-bold">₹<%= order.totalAmount.toLocaleString() %></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Sidebar Info -->
            <div class="space-y-8">
                <!-- Shipping Address -->
                <div class="bg-black-card border border-black-border p-10">
                    <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-8 border-b border-black-border pb-4">Dispatch Destination</h3>
                    <div class="text-white/60 text-xs leading-relaxed space-y-2 uppercase">
                        <p class="font-bold text-white"><%= order.shippingAddress.fullName %></p>
                        <p><%= order.shippingAddress.streetAddress %></p>
                        <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pinCode %></p>
                        <p class="pt-4 text-[10px] font-mono tracking-tighter text-white/40">+91 <%= order.shippingAddress.phone %></p>
                    </div>
                </div>

                <!-- Payment Info -->
                <div class="bg-black-card border border-black-border p-10">
                    <h3 class="text-white text-[11px] font-bold tracking-widest uppercase mb-8 border-b border-black-border pb-4">Financial Ledger</h3>
                    <div class="space-y-6">
                        <div class="flex justify-between items-center">
                            <span class="text-white/30 text-[9px] uppercase font-bold tracking-widest">Method</span>
                            <span class="text-white text-[10px] font-bold uppercase"><%= order.paymentMethod %></span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-white/30 text-[9px] uppercase font-bold tracking-widest">Status</span>
                            <span class="text-[9px] font-bold uppercase tracking-widest <%= order.paymentStatus === 'Paid' ? 'text-status-success' : (order.paymentStatus === 'Failed' ? 'text-status-danger' : 'text-status-warning') %>"><%= order.paymentStatus %></span>
                        </div>
                    </div>
                </div>

                <!-- Support -->
                <div class="bg-accent/5 border border-accent/10 p-10">
                    <h3 class="text-accent text-[11px] font-bold tracking-widest uppercase mb-4">Need Assistance?</h3>
                    <p class="text-white/40 text-[10px] leading-relaxed mb-6 uppercase">Our logistics team is available 24/7 for any inquiries regarding your dispatch.</p>
                    <a href="/support" class="text-white text-[9px] font-bold tracking-[0.2em] uppercase hover:text-accent transition-colors underline">Contact Support Interface</a>
                </div>
            </div>
        </div>
    </div>
</div>


<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    async function retryPayment(orderId) {
        try {
            const response = await fetch('/checkout/retry-payment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ orderId })
            });
            
            const data = await response.json();
            
            if (data.success) {
                const options = {
                    key: "<%= razorpayKeyId %>",
                    amount: data.razorpayOrder.amount,
                    currency: data.razorpayOrder.currency,
                    name: "STARZO MOBILES",
                    description: "Complete Your Order Payment",
                    order_id: data.razorpayOrder.id,
                    handler: async function (response) {
                        await verifyPayment(response, orderId);
                    },
                    prefill: {
                        name: "<%= order.shippingAddress.fullName %>",
                        contact: "<%= order.shippingAddress.phone %>"
                    },
                    theme: { color: "#ff6a00" }
                };
                const rzp = new Razorpay(options);
                rzp.open();
            } else {
                throw new Error(data.message || "Failed to initiate payment");
            }
        } catch (error) {
            dispatchGlobalToast('error', 'Payment Error', error.message);
        }
    }

    async function verifyPayment(razorpayResponse, orderId) {
        try {
            const res = await fetch('/checkout/verify-payment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    ...razorpayResponse,
                    orderId: orderId
                })
            });
            const data = await res.json();
            if(data.success) {
                dispatchGlobalToast('success', 'Payment Verified', 'Your order is now confirmed.');
                
                const res = await fetch(window.location.href);
                const html = await res.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                document.getElementById('order-container').innerHTML = doc.getElementById('order-container').innerHTML;
            } else {
                throw new Error(data.message || 'Payment verification failed.');
            }
        } catch(error) {
            dispatchGlobalToast('error', 'Verification Failed', error.message);
        }
    }

    async function confirmReturn(orderId) {
        const reason = await window.confirmAction({
            title: 'Request Return',
            message: 'Please specify why you want to return this order.',
            type: 'warning',
            hasInput: true,
            inputLabel: 'Reason for return',
            inputPlaceholder: 'Minimum 10 characters required...',
            confirmText: 'Submit Request',
            cancelText: 'Cancel',
            inputValidator: (value) => {
                if (!value || value.trim().length < 10) {
                    return 'Please provide a reason with at least 10 characters';
                }
            }
        });

        if (reason) {
            try {
                const response = await fetch('/account/orders/return', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, reason })
                });
                const data = await response.json();
                if (data.success) {
                    dispatchGlobalToast('success', 'Request Submitted', data.message);
                    
                    const res = await fetch(window.location.href);
                    const html = await res.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    document.getElementById('order-container').innerHTML = doc.getElementById('order-container').innerHTML;
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                dispatchGlobalToast('error', 'Error', error.message || 'Could not submit return request.');
            }
        }
    }

    async function confirmCancel(orderId) {
        const reason = await window.confirmAction({
            title: 'Cancel Order?',
            message: 'Are you sure you want to cancel this order? This cannot be undone. Please specify a reason.',
            type: 'danger',
            hasInput: true,
            inputLabel: 'Reason for cancellation',
            inputPlaceholder: 'Type your reason here (e.g. changed my mind)...',
            confirmText: 'Yes, Cancel It',
            cancelText: 'Keep Order',
            inputValidator: (value) => {
                if (!value || value.trim().length < 5) {
                    return 'Please provide a reason with at least 5 characters';
                }
            }
        });

        if (reason) {
            try {
                const response = await fetch('/account/orders/cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, reason })
                });
                const data = await response.json();
                if (data.success) {
                    dispatchGlobalToast('success', 'Order Cancelled', 'Your order has been successfully terminated.');
                    
                    const res = await fetch(window.location.href);
                    const html = await res.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    document.getElementById('order-container').innerHTML = doc.getElementById('order-container').innerHTML;
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                dispatchGlobalToast('error', 'Error', error.message || 'Could not cancel order.');
            }
        }
    }

    async function confirmCancelItem(orderId, itemId, productName) {
        const reason = await window.confirmAction({
            title: 'Cancel Item?',
            message: `Are you sure you want to cancel <span class="text-white font-black">${productName}</span>? This specific item will be removed from your order.`,
            type: 'danger',
            hasInput: true,
            inputLabel: 'Reason for cancellation',
            inputPlaceholder: 'Please specify why you are cancelling this item...',
            confirmText: 'Confirm Cancellation',
            cancelText: 'Keep Item',
            inputValidator: (value) => {
                if (!value || value.trim().length < 5) {
                    return 'Please provide a reason with at least 5 characters';
                }
            }
        });

        if (reason) {
            try {
                const response = await fetch('/account/orders/cancel-item', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, itemId, reason })
                });
                const data = await response.json();
                if (data.success) {
                    dispatchGlobalToast('success', 'Item Cancelled', data.message);
                    
                    const res = await fetch(window.location.href);
                    const html = await res.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    document.getElementById('order-container').innerHTML = doc.getElementById('order-container').innerHTML;
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                dispatchGlobalToast('error', 'Error', error.message || 'Could not cancel item.');
            }
        }
    }

    async function confirmReturnItem(orderId, itemId, productName) {
        const reason = await window.confirmAction({
            title: 'Return Item',
            message: `Please specify why you want to return ${productName}.`,
            type: 'warning',
            hasInput: true,
            inputLabel: 'Reason for return',
            inputPlaceholder: 'Minimum 10 characters required...',
            confirmText: 'Submit Request',
            cancelText: 'Cancel',
            inputValidator: (value) => {
                if (!value || value.trim().length < 10) {
                    return 'Please provide a reason with at least 10 characters';
                }
            }
        });

        if (reason) {
            try {
                const response = await fetch('/account/orders/return-item', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, itemId, reason })
                });
                const data = await response.json();
                if (data.success) {
                    dispatchGlobalToast('success', 'Request Submitted', data.message);
                    
                    const res = await fetch(window.location.href);
                    const html = await res.text();
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    document.getElementById('order-container').innerHTML = doc.getElementById('order-container').innerHTML;
                } else {
                    throw new Error(data.message);
                }
            } catch (error) {
                dispatchGlobalToast('error', 'Error', error.message || 'Could not submit return request.');
            }
        }
    }
</script>
