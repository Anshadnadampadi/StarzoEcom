<!-- views/user/account/orders.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-24">
	<div class="max-w-screen-xl mx-auto px-6 lg:px-8">
		<div class="mb-10 md:mb-16 fade-up">
			<span class="text-accent text-[9px] md:text-[10px] font-bold uppercase tracking-[0.3em] mb-3 md:mb-4 block text-center md:text-left">Personal Archives</span>
			<h1 class="text-white text-3xl md:text-5xl font-black tracking-tighter uppercase font-display italic text-center md:text-left">PURCHASE HISTORY.</h1>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
			
			<!-- Sidebar Nav (Col 1-2) -->
			<div class="lg:col-span-2">
				<%- include('../../partials/account-sidebar', { activeTab: 'orders' }) %>
			</div>

			<!-- Filter Sidebar (Col 3-5) -->
			<div class="lg:col-span-3 order-2 lg:order-1">
				<div class="bg-[#0a0a0a] border border-white/[0.03] shadow-2xl overflow-hidden lg:sticky lg:top-24 rounded-sm">
					<div class="px-6 py-4 border-b border-white/[0.03] bg-white/[0.01]">
						<h3 class="text-white text-[10px] font-black uppercase tracking-[0.2em]">Filters</h3>
					</div>
					
					<div class="p-6">
						<form action="/account/orders" method="GET" id="filterForm">
							<input type="hidden" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>">
							
							<!-- Order Status -->
							<div class="mb-6">
								<h4 class="text-white/40 text-[9px] font-bold uppercase tracking-widest mb-4">Transmission Status</h4>
								<div class="space-y-4">
									<% const selectedStatus = typeof status !== 'undefined' ? status : ''; %>
									<label class="flex items-center gap-3 cursor-pointer group">
										<div class="relative flex items-center justify-center">
											<input type="radio" name="status" value="" <%= !selectedStatus ? 'checked' : '' %> class="peer sr-only">
											<div class="w-3 h-3 border border-white/20 rounded-full peer-checked:border-accent transition-all"></div>
											<div class="absolute w-1.5 h-1.5 bg-accent rounded-full scale-0 peer-checked:scale-100 transition-transform"></div>
										</div>
										<span class="text-white/70 text-[11px] font-medium group-hover:text-white transition-colors">All Transmissions</span>
									</label>

									<% ['Processing', 'Pending', 'Delivered', 'Cancelled', 'Returned'].forEach(s => { %>
										<label class="flex items-center gap-3 cursor-pointer group">
											<div class="relative flex items-center justify-center">
												<input type="radio" name="status" value="<%= s %>" <%= selectedStatus === s ? 'checked' : '' %> class="peer sr-only">
												<div class="w-3 h-3 border border-white/20 rounded-full peer-checked:border-accent transition-all"></div>
												<div class="absolute w-1.5 h-1.5 bg-accent rounded-full scale-0 peer-checked:scale-100 transition-transform"></div>
											</div>
											<span class="text-white/70 text-[11px] font-medium group-hover:text-white transition-colors">
												<%= s === 'Processing' ? 'On the way' : (s === 'Pending' ? 'Pending Payment' : s) %>
											</span>
										</label>
									<% }) %>
								</div>
							</div>
						</form>
					</div>
				</div>
			</div>

			<!-- Orders List (Col 6-12) -->
			<div class="lg:col-span-7 order-1 lg:order-2 flex flex-col gap-4" id="ordersContainer">
				
				<!-- Search Bar -->
				<div class="bg-[#0a0a0a] border border-white/[0.03] overflow-hidden flex items-center shadow-lg group focus-within:border-white/10 transition-colors rounded-sm">
					<form action="/account/orders" method="GET" class="w-full flex flex-col sm:flex-row" id="searchForm">
						<input type="hidden" name="status" value="<%= typeof status !== 'undefined' ? status : '' %>">
						<div class="flex-1 flex items-center">
							<div class="pl-6 flex items-center text-white/20 group-focus-within:text-accent transition-colors">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
							</div>
							<input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" 
								   placeholder="Search Orders..." 
								   class="w-full bg-transparent px-4 py-4 text-[11px] text-white placeholder:text-white/20 focus:outline-none transition-colors">
						</div>
						<button type="submit" class="bg-white text-black px-8 py-4 text-[10px] font-black tracking-[0.2em] uppercase hover:bg-accent transition-colors w-full sm:w-auto">
							Search
						</button>
					</form>
				</div>

						<!-- List Items -->
						<% if (typeof orders !== 'undefined' && orders.length > 0) { %>
							<div class="space-y-4">
								<% orders.forEach(order => { %>
									<% 
										const filteredItems = order.items.filter(item => {
											// Status Filter
											if (typeof status !== 'undefined' && status && status !== 'all') {
												const s = status.toLowerCase();
												const itemStatus = (item.status || order.orderStatus || 'ordered').toLowerCase();
												
												if (s === 'processing') {
													if (!['ordered', 'shipped', 'pending', 'processing', 'confirmed'].includes(itemStatus)) {
														return false;
													}
												} else if (s === 'returned') {
													if (!['returned', 'return requested', 'return approved', 'return picked'].includes(itemStatus)) {
														return false;
													}
												} else if (itemStatus !== s) {
													return false;
												}
											}

											// Search Filter
											if (typeof search !== 'undefined' && search) {
												const searchLower = search.toLowerCase();
												const orderIdMatch = (order.orderId || '').toLowerCase().includes(searchLower);
												const productNameMatch = (item.product && item.product.name) ? item.product.name.toLowerCase().includes(searchLower) : false;
												if (!orderIdMatch && !productNameMatch) return false;
											}

											return true;
										});
									%>
									<% filteredItems.forEach(item => { %>
										<% 
											const productTitle = item.productName || (item.product && item.product.name) || 'Product Unavailable';
											let productImg = item.productImage || '/images/placeholder.png';
											
											if (!item.productImage && item.product && item.product.variants && item.product.variants.length > 0) {
												const targetVar = item.variant || {};
												const matchedVariant = item.product.variants.find(v => 
													(!targetVar.color || v.color === targetVar.color) && 
													(!targetVar.storage || v.storage === targetVar.storage) && 
													(!targetVar.ram || v.ram === targetVar.ram)
												) || item.product.variants[0];
												
												if (matchedVariant && matchedVariant.images && matchedVariant.images.length > 0) {
													productImg = matchedVariant.images[0];
												}
											}

											const itemStatus = (item.status || order.orderStatus || 'pending').toLowerCase();
											let dotColor = 'bg-accent';
											let statusText = 'Processing';
											let subText = 'Your item is being processed';

											if (itemStatus === 'delivered') {
												dotColor = 'bg-status-success';
												statusText = `Delivered on ${new Date(order.updatedAt || order.createdAt).toLocaleDateString('en-IN', { month: 'short', day: 'numeric' })}`;
												subText = 'Your item has been delivered';
											} else if (itemStatus === 'cancelled') {
												dotColor = 'bg-status-danger';
												statusText = 'Cancelled';
												subText = 'You cancelled this item';
											} else if (itemStatus.includes('return')) {
												dotColor = 'bg-status-warning';
												statusText = itemStatus === 'returned' ? 'Returned' : 'Return Requested';
												subText = 'Item return initiated';
											} else if (itemStatus === 'shipped') {
												dotColor = 'bg-accent';
												statusText = 'Shipped';
												subText = 'Your item is on the way';
											} else if (itemStatus === 'ordered' || itemStatus === 'pending') {
												if (order.paymentStatus === 'Failed') {
													dotColor = 'bg-status-danger';
													statusText = 'Payment Failed';
													subText = 'Transaction failed. Please retry to confirm order.';
												} else if (order.paymentStatus === 'Pending') {
													dotColor = 'bg-status-warning';
													statusText = 'Pending Payment';
													subText = 'Payment is awaiting completion';
												} else {
													dotColor = 'bg-status-warning';
													statusText = 'Ordered';
													subText = 'Your order has been placed';
												}
											}
										%>

										<a href="/account/orders/<%= order._id %>" class="block bg-[#0a0a0a] border border-white/[0.03] hover:border-white/20 transition-all duration-300 shadow-xl overflow-hidden group relative rounded-sm">
											
											<!-- Top tiny accent bar -->
											<div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

											<div class="p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
												
												<!-- Image -->
												<div class="w-24 h-24 flex-shrink-0 bg-black/50 p-2 flex items-center justify-center group-hover:scale-105 transition-transform duration-500">
													<img src="<%= productImg %>" class="max-w-full max-h-full object-contain filter brightness-90 group-hover:brightness-100 transition-all" alt="<%= productTitle %>">
												</div>

												<!-- Details -->
												<div class="flex-1 w-full text-center md:text-left">
													<h3 class="text-white text-[13px] font-bold mb-1.5 group-hover:text-accent transition-colors truncate pr-0 md:pr-4"><%= productTitle %></h3>
													<p class="text-white/40 text-[9px] uppercase tracking-widest font-mono mb-2">
														<%= (typeof item.variant === 'object' && item.variant !== null) ? [item.variant.color, item.variant.storage, item.variant.ram].filter(Boolean).join(' / ') : (item.variant || 'Standard') %>
													</p>
													<p class="text-white/30 text-[8px] uppercase tracking-widest mb-4">Seller: STARZO Retail</p>
												</div>

												<!-- Price -->
												<div class="w-full md:w-28 flex-shrink-0 text-center md:text-left mt-2 md:mt-0">
													<p class="text-white text-base font-mono font-bold">₹<%= (item.price * item.qty).toLocaleString() %></p>
													<% if (item.qty > 1) { %>
														<p class="text-white/30 text-[8px] font-mono mt-1">Qty: <%= item.qty %></p>
													<% } %>
												</div>

												<!-- Status -->
												<div class="w-full md:w-64 flex-shrink-0 flex flex-col justify-center items-center md:items-start mt-4 md:mt-0 md:pl-6 border-t md:border-t-0 md:border-l border-white/[0.03] pt-4 md:pt-0">
													<div class="flex items-center gap-3 mb-1.5">
														<span class="w-2.5 h-2.5 rounded-full <%= dotColor %> shadow-[0_0_10px_currentColor]"></span>
														<p class="text-white text-[11px] font-bold"><%= statusText %></p>
													</div>
													<p class="text-white/40 text-[9px] md:pl-5 mb-3"><%= subText %></p>
													
													<% if ((order.orderStatus === 'Pending' || order.orderStatus === 'Confirmed') && (order.paymentStatus === 'Pending' || order.paymentStatus === 'Failed') && order.paymentMethod === 'ONLINE PAYMENT') { %>
														<button onclick="event.preventDefault(); retryPayment('<%= order.orderId %>')" 
															class="md:ml-5 px-4 py-2 bg-accent text-black text-[9px] font-black uppercase tracking-widest hover:bg-white transition-all shadow-[0_0_15px_rgba(255,106,0,0.2)]">
															Retry Payment
														</button>
													<% } %>
												</div>

												<!-- Chevron Arrow -->
												<div class="hidden md:flex items-center justify-center text-white/10 group-hover:text-accent transition-colors">
													<svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
												</div>

											</div>
										</a>
									<% }) %>
								<% }) %>
							</div>
							
							<!-- Pagination -->
							<% if (typeof totalPages !== 'undefined') { %>
								<div class="mt-10">
									<%- include('../../partials/pagination') %>
								</div>
							<% } %>
						<% } else { %>
							<div class="py-32 text-center bg-[#0a0a0a] border border-white/[0.03] rounded-sm shadow-2xl">
								<div class="mb-8 opacity-20">
									<svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
								</div>
								<p class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] mb-8">No orders found matching criteria</p>
								<a href="/products" class="bg-white text-black font-bold px-10 py-4 text-[10px] tracking-[0.3em] uppercase hover:bg-accent transition-all">START SHOPPING</a>
							</div>
						<% } %>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Processing Overlay -->
<div id="processing-overlay" class="fixed inset-0 z-[100] bg-black/90 flex-col items-center justify-center p-6 hidden">
    <div class="relative mb-12">
        <div class="w-24 h-24 border-2 border-white/5 rounded-full"></div>
        <div class="absolute inset-0 border-t-2 border-accent rounded-full animate-spin"></div>
        <div class="absolute inset-4 bg-accent/10 rounded-full animate-pulse"></div>
    </div>
    <h2 class="text-white text-2xl md:text-3xl font-black tracking-[0.2em] uppercase mb-4 text-center">Verifying Payment</h2>
    <p class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] max-w-xs text-center leading-relaxed">
        Connecting to secure vault. Please do not refresh or close this window.
    </p>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
	let isPaymentSuccessful = false;

	function showOverlay() {
		document.getElementById('processing-overlay').classList.remove('hidden');
		document.getElementById('processing-overlay').classList.add('flex');
	}

	function hideOverlay() {
		document.getElementById('processing-overlay').classList.add('hidden');
		document.getElementById('processing-overlay').classList.remove('flex');
	}

	async function retryPayment(orderId) {
		try {
			isPaymentSuccessful = false;
			const response = await fetch('/checkout/retry-payment', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ orderId })
			});
			
			const data = await response.json();
			
			if (data.success) {
				const options = {
					key: "<%= typeof razorpayKeyId !== 'undefined' ? razorpayKeyId : '' %>",
					amount: data.razorpayOrder.amount,
					currency: data.razorpayOrder.currency,
					name: "STARZO MOBILES",
					description: "Complete Your Order Payment",
					order_id: data.razorpayOrder.id,
					handler: async function (response) {
						isPaymentSuccessful = true;
						showOverlay();
						await verifyPayment(response, orderId);
					},
					theme: { color: "#ff6a00" },
					modal: {
						ondismiss: function() {
							hideOverlay();
						}
					}
				};
				const rzp = new Razorpay(options);
				rzp.on('payment.failed', function (response) {
					if (isPaymentSuccessful) return;
					hideOverlay();
					if (window.dispatchGlobalToast) {
						dispatchGlobalToast('error', 'Payment Failed', 'The payment process was interrupted.');
					} else {
						alert('Payment Failed');
					}
				});
				rzp.open();
			} else {
				throw new Error(data.message || "Failed to initiate payment");
			}
		} catch (error) {
			console.error('Retry error:', error);
			alert(error.message);
			hideOverlay();
		}
	}

	async function verifyPayment(razorpayResponse, orderId) {
		try {
			const res = await fetch('/checkout/verify-payment', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					...razorpayResponse,
					orderId: orderId
				})
			});
			const data = await res.json();
			if(data.success) {
				window.location.href = '/checkout/success/' + orderId;
			} else {
				throw new Error(data.message || 'Payment verification failed.');
			}
		} catch(error) {
			hideOverlay();
			alert(error.message);
		}
	}

	document.addEventListener('DOMContentLoaded', () => {
		const ordersContainer = document.getElementById('ordersContainer');
		const filterFormInputs = document.querySelectorAll('#filterForm input[name="status"]');
		
		const updateContent = async (url, push = true) => {
			ordersContainer.style.opacity = '0.4';
			ordersContainer.style.pointerEvents = 'none';
			
			try {
				const response = await fetch(url, {
					headers: { 'X-Requested-With': 'XMLHttpRequest' }
				});
				
				if (!response.ok) throw new Error('Network response was not ok');
				
				const html = await response.text();
				const parser = new DOMParser();
				const doc = parser.parseFromString(html, 'text/html');
				
				const newContent = doc.getElementById('ordersContainer');
				if (!newContent) throw new Error('Could not find orders container');
				
				// Update the content
				ordersContainer.innerHTML = newContent.innerHTML;
				
				// Synchronize search inputs
				const urlObj = new URL(url, window.location.origin);
				const searchInputs = document.querySelectorAll('input[name="search"]');
				searchInputs.forEach(i => i.value = urlObj.searchParams.get('search') || '');
				
				if (push) window.history.pushState({ url }, '', url);
				
				attachContentListeners();
				window.scrollTo({ top: 0, behavior: 'smooth' });
			} catch (error) {
				console.error('Update failed:', error);
				window.location.href = url;
			} finally {
				ordersContainer.style.opacity = '1';
				ordersContainer.style.pointerEvents = 'auto';
			}
		};

		const attachContentListeners = () => {
			const searchForm = document.getElementById('searchForm');
			if (searchForm) {
				searchForm.addEventListener('submit', (e) => {
					e.preventDefault();
					const searchInput = searchForm.querySelector('input[name="search"]');
					const url = new URL(window.location.href);
					url.searchParams.set('search', searchInput.value);
					url.searchParams.set('page', '1');
					updateContent(url.toString());
				});
			}

			const paginationLinks = document.querySelectorAll('#ordersContainer a[href*="page="]');
			paginationLinks.forEach(link => {
				link.addEventListener('click', (e) => {
					e.preventDefault();
					updateContent(link.href);
				});
			});
		};

		filterFormInputs.forEach(input => {
			input.addEventListener('change', (e) => {
				const url = new URL(window.location.href);
				url.searchParams.set('status', e.target.value);
				url.searchParams.set('page', '1');
				updateContent(url.toString());
			});
		});

		attachContentListeners();

		window.addEventListener('popstate', (e) => {
			if (e.state && e.state.url) {
				updateContent(e.state.url, false);
				
				const params = new URLSearchParams(new URL(e.state.url).search);
				const status = params.get('status') || '';
				const radio = document.querySelector(`#filterForm input[name="status"][value="${status}"]`);
				if (radio) radio.checked = true;
			} else {
				window.location.reload();
			}
		});
	});
</script>
