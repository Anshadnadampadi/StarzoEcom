<!-- views/user/account/profile.ejs -->
<%- contentFor('body') %>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <div class="min-h-screen bg-black py-24" x-data="profileManager()">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">

            <!-- Header & Breadcrumbs -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8 fade-up">
                <div class="space-y-4">
                    <!-- <nav class="flex items-center gap-3 text-[10px] font-bold tracking-widest uppercase text-white/30">
                        <a href="/" class="hover:text-accent transition-colors">Home</a>
                        <span>/</span>
                        <a href="/account" class="hover:text-accent transition-colors">Account</a>
                        <span>/</span>
                        <span class="text-white">Profile</span>
                    </nav> -->
                    <h1
                        class="text-white text-display font-display font-black tracking-tighter uppercase leading-[0.9]">
                        <br><span class="text-accent underline decoration-4 underline-offset-8"></span>
                    </h1>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-right hidden md:block">
                        <p class="text-white/30 text-[9px] font-bold uppercase tracking-widest mb-1"></p>
                        <div class="flex items-center gap-2 justify-end">
                            <span class="w-1.5 h-1.5 rounded-full bg-status-success animate-pulse"></span>

                        </div>
                    </div>
                    <a href="/auth/logout"
                        @click.prevent="if(await window.confirmAction({ title: 'Logout?', message: 'Are you sure you want to end your session?', confirmText: 'Logout', cancelText: 'Cancel', type: 'danger' })) window.location.href='/auth/logout'"
                        class="group flex items-center gap-4 bg-accent px-10 py-5 hover:bg-white transition-all duration-500 shadow-[0_10px_30px_rgba(255,106,0,0.3)]">
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-black">Sign Out</span>
                        <svg class="w-4 h-4 text-black transform group-hover:translate-x-1 transition-transform"
                            fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>

                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
                <!-- Sidebar Nav -->
                <%- include('../../partials/account-sidebar', { activeTab: 'profile' }) %>

                    <!-- Main Content Area -->
                    <div class="lg:col-span-3 space-y-12">

                        <!-- Profile Avatar & Key Stats -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 fade-up" style="animation-delay: 200ms">
                            <!-- Avatar Upload -->
                            <div
                                class="md:col-span-1 flex flex-col items-center justify-center p-10 bg-black-elevated border border-black-border relative group overflow-hidden transition-all hover:border-accent/40">
                                <div
                                    class="relative w-40 h-40 rounded-full overflow-hidden border-2 border-white/10 group-hover:border-accent transition-all duration-500 shadow-2xl">
                                    <img id="profile-preview"
                                        src="<%= user.profileImage || '/images/default-avatar.png' %>"
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">

                                    <div
                                        class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center backdrop-blur-sm cursor-pointer">
                                        <svg class="w-6 h-6 text-white mb-2" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z">
                                            </path>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        </svg>
                                        <span
                                            class="text-[9px] font-black uppercase tracking-widest text-white">Upload</span>
                                        <input type="file" @change="openCropper($event)"
                                            class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*">
                                    </div>
                                </div>

                                <div class="mt-6 text-center space-y-1">
                                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-white">Profile
                                        Photo</p>
                                    <p class="text-[8px] font-bold uppercase tracking-widest text-white/30">JPG, PNG
                                        (Max 2MB)</p>
                                </div>

                                <!-- Premium Loader Overlay -->
                                <div x-show="isUploading" x-cloak
                                    class="absolute inset-0 bg-black/80 flex items-center justify-center backdrop-blur-md z-10">
                                    <div
                                        class="w-10 h-10 border-2 border-accent border-t-transparent rounded-full animate-spin">
                                    </div>
                                </div>
                            </div>

                            <!-- Referral Section -->
                            <div class="md:col-span-2 flex flex-col justify-center bg-black-elevated border border-black-border p-12 relative overflow-hidden group rounded-sm transition-all hover:border-accent/30">
                                <div
                                    class="absolute right-0 top-0 w-64 h-64 bg-accent/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2">
                                </div>
    
                                <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center">
                                    <div class="flex-1 space-y-6">
                                        <h3
                                            class="text-white text-4xl font-display font-black tracking-tighter uppercase leading-none">
                                            Build Your<br><span class="text-accent italic">REFERRALS</span></h3>
                                        <p class="text-white/40 text-xs leading-relaxed max-w-sm">Expand the Mobiverse.
                                            Every
                                            user who signs up with your unique protocol code generates credits for your
                                            vault.
                                            Elite rewards for elite networks.</p>
                                    </div>
                                    <div class="w-full md:w-auto space-y-4">
                                        <div
                                            class="bg-black border border-black-border px-8 py-6 backdrop-blur-md flex flex-col items-center group-hover:border-accent/40 transition-colors">
                                            <span
                                                class="text-white/30 text-[9px] font-black tracking-[0.3em] uppercase mb-4">Your
                                                Protocol Code</span>
                                            <div class="flex items-center gap-6 mb-6">
                                                <span
                                                    class="text-white text-4xl font-mono font-black tracking-[0.1em] selection:bg-accent selection:text-black">
                                                    <%= user.referralCode %>
                                                </span>
                                                <button @click="copyToClipboard('<%= user.referralCode %>')"
                                                    class="text-accent hover:text-white transition-colors p-2" title="Copy Code">
                                                    <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2.5"
                                                            d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                                        </path>
                                                    </svg>
                                                </button>
                                            </div>

                                            <div class="w-full border-t border-white/5 pt-4">
                                                <span class="text-white/20 text-[8px] font-bold uppercase tracking-widest block mb-2 text-center">Share Protocol Link</span>
                                                <button @click="copyToClipboard(window.location.origin + '/auth/register?ref=<%= user.referralCode %>')"
                                                    class="w-full bg-white/5 hover:bg-accent hover:text-black py-3 px-4 transition-all flex items-center justify-between group/link">
                                                    <span class="text-[9px] font-mono text-white/40 group-hover/link:text-black truncate max-w-[150px]">
                                                        auth/register?ref=<%= user.referralCode %>
                                                    </span>
                                                    <svg class="w-3 h-3 group-hover/link:text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"/>
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Personal Information Grid -->
                        <div class="space-y-8 fade-up" style="animation-delay: 300ms">
                            <div class="flex justify-between items-end border-b border-black-border pb-6">
                                <h2
                                    class="text-white text-2xl font-display font-black tracking-tighter uppercase leading-none">
                                    The <span
                                        class="text-accent underline decoration-2 underline-offset-4 font-mono">Profile.</span>
                                </h2>
                                <button @click="openModal('editProfile')" class="bg-white/5 border border-white/5 hover:bg-accent hover:text-black p-3 transition-all flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                                    </svg>
                                    <span class="text-[10px] uppercase font-bold tracking-widest hidden md:inline">Edit Details</span>
                                </button>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                                <div class="space-y-10">
                                    <!-- Field: Name -->
                                    <div class="group relative">
                                        <label
                                            class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Identification</label>
                                        <div class="flex items-center justify-between">
                                            <p class="text-white text-lg font-bold uppercase tracking-tight">
                                                <%= (user.firstName || user.name) %>
                                                    <%= (user.lastName || '' ) %>
                                            </p>
                                            <span
                                                class="text-[9px] text-white/10 font-mono tracking-widest">REAL_ID</span>
                                        </div>
                                    </div>
                                    <!-- Field: Phone -->
                                    <div class="group relative">
                                        <label
                                            class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Comms
                                            Link</label>
                                        <div class="flex items-center justify-between">
                                            <p class="text-white text-lg font-bold tabular-nums">
                                                <%= user.phone || '+ -- --- --- ----' %>
                                            </p>
                                            <span
                                                class="text-[9px] text-white/10 font-mono tracking-widest">PHONE_CH</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="space-y-10">
                                    <!-- Field: Email -->
                                    <div class="group relative">
                                        <label
                                            class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Primary
                                            Access</label>
                                        <div class="flex items-center justify-between">
                                            <div class="space-y-1">
                                                <p class="text-white text-lg font-bold lowercase tracking-tight">
                                                    <%= user.email %>
                                                </p>
                                                <div class="flex items-center gap-2">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-status-success"></span>
                                                    <span
                                                        class="text-[9px] text-status-success font-black uppercase tracking-widest">Primary
                                                        & Secured</span>
                                                </div>
                                            </div>
                                            <button @click="openModal('editEmail')"
                                                class="bg-white/5 border border-white/5 hover:bg-white hover:text-black p-3 transition-all">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                                    </path>
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                    <!-- Security Toggle -->
                                    <div class="group relative">
                                        <label
                                            class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Vault
                                            Security</label>
                                        <div class="flex items-center justify-between">
                                            <p class="text-white text-lg font-bold uppercase tracking-tight">
                                                ••••••••••••
                                            </p>
                                            <button @click="openModal('changePassword')"
                                                class="text-accent text-[10px] font-black uppercase tracking-[0.2em] border border-accent/20 px-6 py-3 hover:bg-accent hover:text-black transition-all">
                                                Change Password</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
            </div>
        </div>

        <!-- Edit Profile Modal -->
        <div x-show="modals.editProfile" x-cloak
            class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/90 backdrop-blur-md"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div class="bg-black-elevated border border-black-border w-full max-w-lg max-h-[95vh] overflow-y-auto shadow-2xl relative group/modal"
                @click.away="closeModal('editProfile')">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-2xl font-display font-black tracking-tight uppercase leading-none">
                            Update<br><span class="text-accent italic">Profile</span></h3>
                        <button @click="closeModal('editProfile')"
                            class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <form id="editProfileForm" @submit.prevent="submitProfileUpdate" data-no-spa class="space-y-6">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-2">
                                <label
                                    class="text-[9px] font-black uppercase tracking-widest text-white/30">First Name</label>
                                <input type="text" name="firstName" x-model="profileForm.firstName"
                                    @input="validateProfileField('firstName')"
                                    :class="profileErrors.firstName ? 'border-status-danger' : 'border-white/10'"
                                    class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 font-bold uppercase text-sm">
                                <span x-show="profileErrors.firstName" x-text="profileErrors.firstName"
                                    class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="text-[9px] font-black uppercase tracking-widest text-white/30">Last Name</label>
                                <input type="text" name="lastName" x-model="profileForm.lastName"
                                    @input="validateProfileField('lastName')"
                                    :class="profileErrors.lastName ? 'border-status-danger' : 'border-white/10'"
                                    class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 font-bold uppercase text-sm">
                                <span x-show="profileErrors.lastName" x-text="profileErrors.lastName"
                                    class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-[9px] font-black uppercase tracking-widest text-white/30">Phone Number</label>
                            <input type="text" name="phone" x-model="profileForm.phone"
                                @input="validateProfileField('phone')"
                                :class="profileErrors.phone ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 font-mono text-sm font-bold">
                            <span x-show="profileErrors.phone" x-text="profileErrors.phone"
                                class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Bio (Optional)</label>
                            <textarea name="bio" x-model="profileForm.bio" @input="validateProfileField('bio')"
                                :class="profileErrors.bio ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 font-medium min-h-[100px] resize-none text-sm leading-relaxed"></textarea>
                            <span x-show="profileErrors.bio" x-text="profileErrors.bio"
                                class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>

                        <button type="submit"
                            class="w-full bg-accent text-black py-4 flex items-center justify-center gap-2 transition-all hover:bg-white btn-press">
                            <span class="text-[10px] font-black uppercase tracking-[0.2em]"
                                x-text="isSubmitting ? 'Saving...' : 'Save Changes'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Minimal Change Email Modal -->
        <div x-show="modals.editEmail" x-cloak
            class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div
                class="bg-black-elevated border border-black-border w-full max-w-sm overflow-hidden shadow-2xl relative">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-xl font-display font-black tracking-tight uppercase"
                            x-text="emailStep === 1 ? 'Update Email' : 'Verify Code'"></h3>
                        <button @click="closeModal('editEmail')"
                            class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <!-- Step 1: Request OTP -->
                    <form x-show="emailStep === 1" @submit.prevent="requestEmailOtp" data-no-spa class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-white/30">New Identity
                                Endpoint</label>
                            <input type="email" x-model="newEmail"
                                class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 text-sm"
                                placeholder="target@mobiverse.com">
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Acquiring...' : 'Generate OTP'"></span>
                        </button>
                    </form>

                    <!-- Step 2: Verify OTP -->
                    <form x-show="emailStep === 2" @submit.prevent="verifyEmailOtp" data-no-spa class="space-y-8">
                        <div class="text-center space-y-4">
                            <p class="text-white/40 text-[10px] uppercase tracking-widest">Protocol sent to <br><span
                                    class="text-accent font-bold" x-text="newEmail"></span></p>
                            <div class="flex justify-center gap-2">
                                <template x-for="(i, index) in 6">
                                    <input type="text" maxlength="1" @input="handleOtpInput($event, index)"
                                        @keydown.backspace="handleOtpBackspace($event, index)" :id="'otp-' + index"
                                        class="w-10 h-12 bg-black border border-white/10 text-white text-center text-xl font-mono font-black focus:border-accent outline-none transition-all">
                                </template>
                            </div>
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Verifying...' : 'Confirm Activation'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Minimal Password Change Modal -->
        <div x-show="modals.changePassword" x-cloak
            class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div
                class="bg-black-elevated border border-black-border w-full max-w-sm overflow-hidden shadow-2xl relative">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-xl font-display font-black tracking-tight uppercase">Update <br><span
                                class="text-accent italic">Password</span></h3>
                        <button @click="closeModal('changePassword')"
                            class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <form @submit.prevent="submitPasswordChange" data-no-spa class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Current
                                Code</label>
                            <input type="password" name="currentPw" x-model="passwordForm.current"
                                @input="validatePassword('current')"
                                :class="passwordErrors.current ? 'border-status-danger' : 'border-white/10'"
                                class="w-full bg-black border text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                            <span x-show="passwordErrors.current" x-text="passwordErrors.current"
                                class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-[9px] font-black uppercase tracking-widest text-white/30">New
                                    Code</label>
                                <input type="password" name="newPw" x-model="passwordForm.new"
                                    @input="validatePassword('new')"
                                    :class="passwordErrors.new ? 'border-status-danger' : 'border-white/10'"
                                    class="w-full bg-black border text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                                <span x-show="passwordErrors.new" x-text="passwordErrors.new"
                                    class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Verify
                                    Code</label>
                                <input type="password" name="confirmPw" x-model="passwordForm.confirm"
                                    @input="validatePassword('confirm')"
                                    :class="passwordErrors.confirm ? 'border-status-danger' : 'border-white/10'"
                                    class="w-full bg-black border text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                                <span x-show="passwordErrors.confirm" x-text="passwordErrors.confirm"
                                    class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                            </div>
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Encrypting...' : 'Save Changes'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Cropper Modal -->
        <div x-show="modals.cropImage" x-cloak
            class="fixed inset-0 z-[9999] flex items-center justify-center p-4 bg-black/90 backdrop-blur-md"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div class="bg-black-elevated border border-black-border w-full max-w-lg max-h-[95vh] overflow-y-auto shadow-2xl relative">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isUploading" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-6">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-white text-xl font-display font-black tracking-tight uppercase">Calibrate <span class="text-accent italic">Avatar</span></h3>
                        <button @click="closeModal('cropImage')" class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                    
                    <div class="w-full bg-black flex justify-center items-center overflow-hidden" style="max-height: 400px;">
                        <img id="cropper-image" :src="selectedImageUri" class="max-w-full block" />
                    </div>

                    <div class="flex gap-4">
                        <button @click="closeModal('cropImage')"
                            class="flex-1 bg-white/5 border border-white/10 text-white py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-status-danger hover:border-status-danger btn-press">
                            Cancel
                        </button>
                        <button @click="uploadCroppedAvatar()"
                            class="flex-1 bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isUploading ? 'Encoding...' : 'Upload Avatar'"></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        function profileManager() {
            return {
                modals: {
                    editProfile: false,
                    editEmail: false,
                    changePassword: false,
                    cropImage: false
                },
                emailStep: 1,
                newEmail: '',
                otpValue: ['', '', '', '', '', ''],
                isSubmitting: false,
                isUploading: false,
                cropper: null,
                selectedImageUri: null,
                passwordForm: { current: '', new: '', confirm: '' },
                passwordErrors: { current: '', new: '', confirm: '' },
                profileForm: {
                    firstName: <%- JSON.stringify(user.firstName || '') %>,
                    lastName: <%- JSON.stringify(user.lastName || '') %>,
                    phone: <%- JSON.stringify(user.phone || '') %>,
                    bio: <%- JSON.stringify(user.bio || '') %> 
                },
                profileErrors: { firstName: '', lastName: '', phone: '', bio: '' },

                openModal(name) {
                    this.modals[name] = true;
                    document.body.style.overflow = 'hidden';
                },

                closeModal(name) {
                    if (!name) return;
                    this.modals[name] = false;
                    document.body.style.overflow = 'auto';
                    this.isSubmitting = false;

                    if (name === 'editEmail') {
                        this.emailStep = 1;
                        this.newEmail = '';
                        this.otpValue = ['', '', '', '', '', ''];
                    }
                    if (name === 'changePassword') {
                        this.passwordForm = { current: '', new: '', confirm: '' };
                        this.passwordErrors = { current: '', new: '', confirm: '' };
                    }
                    if (name === 'editProfile') {
                        this.profileForm = {
                            firstName: <%- JSON.stringify(user.firstName || '') %>,
                            lastName: <%- JSON.stringify(user.lastName || '') %>,
                            phone: <%- JSON.stringify(user.phone || '') %>,
                            bio: <%- JSON.stringify(user.bio || '') %> 
                        };
                        this.profileErrors = { firstName: '', lastName: '', phone: '', bio: '' };
                    }
                    if (name === 'cropImage') {
                        if(this.cropper) {
                            this.cropper.destroy();
                            this.cropper = null;
                        }
                        this.selectedImageUri = null;
                    }
                },

                openCropper(e) {
                    const file = e.target.files[0];
                    if (!file) return;
                    
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        this.selectedImageUri = e.target.result;
                        this.openModal('cropImage');
                        setTimeout(() => this.initCropper(), 50);
                    };
                    reader.readAsDataURL(file);
                    e.target.value = ''; // clear input
                },

                initCropper() {
                    const imageElement = document.getElementById('cropper-image');
                    if (imageElement) {
                         // Double check image is loaded
                         if(imageElement.complete) {
                            this.cropper = new Cropper(imageElement, { aspectRatio: 1, viewMode: 1, background: false });
                         } else {
                             imageElement.onload = () => {
                                 this.cropper = new Cropper(imageElement, { aspectRatio: 1, viewMode: 1, background: false });
                             };
                         }
                    }
                },

                async uploadCroppedAvatar() {
                    if (!this.cropper) return;
                    this.isUploading = true;
                    
                    this.cropper.getCroppedCanvas({ width: 400, height: 400 }).toBlob(async (blob) => {
                        const formData = new FormData();
                        formData.append('profileImage', blob, 'avatar.jpg');

                        try {
                            const res = await fetch('/upload-profile', {
                                method: 'POST',
                                body: formData
                            });
                            const data = await res.json();

                            if (data.success) {
                                document.getElementById('profile-preview').src = data.imageUrl + '?t=' + new Date().getTime(); // bypass cache
                                window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Identity visualization updated.', type: 'success' } }));
                                this.closeModal('cropImage');
                            } else {
                                throw new Error(data.message);
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: err.message, type: 'error' } }));
                        } finally {
                            this.isUploading = false;
                        }
                    }, 'image/jpeg', 0.9);
                },

                async submitProfileUpdate(e) {
                    if (!this.validateProfileForm()) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: 'Metadata invalidated. Check your profile entries.', type: 'error' }
                        }));
                        return;
                    }
                    this.isSubmitting = true;
                    const body = { ...this.profileForm };

                    try {
                        const res = await fetch('/profile', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Metadata synchronization successful.', type: 'success' }
                            }));
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                async requestEmailOtp() {
                    this.isSubmitting = true;
                    try {
                        const res = await fetch('/change-email/request', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: this.newEmail })
                        });
                        const data = await res.json();

                        if (data.success) {
                            this.emailStep = 2;
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Verification protocol dispatched.', type: 'success' }
                            }));
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                handleOtpInput(e, index) {
                    const val = e.target.value;
                    this.otpValue[index] = val;
                    if (val && index < 5) {
                        document.getElementById(`otp-${index + 1}`).focus();
                    }
                },

                handleOtpBackspace(e, index) {
                    if (!e.target.value && index > 0) {
                        document.getElementById(`otp-${index - 1}`).focus();
                    }
                },

                async verifyEmailOtp() {
                    this.isSubmitting = true;
                    const otp = this.otpValue.join('');
                    try {
                        const res = await fetch('/change-email/verify', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ otp })
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Access endpoint updated.', type: 'success' }
                            }));
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                validatePassword(field) {
                    if (field === 'current') {
                        this.passwordErrors.current = this.passwordForm.current.length < 1 ? 'Current password is required' : '';
                    }
                    if (field === 'new') {
                        const pw = this.passwordForm.new;
                        const hasUpper = /[A-Z]/.test(pw);
                        const hasLower = /[a-z]/.test(pw);
                        const hasNumber = /\d/.test(pw);
                        const hasSpecial = /[\W_]/.test(pw);

                        if (pw.length < 8) {
                            this.passwordErrors.new = 'Pin must be at least 8 segments';
                        } else if (!hasUpper || !hasLower || !hasNumber || !hasSpecial) {
                            this.passwordErrors.new = 'Requires upper, lower, numeric & special char';
                        } else {
                            this.passwordErrors.new = '';
                        }
                        // Re-validate confirm if new changes
                        if (this.passwordForm.confirm) this.validatePassword('confirm');
                    }
                    if (field === 'confirm') {
                        this.passwordErrors.confirm = this.passwordForm.confirm !== this.passwordForm.new ? 'Protocols do not match' : '';
                    }
                },

                validatePasswordForm() {
                    this.validatePassword('current');
                    this.validatePassword('new');
                    this.validatePassword('confirm');
                    return !this.passwordErrors.current && !this.passwordErrors.new && !this.passwordErrors.confirm;
                },

                validateProfileField(field) {
                    if (field === 'firstName') {
                        this.profileErrors.firstName = this.profileForm.firstName.trim().length < 2 ? 'Required (Min 2)' : '';
                    }
                    if (field === 'lastName') {
                        this.profileErrors.lastName = this.profileForm.lastName.trim().length < 1 ? 'Legacy identifier required' : '';
                    }
                    if (field === 'phone') {
                        const regex = /^[0-9]{10}$/;
                        this.profileErrors.phone = !regex.test(this.profileForm.phone) ? '10-digit communication code required' : '';
                    }
                    if (field === 'bio') {
                        this.profileErrors.bio = this.profileForm.bio.length > 200 ? 'Limit exceeds 200 segments' : '';
                    }
                },

                validateProfileForm() {
                    this.validateProfileField('firstName');
                    this.validateProfileField('lastName');
                    this.validateProfileField('phone');
                    this.validateProfileField('bio');
                    return !this.profileErrors.firstName && !this.profileErrors.lastName && !this.profileErrors.phone && !this.profileErrors.bio;
                },

                async submitPasswordChange(e) {
                    if (!this.validatePasswordForm()) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: 'Security protocols invalidated. Check entries.', type: 'error' }
                        }));
                        return;
                    }
                    this.isSubmitting = true;
                    const body = {
                        currentPw: this.passwordForm.current,
                        newPw: this.passwordForm.new,
                        confirmPw: this.passwordForm.confirm
                    };

                    try {
                        const res = await fetch('/profile/password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Security hash rotated successfully.', type: 'success' }
                            }));
                            this.closeModal('changePassword');
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                async copyToClipboard(text) {
                    try {
                        await navigator.clipboard.writeText(text);
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: 'Linked to clipboard.', type: 'success' }
                        }));
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: 'Copy failed.', type: 'error' }
                        }));
                    }
                }
            }
        }
    </script>

    <style>
        [x-cloak] {
            display: none !important;
        }

        .fade-up {
            animation: fadeUp 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
            opacity: 0;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-press:active {
            transform: scale(0.98);
        }
    </style>