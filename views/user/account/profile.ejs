<!-- views/user/account/profile.ejs -->
<%- contentFor('body') %>

    <div class="min-h-screen bg-black py-24" x-data="profileManager()">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">

            <!-- Header & Breadcrumbs -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8 fade-up">
                <div class="space-y-4">
                    <nav class="flex items-center gap-3 text-[10px] font-bold tracking-widest uppercase text-white/30">
                        <a href="/" class="hover:text-accent transition-colors">Home</a>
                        <span>/</span>
                        <a href="/account" class="hover:text-accent transition-colors">Account</a>
                        <span>/</span>
                        <span class="text-white">Profile</span>
                    </nav>
                    <h1 class="text-white text-display font-display font-black tracking-tighter uppercase leading-[0.9]">
                    <br><span class="text-accent underline decoration-4 underline-offset-8"></span>
                    </h1>
                </div>
                <div class="flex items-center gap-6">
                    <div class="text-right hidden md:block">
                        <p class="text-white/30 text-[9px] font-bold uppercase tracking-widest mb-1"></p>
                        <div class="flex items-center gap-2 justify-end">
                            <span class="w-1.5 h-1.5 rounded-full bg-status-success animate-pulse"></span>
                       
                        </div>
                    </div>
                    <a href="/auth/logout"
                        class="group flex items-center gap-4 bg-accent px-10 py-5 hover:bg-white transition-all duration-500 shadow-[0_10px_30px_rgba(255,106,0,0.3)]">
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-black">Sign Out</span>
                        <svg class="w-4 h-4 text-black transform group-hover:translate-x-1 transition-transform" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            <!-- Sidebar Nav -->
            <%- include('../../partials/account-sidebar', { activeTab: 'profile' }) %>

                <!-- Main Content Area -->
                <div class="lg:col-span-3 space-y-12">

                    <!-- Profile Avatar & Key Stats -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 fade-up" style="animation-delay: 200ms">
                        <!-- Avatar Upload -->
                        <div
                            class="md:col-span-1 flex flex-col items-center justify-center p-10 bg-black-elevated border border-black-border relative group overflow-hidden transition-all hover:border-accent/40">
                            <div
                                class="relative w-40 h-40 rounded-full overflow-hidden border-2 border-white/10 group-hover:border-accent transition-all duration-500 shadow-2xl">
                                <img id="profile-preview" src="<%= user.profileImage || '/images/default-avatar.png' %>"
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                                
                                <div
                                    class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col items-center justify-center backdrop-blur-sm cursor-pointer">
                                    <svg class="w-6 h-6 text-white mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    </svg>
                                    <span class="text-[9px] font-black uppercase tracking-widest text-white">Upload</span>
                                    <input type="file" @change="uploadAvatar($event)"
                                        class="absolute inset-0 opacity-0 cursor-pointer" accept="image/*">
                                </div>
                            </div>
                            
                            <div class="mt-6 text-center space-y-1">
                                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-white">Identity Matrix</p>
                                <p class="text-[8px] font-bold uppercase tracking-widest text-white/30">JPG, PNG (Max 2MB)</p>
                            </div>

                            <!-- Premium Loader Overlay -->
                            <div x-show="isUploading" x-cloak
                                class="absolute inset-0 bg-black/80 flex items-center justify-center backdrop-blur-md z-10">
                                <div
                                    class="w-10 h-10 border-2 border-accent border-t-transparent rounded-full animate-spin">
                                </div>
                            </div>
                        </div>

                        <!-- Wallet & Referrals -->
                        <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-8">
                            <div
                                class="flex flex-col justify-center p-10 bg-black-elevated border border-black-border relative group overflow-hidden transition-all hover:border-accent/40">
                                <div
                                    class="absolute -right-2 -top-2 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-700 pointer-events-none">
                                    <svg class="w-24 h-24 text-accent" fill="currentColor" viewBox="0 0 24 24">
                                        <path
                                            d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z">
                                        </path>
                                    </svg>
                                </div>
                                <h4 class="text-white/30 text-[9px] font-black tracking-widest uppercase mb-4">Elite Balance</h4>
                                <div class="flex items-baseline gap-2">
                                    <span
                                        class="text-white text-5xl font-mono font-black italic tracking-tighter tabular-nums">₹
                                        <%= (user.walletBalance || 0).toLocaleString() %></span>
                                    <span
                                        class="text-accent text-[10px] font-bold uppercase tracking-widest">+12.5%</span>
                                </div>
                            </div>
                            <div
                                class="flex flex-col justify-center p-10 bg-black-elevated border border-black-border relative group overflow-hidden transition-all hover:border-accent/40">
                                <div
                                    class="absolute -right-2 -top-2 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-700 pointer-events-none">
                                    <svg class="w-24 h-24 text-accent" fill="currentColor" viewBox="0 0 24 24">
                                        <path
                                            d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z">
                                        </path>
                                    </svg>
                                </div>
                                <h4 class="text-white/30 text-[9px] font-black tracking-widest uppercase mb-4">Network Growth</h4>
                                <div class="flex items-baseline gap-2">
                                    <span
                                        class="text-white text-5xl font-mono font-black italic tracking-tighter tabular-nums">
                                        <%= user.referralCount || 0 %>
                                    </span>
                                    <span class="text-text-muted text-[10px] font-bold uppercase tracking-widest">Active nodes</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Personal Information Grid -->
                    <div class="space-y-8 fade-up" style="animation-delay: 300ms">
                        <div class="flex justify-between items-end border-b border-black-border pb-6">
                            <h2
                                class="text-white text-2xl font-display font-black tracking-tighter uppercase leading-none">
                                The <span
                                    class="text-accent underline decoration-2 underline-offset-4 font-mono">Profile.</span>
                            </h2>
                       
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                            <div class="space-y-10">
                                <!-- Field: Name -->
                                <div class="group relative">
                                    <label
                                        class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Identification</label>
                                    <div class="flex items-center justify-between">
                                        <p class="text-white text-lg font-bold uppercase tracking-tight">
                                            <%= (user.firstName || user.name) %>
                                                <%= (user.lastName || '' ) %>
                                        </p>
                                        <span class="text-[9px] text-white/10 font-mono tracking-widest">REAL_ID</span>
                                    </div>
                                </div>
                                <!-- Field: Phone -->
                                <div class="group relative">
                                    <label
                                        class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Comms
                               Link</label>
                                    <div class="flex items-center justify-between">
                                        <p class="text-white text-lg font-bold tabular-nums">
                                            <%= user.phone || '+ -- --- --- ----' %>
                                        </p>
                                        <span class="text-[9px] text-white/10 font-mono tracking-widest">PHONE_CH</span>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-10">
                                <!-- Field: Email -->
                                <div class="group relative">
                                    <label
                                        class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Primary
                                        Access</label>
                                    <div class="flex items-center justify-between">
                                        <div class="space-y-1">
                                            <p class="text-white text-lg font-bold lowercase tracking-tight">
                                                <%= user.email %>
                                            </p>
                                            <div class="flex items-center gap-2">
                                                <span class="w-1.5 h-1.5 rounded-full bg-status-success"></span>
                                                <span
                                                    class="text-[9px] text-status-success font-black uppercase tracking-widest">Primary
                                                    & Secured</span>
                                            </div>
                                        </div>
                                        <button @click="openModal('editEmail')"
                                            class="bg-white/5 border border-white/5 hover:bg-white hover:text-black p-3 transition-all">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                                </path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <!-- Security Toggle -->
                                <div class="group relative">
                                    <label
                                        class="text-white/20 text-[9px] font-black uppercase tracking-widest block mb-2 group-hover:text-accent transition-colors">Vault
                                        Security</label>
                                    <div class="flex items-center justify-between">
                                        <p class="text-white text-lg font-bold uppercase tracking-tight">••••••••••••
                                        </p>
                                        <button @click="openModal('changePassword')"
                                            class="text-accent text-[10px] font-black uppercase tracking-[0.2em] border border-accent/20 px-6 py-3 hover:bg-accent hover:text-black transition-all">
                                        Change Password</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Referral Section -->
                    <div class="bg-black-elevated border border-black-border p-12 relative overflow-hidden group fade-up rounded-sm transition-all hover:border-accent/30"
                        style="animation-delay: 400ms">
                        <div
                            class="absolute right-0 top-0 w-64 h-64 bg-accent/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2">
                        </div>

                        <div class="relative z-10 flex flex-col md:flex-row gap-12 items-center">
                            <div class="flex-1 space-y-6">
                                <h3
                                    class="text-white text-4xl font-display font-black tracking-tighter uppercase leading-none">
                                    Build Your<br><span class="text-accent italic">REFERALS</span></h3>
                                <p class="text-white/40 text-xs leading-relaxed max-w-sm">Expand the Mobiverse. Every
                                    user who signs up with your unique protocol code generates credits for your vault.
                                    Elite rewards for elite networks.</p>
                            </div>
                            <div class="w-full md:w-auto space-y-4">
                                <div
                                    class="bg-black border border-black-border px-8 py-6 backdrop-blur-md flex flex-col items-center group-hover:border-accent/40 transition-colors">
                                    <span
                                        class="text-white/30 text-[9px] font-black tracking-[0.3em] uppercase mb-4">Your
                                        Protocol Code</span>
                                    <div class="flex items-center gap-6">
                                        <span
                                            class="text-white text-4xl font-mono font-black tracking-[0.1em] selection:bg-accent selection:text-black">
                                            <%= user.referralCode %>
                                        </span>
                                        <button @click="copyReferral('<%= user.referralCode %>')"
                                            class="text-accent hover:text-white transition-colors p-2">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                                </path>
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Edit Profile Modal -->
        <div x-show="modals.editProfile" x-cloak
            class="fixed inset-0 z-[110] flex items-center justify-center p-6 bg-black/95 backdrop-blur-2xl"
            x-transition:enter="transition ease-out duration-500" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div class="bg-black border border-white/5 w-full max-w-2xl overflow-hidden shadow-[0_40px_100px_rgba(255,106,0,0.1)] relative group/modal"
                @click.away="closeModal('editProfile')">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-16 space-y-12">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-5xl font-display font-black tracking-tight uppercase leading-[0.8]">Update<br><span
                                class="text-accent italic"></span></h3>
                        <button @click="closeModal('editProfile')"
                            class="text-white/20 hover:text-white p-2 transition-colors">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <form id="editProfileForm" @submit.prevent="submitProfileUpdate" class="space-y-10">
                        <div class="grid grid-cols-2 gap-8">
                            <div class="space-y-3">
                                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 ml-1">Protocol Identifier (First)</label>
                                <input type="text" name="firstName" value="<%= user.firstName %>"
                                    class="w-full bg-white/5 border-white/10 text-white px-8 py-5 border focus:border-accent focus:bg-white/[0.08] outline-none transition-all placeholder:text-white/10 font-bold uppercase text-sm">
                            </div>
                            <div class="space-y-3">
                                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 ml-1">Legacy Name (Last)</label>
                                <input type="text" name="lastName" value="<%= user.lastName %>"
                                    class="w-full bg-white/5 border-white/10 text-white px-8 py-5 border focus:border-accent focus:bg-white/[0.08] outline-none transition-all placeholder:text-white/10 font-bold uppercase text-sm">
                            </div>
                        </div>
                        <div class="space-y-3">
                            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 ml-1">Communication Channel (Phone)</label>
                            <input type="text" name="phone" value="<%= user.phone %>"
                                class="w-full bg-white/5 border-white/10 text-white px-8 py-5 border focus:border-accent focus:bg-white/[0.08] outline-none transition-all placeholder:text-white/10 font-mono text-lg font-bold">
                        </div>
                        <div class="space-y-3">
                            <label class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 ml-1">Identity Abstract (Bio)</label>
                            <textarea name="bio"
                                class="w-full bg-white/5 border-white/10 text-white px-8 py-5 border focus:border-accent focus:bg-white/[0.08] outline-none transition-all placeholder:text-white/10 font-medium min-h-[140px] resize-none text-sm leading-relaxed"><%= user.bio %></textarea>
                        </div>

                        <button type="submit"
                            class="w-full bg-accent text-black py-6 flex items-center justify-center gap-4 transition-all hover:bg-white group overflow-hidden relative btn-press">
                            <span class="text-[12px] font-black uppercase tracking-[0.3em]"
                                x-text="isSubmitting ? 'Synchronizing...' : 'Saves Changes'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Minimal Change Email Modal -->
        <div x-show="modals.editEmail" x-cloak
            class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div
                class="bg-black-elevated border border-black-border w-full max-w-sm overflow-hidden shadow-2xl relative">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-xl font-display font-black tracking-tight uppercase"
                            x-text="emailStep === 1 ? 'Update Email' : 'Verify Code'"></h3>
                        <button @click="closeModal('editEmail')"
                            class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <!-- Step 1: Request OTP -->
                    <form x-show="emailStep === 1" @submit.prevent="requestEmailOtp" class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-white/30">New Identity Endpoint</label>
                            <input type="email" x-model="newEmail" required
                                class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all placeholder:text-white/10 text-sm"
                                placeholder="target@mobiverse.com">
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Acquiring...' : 'Generate OTP'"></span>
                        </button>
                    </form>

                    <!-- Step 2: Verify OTP -->
                    <form x-show="emailStep === 2" @submit.prevent="verifyEmailOtp" class="space-y-8">
                        <div class="text-center space-y-4">
                            <p class="text-white/40 text-[10px] uppercase tracking-widest">Protocol sent to <br><span
                                    class="text-accent font-bold" x-text="newEmail"></span></p>
                            <div class="flex justify-center gap-2">
                                <template x-for="(i, index) in 6">
                                    <input type="text" maxlength="1" @input="handleOtpInput($event, index)"
                                        @keydown.backspace="handleOtpBackspace($event, index)" :id="'otp-' + index"
                                        class="w-10 h-12 bg-black border border-white/10 text-white text-center text-xl font-mono font-black focus:border-accent outline-none transition-all">
                                </template>
                            </div>
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Verifying...' : 'Confirm Activation'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Minimal Password Change Modal -->
        <div x-show="modals.changePassword" x-cloak
            class="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100">
            <div
                class="bg-black-elevated border border-black-border w-full max-w-sm overflow-hidden shadow-2xl relative">
                <div class="h-1 bg-accent/20 w-full overflow-hidden">
                    <div x-show="isSubmitting" class="h-full bg-accent animate-progress"></div>
                </div>
                <div class="p-8 space-y-8">
                    <div class="flex justify-between items-start">
                        <h3 class="text-white text-xl font-display font-black tracking-tight uppercase">Update <br><span
                                class="text-accent italic">Password</span></h3>
                        <button @click="closeModal('changePassword')"
                            class="text-white/20 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>

                    <form @submit.prevent="submitPasswordChange" class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Current Code</label>
                            <input type="password" name="currentPw" required
                                class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-[9px] font-black uppercase tracking-widest text-white/30">New Code</label>
                                <input type="password" name="newPw" required
                                    class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                            </div>
                            <div class="space-y-2">
                                <label class="text-[9px] font-black uppercase tracking-widest text-white/30">Verify Code</label>
                                <input type="password" name="confirmPw" required
                                    class="w-full bg-black border border-white/10 text-white px-4 py-3 focus:border-accent outline-none transition-all font-mono text-sm">
                            </div>
                        </div>
                        <button type="submit"
                            class="w-full bg-accent text-black py-4 text-[10px] font-black uppercase tracking-[0.2em] transition-all hover:bg-white btn-press">
                            <span x-text="isSubmitting ? 'Encrypting...' : 'Save Changes'"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <script>
        function profileManager() {
            return {
                modals: {
                    editProfile: false,
                    editEmail: false,
                    changePassword: false
                },
                emailStep: 1,
                newEmail: '',
                otpValue: ['', '', '', '', '', ''],
                isSubmitting: false,
                isUploading: false,

                openModal(name) {
                    this.modals[name] = true;
                    document.body.style.overflow = 'hidden';
                },

                closeModal(name) {
                    this.modals[name] = false;
                    document.body.style.overflow = 'auto';
                    if (name === 'editEmail') {
                        this.emailStep = 1;
                        this.newEmail = '';
                        this.otpValue = ['', '', '', '', '', ''];
                    }
                },

                async uploadAvatar(e) {
                    const file = e.target.files[0];
                    if (!file) return;

                    this.isUploading = true;
                    const formData = new FormData();
                    formData.append('profileImage', file);

                    try {
                        const res = await fetch('/upload-profile', {
                            method: 'POST',
                            body: formData
                        });
                        const data = await res.json();

                        if (data.success) {
                            document.getElementById('profile-preview').src = data.imageUrl;
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Identity visualization updated.', type: 'success' }
                            }));
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isUploading = false;
                    }
                },

                async submitProfileUpdate(e) {
                    this.isSubmitting = true;
                    const formData = new FormData(e.target);
                    const body = Object.fromEntries(formData);

                    try {
                        const res = await fetch('/profile', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Metadata synchronization successful.', type: 'success' }
                            }));
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                async requestEmailOtp() {
                    this.isSubmitting = true;
                    try {
                        const res = await fetch('/change-email/request', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: this.newEmail })
                        });
                        const data = await res.json();

                        if (data.success) {
                            this.emailStep = 2;
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Verification protocol dispatched.', type: 'success' }
                            }));
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                handleOtpInput(e, index) {
                    const val = e.target.value;
                    this.otpValue[index] = val;
                    if (val && index < 5) {
                        document.getElementById(`otp-${index + 1}`).focus();
                    }
                },

                handleOtpBackspace(e, index) {
                    if (!e.target.value && index > 0) {
                        document.getElementById(`otp-${index - 1}`).focus();
                    }
                },

                async verifyEmailOtp() {
                    this.isSubmitting = true;
                    const otp = this.otpValue.join('');
                    try {
                        const res = await fetch('/change-email/verify', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ otp })
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Access endpoint updated.', type: 'success' }
                            }));
                            setTimeout(() => window.location.reload(), 1500);
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                    }
                },

                async submitPasswordChange(e) {
                    this.isSubmitting = true;
                    const formData = new FormData(e.target);
                    const body = Object.fromEntries(formData);

                    try {
                        const res = await fetch('/profile/password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();

                        if (data.success) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Security hash rotated successfully.', type: 'success' }
                            }));
                            this.closeModal('changePassword');
                        } else {
                            throw new Error(data.message);
                        }
                    } catch (err) {
                        window.dispatchEvent(new CustomEvent('show-toast', {
                            detail: { message: err.message, type: 'error' }
                        }));
                    } finally {
                        this.isSubmitting = false;
                        e.target.reset();
                    }
                },

                copyReferral(code) {
                    navigator.clipboard.writeText(code);
                    window.dispatchEvent(new CustomEvent('show-toast', {
                        detail: { message: 'Protocol code linked to clipboard.', type: 'info' }
                    }));
                }
            }
        }
    </script>

    <style>
        [x-cloak] {
            display: none !important;
        }

        .fade-up {
            animation: fadeUp 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
            opacity: 0;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-press:active {
            transform: scale(0.98);
        }
    </style>