<!-- views/user/auth/forgotPassword.ejs -->
<%- contentFor('body') %>

    <div class="min-h-[80vh] flex items-center justify-center bg-black py-20 px-6">
        <div class="w-full max-w-md fade-up">
            <div class="text-center mb-12">
                <h1 class="text-white text-display font-bold tracking-tight uppercase mb-4 font-display">RESET ACCESS.
                </h1>
                <p class="text-text-muted text-label font-bold uppercase">Enter your email to receive a code</p>
            </div>

            <form @submit.prevent="submitForgot" x-data="forgotForm()" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-label font-bold uppercase text-text-muted ml-1">Email Address</label>
                    <input type="email" x-model="email" @input="validateEmail()"
                        class="w-full bg-black-elevated border px-6 py-4 text-sm text-white focus:outline-none transition-all placeholder:text-white/5"
                        :class="error ? 'border-status-danger' : 'border-black-border focus:border-accent'"
                        placeholder="hello@example.com">
                    <p x-show="error" x-text="error" class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 ml-1"></p>
                </div>

                <div class="pt-4">
                    <button type="submit" :disabled="loading"
                        class="w-full bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press disabled:opacity-50">
                        <span x-text="loading ? 'SENDING...' : 'SEND CODE'"></span>
                    </button>
                </div>
            </form>

            <script>
                function forgotForm() {
                    return {
                        email: '',
                        error: '',
                        loading: false,

                        validateEmail() {
                            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                            this.error = !emailRegex.test(this.email) ? 'Invalid email address' : '';
                        },

                        async submitForgot() {
                            this.validateEmail();
                            if (this.error || !this.email) return;

                            this.loading = true;
                            try {
                                const response = await fetch('/auth/forgot', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ email: this.email })
                                });

                                const status = response.status;
                                const result = await response.json();

                                if (result.success) {
                                    window.dispatchEvent(new CustomEvent('show-toast', {
                                        detail: { message: 'Verification code sent!', type: 'success', status }
                                    }));
                                    setTimeout(() => {
                                        window.location.href = result.redirect || ('/auth/verify-otp?email=' + encodeURIComponent(this.email) + '&context=forgot');
                                    }, 1000);
                                } else {
                                    window.dispatchEvent(new CustomEvent('show-toast', {
                                        detail: { message: result.message || 'Error occurred', type: 'error', status }
                                    }));
                                }
                            } catch (err) {
                                window.dispatchEvent(new CustomEvent('show-toast', {
                                    detail: { message: 'Network error. Please try again.', type: 'error', status: 0 }
                                }));
                            } finally {
                                this.loading = false;
                            }
                        }
                    }
                }
            </script>

            <div class="mt-12 pt-10 border-t border-black-border text-center">
                <a href="/auth/login"
                    class="text-white hover:text-accent font-bold text-xs tracking-[0.1em] uppercase transition-colors">Return
                    to Sign In</a>
            </div>
        </div>
    </div>