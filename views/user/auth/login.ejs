<!-- views/user/auth/login.ejs -->
<%- contentFor('body') %>

    <div class="min-h-[80vh] flex items-center justify-center bg-black py-20 px-6">
        <div class="w-full max-w-md fade-up">
            <div class="text-center mb-12">
                <h1 class="text-white text-display font-bold tracking-tight uppercase mb-4 font-display">SIGN IN.</h1>
                <p class="text-text-muted text-label font-bold uppercase">Access your MOBIVERSE profile</p>
            </div>

            <form @submit.prevent="submitLogin" x-data="loginForm()" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-label font-bold uppercase text-text-muted ml-1">Email Address</label>
                    <input type="email" x-model="formData.email" @input="validateField('email')"
                        class="w-full bg-black-elevated border px-6 py-4 text-sm text-white focus:outline-none transition-all placeholder:text-white/5"
                        :class="errors.email ? 'border-status-danger' : 'border-black-border focus:border-accent'"
                        placeholder="hello@example.com">
                    <p x-show="errors.email" x-text="errors.email" class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 ml-1"></p>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-1">
                        <label class="text-label font-bold uppercase text-text-muted">Password</label>
                        <a href="/auth/forgot"
                            class="text-label font-bold uppercase text-accent hover:underline">Forgot?</a>
                    </div>
                    <div class="relative group">
                        <input :type="showPassword ? 'text' : 'password'" x-model="formData.password" @input="validateField('password')"
                            class="w-full bg-black-elevated border px-6 py-4 pr-14 text-sm text-white focus:outline-none transition-all placeholder:text-white/5"
                            :class="errors.password ? 'border-status-danger' : 'border-black-border focus:border-accent'"
                            placeholder="••••••••">
                        <button type="button" @click="showPassword = !showPassword"
                            class="absolute right-0 top-0 h-full w-14 flex items-center justify-center text-white/20 hover:text-accent transition-colors focus:outline-none"
                            aria-label="Toggle password visibility">
                            <span x-show="!showPassword">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                                    </path>
                                </svg>
                            </span>
                            <span x-show="showPassword">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a10.024 10.024 0 014.504-4.825m10.922 8.582A10.012 10.012 0 0021.542 12c-1.274-4.057-5.064-7-9.542-7-1.274 0-2.48.209-3.602.597m4.886 4.886A3 3 0 1111 11.34">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                        d="M1 1l22 22"></path>
                                </svg>
                            </span>
                        </button>
                    </div>
                    <p x-show="errors.password" x-text="errors.password" class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 ml-1"></p>
                </div>

                <div class="pt-4">
                    <button type="submit" :disabled="loading"
                        class="w-full bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press disabled:opacity-50 disabled:cursor-not-allowed">
                        <span x-text="loading ? 'AUTHENTICATING...' : 'SIGN IN'"></span>
                    </button>

                    <div class="relative py-4">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-black-border"></div>
                        </div>
                        <div class="relative flex justify-center text-xs uppercase">
                            <span class="bg-black px-4 text-text-muted font-bold tracking-widest">OR</span>
                        </div>
                    </div>

                    <a href="/google"
                        class="w-full border border-black-border text-white font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-black-elevated transition-all flex items-center justify-center gap-4">
                        <svg class="w-5 h-5" viewBox="0 0 24 24">
                            <path fill="currentColor"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="currentColor"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="currentColor"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
                            <path fill="currentColor"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                        CONTINUE WITH GOOGLE
                    </a>
                </div>
            </form>

            <script>
                function loginForm() {
                    return {
                        formData: {
                            email: '',
                            password: ''
                        },
                        errors: {},
                        loading: false,
                        showPassword: false,

                        validateField(field) {
                            switch (field) {
                                case 'email':
                                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                                    this.errors.email = !emailRegex.test(this.formData.email) ? 'Invalid email address' : '';
                                    break;
                                case 'password':
                                    this.errors.password = this.formData.password.length === 0 ? 'Password is required' : '';
                                    break;
                            }
                        },

                        validateForm() {
                            this.validateField('email');
                            this.validateField('password');
                            return !Object.values(this.errors).some(error => error !== '');
                        },

                        async submitLogin() {
                            if (!this.validateForm()) return;

                            this.loading = true;
                            try {
                                const response = await fetch('/auth/login', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(this.formData)
                                });

                                const status = response.status;
                                const result = await response.json();

                                if (result.success) {
                                    window.dispatchEvent(new CustomEvent('show-toast', {
                                        detail: { message: 'Signed in successfully!', type: 'success', status }
                                    }));
                                    setTimeout(() => {
                                        window.location.href = result.redirect || '/';
                                    }, 1000);
                                } else {
                                    window.dispatchEvent(new CustomEvent('show-toast', {
                                        detail: { message: result.message || 'Verification failed', type: 'error', status }
                                    }));
                                    if (result.errors) {
                                        this.errors = { ...this.errors, ...result.errors };
                                    }
                                }
                            } catch (err) {
                                window.dispatchEvent(new CustomEvent('show-toast', {
                                    detail: { message: 'Network error. Please try again.', type: 'error', status: 0 }
                                }));
                            } finally {
                                this.loading = false;
                            }
                        }
                    }
                }
            </script>

            <div class="mt-12 pt-10 border-t border-black-border text-center">
                <p class="text-text-muted text-label font-bold uppercase mb-4">New to Mobiverse?</p>
                <a href="/auth/register"
                    class="text-white hover:text-accent font-bold text-xs tracking-[0.1em] uppercase transition-colors">Create
                    an Account</a>
            </div>
        </div>
    </div>