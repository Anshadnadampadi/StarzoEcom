<!-- views/user/auth/resetPassword.ejs -->
<%- contentFor('body') %>

<div class="min-h-[80vh] flex items-center justify-center bg-black py-20 px-6">
    <div class="w-full max-w-md fade-up">
        <div class="text-center mb-12">
            <h1 class="text-white text-display font-bold tracking-tight uppercase mb-4 font-display">CREATE PASSWORD.</h1>
            <p class="text-text-muted text-label font-bold uppercase">Establish a new standard of security</p>
        </div>

        <form @submit.prevent="submitReset" x-data="resetForm('<%= typeof email !== 'undefined' ? email : '' %>')" class="space-y-6">
            <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
            
            <div class="space-y-2">
                <label class="text-label font-bold uppercase text-text-muted ml-1">New Password</label>
                <div class="relative group">
                    <input :type="showPassword ? 'text' : 'password'" x-model="formData.password" @input="validateField('password')"
                           class="w-full bg-black-elevated border px-6 py-4 pr-14 text-sm text-white focus:outline-none transition-all placeholder:text-white/5"
                           :class="errors.password ? 'border-status-danger' : 'border-black-border focus:border-accent'"
                           placeholder="••••••••">
                    <button type="button" @click="showPassword = !showPassword" 
                            class="absolute right-0 top-0 h-full w-14 flex items-center justify-center text-white/20 hover:text-accent transition-colors focus:outline-none"
                            aria-label="Toggle password visibility">
                        <span x-show="!showPassword">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        </span>
                        <span x-show="showPassword">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a10.024 10.024 0 014.504-4.825m10.922 8.582A10.012 10.012 0 0021.542 12c-1.274-4.057-5.064-7-9.542-7-1.274 0-2.48.209-3.602.597m4.886 4.886A3 3 0 1111 11.34"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M1 1l22 22"></path></svg>
                        </span>
                    </button>
                </div>
                <p x-show="errors.password" x-text="errors.password" class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 ml-1"></p>
            </div>

            <div class="space-y-2">
                <label class="text-label font-bold uppercase text-text-muted ml-1">Confirm New Password</label>
                <div class="relative group">
                    <input :type="showConfirmPassword ? 'text' : 'password'" x-model="formData.confirmPassword" @input="validateField('confirmPassword')"
                           class="w-full bg-black-elevated border px-6 py-4 pr-14 text-sm text-white focus:outline-none transition-all placeholder:text-white/5"
                           :class="errors.confirmPassword ? 'border-status-danger' : 'border-black-border focus:border-accent'"
                           placeholder="••••••••">
                    <button type="button" @click="showConfirmPassword = !showConfirmPassword" 
                            class="absolute right-0 top-0 h-full w-14 flex items-center justify-center text-white/20 hover:text-accent transition-colors focus:outline-none"
                            aria-label="Toggle password visibility">
                        <span x-show="!showConfirmPassword">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                        </span>
                        <span x-show="showConfirmPassword">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a10.024 10.024 0 014.504-4.825m10.922 8.582A10.012 10.012 0 0021.542 12c-1.274-4.057-5.064-7-9.542-7-1.274 0-2.48.209-3.602.597m4.886 4.886A3 3 0 1111 11.34"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M1 1l22 22"></path></svg>
                        </span>
                    </button>
                </div>
                <p x-show="errors.confirmPassword" x-text="errors.confirmPassword" class="text-status-danger text-[9px] font-bold uppercase tracking-widest mt-1 ml-1"></p>
            </div>

            <div class="pt-4">
                <button type="submit" :disabled="loading"
                        class="w-full bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press disabled:opacity-50">
                    <span x-text="loading ? 'UPDATING...' : 'UPDATE PASSWORD'"></span>
                </button>
            </div>
        </form>

        <script>
            function resetForm(initialEmail) {
                return {
                    formData: {
                        password: '',
                        confirmPassword: '',
                        email: initialEmail
                    },
                    errors: {},
                    loading: false,
                    showPassword: false,
                    showConfirmPassword: false,

                    validateField(field) {
                        switch (field) {
                            case 'password':
                                this.errors.password = this.formData.password.length < 8 ? 'Min. 8 characters required' : '';
                                break;
                            case 'confirmPassword':
                                this.errors.confirmPassword = this.formData.password !== this.formData.confirmPassword ? 'Passwords do not match' : '';
                                break;
                        }
                    },

                    async submitReset() {
                        this.validateField('password');
                        this.validateField('confirmPassword');
                        if (Object.values(this.errors).some(err => err !== '')) return;

                        this.loading = true;
                        try {
                            const response = await fetch('/auth/reset-password', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.formData)
                            });

                            const status = response.status;
                            const result = await response.json();

                            if (result.success) {
                                window.dispatchEvent(new CustomEvent('show-toast', {
                                    detail: { message: 'Password updated successfully!', type: 'success', status }
                                }));
                                setTimeout(() => {
                                    window.location.href = '/auth/login';
                                }, 1500);
                            } else {
                                window.dispatchEvent(new CustomEvent('show-toast', {
                                    detail: { message: result.message || 'Reset failed', type: 'error', status }
                                }));
                            }
                        } catch (err) {
                            window.dispatchEvent(new CustomEvent('show-toast', {
                                detail: { message: 'Network error. Please try again.', type: 'error', status: 0 }
                            }));
                        } finally {
                            this.loading = false;
                        }
                    }
                }
            }
        </script>
    </div>
</div>
