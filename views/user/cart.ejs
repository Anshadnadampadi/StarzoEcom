<!-- views/user/cart.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-24">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
        <header class="mb-16">
            <h1 class="text-white text-display font-bold tracking-tight uppercase font-display">Shopping Cart</h1>
            <p class="text-text-secondary text-sm mt-4">Review and manage the items in your cart before checkout.</p>
        </header>

        <% if (typeof cart !== 'undefined' && cart.items.length > 0) { %>
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                
                <!-- Left: Cart Items -->
                <div class="lg:col-span-8 space-y-px bg-black-border border border-black-border">
                    <% cart.items.forEach(item => { %>
                        <div class="bg-black p-8 flex flex-col md:flex-row gap-8 items-center" id="item-<%= item._id %>">
                            <!-- Image -->
                            <div class="w-32 h-32 bg-black-surface border border-black-border p-4 flex-shrink-0">
                                <img src="<%= item.displayImage %>" class="w-full h-full object-contain" alt="<%= item.product.name %>">
                            </div>
  
                            <!-- Details -->
                            <div class="flex-1 text-center md:text-left">
                                <p class="text-accent text-label font-bold uppercase mb-2"><%= item.product.brand %></p>
                                <h3 class="text-white text-lg font-bold mb-1 hover:text-accent transition-colors">
                                    <a href="/products/<%= item.product._id %>"><%= item.product.name %></a>
                                </h3>
                                <p class="text-text-muted text-xs uppercase tracking-widest"><%= item.variant %></p>
                            </div>
  
                            <!-- Qty & Price -->
                            <div class="flex flex-col md:items-end gap-4 w-full md:w-auto">
                                <div class="flex items-center border border-black-border w-fit mx-auto md:mx-0">
                                    <button class="px-4 py-2 text-white hover:bg-black-elevated transition-colors" onclick="updateQty('<%= item._id %>', -1)">−</button>
                                    <span class="px-6 py-2 text-white font-mono text-sm border-x border-black-border min-w-[3rem] text-center"><%= item.qty %></span>
                                    <button class="px-4 py-2 text-white hover:bg-black-elevated transition-colors" onclick="updateQty('<%= item._id %>', 1)">+</button>
                                </div>
                                <div class="text-right">
                                    <p class="text-white font-mono font-bold text-lg">₹<%= (item.price * item.qty).toLocaleString() %></p>
                                    <button class="text-status-danger text-[10px] font-bold tracking-widest uppercase mt-2 hover:underline" onclick="removeItem('<%= item._id %>')">REMOVE</button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Right: Summary -->
                <div class="lg:col-span-4 sticky top-40">
                    <div class="bg-black-card border border-black-border p-8">
                        <h2 class="text-white text-label font-bold uppercase mb-8 border-b border-black-border pb-4">Order Summary</h2>
                        
                        <div class="space-y-6">
                            <div class="flex justify-between text-text-secondary text-sm">
                                <span>Subtotal</span>
                                <span class="text-white font-mono">₹<%= cart.subtotal.toLocaleString() %></span>
                            </div>
                            <div class="flex justify-between text-text-secondary text-sm">
                                <span>Delivery</span>
                                <span class="text-status-success font-bold uppercase">FREE</span>
                            </div>
                            <div class="pt-6 border-t border-black-border flex justify-between items-baseline">
                                <span class="text-white text-label font-bold uppercase">Total Pay</span>
                                <span class="text-white text-2xl font-mono font-bold">₹<%= cart.subtotal.toLocaleString() %></span>
                            </div>
                        </div>

                        <a href="/checkout" class="w-full bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-white transition-all btn-press mt-10 block text-center">
                            PROCEED TO CHECKOUT
                        </a>
                        
                        <div class="mt-8 flex items-center justify-center gap-4 opacity-30 grayscale">
                            <!-- Payment Logos -->
                            <span class="text-[10px] uppercase font-bold tracking-widest">Razorpay</span>
                            <span class="text-[10px] uppercase font-bold tracking-widest">Visa</span>
                            <span class="text-[10px] uppercase font-bold tracking-widest">Mastercard</span>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-32 bg-black border border-black-border">
                <div class="mb-8 flex justify-center">
                    <div class="w-20 h-20 bg-black-surface border border-black-border flex items-center justify-center opacity-50">
                        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                        </svg>
                    </div>
                </div>
                <h2 class="text-white text-2xl font-bold mb-4 uppercase tracking-wider">Your cart is empty</h2>
                <p class="text-text-secondary mb-12 max-w-md mx-auto">Looks like you haven't added anything to your cart yet. Explore our premium collection of flagship phones.</p>
                <a href="/products" class="inline-block bg-accent text-black font-bold px-12 py-5 text-sm tracking-[0.2em] uppercase hover:bg-white transition-all btn-press">
                    START SHOPPING
                </a>
            </div>
        <% } %>
    </div>
</div>

<script>
async function updateQty(itemId, change) {
    try {
        const res = await fetch('/cart/update-qty', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ itemId, change })
        });
        const data = await res.json();
        
        if (data.success) {
            window.location.reload(); // Quickest way to sync state for now
        } else {
            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Error updating quantity', type: 'error' } }));
        }
    } catch (err) {
        console.error(err);
        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Server connection failed', type: 'error' } }));
    }
}

async function removeItem(itemId) {
    const confirmed = await window.confirmAction({
        title: 'Remove Item',
        message: 'Are you sure you want to remove this item from your cart?',
        type: 'danger'
    });
    if (!confirmed) return;
    
    try {
        const res = await fetch('/cart/remove', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ itemId })
        });
        const data = await res.json();
        
        if (data.success) {
            if (data.isEmpty) {
                window.location.reload();
            } else {
                document.getElementById('item-' + itemId).remove();
                window.location.reload(); // To update total/subtotal easily
            }
        } else {
            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Error removing item', type: 'error' } }));
        }
    } catch (err) {
        console.error(err);
        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Server connection failed', type: 'error' } }));
    }
}
</script>
