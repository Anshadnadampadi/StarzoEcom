<!-- views/user/catalog.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black" x-data="{ mobileFilters: false }">
    <!-- Catalog Header -->
    <header class="py-16 bg-black border-b border-black-border">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
            <h1 class="text-white text-display font-bold tracking-tight uppercase mb-4 font-display">
                <%= typeof category !== 'undefined' ? category.name : 'ALL PHONES' %>
            </h1>
            <p class="text-text-secondary text-sm max-w-xl">
                Explore our curated collection of high-performance mobile devices, sourced from the world's leading technology brands.
            </p>
        </div>
    </header>

    <!-- Toolbar -->
    <div class="sticky top-20 z-30 glass border-b border-black-border py-4">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8 flex items-center justify-between">
            <div class="flex items-center gap-6">
                <button @click="mobileFilters = true" class="lg:hidden flex items-center gap-2 text-label font-bold uppercase text-text-secondary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                    Filters
                </button>
                <p class="text-label font-bold uppercase text-text-muted hidden lg:block">
                    Showing <%= products.length %> Results
                </p>
            </div>

            <div class="flex items-center gap-4">
                <select class="bg-black text-label font-bold uppercase text-white border-none focus:ring-0 cursor-pointer">
                    <option>Sort By: Relevant</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Newest Arrivals</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-screen-xl mx-auto px-6 lg:px-8 py-12 flex gap-12">
        <!-- Sidebar Filters (Desktop) -->
        <aside class="hidden lg:block w-64 flex-shrink-0">
            <div class="space-y-10 sticky top-40">
                <!-- Brands -->
                <div>
                    <h3 class="text-white text-label font-bold uppercase mb-6">BRANDS</h3>
                    <div class="space-y-3">
                        <% ['Apple', 'Samsung', 'Google', 'OnePlus', 'Nothing'].forEach(brand => { %>
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" class="w-4 h-4 rounded-sm bg-black-elevated border-black-border border text-accent focus:ring-accent focus:ring-offset-black transition-all">
                                <span class="text-text-secondary text-xs group-hover:text-white transition-colors"><%= brand %></span>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <!-- Price Range -->
                <div>
                    <h3 class="text-white text-[10px] font-bold tracking-widest uppercase mb-6">PRICE RANGE</h3>
                    <div class="space-y-2">
                        <input type="range" class="w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-accent">
                        <div class="flex justify-between text-[10px] font-mono text-white/40">
                            <span>₹10,000</span>
                            <span>₹2,50,000+</span>
                        </div>
                    </div>
                </div>

                <!-- Storage -->
                <div>
                    <h3 class="text-white text-[10px] font-bold tracking-widest uppercase mb-6">STORAGE</h3>
                    <div class="grid grid-cols-2 gap-2">
                        <% ['128GB', '256GB', '512GB', '1TB'].forEach(size => { %>
                            <button class="border border-white/10 py-2 text-[10px] font-bold text-white/40 hover:border-white hover:text-white transition-all uppercase"><%= size %></button>
                        <% }) %>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <div class="flex-1">
            <div class="grid grid-cols-2 lg:grid-cols-3 gap-px bg-black-border border border-black-border">
                <% if (products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <%- include('../partials/product-card', { product }) %>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-32 text-center">
                        <p class="text-white/20 text-[11px] font-bold tracking-widest uppercase">No products match your criteria</p>
                        <a href="/phones" class="text-accent underline text-xs mt-4 inline-block">Clear All Filters</a>
                    </div>
                <% } %>
            </div>

            <!-- Pagination -->
            <%- include('../partials/pagination') %>
        </div>
    </div>

    <!-- Mobile Filters Tool Drawer -->
    <div x-show="mobileFilters" 
         class="fixed inset-0 z-[100] lg:hidden"
         style="display: none;">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" @click="mobileFilters = false"></div>
        
        <!-- Drawer -->
        <div x-show="mobileFilters"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="-translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="-translate-x-full"
             class="absolute left-0 top-0 bottom-0 w-[85%] max-w-sm bg-black p-8 overflow-y-auto">
            <div class="flex justify-between items-center mb-10">
                <h2 class="text-white text-sm font-bold tracking-widest uppercase">Filters</h2>
                <button @click="mobileFilters = false" class="text-white/40">✕</button>
            </div>
            
            <!-- (Filter groups same as desktop) -->
        </div>
    </div>
</div>
