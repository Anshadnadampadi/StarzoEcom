<!-- views/user/checkout.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-black py-24" x-data="{ currentStep: 0 }">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
        
        <!-- Step Indicator -->
        <div class="flex items-center justify-center gap-0 mb-20">
            <% ['Shipping', 'Review', 'Payment'].forEach((step, i) => { %>
                <div class="flex items-center">
                    <div class="flex flex-col items-center">
                        <div class="w-10 h-10 flex items-center justify-center border font-mono text-sm transition-all duration-500"
                             :class="currentStep > <%= i %> ? 'bg-accent border-accent text-black' :
                                    currentStep === <%= i %> ? 'border-accent text-accent shadow-[0_0_15px_rgba(255,106,0,0.3)]' :
                                    'border-white/10 text-white/20'">
                             <%= i + 1 %>
                        </div>
                        <span class="text-[9px] mt-3 font-bold uppercase tracking-widest"
                              :class="currentStep === <%= i %> ? 'text-white' : 'text-white/20'">
                            <%= step %>
                        </span>
                    </div>
                    <% if (i < 2) { %>
                        <div class="w-20 md:w-32 h-px -mt-6 mx-2 transition-colors duration-500"
                             :class="currentStep > <%= i %> ? 'bg-accent' : 'bg-white/10'"></div>
                    <% } %>
                </div>
            <% }) %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            
            <!-- Left: Form Steps -->
            <div class="lg:col-span-8">
                
                <!-- Step 0: Shipping Address -->
                <div x-show="currentStep === 0" x-transition class="space-y-12">
                    <h2 class="text-white text-2xl font-bold tracking-tight uppercase mb-8">Shipping Information</h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-label font-bold uppercase text-text-muted">Full Name</label>
                            <input type="text" class="w-full bg-black-surface border border-black-border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all placeholder:text-white/10" placeholder="Anshad .">
                        </div>
                        <div class="space-y-2">
                            <label class="text-label font-bold uppercase text-text-muted">Phone Number</label>
                            <input type="tel" class="w-full bg-black-surface border border-black-border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all placeholder:text-white/10" placeholder="+91 00000 00000">
                        </div>
                        <div class="md:col-span-2 space-y-2">
                            <label class="text-label font-bold uppercase text-text-muted">Street Address</label>
                            <input type="text" class="w-full bg-black-surface border border-black-border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all placeholder:text-white/10" placeholder="Building, Street, Area">
                        </div>
                        <div class="space-y-2">
                            <label class="text-label font-bold uppercase text-text-muted">City</label>
                            <input type="text" class="w-full bg-black-surface border border-black-border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all placeholder:text-white/10" placeholder="Mumbai">
                        </div>
                        <div class="space-y-2">
                            <label class="text-label font-bold uppercase text-text-muted">PIN Code</label>
                            <input type="text" class="w-full bg-black-surface border border-black-border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all placeholder:text-white/10" placeholder="400001">
                        </div>
                    </div>

                    <button @click="currentStep = 1" class="bg-accent text-black font-bold px-12 py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press">
                        CONTINUE TO REVIEW
                    </button>
                </div>

                <!-- Step 1: Review Order -->
                <div x-show="currentStep === 1" x-transition style="display: none;" class="space-y-12">
                    <h2 class="text-white text-2xl font-bold tracking-tight uppercase mb-8">Review Your Order</h2>
                    
                    <div class="bg-black-surface border border-black-border p-8">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <h3 class="text-white text-label font-bold uppercase mb-4 opacity-40">Ship To:</h3>
                                <p class="text-white text-sm font-medium">Anshad .</p>
                                <p class="text-text-secondary text-xs">Mobi Street, Tech Central, Mumbai, 400001</p>
                                <p class="text-text-secondary text-xs mt-1">+91 00000 00000</p>
                            </div>
                            <button @click="currentStep = 0" class="text-accent text-label font-bold uppercase hover:underline">Edit</button>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <button @click="currentStep = 0" class="border border-black-border text-white font-bold px-12 py-5 text-sm tracking-[0.2em] uppercase hover:border-white transition-all">
                            GO BACK
                        </button>
                        <button @click="currentStep = 2" class="bg-accent text-black font-bold px-12 py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press">
                            PROCEED TO PAYMENT
                        </button>
                    </div>
                </div>

                <!-- Step 2: Payment -->
                <div x-show="currentStep === 2" x-transition style="display: none;" class="space-y-12">
                     <h2 class="text-white text-2xl font-bold tracking-tight uppercase mb-8">Secure Payment</h2>
                     
                     <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% ['RAZORPAY', 'CARD', 'UPI', 'EMI', 'CASH ON DELIVERY'].forEach(method => { %>
                            <button class="flex items-center gap-4 border border-black-border p-6 text-left group hover:border-accent transition-all ring-accent focus:ring-1">
                                <div class="w-4 h-4 rounded-full border border-accent flex-shrink-0 flex items-center justify-center">
                                    <div class="w-2 h-2 bg-accent rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                </div>
                                <span class="text-white text-label font-bold uppercase"><%= method %></span>
                            </button>
                        <% }) %>
                     </div>

                     <div class="pt-8 border-t border-black-border">
                        <button class="w-full max-w-sm bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-accent-hover transition-all btn-press">
                            PAY ₹<%= (typeof cart !== 'undefined' ? cart.subtotal : '0').toLocaleString() %>
                        </button>
                     </div>
                </div>
            </div>

            <!-- Right: Summary Sidebar -->
            <div class="lg:col-span-4">
                <div class="bg-black-surface border border-white/5 p-8 sticky top-40">
                    <h3 class="text-white text-[10px] font-bold tracking-widest uppercase mb-8 border-b border-white/5 pb-4">In Your Cart</h3>
                    
                    <% if (typeof cart !== 'undefined') { %>
                        <div class="space-y-6 mb-10 max-h-[300px] overflow-y-auto custom-scrollbar pr-4">
                            <% cart.items.forEach(item => { %>
                                <div class="flex gap-4">
                                    <div class="w-20 h-20 bg-black p-2 flex-shrink-0 border border-black-border">
                                        <img src="<%= item.product.images[0].url %>" class="w-full h-full object-contain">
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-white text-label font-bold uppercase truncate"><%= item.product.title %></p>
                                        <p class="text-text-muted text-[9px] uppercase"><%= item.qty %> unit · <%= item.variant %></p>
                                        <p class="text-white font-mono text-xs font-bold mt-1">₹<%= (item.product.price * item.qty).toLocaleString() %></p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <div class="space-y-4 pt-6 border-t border-black-border">
                            <div class="flex justify-between text-text-secondary text-xs">
                                <span>Subtotal</span>
                                <span class="text-white font-mono">₹<%= cart.subtotal.toLocaleString() %></span>
                            </div>
                            <div class="flex justify-between text-text-secondary text-xs">
                                <span>Delivery Cost</span>
                                <span class="text-status-success font-bold uppercase text-[10px]">FREE</span>
                            </div>
                            <div class="flex justify-between items-baseline pt-4 border-t border-black-border">
                                <span class="text-white text-label font-bold uppercase">Total Pay</span>
                                <span class="text-white text-2xl font-mono font-bold">₹<%= cart.subtotal.toLocaleString() %></span>
                            </div>
                        </div>
                    <% } else { %>
                         <div class="py-10 text-center text-text-muted text-label uppercase italic">Your cart is empty</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
