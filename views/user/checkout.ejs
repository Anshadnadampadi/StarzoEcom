<!-- views/user/checkout.ejs -->
<%- contentFor('body') %>

<div class="min-h-screen bg-[#050505] py-24 relative overflow-hidden" x-data="checkoutManager()">
    <!-- Background Accents -->
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-accent/5 to-transparent pointer-events-none"></div>
    <div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-screen-xl mx-auto px-6 lg:px-8 relative z-10">
        
        <!-- Premium Step Indicator -->
        <div class="flex items-center justify-center mb-16 max-w-2xl mx-auto">
            <template x-for="(step, index) in ['Shipping', 'Review Details', 'Payment']" :key="index">
                <div class="flex items-center w-full relative">
                    <!-- Connector line -->
                    <div x-show="index > 0" class="absolute left-[-50%] right-[50%] h-[2px] top-4 -z-10"
                         :class="currentStep >= index ? 'bg-accent shadow-[0_0_10px_rgba(255,106,0,0.5)]' : 'bg-white/10'"></div>
                    
                    <div class="flex flex-col items-center w-full">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center transition-all duration-500 cursor-pointer text-xs font-black font-mono border-2 bg-[#050505]"
                             @click="if(currentStep > index) currentStep = index"
                             :class="currentStep > index ? 'border-accent text-accent shadow-[0_0_15px_rgba(255,106,0,0.4)]' :
                                    currentStep === index ? 'border-accent bg-accent text-black scale-110 shadow-[0_0_20px_rgba(255,106,0,0.6)]' :
                                    'border-white/20 text-white/40'">
                             <span x-show="currentStep <= index" x-text="index + 1"></span>
                             <svg x-show="currentStep > index" class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span class="text-[9px] mt-4 font-black uppercase tracking-[0.2em] transition-colors"
                              :class="currentStep === index ? 'text-white' : 'text-white/40'" x-text="step">
                        </span>
                    </div>
                </div>
            </template>
        </div>

        <div class="flex flex-col lg:flex-row gap-8 items-start w-full">
            
            <!-- Left: Terminal Setup Form -->
            <div class="w-full lg:w-3/5 flex-shrink-0">
                
                <!-- STAGE 0: SHIPPING -->
                <div x-show="currentStep === 0" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="bg-white/[0.02] border border-white/10 backdrop-blur-md p-8 relative isolate overflow-hidden shadow-2xl">
                    <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent pointer-events-none"></div>
                    
                    <div class="flex justify-between items-center mb-8 relative z-10 border-b border-white/10 pb-4">
                        <h2 class="text-white text-xl font-black tracking-widest uppercase flex items-center gap-3">
                            <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
                            Delivery Address
                        </h2>
                        <button type="button" @click="openAddressModal('add')" class="text-accent text-[10px] font-bold uppercase tracking-[0.2em] hover:text-white transition-colors border border-accent/30 px-3 py-1.5 hover:bg-accent/10">Add New</button>
                    </div>
                    
                    <% if (addresses && addresses.length > 0) { %>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 relative z-10">
                            <% addresses.forEach((addr, idx) => { %>
                                <label class="cursor-pointer group">
                                    <input type="radio" x-model="orderData.addressId" value="<%= addr._id %>" class="peer sr-only">
                                    <div class="bg-black/50 border border-white/10 p-6 peer-checked:border-accent peer-checked:bg-accent/[0.05] relative transition-all duration-300 h-full overflow-hidden hover:border-white/30">
                                        
                                        <!-- Active Indicator Accent bar -->
                                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-accent transform -translate-x-full peer-checked:translate-x-0 transition-transform duration-300"></div>

                                        <div class="flex justify-between items-start mb-3">
                                            <div class="flex items-center gap-2">
                                                <p class="text-white font-bold uppercase text-sm tracking-wide"><%= addr.name %></p>
                                                <span class="px-2 py-[2px] bg-white/10 text-white/70 text-[8px] font-black tracking-[0.2em] rounded-sm uppercase"><%= addr.type %></span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <button type="button" @click.stop="openAddressModal('edit', addresses.find(a => a._id === '<%= addr._id %>'))" class="text-white/40 hover:text-accent text-[10px] uppercase font-bold tracking-widest uppercase transition-colors relative z-20">Edit</button>
                                                <div class="w-4 h-4 rounded-full border border-white/30 peer-checked:border-accent flex items-center justify-center flex-shrink-0 transition-colors">
                                                    <div class="w-2 h-2 rounded-full bg-accent scale-0 peer-checked:scale-100 transition-transform duration-300"></div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <p class="text-white/60 text-[10px] uppercase font-mono mb-2 trackig-wider flex items-center gap-2">
                                            <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                            <%= addr.phone %>
                                        </p>
                                        <p class="text-white/40 text-[10px] uppercase leading-relaxed max-w-[90%] font-mono"><%= addr.addr1 %>, <%= addr.addr2 ? addr.addr2 + ',' : '' %> <%= addr.city %>, <%= addr.state %> <%= addr.zip %></p>
                                    </div>
                                </label>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="py-16 border border-dashed border-white/20 text-center relative z-10 bg-black/20">
                            <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-4">
                                <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            </div>
                            <p class="text-white/50 text-[11px] font-bold uppercase tracking-widest mb-6 font-mono">No delivery addresses found.</p>
                            <button type="button" @click="openAddressModal('add')" class="inline-block bg-accent text-black px-8 py-3 text-[10px] font-black tracking-[0.2em] uppercase hover:bg-white transition-all shadow-[0_0_15px_rgba(255,106,0,0.3)]">Add New Address</button>
                        </div>
                    <% } %>

                    <div class="mt-8 pt-6 border-t border-white/10 flex justify-end relative z-10">
                        <button @click="proceedToReview" class="bg-accent text-black font-black px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all shadow-[0_0_20px_rgba(255,106,0,0.2)] disabled:opacity-30 disabled:cursor-not-allowed flex items-center gap-3 group" :disabled="!orderData.addressId">
                            Continue to Review
                            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>
                    </div>
                </div>

                <!-- STAGE 1: REVIEW -->
                <div x-show="currentStep === 1" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="bg-white/[0.02] border border-white/10 backdrop-blur-md p-8 relative shadow-2xl">
                    <h2 class="text-white text-xl font-black tracking-widest uppercase mb-8 border-b border-white/10 pb-4 flex items-center gap-3">
                        <span class="text-accent">02.</span> Confirm Details
                    </h2>
                    
                    <div class="bg-black/40 border border-white/5 p-6 mb-8 relative group overflow-hidden">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-accent/5 rounded-full blur-2xl transform translate-x-10 -translate-y-10 group-hover:bg-accent/10 transition-colors"></div>
                        <div class="flex justify-between items-start relative z-10">
                            <div>
                                <h3 class="text-accent text-[9px] font-black tracking-[0.3em] uppercase mb-4 flex items-center gap-2">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path></svg>
                                    Selected Address
                                </h3>
                                <div x-html="getSelectedAddressHTML()" class="space-y-1"></div>
                            </div>
                            <button @click="currentStep = 0" class="text-white/40 text-[9px] font-bold uppercase tracking-widest hover:text-white transition-colors border-b border-white/20 pb-0.5">Modify</button>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <button @click="currentStep = 0" class="border border-white/20 text-white/70 font-bold px-8 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white/5 hover:text-white transition-all">
                            Back
                        </button>
                        <button @click="currentStep = 2" class="bg-accent text-black font-black px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-all shadow-[0_0_20px_rgba(255,106,0,0.2)] flex-1 flex items-center gap-3 justify-center group" :disabled="!orderData.addressId">
                            Continue to Payment
                            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>

                <!-- STAGE 2: SECURE PAYMENT -->
                <div x-show="currentStep === 2" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="bg-white/[0.02] border border-white/10 backdrop-blur-md p-8 relative shadow-2xl">
                     <h2 class="text-white text-xl font-black tracking-widest uppercase mb-8 border-b border-white/10 pb-4 flex items-center gap-3">
                        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        Payment Method
                     </h2>
                     
                     <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <label class="cursor-pointer group">
                            <input type="radio" x-model="orderData.paymentMethod" value="CASH ON DELIVERY" class="peer sr-only">
                            <div class="flex flex-col border border-white/10 p-6 peer-checked:border-accent peer-checked:bg-accent/[0.05] transition-all bg-black/40 h-full relative overflow-hidden group-hover:border-white/30">
                                <div class="flex items-center justify-between mb-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center">
                                            <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                        </div>
                                        <span class="text-white text-xs font-black uppercase tracking-widest">Cash on Delivery</span>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-white/30 peer-checked:border-accent flex items-center justify-center transition-colors">
                                        <div class="w-2 h-2 rounded-full bg-accent scale-0 peer-checked:scale-100 transition-transform"></div>
                                    </div>
                                </div>
                                <p class="text-white/40 text-[9px] font-mono leading-relaxed mt-auto uppercase tracking-wide">Pay securely with cash upon delivery.</p>
                            </div>
                        </label>

                        <label class="cursor-pointer group">
                            <input type="radio" x-model="orderData.paymentMethod" value="ONLINE PAYMENT" class="peer sr-only">

                            <div class="flex flex-col border border-white/10 p-6 peer-checked:border-accent peer-checked:bg-accent/[0.05] transition-all bg-black/40 h-full relative overflow-hidden group-hover:border-white/30">
                                <div class="absolute -right-10 -top-10 w-24 h-24 bg-blue-500/10 rounded-full blur-xl filter"></div>
                                <div class="flex items-center justify-between mb-4 relative z-10">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center">
                                            <svg class="w-4 h-4 text-blue-400/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                                        </div>
                                        <span class="text-white text-xs font-black uppercase tracking-widest">Online Payment</span>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-white/30 peer-checked:border-accent flex items-center justify-center transition-colors">
                                        <div class="w-2 h-2 rounded-full bg-accent scale-0 peer-checked:scale-100 transition-transform"></div>
                                    </div>
                                </div>
                                <p class="text-white/40 text-[9px] font-mono leading-relaxed mt-auto uppercase tracking-wide">Pay instantly via UPI, Credit Card, and other secure digital gateways.</p>
                            </div>
                        </label>

                        <label class="cursor-pointer group">
                            <input type="radio" x-model="orderData.paymentMethod" value="WALLET" class="peer sr-only" :disabled="walletBalance < totalAmount">

                            <div class="flex flex-col border border-white/10 p-6 peer-checked:border-accent peer-checked:bg-accent/[0.05] transition-all bg-black/40 h-full relative overflow-hidden group-hover:border-white/30"
                                :class="walletBalance < totalAmount ? 'opacity-50 cursor-not-allowed' : ''">
                                <div class="absolute -right-10 -top-10 w-24 h-24 bg-emerald-500/10 rounded-full blur-xl filter"></div>
                                <div class="flex items-center justify-between mb-4 relative z-10">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center">
                                            <svg class="w-4 h-4 text-emerald-400/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-white text-xs font-black uppercase tracking-widest">Wallet Payment</span>
                                            <span class="text-emerald-400/80 text-[8px] font-black uppercase tracking-widest" x-text="'Balance: ₹' + walletBalance.toLocaleString()"></span>
                                        </div>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-white/30 peer-checked:border-accent flex items-center justify-center transition-colors">
                                        <div class="w-2 h-2 rounded-full bg-accent scale-0 peer-checked:scale-100 transition-transform"></div>
                                    </div>
                                </div>
                                <p class="text-white/40 text-[9px] font-mono leading-relaxed mt-auto uppercase tracking-wide">Pay using your Starzo Wallet balance.</p>
                                <p x-show="walletBalance < totalAmount" class="text-status-danger text-[7px] font-black uppercase tracking-widest mt-2">Insufficient Balance</p>
                            </div>
                        </label>
                     </div>

                     <div class="pt-8 mt-8 border-t border-white/10">
                        <template x-if="hasCartIssues">
                            <div class="mb-4 p-4 bg-status-danger/10 border border-status-danger/20">
                                <p class="text-status-danger text-[9px] font-black uppercase tracking-widest text-center">
                                    Some items have stock/availability issues. Please return to cart.
                                </p>
                            </div>
                        </template>

                        <button @click="submitOrder" class="w-full bg-accent text-black font-black py-5 text-[11px] tracking-[0.3em] uppercase hover:bg-white transition-all shadow-[0_0_30px_rgba(255,106,0,0.2)] flex items-center justify-center gap-3" :class="{ 'opacity-50 cursor-not-allowed': isSubmitting || hasCartIssues }" :disabled="isSubmitting || hasCartIssues">
                            <span x-show="!isSubmitting" class="flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Place Order
                            </span>
                            <span x-show="isSubmitting" class="flex items-center gap-2 font-mono" x-cloak>
                                <svg class="animate-spin w-4 h-4 text-black" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                PROCESSING ORDER...
                            </span>
                        </button>
                     </div>
                </div>
            </div>

            <!-- Right: Dynamic Cart Hologram -->
            <div class="w-full lg:w-2/5 flex-shrink-0">
                <div class="bg-white/[0.02] border border-white/10 backdrop-blur-md p-8 sticky top-24 shadow-2xl">
                    <h3 class="text-white text-[10px] font-black tracking-widest uppercase mb-6 border-b border-white/10 pb-4 flex items-center gap-2">
                        <svg class="w-3 h-3 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        Order Items
                    </h3>
                    
                    <% if (typeof cart !== 'undefined' && cart.items.length > 0) { %>
                        <div class="space-y-4 mb-8 max-h-[350px] overflow-y-auto custom-scrollbar pr-2">
                            <% cart.items.forEach((item, index) => { %>
                                <div class="flex gap-4 group bg-black/40 border border-white/5 p-3 hover:border-accent/40 transition-colors">
                                    <div class="w-16 h-16 bg-black flex-shrink-0 relative overflow-hidden">
                                        <% let img = '/images/placeholder.png';
                                           if (item.displayImage) img = item.displayImage;
                                           else if (item.product.variants && item.product.variants.length > 0) {
                                               let v = item.product.variants.find(v => v._id.toString() === item.variant || v.color === item.variant);
                                               if (v && v.images && v.images.length > 0) img = v.images[0];
                                               else if (item.product.variants[0].images.length > 0) img = item.product.variants[0].images[0];
                                           }
                                        %>
                                        <div class="absolute inset-0 bg-accent/20 mix-blend-overlay opacity-0 group-hover:opacity-100 transition-opacity z-10"></div>
                                        <img src="<%= img %>" class="w-full h-full object-contain transform group-hover:scale-110 transition-transform duration-500">
                                    </div>
                                    <div class="flex-1 flex flex-col justify-center">
                                        <p class="text-white text-[11px] font-bold uppercase truncate max-w-[140px]"><%= item.product.name %></p>
                                        <div class="flex justify-between items-center mt-1 w-full">
                                            <p class="text-white/40 text-[9px] uppercase font-mono"><%= item.qty %>x <%= item.variantDisplay || 'Standard' %></p>
                                            <p class="text-accent font-mono text-[11px] font-bold">₹<%= (item.price * item.qty).toLocaleString() %></p>
                                        </div>
                                        <% if (item.isUnavailable) { %>
                                            <p class="text-status-danger text-[7px] font-black uppercase tracking-widest mt-1">● Unavailable</p>
                                        <% } else if (item.isOutOfStock) { %>
                                            <p class="text-status-danger text-[7px] font-black uppercase tracking-widest mt-1">● Out of Stock</p>
                                        <% } else if (item.insufficientStock) { %>
                                            <p class="text-status-warning text-[7px] font-black uppercase tracking-widest mt-1">● Only <%= item.availableStock %> Left</p>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Protocol Override Section (Coupons) -->
                        <div class="mb-8 p-4 bg-black/40 border border-white/5 border-l-2 border-l-accent/50">
                            <label class="text-[8px] font-black uppercase tracking-[0.2em] text-white/40 block mb-2">Apply Coupon (Try: SYNC10)</label>
                            <div class="flex gap-2">
                                <input type="text" x-model="orderData.couponCode" class="w-full bg-black border border-white/10 text-white px-3 py-2 text-[10px] font-mono focus:border-accent outline-none transition-all uppercase placeholder-white/20" placeholder="ENTER COUPON CODE">
                                <button type="button" @click="applyCoupon" class="bg-white/5 border border-white/10 text-white px-4 py-2 text-[9px] font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all">Verify</button>
                            </div>
                        </div>

                        <!-- Data Readout -->
                        <div class="space-y-3 pt-6 border-t border-white/10">
                            <div class="flex justify-between text-white/50 text-[10px] font-mono tracking-widest uppercase">
                                <span>Subtotal</span>
                                <span class="text-white" x-text="'₹' + subtotal.toLocaleString()"></span>
                            </div>
                            <div class="flex justify-between text-white/50 text-[10px] font-mono tracking-widest uppercase">
                                <span>Tax (18% GST)</span>
                                <span class="text-white" x-text="'₹' + tax.toLocaleString()"></span>
                            </div>
                            <div class="flex justify-between text-white/50 text-[10px] font-mono tracking-widest uppercase">
                                <span>Discount</span>
                                <span class="text-white" :class="discount > 0 ? 'text-accent' : ''" x-text="'-₹' + discount.toLocaleString()"></span>
                            </div>
                            <div class="flex justify-between text-white/50 text-[10px] font-mono tracking-widest uppercase items-center">
                                <span>Shipping Fee</span>
                                <span x-show="shippingFee === 0" class="text-accent text-[9px] font-black tracking-widest py-0.5 px-2 bg-accent/10 border border-accent/20 rounded-sm italic" x-cloak>WAIVED</span>
                                <span x-show="shippingFee > 0" class="text-white" x-text="'₹' + shippingFee.toLocaleString()" x-cloak></span>
                            </div>
                            
                            <div class="flex justify-between items-end pt-4 mt-4 border-t border-white/10 relative">
                                <div class="absolute -left-8 right-0 bottom-0 h-[1px] bg-gradient-to-r from-transparent via-accent/50 to-transparent"></div>
                                <span class="text-white text-[10px] font-black uppercase tracking-[0.3em] mb-1">Total Amount</span>
                                <span class="text-accent text-3xl font-display font-black tracking-tighter" x-text="'₹' + totalAmount.toLocaleString()"></span>
                            </div>
                        </div>
                    <% } else { %>
                         <div class="py-16 text-center text-white/20 text-[10px] uppercase font-mono tracking-widest border border-dashed border-white/10">No items available.</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Address Slide-over Modal -->
    <div x-show="addressModalOpen" 
         x-cloak
         class="fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm flex justify-end"
         @click.self="addressModalOpen = false">
        
        <div x-show="addressModalOpen"
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="translate-x-full"
             x-transition:enter-end="translate-x-0"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="translate-x-0"
             x-transition:leave-end="translate-x-full"
             class="w-full max-w-xl bg-black border-l border-white/10 h-full overflow-y-auto p-12 shadow-[0_0_100px_rgba(0,0,0,0.5)]">
            
            <div class="flex justify-between items-center mb-16">
                <h2 class="text-white text-2xl font-bold uppercase tracking-tight" x-text="addressMode === 'add' ? 'NEW ADDRESS' : 'EDIT ADDRESS'"></h2>
                <button @click="addressModalOpen = false" class="text-white/20 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <form @submit.prevent="saveAddress" class="space-y-8">
                <!-- Address Type -->
                <div class="space-y-4">
                    <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Location Type</label>
                    <div class="grid grid-cols-3 gap-4">
                        <template x-for="type in ['Home', 'Work', 'Other']">
                            <button type="button" 
                                    @click="addressForm.type = type"
                                    :class="addressForm.type === type ? 'bg-white text-black' : 'bg-[#0A0A0A] text-white/40 border-white/5 border'"
                                    class="py-3 text-[10px] font-bold uppercase tracking-widest transition-all"
                                    x-text="type"></button>
                        </template>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Full Name</label>
                        <input type="text" x-model="addressForm.name" placeholder="Receiver's name"
                               @input="validateAddressField('name')"
                               :class="addressErrors.name ? 'border-status-danger' : 'border-white/10'"
                               class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all">
                        <span x-show="addressErrors.name" x-text="addressErrors.name" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Phone Number</label>
                        <input type="tel" x-model="addressForm.phone" placeholder="Delivery contact"
                               @input="validateAddressField('phone')"
                               :class="addressErrors.phone ? 'border-status-danger' : 'border-white/10'"
                               class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all">
                        <span x-show="addressErrors.phone" x-text="addressErrors.phone" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Street Address</label>
                        <input type="text" x-model="addressForm.addr1" placeholder="House/Apartment/Street"
                               @input="validateAddressField('addr1')"
                               :class="addressErrors.addr1 ? 'border-status-danger' : 'border-white/10'"
                               class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all mb-4">
                        <span x-show="addressErrors.addr1" x-text="addressErrors.addr1" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block mb-4"></span>
                        
                        <input type="text" x-model="addressForm.addr2" placeholder="Area/Landmark (Optional)"
                               @input="if(addressErrors.addr2) delete addressErrors.addr2"
                               :class="addressErrors.addr2 ? 'border-status-danger' : 'border-white/10'"
                               class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all">
                        <span x-show="addressErrors.addr2" x-text="addressErrors.addr2" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">City</label>
                            <input type="text" x-model="addressForm.city"
                                   @input="validateAddressField('city')"
                                   :class="addressErrors.city ? 'border-status-danger' : 'border-white/10'"
                                   class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all">
                            <span x-show="addressErrors.city" x-text="addressErrors.city" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">State</label>
                            <input type="text" x-model="addressForm.state"
                                   @input="validateAddressField('state')"
                                   :class="addressErrors.state ? 'border-status-danger' : 'border-white/10'"
                                   class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all">
                            <span x-show="addressErrors.state" x-text="addressErrors.state" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Postal Code</label>
                            <input type="text" x-model="addressForm.zip"
                                   @input="validateAddressField('zip')"
                                   :class="addressErrors.zip ? 'border-status-danger' : 'border-white/10'"
                                   class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all font-mono">
                            <span x-show="addressErrors.zip" x-text="addressErrors.zip" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-bold uppercase text-white/40 tracking-widest ml-1">Country</label>
                            <select x-model="addressForm.country"
                                    @change="if(addressErrors.country) delete addressErrors.country"
                                    :class="addressErrors.country ? 'border-status-danger' : 'border-white/10'"
                                    class="w-full bg-[#0A0A0A] border px-6 py-4 text-sm text-white focus:outline-none focus:border-accent transition-all appearance-none uppercase font-bold tracking-widest">
                                <option value="India">India</option>
                                <option value="UAE">UAE</option>
                                <option value="USA">USA</option>
                            </select>
                            <span x-show="addressErrors.country" x-text="addressErrors.country" class="text-red-500 text-[9px] font-bold uppercase tracking-widest mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="pt-10 flex gap-4">
                    <button type="submit" 
                            :disabled="addressSaving"
                            class="flex-1 bg-accent text-black font-bold py-5 text-sm tracking-[0.2em] uppercase hover:bg-white transition-all disabled:opacity-50"
                            x-text="addressSaving ? 'SAVING...' : (addressMode === 'add' ? 'SAVE ADDRESS' : 'UPDATE ADDRESS')"></button>
                    <button type="button" 
                            @click="addressModalOpen = false"
                            class="px-10 border border-white/10 text-white text-[10px] font-bold uppercase tracking-widest hover:border-white transition-all">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    const userAddresses = <%- JSON.stringify(addresses || []) %>;
    const baseSubtotal = <%= typeof cart !== 'undefined' ? cart.subtotal : 0 %>;
    const hasCartIssues = <%= cart.items.some(item => item.isUnavailable || item.isOutOfStock || item.insufficientStock) %>;
    const userEmail = "<%= user.email %>";
    const userPhone = "<%= addresses && addresses.length > 0 ? addresses[0].phone : '' %>";

    function checkoutManager() {
        return {
            currentStep: 0,
            isSubmitting: false,
            addresses: userAddresses,
            hasCartIssues: hasCartIssues,
            walletBalance: <%= walletBalance %>,
            
            // Financials logic
            subtotal: baseSubtotal,
            shippingFee: baseSubtotal > 500 ? 0 : 50,
            tax: Math.floor(baseSubtotal * 0.18),
            discount: 0,
            
            get totalAmount() {
                return Math.max(0, this.subtotal + this.tax + this.shippingFee - this.discount);
            },
            
            applyCoupon() {
                const code = this.orderData.couponCode ? this.orderData.couponCode.trim().toUpperCase() : '';
                if(code === 'SYNC10') {
                    this.discount = Math.floor((this.subtotal + this.tax) * 0.10);
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Coupon applied successfully. 10% off.', type: 'success' }}));
                } else if(code === '') {
                    this.discount = 0;
                } else {
                    this.discount = 0;
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Invalid coupon code.', type: 'error' }}));
                }
            },

            orderData: {
                addressId: userAddresses.length > 0 ? (userAddresses.find(a => a.default) ? userAddresses.find(a => a.default)._id : userAddresses[0]._id) : '',
                paymentMethod: 'CASH ON DELIVERY',
                couponCode: ''
            },

            // Address overlay functionality
            addressModalOpen: false,
            addressMode: 'add',
            addressSaving: false,
            addressErrors: {},
            addressForm: {
                id: null,
                type: 'Home',
                name: '',
                phone: '',
                addr1: '',
                addr2: '',
                city: '',
                state: '',
                zip: '',
                country: 'India',
                default: false
            },

            openAddressModal(mode, data = null) {
                this.addressMode = mode;
                this.addressErrors = {};
                if (mode === 'edit' && data) {
                    this.addressForm = { ...data, id: data._id };
                } else {
                    this.addressForm = {
                        id: null, type: 'Home', name: '', phone: '',
                        addr1: '', addr2: '', city: '', state: '', zip: '',
                        country: 'India', default: false
                    };
                }
                this.addressModalOpen = true;
            },

            validateAddressField(field) {
                switch (field) {
                    case 'name':
                        this.addressErrors.name = this.addressForm.name.trim().length < 3 ? 'Full name is too short' : '';
                        break;
                    case 'phone':
                        const phoneRegex = /^[0-9]{10}$/;
                        this.addressErrors.phone = !phoneRegex.test(this.addressForm.phone) ? 'Enter a valid 10-digit number' : '';
                        break;
                    case 'addr1':
                        this.addressErrors.addr1 = this.addressForm.addr1.trim().length < 5 ? 'Address is too short' : '';
                        break;
                    case 'city':
                        this.addressErrors.city = this.addressForm.city.trim().length < 2 ? 'Invalid city name' : '';
                        break;
                    case 'state':
                        this.addressErrors.state = this.addressForm.state.trim().length < 2 ? 'Invalid state name' : '';
                        break;
                    case 'zip':
                        const zipRegex = /^[0-9]{6}$/;
                        this.addressErrors.zip = !zipRegex.test(this.addressForm.zip) ? 'Enter a valid 6-digit postal code' : '';
                        break;
                }
            },

            validateAddressForm() {
                this.validateAddressField('name');
                this.validateAddressField('phone');
                this.validateAddressField('addr1');
                this.validateAddressField('city');
                this.validateAddressField('state');
                this.validateAddressField('zip');
                return !Object.values(this.addressErrors).some(error => error !== '');
            },

            async saveAddress() {
                if (!this.validateAddressForm()) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Some fields are invalid.', type: 'error' } }));
                    return;
                }
                this.addressSaving = true;
                try {
                    const url = this.addressMode === 'add' ? '/account/address' : `/account/address/${this.addressForm.id}`;
                    const method = this.addressMode === 'add' ? 'POST' : 'PUT';
                    
                    const response = await fetch(url, {
                        method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(this.addressForm)
                    });
                    
                    const result = await response.json();
                    if (result.success) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: `Address ${this.addressMode === 'add' ? 'saved' : 'updated'} successfully`, type: 'success' } }));
                        setTimeout(() => window.location.reload(), 1000); 
                    } else {
                        this.addressErrors = result.errors || {};
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: result.message || 'Validation failed on server', type: 'error' } }));
                    }
                } catch(error) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Network error. Please try again.', type: 'error' } }));
                } finally {
                    this.addressSaving = false;
                }
            },
            
            proceedToReview() {
                if(!this.orderData.addressId) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Please select a delivery address.', type: 'error' }}));
                    return;
                }
                this.currentStep = 1;
            },

            getSelectedAddressHTML() {
                if(!this.orderData.addressId) return '<p class="text-accent text-xs font-mono">NO ADDRESS SELECTED</p>';
                const addr = this.addresses.find(a => a._id === this.orderData.addressId);
                if(!addr) return '<p class="text-accent text-xs font-mono">INVALID ADDRESS DATA</p>';
                
                return `
                    <p class="text-white text-sm font-bold uppercase tracking-wide">${addr.name}</p>
                    <p class="text-white/60 text-[10px] uppercase font-mono mt-1 flex items-center gap-2">
                         <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                         ${addr.phone}
                    </p>
                    <p class="text-white/40 text-[10px] uppercase leading-relaxed mt-2 max-w-[80%] font-mono">${addr.addr1}, ${addr.addr2 ? addr.addr2 + ', ' : ''}${addr.city}, ${addr.state} ${addr.zip}</p>
                `;
            },

            async submitOrder() {
                if(!this.orderData.addressId || !this.orderData.paymentMethod) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Please select an address and payment method.', type: 'error' }}));
                    return;
                }

                this.isSubmitting = true;
                try {
                    const res = await fetch('/checkout/place-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(this.orderData)
                    });
                    const data = await res.json();
                    
                    if(data.success) {
                        if (data.paymentMethod === 'ONLINE PAYMENT') {
                            this.initiateRazorpay(data);
                        } else {
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Order placed successfully. Redirecting...', type: 'success' }}));
                            setTimeout(() => window.location.href = '/checkout/success/' + data.orderId, 1200);
                        }
                    } else {
                        throw new Error(data.message || 'Order could not be placed.');
                    }
                } catch(error) {
                    if (this.isSubmitting) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: error.message, type: 'error' }}));
                    }
                    this.isSubmitting = false;
                }
            },

            initiateRazorpay(orderInfo) {
                const selectedAddr = this.addresses.find(a => a._id === this.orderData.addressId) || {};
                
                const options = {
                    key: "<%= razorpayKeyId %>", 
                    amount: orderInfo.razorpayOrder.amount,
                    currency: orderInfo.razorpayOrder.currency,
                    name: "STARZO MOBILES",
                    description: "Secure Order Payment",
                    order_id: orderInfo.razorpayOrder.id,
                    handler: async (response) => {
                        await this.verifyOnlinePayment(response, orderInfo.orderId);
                    },
                    prefill: {
                        name: selectedAddr.name || "Customer",
                        email: userEmail,
                        contact: selectedAddr.phone || userPhone
                    },
                    theme: {
                        color: "#ff6a00"
                    },
                    modal: {
                        ondismiss: () => {
                            this.isSubmitting = false;
                            window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Payment window closed. Please complete the payment to place order.', type: 'warning' }}));
                        }
                    }
                };
                try {
                    const rzp = new Razorpay(options);
                    rzp.on('payment.failed', function (response){
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Payment Declined: ' + response.error.description, type: 'error' }}));
                    });
                    rzp.open();
                } catch (err) {
                    console.error("Razorpay Open Error:", err);
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Failed to open payment gateway. Please try again.', type: 'error' }}));
                    this.isSubmitting = false;
                }
            },

            async verifyOnlinePayment(razorpayResponse, orderId) {
                try {
                    const res = await fetch('/checkout/verify-payment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            ...razorpayResponse,
                            orderId: orderId
                        })
                    });
                    const data = await res.json();
                    if(data.success) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Payment verified! Order completed.', type: 'success' }}));
                        setTimeout(() => window.location.href = '/checkout/success/' + orderId, 1000);
                    } else {
                        throw new Error(data.message || 'Payment verification failed.');
                    }
                } catch(error) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: error.message, type: 'error' }}));
                    this.isSubmitting = false;
                }
            }
        }
    }
</script>


<style>
    /* Premium aesthetics requirements */
    [x-cloak] { display: none !important; }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #ff6a00; /* accent */
    }
</style>