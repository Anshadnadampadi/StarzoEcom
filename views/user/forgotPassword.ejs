<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Starzo - Recover Access</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: #f4f6f9;
    font-family: 'Segoe UI', sans-serif;
}

/* Center wrapper */
.page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}

/* Logo */
.brand-logo {
    width: 45px;
    height: 45px;
    background: #111827;
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 10px;
}

.brand-logo span {
    color: white;
    font-weight: bold;
    font-size: 20px;
}

.brand-name {
    font-size: 12px;
    letter-spacing: 3px;
    color: #6c757d;
    margin-bottom: 30px;
}

/* Card */
.recover-card {
    width: 100%;
    max-width: 400px;
    padding: 35px;
    border-radius: 15px;
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.recover-card h4 {
    font-weight: 600;
}

.recover-card p {
    font-size: 14px;
    color: #6c757d;
}

/* Button */
.btn-primary {
    padding: 10px;
    font-weight: 500;
    border-radius: 8px;
}

/* Footer small text */
.footer-info {
    margin-top: 30px;
    font-size: 12px;
    color: #6c757d;
    text-align: center;
}
</style>
</head>

<body>

<div class="page-wrapper">

    <!-- Logo -->
    <div class="brand-logo">
        <span>📱</span>
    </div>
    <div class="brand-name">STARZO</div>

    <!-- Card -->
    <div class="recover-card text-center">

        <h4 class="mb-2">Recover Access</h4>
        <p class="mb-4">
            Enter the email associated with your account to receive a secure recovery code.
        </p>

        <form id="recoverForm" action="/auth/forgot" method="post">

            <div class="mb-3 text-start">
                <label class="form-label small">EMAIL ADDRESS</label>
                <input type="email" name="email" class="form-control" id="email" placeholder="name@example.com">
                <div id="emailError" class="text-danger small mt-1"></div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                 Send OTP → 
            </button>

        </form>

        <div class="mt-3">
            <a href="/auth/login">Back to Login</a>
        </div>

    </div>

    <!-- Footer -->
    <div class="footer-info">
        <div class="mb-1">
            🔒 VERIFIED ENCRYPTION &nbsp;&nbsp; • &nbsp;&nbsp; 24/7 PRIORITY SUPPORT
        </div>
        <div>
            Starzo SMARTPHONE SERIES © 2026. ALL RIGHTS RESERVED.
        </div>
    </div>

</div>

<script>

// Email validation
document.getElementById("recoverForm").addEventListener("submit", function(e){
        const email = document.getElementById("email").value.trim(); // name attribute now ensures backend receives email

        const emailError = document.getElementById("emailError");

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!emailRegex.test(email)) {
            e.preventDefault();
            emailError.textContent = "Please enter a valid email address.";
            return;
        }

        // allow the form to submit normally; server will take over
    });
</script>

</body>
</html>