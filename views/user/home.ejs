<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    :root {
        --apple-easing: cubic-bezier(0.4, 0, 0.2, 1);
    }
    .apple-hero {
        height: 100vh;
        width: 100%;
        position: relative;
        overflow: hidden;
        background: #000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        text-align: center;
        padding-top: 12vh;
    }
    .apple-text-gradient {
        background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.7) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .apple-link {
        font-size: 21px;
        font-weight: 400;
        letter-spacing: 0.011em;
        color: #ff6a00;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.3s var(--apple-easing);
    }
    .apple-link:hover {
        text-decoration: underline;
    }
    .apple-btn {
        background: #ff6a00;
        color: #000;
        padding: 14px 32px;
        border-radius: 980px;
        font-size: 17px;
        font-weight: 600;
        transition: all 0.3s var(--apple-easing);
    }
    .apple-btn:hover {
        background: #fff;
        transform: scale(1.02);
    }
    .apple-grid-card {
        background: #161617;
        border-radius: 28px;
        overflow: hidden;
        position: relative;
        height: 580px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-top: 50px;
        transition: transform 0.5s var(--apple-easing);
    }
    .apple-grid-card:hover {
        transform: scale(1.01);
    }
    .video-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        opacity: 0.8;
    }
    .apple-section-divider {
        height: 12px;
        background: #000;
    }
</style>

<div class="bg-black">
    <!-- 1. iPhone 17 Pro Hero (Apple Style) -->
    <section class="apple-hero group">
        <video autoplay muted loop playsinline class="video-bg opacity-60">
            <source src="/video/Introducing iPhone 17 Pro and iPhone 17 Pro Max - Vodafone Australia (1080p).mp4" type="video/mp4">
        </video>
        <div class="relative z-10 space-y-4">
            <h1 class="text-5xl md:text-7xl font-bold apple-text-gradient tracking-tight">iPhone 17 Pro</h1>
            <p class="text-2xl md:text-3xl text-white font-medium">Hello, Apple Intelligence.</p>
            <div class="flex items-center justify-center gap-8 pt-6">
                <a href="/products" class="apple-btn">Buy</a>
                <a href="/catalog" class="apple-link">Learn more <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="3"></path></svg></a>
            </div>
        </div>
    </section>

    <div class="apple-section-divider"></div>

    <!-- 2. Pixel 10 Pro Hero -->
    <section class="apple-hero group !justify-end !pb-[12vh] !pt-0">
        <video autoplay muted loop playsinline class="video-bg opacity-50">
            <source src="/video/YouTube_Meet-Google-Pixel-10-Pro-With-Gemini-The_Media_Z3lqOEM6Zig_001_1080p.mp4" type="video/mp4">
        </video>
        <div class="relative z-10 space-y-4">
            <h2 class="text-5xl md:text-7xl font-bold text-white tracking-tight">Pixel 10 Pro</h2>
            <p class="text-2xl md:text-3xl text-white font-medium">Built for the Gemini era.</p>
            <div class="flex items-center justify-center gap-8 pt-6">
                <a href="/products" class="apple-btn">Pre-order</a>
                <a href="/catalog" class="apple-link">Learn more <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="3"></path></svg></a>
            </div>
        </div>
    </section>

    <div class="apple-section-divider"></div>

    <!-- 3. Apple Style Bento Grid (2x2) -->
    <section class="max-w-[1260px] mx-auto px-4 py-3">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <!-- Watch / Accessories -->
            <div class="apple-grid-card">
                <div class="relative z-10 space-y-2">
                    <h3 class="text-4xl font-bold text-white">Apple Watch</h3>
                    <p class="text-xl text-white/80">Thinner. Faster. Smarter.</p>
                    <div class="flex items-center justify-center gap-6 pt-2">
                        <a href="/catalog?category=watch" class="apple-link !text-lg">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                        <a href="/catalog?category=watch" class="apple-link !text-lg">Buy <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                    </div>
                </div>
                <img src="https://images.unsplash.com/photo-1544117518-30dd5bd7a974?q=80&w=1000&auto=format&fit=crop" class="absolute bottom-0 w-[80%] h-auto object-contain opacity-60 group-hover:scale-105 transition-transform duration-700" alt="">
            </div>

            <!-- Gaming -->
            <div class="apple-grid-card">
                <div class="relative z-10 space-y-2">
                    <h3 class="text-4xl font-bold text-white">Gaming</h3>
                    <p class="text-xl text-white/80">Console-grade performance.</p>
                    <div class="flex items-center justify-center gap-6 pt-2">
                        <a href="/catalog?category=gaming" class="apple-link !text-lg">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                        <a href="/catalog?category=gaming" class="apple-link !text-lg">Buy <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                    </div>
                </div>
                <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1000&auto=format&fit=crop" class="absolute bottom-0 w-full h-full object-cover opacity-20" alt="">
            </div>

            <!-- iPad -->
            <div class="apple-grid-card !bg-white">
                <div class="relative z-10 space-y-2">
                    <h3 class="text-4xl font-bold text-black">iPad Pro</h3>
                    <p class="text-xl text-black/60">Thinpossible.</p>
                    <div class="flex items-center justify-center gap-6 pt-2">
                        <a href="/catalog?category=tablets" class="apple-link !text-lg">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                        <a href="/catalog?category=tablets" class="apple-link !text-lg">Buy <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                    </div>
                </div>
                <img src="https://images.unsplash.com/photo-1544244015-0df4b3ffc6b0?q=80&w=1000&auto=format&fit=crop" class="absolute bottom-0 w-[70%] h-auto object-contain" alt="">
            </div>

            <!-- AirPods -->
            <div class="apple-grid-card">
                <div class="relative z-10 space-y-2">
                    <h3 class="text-4xl font-bold text-white">AirPods Pro</h3>
                    <p class="text-xl text-white/80">Rebuilt from the sound up.</p>
                    <div class="flex items-center justify-center gap-6 pt-2">
                        <a href="/catalog?category=audio" class="apple-link !text-lg">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                        <a href="/catalog?category=audio" class="apple-link !text-lg">Buy <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2.5"></path></svg></a>
                    </div>
                </div>
                <img src="https://images.unsplash.com/photo-1588423770186-80f3ef0abc39?q=80&w=1000&auto=format&fit=crop" class="absolute bottom-0 w-[60%] h-auto object-contain opacity-80" alt="">
            </div>
        </div>
    </section>

    <!-- 4. Carousel for Trending (Apple Style) -->
    <section class="py-24 overflow-hidden">
        <div class="max-w-[1260px] mx-auto px-4 mb-12">
            <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Trending Now.</h2>
        </div>
        
        <div class="swiper trendingSwiper !px-[max(24px,calc((100%-1260px)/2))]">
            <div class="swiper-wrapper">
                <% if (typeof featuredProducts !== 'undefined') { %>
                    <% featuredProducts.forEach(product => { %>
                        <div class="swiper-slide !w-[420px]">
                            <div class="relative h-[520px] rounded-[28px] overflow-hidden bg-[#161617] group">
                                <img src="/uploads/<%= product.images[0] %>" class="absolute inset-0 w-full h-full object-contain p-12 group-hover:scale-105 transition-transform duration-700" alt="">
                                <div class="absolute bottom-0 left-0 right-0 p-10 bg-gradient-to-t from-black via-black/40 to-transparent">
                                    <p class="text-white font-bold text-2xl mb-1"><%= product.name %></p>
                                    <p class="text-white/60 text-base mb-6">From ₹<%= product.salePrice.toLocaleString() %></p>
                                    <a href="/product/<%= product._id %>" class="apple-btn !py-2.5 !text-[14px]">View Details</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </section>

</div>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        new Swiper('.trendingSwiper', {
            slidesPerView: 'auto',
            spaceBetween: 24,
            grabCursor: true,
            freeMode: true,
            mousewheel: {
                forceToAxis: true,
            },
        });
    });
</script>