<!-- views/user/home.ejs -->
<%- contentFor('body') %>

    <!-- 1. Hero Banner -->
    <section class="h-screen w-full bg-black relative group overflow-hidden">
        <!-- Placeholder for large product image (Insta360 style) -->
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1616348436168-de43ad0db179?q=80&w=2000&auto=format&fit=crop"
                class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-[2000ms] ease-out"
                alt="Featured Phone">
        </div>

        <!-- Content -->
        <div class="absolute inset-0 z-10 flex flex-col justify-center px-6 lg:px-24">
            <div class="max-w-3xl fade-up">
                <span class="text-accent text-label font-bold mb-6 block">THE NEW STANDARD</span>
                <h1 class="text-white text-display lg:text-hero font-bold leading-tight mb-8 font-display">
                    MOBI 15 <br> <span class="text-text-secondary">ULTRA PRO.</span>
                </h1>
                <p class="text-text-secondary text-lg lg:text-xl font-medium mb-10 max-w-lg leading-relaxed">
                    Experience the world's most powerful imaging system on a mobile device. Engineered for those who
                    demand perfection.
                </p>

                <div class="flex flex-wrap gap-4">
                    <a href="/phones"
                        class="bg-accent text-black font-bold px-10 py-5 text-xs tracking-[0.2em] uppercase hover:bg-white transition-all btn-press">
                        ORDER NOW
                    </a>
                    <a href="/phones/flagship"
                        class="border border-white/20 text-white font-bold px-10 py-5 text-xs tracking-[0.2em] uppercase hover:bg-white/5 transition-all">
                        LEARN MORE
                    </a>
                </div>
            </div>
        </div>

        <!-- Banner Navigation / Progress (Simulated) -->
        <div class="absolute bottom-12 left-6 lg:left-24 right-6 lg:right-24 z-20 flex items-center justify-between">
            <div class="flex gap-2">
                <div class="w-12 h-1 bg-accent"></div>
                <div class="w-12 h-1 bg-white/20"></div>
                <div class="w-12 h-1 bg-white/20"></div>
            </div>
            <div class="text-white/20 font-mono text-xs tracking-widest uppercase">01 / 03</div>
        </div>
    </section>

    <!-- 2. Brand Marquee -->
    <section class="py-12 bg-black-surface border-y border-black-border overflow-hidden">
        <div
            class="flex items-center gap-16 animate-marquee whitespace-nowrap opacity-30 hover:opacity-100 transition-opacity">
            <% ['APPLE', 'SAMSUNG' , 'GOOGLE' , 'ONEPLUS' , 'XIAOMI' , 'VIVO' , 'OPPO' , 'REALME' , 'ASUS' , 'NOTHING'
                ].forEach(brand=> { %>
                <span
                    class="text-white text-xl font-black tracking-tighter uppercase grayscale hover:grayscale-0 transition-all cursor-default">
                    <%= brand %>
                </span>
                <% }) %>
                    <!-- Duplicate for loop -->
                    <% ['APPLE', 'SAMSUNG' , 'GOOGLE' , 'ONEPLUS' , 'XIAOMI' , 'VIVO' , 'OPPO' , 'REALME' , 'ASUS'
                        , 'NOTHING' ].forEach(brand=> { %>
                        <span
                            class="text-white text-xl font-black tracking-tighter uppercase grayscale hover:grayscale-0 transition-all cursor-default">
                            <%= brand %>
                        </span>
                        <% }) %>
        </div>
    </section>

    <!-- 3. Flash Sale -->
    <section class="py-24 bg-black">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
                <div class="fade-up">
                    <span class="text-accent text-[10px] font-bold tracking-[0.3em] uppercase mb-4 block">Limited
                        Time</span>
                    <h2 class="text-white text-3xl lg:text-4xl font-bold tracking-tight uppercase">FLASH SALE.</h2>
                </div>

                <div class="flex gap-4 items-center mb-1">
                    <p class="text-white/30 text-[10px] font-bold tracking-widest uppercase">Ends In:</p>
                    <div class="flex gap-2 font-mono text-xl font-bold text-white">
                        <span class="bg-black-card border border-white/5 px-2 py-1">04</span>
                        <span class="text-accent">:</span>
                        <span class="bg-black-card border border-white/5 px-2 py-1">22</span>
                        <span class="text-accent">:</span>
                        <span class="bg-black-card border border-white/5 px-2 py-1">59</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-black-border border border-black-border">
                <% if (typeof newArrivals !=='undefined' ) { %>
                    <% newArrivals.forEach(product=> { %>
                        <%- include('../partials/product-card', { product }) %>
                            <% }) %>
                                <% } else { %>
                                    <!-- Dummy cards if no data -->
                                    <div
                                        class="p-12 text-white/20 text-xs uppercase tracking-widest text-center bg-black">
                                        No Active Flash Sales</div>
                                    <% } %>
            </div>
        </div>
    </section>

    <!-- 4. Categories Grid -->
    <section class="py-24 bg-black-surface">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="text-accent text-[10px] font-bold tracking-[0.3em] uppercase mb-4 block">Browse
                    Collection</span>
                <h2 class="text-white text-3xl font-bold tracking-tight uppercase">SHOP BY TECH.</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% const cats=[ { name: 'Flagship Systems' ,
                    img: 'https://images.unsplash.com/photo-1592890288564-76628a30a657?q=80&w=1000&auto=format&fit=crop'
                    , link: '/phones/category/flagship' }, { name: 'Imaging Pro' ,
                    img: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=1000&auto=format&fit=crop'
                    , link: '/phones/category/pro-camera' }, { name: 'Gaming Rig' ,
                    img: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1000&auto=format&fit=crop' ,
                    link: '/phones/category/gaming' } ] %>
                    <% cats.forEach(cat=> { %>
                        <a href="<%= cat.link %>"
                            class="group relative aspect-[4/5] bg-black overflow-hidden ring-1 ring-white/10 hover:ring-accent transition-all">
                            <img src="<%= cat.img %>" alt="<%= cat.name %>"
                                class="w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-700">
                            <div
                                class="absolute inset-0 flex flex-col justify-end p-8 bg-gradient-to-t from-black/80 to-transparent">
                                <h3 class="text-white text-2xl font-bold mb-2">
                                    <%= cat.name %>
                                </h3>
                                <span
                                    class="text-accent text-[10px] font-bold tracking-widest uppercase flex items-center gap-2">
                                    Explore <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                    </svg>
                                </span>
                            </div>
                        </a>
                        <% }) %>
            </div>
        </div>
    </section>

    <!-- 5. Featured Section -->
    <section class="py-24 bg-black">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
            <div class="flex justify-between items-end mb-12">
                <h2 class="text-white text-3xl font-bold tracking-tight uppercase">TRENDING PHONES.</h2>
                <a href="/phones"
                    class="text-accent text-[11px] font-bold tracking-widest uppercase hover:underline">View All</a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px bg-white/5 border border-white/5">
                <% if (typeof featuredProducts !=='undefined' ) { %>
                    <% featuredProducts.forEach(product=> { %>
                        <%- include('../partials/product-card', { product }) %>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-span-full py-20 text-center text-white/20 italic">Loading trending
                                        products...</div>
                                    <% } %>
            </div>
        </div>
    </section>

    <!-- 6. Trust Strip -->
    <section class="py-16 bg-black border-t border-black-border">
        <div class="max-w-screen-xl mx-auto px-6 lg:px-8">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
                <div class="text-center">
                    <div class="text-accent text-2xl mb-4">🚚</div>
                    <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-2">Free Delivery</h4>
                    <p class="text-white/40 text-[10px] uppercase tracking-wide">On orders above ₹15,000</p>
                </div>
                <div class="text-center">
                    <div class="text-accent text-2xl mb-4">🛡️</div>
                    <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-2">Genuine Stock</h4>
                    <p class="text-white/40 text-[10px] uppercase tracking-wide">100% authentic products</p>
                </div>
                <div class="text-center">
                    <div class="text-accent text-2xl mb-4">🔄</div>
                    <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-2">Easy Returns</h4>
                    <p class="text-white/40 text-[10px] uppercase tracking-wide">7-day replacement policy</p>
                </div>
                <div class="text-center">
                    <div class="text-accent text-2xl mb-4">💬</div>
                    <h4 class="text-white text-xs font-bold tracking-widest uppercase mb-2">24/7 Support</h4>
                    <p class="text-white/40 text-[10px] uppercase tracking-wide">Expert tech assistance</p>
                </div>
            </div>
        </div>
    </section>