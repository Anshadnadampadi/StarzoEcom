<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
  .logo-box {
    width: 35px;
    height: 35px;
    background: #111827;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    font-weight: 700;
  }

  .top-links .nav-link {
    font-weight: 500;
  }

  .search-box {
    position: relative;
    width: min(460px, 100%);
  }

  .search-box input {
    padding-left: 40px;
    border-radius: 999px;
  }

  .search-box i {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
    pointer-events: none;
  }

  .profile-btn {
    background: #0d6efd;
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 6px 14px;
  }

  .profile-btn:hover {
    background: #0b5ed7;
  }

  @media (max-width: 991.98px) {
    .top-links {
      gap: 0.25rem; 
    }

    .search-box {
      width: 100%;
      margin: 0.5rem 0;
    }

    .top-auth-actions {
      width: 100%;
      justify-content: flex-start;
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 575.98px) {
    .main-top-nav {
      padding-left: 0.75rem !important;
      padding-right: 0.75rem !important;
    }
  }
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm px-4 main-top-nav">
  <div class="container-fluid p-0">
    <a class="navbar-brand d-flex align-items-center" href="/">
      <div class="logo-box">S</div>
      <span class="ms-2 fw-bold">Starzo</span>
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarAfter" aria-controls="navbarAfter" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse align-items-lg-center" id="navbarAfter">
      <ul class="navbar-nav top-links">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="#categories">Categories</a></li>
        <li class="nav-item"><a class="nav-link" href="#best-selling">Best Selling</a></li>
        <li class="nav-item"><a class="nav-link" href="#newsletter">Newsletter</a></li>
      </ul>

      <form class="search-box d-flex mx-lg-auto" action="/" method="GET">
        <i class="bi bi-search"></i>
        <input class="form-control" type="text" name="query" placeholder="Search products...">
      </form>

      <% if(user){ %>
        <div class="dropdown ms-lg-3">
          <button class="profile-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-person"></i> Account
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
            <li><a class="dropdown-item" href="/address"><i class="bi bi-geo-alt me-2"></i>My Address</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
          </ul>
        </div>
      <% } else { %>
        <div class="d-flex align-items-center gap-2 top-auth-actions ms-lg-3">
          <a class="btn btn-outline-primary" href="/auth/login">Login</a>
          <a class="btn btn-primary" href="/auth/signup">Signup</a>
        </div>
      <% } %>
    </div>
  </div>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
