<!-- views/user/paymentFailure.ejs -->
<%- contentFor('body') %>

<div class="min-h-[85vh] flex items-center justify-center p-4 bg-black">
    <div class="max-w-lg w-full bg-[#0a0a0a] border border-white/10 rounded-2xl p-8 md:p-12 text-center shadow-2xl relative overflow-hidden">
        
        <!-- Subtle Danger Glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-64 h-32 bg-status-danger/20 blur-[80px] pointer-events-none"></div>

        <!-- Failure Icon -->
        <div class="w-20 h-20 bg-status-danger/10 border border-status-danger/20 rounded-full flex items-center justify-center mx-auto mb-8 relative z-10 shadow-[0_0_20px_rgba(255,59,48,0.2)]">
            <svg class="w-10 h-10 text-status-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </div>

        <h1 class="text-3xl md:text-4xl font-display font-black tracking-tight text-white mb-3 relative z-10">Payment Failed!</h1>
        <p class="text-white/60 mb-8 max-w-sm mx-auto relative z-10 text-sm leading-relaxed">
            Transaction aborted by the gateway. <br>
            Your payment was not processed successfully.
        </p>

        <!-- Order Summary Card -->
        <% if (order) { %>
        <div class="bg-black border border-white/10 rounded-xl p-6 text-left mb-8 relative z-10 shadow-inner">
            <div class="flex justify-between items-center mb-4 pb-4 border-b border-white/5">
                <span class="text-white/40 text-xs font-semibold uppercase tracking-wider">Order ID</span>
                <span class="text-white font-mono font-bold text-sm"><%= order.orderId %></span>
            </div>
            
            <div class="flex justify-between items-center mb-4 pb-4 border-b border-white/5">
                <span class="text-white/40 text-xs font-semibold uppercase tracking-wider">Payment Status</span>
                <span class="text-status-danger font-bold text-xs uppercase tracking-widest">Failed / Pending</span>
            </div>
            
            <div class="flex justify-between items-center">
                <span class="text-white/40 text-xs font-semibold uppercase tracking-wider">Total amount</span>
                <span class="text-status-danger text-2xl font-black tracking-tighter">₹<%= order.totalAmount.toLocaleString() %></span>
            </div>
        </div>
        <% } else { %>
            <div class="bg-black border border-white/10 rounded-xl p-6 text-left mb-8 relative z-10 shadow-inner">
                <div class="flex justify-between items-center">
                    <span class="text-white/40 text-xs font-semibold uppercase tracking-wider">Reference ID</span>
                    <span class="text-white font-mono font-bold text-sm"><%= orderId %></span>
                </div>
            </div>
        <% } %>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-10" x-data="failureHandler()">
            <% if (order) { %>
                <button @click="retryPayment('<%= order.orderId %>')" 
                    class="w-full sm:w-auto px-6 py-4 bg-status-danger text-white font-black uppercase text-xs tracking-widest hover:bg-white hover:text-black rounded-lg transition-all shadow-[0_0_15px_rgba(255,59,48,0.3)] disabled:opacity-50"
                    :disabled="isProcessing">
                    <span x-show="!isProcessing">Retry Payment</span>
                    <span x-show="isProcessing">Processing...</span>
                </button>
                <button @click="returnToCart('<%= order.orderId %>')"
                    class="w-full sm:w-auto px-6 py-4 border border-white/10 bg-white/5 hover:bg-white/10 text-white font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
                    :disabled="isProcessing">
                    Return to Cart
                </button>
            <% } else { %>
                <a href="/cart" class="w-full sm:w-auto px-6 py-4 bg-status-danger text-white font-black uppercase text-xs tracking-widest hover:bg-white hover:text-black rounded-lg transition-all">
                    Back to Cart
                </a>
            <% } %>
            <a href="/account/orders" class="w-full sm:w-auto px-6 py-4 border border-white/10 bg-white/5 hover:bg-white/10 text-white font-bold uppercase text-xs tracking-widest rounded-lg transition-all">
                My Orders
            </a>
        </div>
        
        <p class="mt-10 text-white/20 text-[8px] font-black uppercase tracking-[0.4em] relative z-10">
            Secure encryption active. Your data is safe.
        </p>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    function failureHandler() {
        return {
            isProcessing: false,
            async retryPayment(orderId) {
                this.isProcessing = true;
                try {
                    const response = await fetch('/checkout/retry-payment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ orderId })
                    });
                    const data = await response.json();
                    
                    if (data.success) {
                        const options = {
                            key: '<%= process.env.RAZORPAY_KEY_ID %>',
                            amount: data.razorpayOrder.amount,
                            currency: data.razorpayOrder.currency,
                            name: 'Starzo Mobiles',
                            description: 'Order Payment Retry',
                            order_id: data.razorpayOrder.id,
                            handler: async (res) => {
                                // Verify
                                const vRes = await fetch('/checkout/verify-payment', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ ...res, orderId })
                                });
                                const vData = await vRes.json();
                                if (vData.success) {
                                    window.location.href = `/checkout/success/${orderId}`;
                                } else {
                                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: vData.message || 'Verification failed. Please check My Orders.', type: 'error' }}));
                                }
                            },
                            theme: { color: "#ff3b30" }
                        };
                        const rzp = new Razorpay(options);
                        rzp.open();
                    } else {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Retry failed', type: 'error' }}));
                    }
                } catch (err) {
                    console.error(err);
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'An error occurred during retry', type: 'error' }}));
                } finally {
                    this.isProcessing = false;
                }
            },
            async returnToCart(orderId) {
                const confirmed = await confirmAction({
                    title: 'Return to Cart?',
                    message: 'This will cancel the current order attempt and return items to your cart. Continue?',
                    type: 'warning',
                    confirmText: 'Yes, Return',
                    cancelText: 'Stay Here'
                });

                if (!confirmed) return;
                
                this.isProcessing = true;
                try {
                    const response = await fetch('/checkout/revert-failed-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ orderId })
                    });
                    const data = await response.json();
                    if (data.success) {
                        window.location.href = '/cart';
                    } else {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: data.message || 'Failed to return to cart', type: 'error' }}));
                    }
                } catch (err) {
                    console.error(err);
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'An error occurred while returning to cart', type: 'error' }}));
                } finally {
                    this.isProcessing = false;
                }
            }
        }
    }
</script>

