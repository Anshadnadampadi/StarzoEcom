      </div>

      <!-- RIGHT: PURCHASE PANEL -->
      <div class="sticky-purchase fade-up fade-up-d1">
        <!-- Brand + Title -->
        <div class="mb-5">
          <p class="text-[11px] font-bold tracking-[0.14em] uppercase text-t2 mb-2">
            <%= product.brand %>
          </p>
          <h1 class="font-syne text-2xl md:text-3xl font-extrabold leading-tight mb-1.5">
            <%= product.name %>
          </h1>
          <p class="text-[11px] text-t3 font-mono">SKU: <%= product._id %>
          </p>
        </div>

        <!-- Rating row -->
        <div class="flex flex-wrap items-center gap-3 py-3.5 border-y border-border mb-5">
          <div class="flex gap-0.5 text-accent" id="summaryStars">
            <!-- Stars injected here -->
          </div>
          <a href="#" onclick="switchTab(document.querySelector('[onclick*=reviews]'),'reviews')"
            class="text-[13px] text-t2 no-underline" id="summaryRatingText">0.0 (0 reviews)</a>
          <span class="text-border hidden sm:inline">|</span>
          <span id="stockStatusBadge" class="text-[12px] text-success font-semibold">
            <% if ((defaultVariant ? defaultVariant.stock : product.stock)> 0) { %>● IN STOCK<% } else { %><span
                  style="color:var(--danger)">● OUT OF STOCK</span>
                <% } %>
          </span>
        </div>

        <!-- Price -->
        <div class="mb-5 fade-up fade-up-d2">
          <div class="flex items-baseline gap-3 flex-wrap">
            <% 
              let initialPrice = (defaultVariant ? defaultVariant.price : product.price);
              let initialDiscounted = initialPrice;
              if (product.hasOffer && product.bestOffer) {
                  let discount = 0;
                  if (product.bestOffer.discountType === 'percentage') {
                      discount = (initialPrice * product.bestOffer.discountValue) / 100;
                  } else {
                      discount = product.bestOffer.discountValue;
                  }

                  // Apply cap if defined
                  if (product.bestOffer.maxDiscountAmount && discount > product.bestOffer.maxDiscountAmount) {
                      discount = product.bestOffer.maxDiscountAmount;
                  }

                  // Safety net: Max 95% discount
                  const maxSafety = initialPrice * 0.95;
                  discount = Math.min(discount, maxSafety);

                  initialDiscounted = Math.floor(Math.max(1, initialPrice - discount));
              }
            %>
            <span class="font-mono" style="font-size:34px;font-weight:700;color:var(--t1);" id="productPrice">₹<%= initialDiscounted.toLocaleString() %></span>
            <span class="font-mono" id="originalPrice" style="font-size:18px;color:var(--t3);text-decoration:line-through; <%= product.hasOffer ? '' : 'display:none;' %>">₹<%= initialPrice.toLocaleString() %></span>
          </div>
          <p style="font-size:11px;color:var(--t3);margin-top:4px;">Incl. 18% GST · Free delivery</p>
        </div>

        <% 
          // Helper to normalize units (e.g., "128" -> "128 GB", "512 gb" -> "512 GB")
          const normalizeUnit = (s) => {
            if (!s) return "";
            let v = s.toString().trim();
            if (/^\d+$/.test(v)) return v + " GB";
            if (v.toLowerCase().endsWith("gb")) return v.slice(0, -2).trim() + " GB";
            return v;
          };

          // Normalize variants (Keep all, including unlisted, to keep them visible in UI)
          if (product && product.variants) {
            product.variants = product.variants
              .filter(v => v) // only keep non-null
              .map(v => ({
                ...v,
                color: (v.color || "").trim(),
                storage: normalizeUnit(v.storage),
                ram: normalizeUnit(v.ram)
              }));
          }

          // Case-insensitive unique options extraction
          const uniqueColors = [...new Map(product.variants.map(v => [v.color.toLowerCase(), v.color])).values()];
          const uniqueStorages = [...new Map(product.variants.map(v => [v.storage.toLowerCase(), v.storage])).values()];
          const uniqueRams = [...new Map(product.variants.map(v => [v.ram.toLowerCase(), v.ram])).values()];

          // Find default variant based on first color and first storage
           const variant=defaultVariant; const image=(variant && variant.images && variant.images.length> 0)
            ? variant.images[0]
            : '/images/placeholder.jpg';

            function getHexForColor(colorName) {
            const name = colorName.toLowerCase();
            if (name.includes('black')) return '#1a1a1a';
            if (name.includes('white')) return '#fcfcfc';
            if (name.includes('gray') || name.includes('grey')) return '#888888';
            if (name.includes('brown')) return '#6f4f37';
            if (name.includes('blue')) return '#3b82f6';
            if (name.includes('red')) return '#ef4444';
            if (name.includes('green')) return '#22c55e';
            if (name.includes('gold') || name.includes('yellow')) return '#fbbf24';
            if (name.includes('purple') || name.includes('violet')) return '#8b5cf6';
            if (name.includes('pink')) return '#ec4899';
            if (name.includes('silver')) return '#e5e7eb';
            return '#444444';
            }
            %>

            <% if (uniqueColors.length> 0) { %>
              <!-- Color Variant -->
              <div class="mb-5">
                <div class="flex items-center justify-between mb-2.5">
                  <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-t2">Color</span>
                  <span id="selectedColor" class="text-[13px] text-t1 font-semibold capitalize">
                    <%= defaultVariant ? (defaultVariant.color || '').trim() : uniqueColors[0] %>
                  </span>
                </div>
                <div class="flex flex-wrap gap-2.5" id="colorSwatches">
                  <% uniqueColors.forEach((color, i)=> { %>
                    <button
                      class="color-swatch <%= (defaultVariant && color.toLowerCase() === (defaultVariant.color || '').trim().toLowerCase()) ? 'active' : '' %>"
                      style="background:<%= getHexForColor(color) %>; <%= color.toLowerCase().includes('white') ? 'border:1px solid var(--border);' : '' %>"
                      onclick="selectColor(this,'<%= color %>')" title="<%= color %>"></button>
                    <% }) %>
                </div>
              </div>
              <% } %>

                <% if (uniqueStorages.length> 0) { %>
                  <!-- Storage Variant -->
                  <div class="mb-5">
                    <div class="flex items-center justify-between mb-2.5">
                      <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-t2">Storage</span>
                      <span id="selectedStorage" class="text-[13px] text-t1 font-medium">
                        <%= defaultVariant ? (defaultVariant.storage || '').trim() : uniqueStorages[0] %>
                      </span>
                    </div>
                    <div class="flex gap-2 flex-wrap" id="storagePills">
                      <% uniqueStorages.forEach((storage, i)=> { %>
                        <button
                          class="variant-pill <%= (defaultVariant && storage.toLowerCase() === (defaultVariant.storage || '').trim().toLowerCase()) ? 'active' : '' %>"
                          onclick="selectStorage(this,'<%= storage %>')">
                          <%= storage %>
                        </button>
                        <% }) %>
                    </div>
                  </div>
                  <% } %>

                <% if (uniqueRams.length > 0) { %>
                  <!-- RAM Variant -->
                  <div class="mb-5">
                    <div class="flex items-center justify-between mb-2.5">
                      <span class="text-[12px] font-semibold uppercase tracking-[0.08em] text-t2">RAM</span>
                      <span id="selectedRam" class="text-[13px] text-t1 font-medium">
                        <%= defaultVariant ? (defaultVariant.ram || '').trim() : uniqueRams[0] %>
                      </span>
                    </div>
                    <div class="flex gap-2 flex-wrap" id="ramPills">
                      <% uniqueRams.forEach((ram, i) => { %>
                        <button
                          class="variant-pill <%= (defaultVariant && ram.toLowerCase() === (defaultVariant.ram || '').trim().toLowerCase()) ? 'active' : '' %>"
                          onclick="selectRam(this,'<%= ram %>')">
                          <%= ram %>
                        </button>
                      <% }) %>
                    </div>
                  </div>
                <% } %>

                    <!-- Qty + CTA -->
                    <div class="mb-5">
                      <div class="text-[12px] font-semibold uppercase tracking-[0.08em] text-t2 mb-2.5">Quantity</div>
                      <div class="flex items-center gap-0 w-fit mb-4">
                        <button class="qty-btn" onclick="adjustQty(-1)">−</button>
                        <div class="qty-display" id="qtyDisplay">1</div>
                        <button class="qty-btn" onclick="adjustQty(1)">+</button>
                      </div>
                      <!-- Stock warning -->
                      <div id="stockWarningContainer"
                        class="items-center gap-2 px-3.5 py-2.5 mb-4 border"
                        style="display: <%= (defaultVariant ? defaultVariant.stock : product.stock) > 0 ? 'flex' : 'none' %>; background:<%= (defaultVariant ? defaultVariant.stock : product.stock) <= 5 ? 'rgba(239, 68, 68, 0.06)' : 'rgba(34, 197, 94, 0.06)' %>; border-color: <%= (defaultVariant ? defaultVariant.stock : product.stock) <= 5 ? 'rgba(239, 68, 68, 0.2)' : 'rgba(34, 197, 94, 0.2)' %>;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="<%= (defaultVariant ? defaultVariant.stock : product.stock) <= 5 ? 'var(--danger)' : 'var(--success)' %>" stroke-width="2">
                          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                          <line x1="12" y1="9" x2="12" y2="13" />
                          <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>
                        <span id="stockWarningText" class="text-[12px] font-medium" style="color:<%= (defaultVariant ? defaultVariant.stock : product.stock) <= 5 ? 'var(--danger)' : 'var(--success)' %>;">
                           <% const initialStock = (defaultVariant ? defaultVariant.stock : product.stock); %>
                           <%= initialStock <= 5 ? `Hurry! Only ${initialStock} left in stock — order soon` : `${initialStock} units currently available` %>
                        </span>
                      </div>
                      <button class="btn-primary w-full mb-2.5" onclick="addToCart()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                          <line x1="3" y1="6" x2="21" y2="6" />
                          <path d="M16 10a4 4 0 0 1-8 0" />
                        </svg>
                        Add to Cart
                      </button>
                      
                      <% if (product.bestOffer) { %>
                        <div class="my-5 p-4 bg-success/5 border border-dashed border-success/30">
                          <div class="flex items-center gap-2 mb-2">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2">
                              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
                              <line x1="7" y1="7" x2="7.01" y2="7" />
                            </svg>
                            <span class="text-[11px] font-extrabold uppercase tracking-widest text-success">Active Offer Applied</span>
                          </div>
                          <p class="text-[13px] font-bold text-t1 mb-1"><%= product.bestOffer.name %></p>
                          <p class="text-[11px] text-t2"><%= product.bestOffer.discountType === 'percentage' ? product.bestOffer.discountValue + '%' : '₹' + product.bestOffer.discountValue.toLocaleString() %> discount automatically applied at checkout.</p>
                        </div>
                      <% } %>

                      <button class="btn-secondary w-full">Buy Now</button>
                    </div>

                    <!-- Action row -->
                    <div class="flex gap-2 mb-6">
                      <button class="btn-icon <%= isWishlisted ? 'active' : '' %> flex-1 gap-1.5 w-auto text-[12px] text-t2" id="wishlistBtn" onclick="toggleWishlist('<%= product._id %>')">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="<%= isWishlisted ? 'currentColor' : 'none' %>" stroke="currentColor"
                          stroke-width="1.8">
                          <path
                            d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                        </svg>
                        Wishlist
                      </button>
                      <button class="btn-icon flex-1 gap-1.5 w-auto text-[12px] text-t2">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="1.8">
                          <circle cx="18" cy="5" r="3" />
                          <circle cx="6" cy="12" r="3" />
                          <circle cx="18" cy="19" r="3" />
                          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
                          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
                        </svg>
                        Share
                      </button>
                    </div>

                    <!-- Offers -->
                    <div style="border:1px solid var(--border);background:var(--card);">
                      <div style="padding:14px 16px;border-bottom:1px solid var(--border);">
                        <span class="font-syne"
                          style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;">Available
                          Offers</span>
                      </div>
                      <div style="padding:0 16px;">
                        <div class="offer-item">
                          <div class="offer-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2">
                              <rect x="2" y="5" width="20" height="14" rx="2" />
                              <line x1="2" y1="10" x2="22" y2="10" />
                            </svg></div>
                          <div>
                            <div style="font-size:13px;font-weight:500;margin-bottom:2px;">Bank Offer</div>
                            <div style="font-size:12px;color:var(--t2);">₹7,000 instant discount on HDFC Bank cards
                            </div>
                          </div>
                        </div>
                        <div class="offer-item">
                          <div class="offer-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2">
