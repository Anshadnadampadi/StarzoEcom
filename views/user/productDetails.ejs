    // ── REVIEWS SYSTEM ────────────────────────────────────────────────────────
    let currentRating = 0;

    let reviewListenersAttached = false;
    function initReviewSystem() {
        if (reviewListenersAttached) return;
        
        document.querySelectorAll('.star-input').forEach(star => {
            star.addEventListener('click', function() {
                currentRating = this.dataset.value;
                const rVal = document.getElementById('ratingValue');
                if (rVal) rVal.value = currentRating;
                updateStarInputUI(currentRating);
            });
            
            star.addEventListener('mouseover', function() {
                updateStarInputUI(this.dataset.value);
            });
            
            star.addEventListener('mouseout', function() {
                updateStarInputUI(currentRating);
            });
        });
        reviewListenersAttached = true;
    }

    function updateStarInputUI(val) {
        document.querySelectorAll('.star-input').forEach(s => {
            s.style.color = s.dataset.value <= val ? 'var(--accent)' : 'var(--t3)';
        });
    }

    window.openReviewModal = function() {
        const modal = document.getElementById('reviewModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            
            // Pre-fill if current user has a review
            const currentUserId = '<%= locals.user ? locals.user._id : "" %>';
            const form = document.getElementById('reviewForm');
            
            // We can search the loaded reviews list in the DOM or use the window.allReviews if we had it
            // For now, let's just make sure the UI is initialized
            initReviewSystem();

            // Optional: If we want to be fancy, we could have stored the data in a global variable
            if (window.currentUserReview) {
                currentRating = window.currentUserReview.rating;
                document.getElementById('ratingValue').value = currentRating;
                updateStarInputUI(currentRating);
                form.querySelector('textarea').value = window.currentUserReview.comment;
            }
        }
    }

    window.closeReviewModal = function() {
        const modal = document.getElementById('reviewModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }
    }

    window.handleReviewSubmit = async function(e) {
        if (e) e.preventDefault();
        console.log('[REVIEW_JS] handleReviewSubmit triggered');
        const form = document.getElementById('reviewForm');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        let hasError = false;

        // Reset errors
        document.getElementById('ratingError').classList.add('hidden');
        document.getElementById('commentError').classList.add('hidden');
        form.querySelector('textarea').style.borderColor = 'var(--border)';

        if (!data.rating) {
            document.getElementById('ratingError').classList.remove('hidden');
            hasError = true;
        }

        if (!data.comment || data.comment.trim().length < 10) {
            document.getElementById('commentError').classList.remove('hidden');
            form.querySelector('textarea').style.borderColor = 'var(--danger)';
            hasError = true;
        }

        if (hasError) return;

        const btn = document.getElementById('submitReviewBtn');
        const originalText = btn.innerHTML;
        btn.innerHTML = 'Publishing...';
        btn.disabled = true;

        try {
            const response = await fetch(`/products/${data.productId}/review`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (result.success) {
                dispatchGlobalToast('success', 'Review Published', result.message);
                closeReviewModal();
                loadReviews();
                form.reset();
                currentRating = 0;
                updateStarInputUI(0);
            } else {
                dispatchGlobalToast('error', 'Submission Failed', result.message);
            }
        } catch (err) {
            dispatchGlobalToast('error', 'Error', 'Something went wrong. Please try again.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    window.loadReviews = async function() {
        const productId = '<%= product._id %>';
        const reviewsList = document.getElementById('reviewsList');
        if (!reviewsList) return;
        
        try {
            // Add cache-buster to ensure we get fresh data
            const response = await fetch(`/products/${productId}/reviews?t=${Date.now()}`);
            const data = await response.json();

            if (data.success) {
                updateReviewStats(data.stats);
                
                if (data.reviews.length === 0) {
                    reviewsList.innerHTML = '<div class="text-center py-10 text-zinc-600">No reviews yet. Be the first to review!</div>';
                    return;
                }

                const currentUserId = '<%= locals.user ? locals.user._id : "" %>';
                window.currentUserReview = data.reviews.find(r => r.userId && r.userId._id === currentUserId);

                reviewsList.innerHTML = data.reviews.map(r => {
                    const isOwnReview = r.userId && r.userId._id === currentUserId;
                    const userName = r.userId ? `${r.userId.firstName} ${r.userId.lastName || ''}` : 'Anonymous User';
                    const userInitial = r.userId && r.userId.firstName ? r.userId.firstName[0] : 'U';
                    const userImage = r.userId && r.userId.profileImage ? r.userId.profileImage : null;

                    return `
                        <div class="review-card ${isOwnReview ? 'border-accent/30 bg-accent/5' : ''}" 
                             style="background:var(--card); padding:24px; border-radius:16px; margin-bottom:16px; border:1px solid ${isOwnReview ? 'var(--accent)' : 'var(--border)'};">
                            <div style="display:flex;justify-content:space-between;margin-bottom:12px;">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <div style="width:40px;height:40px;border-radius:50%;background:var(--elevated);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--accent); overflow:hidden; border:1px solid var(--border);">
                                        ${userImage ? `<img src="${userImage}" class="w-full h-full object-cover">` : userInitial}
                                    </div>
                                    <div>
                                        <div style="font-size:14px;font-weight:700; color:var(--t1);">${userName} ${isOwnReview ? '<span style="font-size:10px; color:var(--accent); margin-left:6px; background:rgba(255,106,0,0.1); padding:2px 6px; border-radius:4px;">YOU</span>' : ''}</div>
                                        <div style="font-size:11px;color:var(--t3);">${r.isVerifiedPurchase ? '<span style="color:var(--success)">● Verified Purchase</span>' : 'Community Member'} · ${new Date(r.createdAt).toLocaleDateString()}</div>
                                    </div>
                                </div>
                                <div style="display:flex;gap:2px; color:var(--accent); font-size:12px;">
                                    ${'★'.repeat(r.rating)}${'★'.repeat(5 - r.rating).split('').map(() => `<span style="opacity:0.1">★</span>`).join('')}
                                </div>
                            </div>
                            <p style="font-size:14px;color:var(--t2);line-height:1.8; font-weight:400;">${r.comment}</p>
                        </div>
                    `;
                }).join('');
            }
        } catch (err) {
            console.error("Load Reviews Error:", err);
            reviewsList.innerHTML = '<div class="text-center py-10 text-status-danger">Failed to load reviews.</div>';
        }
    }

    function updateReviewStats(stats) {
        const avg = stats.average ? stats.average.toFixed(1) : "0.0";
        const count = stats.count || 0;

        if (document.getElementById('avgRatingValue')) document.getElementById('avgRatingValue').textContent = avg;
        if (document.getElementById('totalReviewCount')) document.getElementById('totalReviewCount').textContent = `${count} reviews`;
        if (document.getElementById('summaryRatingText')) document.getElementById('summaryRatingText').textContent = `${avg} (${count} reviews)`;
        if (document.getElementById('reviewTabBtn')) document.getElementById('reviewTabBtn').textContent = `Reviews (${count})`;
        
        const fullStars = Math.floor(stats.average || 0);
        const starsHtml = '★'.repeat(fullStars) + '<span style="opacity:0.1">★</span>'.repeat(5 - fullStars);
        
        if (document.getElementById('avgRatingStars')) document.getElementById('avgRatingStars').innerHTML = starsHtml;
        if (document.getElementById('summaryStars')) document.getElementById('summaryStars').innerHTML = starsHtml;
    }

    // Load initial review stats
    document.addEventListener('DOMContentLoaded', loadReviews);

    // Override switchTab to load reviews
    const baseSwitchTab = switchTab;
    window.switchTab = function(btn, tabId) {
        baseSwitchTab(btn, tabId);
        if (tabId === 'reviews') {
            loadReviews();
        }
    };
  </script>

  <!-- Review Modal HTML -->
  <div id="reviewModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.85); backdrop-blur:sm; align-items:center; justify-content:center; padding:20px;">
    <div style="background:#111; border:1px solid var(--border); border-radius:24px; width:100%; max-width:500px; padding:40px; position:relative; box-shadow:0 25px 50px -12px rgba(0,0,0,0.5);">
        <button onclick="closeReviewModal()" style="position:absolute; top:24px; right:24px; background:none; border:none; color:var(--t3); cursor:pointer; font-size:24px;">×</button>
        
        <div style="margin-bottom:32px;">
            <h3 class="font-syne" style="font-size:22px; font-weight:800; text-transform:uppercase; letter-spacing:0.05em; color:var(--t1);">Write a Review</h3>
            <p style="font-size:13px; color:var(--t3); margin-top:8px;">Share your thoughts with the community.</p>
        </div>
        
        <form id="reviewForm" onsubmit="handleReviewSubmit(event); return false;" novalidate>
            <input type="hidden" name="productId" value="<%= product._id %>">
            
            <div style="margin-bottom:28px;">
                <label style="display:block; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:var(--accent); margin-bottom:12px;">Rating</label>
                <div id="starInput" style="display:flex; gap:10px; font-size:28px; color:var(--t3);">
                    <span class="star-input" style="cursor:pointer; transition:color 0.2s;" data-value="1">★</span>
                    <span class="star-input" style="cursor:pointer; transition:color 0.2s;" data-value="2">★</span>
                    <span class="star-input" style="cursor:pointer; transition:color 0.2s;" data-value="3">★</span>
                    <span class="star-input" style="cursor:pointer; transition:color 0.2s;" data-value="4">★</span>
                    <span class="star-input" style="cursor:pointer; transition:color 0.2s;" data-value="5">★</span>
                </div>
                <input type="hidden" name="rating" id="ratingValue">
                <div id="ratingError" class="text-status-danger text-[11px] mt-2 hidden">Please select a star rating.</div>
            </div>

            <div style="margin-bottom:32px;">
                <label style="display:block; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:var(--accent); margin-bottom:12px;">Comment</label>
                <textarea name="comment" placeholder="What's your experience with this phone? (Min 10 characters)" 
                          style="width:100%; height:140px; background:#000; border:1px solid var(--border); border-radius:16px; padding:20px; color:var(--t1); font-size:15px; outline:none; transition:all 0.3s;"
                          oninput="this.style.borderColor='var(--border)'; document.getElementById('commentError').classList.add('hidden')"></textarea>
                <div id="commentError" class="text-status-danger text-[11px] mt-2 hidden">Comment must be at least 10 characters long.</div>
            </div>

            <button type="button" id="submitReviewBtn" onclick="handleReviewSubmit()" class="btn-primary" style="width:100%; padding:18px; font-size:12px; font-weight:900;">Submit Review</button>
        </form>
    </div>
  </div>

  <!-- Full Screen Carousel Modal -->
  <div id="fsCarouselModal" style="display:none; position:fixed; inset:0; z-index:10000; background:rgba(0,0,0,0.95); backdrop-filter:blur(10px); flex-direction:column; justify-content:center; align-items:center;" onclick="closeFsCarousel()">
    <button onclick="closeFsCarousel()" style="position:absolute; top:24px; right:24px; background:rgba(255,255,255,0.1); border:none; color:#fff; width:44px; height:44px; border-radius:50%; cursor:pointer; font-size:24px; display:flex; align-items:center; justify-content:center; transition:background 0.2s; z-index: 10001;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">×</button>
    
    <div style="position:relative; width:90%; height:80%; max-width:1200px; display:flex; justify-content:center; align-items:center;" onclick="(e) => e.stopPropagation()">
        <img id="fsMainImg" src="" style="max-width:100%; max-height:100%; object-fit:contain; transition:opacity 0.3s;" alt="Product Image Fullscreen" onclick="(e) => e.stopPropagation()">
        
        <button id="fsPrevBtn" onclick="fsPrevImage(event)" style="position:absolute; left:0; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.1); color:#fff; border:none; width:50px; height:50px; display:flex; align-items:center; justify-content:center; border-radius:50%; cursor:pointer; transition:background .2s; z-index: 10001;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button id="fsNextBtn" onclick="fsNextImage(event)" style="position:absolute; right:0; top:50%; transform:translateY(-50%); background:rgba(255,255,255,0.1); color:#fff; border:none; width:50px; height:50px; display:flex; align-items:center; justify-content:center; border-radius:50%; cursor:pointer; transition:background .2s; z-index: 10001;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
    </div>
    
    <!-- Dots Container -->
    <div id="fsDotsContainer" style="display:flex; gap:8px; margin-top:20px; z-index: 10001;" onclick="(e) => e.stopPropagation()"></div>
  </div>

  
  </script>