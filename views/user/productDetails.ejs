  <!-- ═══════════════════════════════════════════════════════════ JAVASCRIPT -->
  <script>
    // ── DATA ──────────────────────────────────────────────────────────────────
    const product = <%- JSON.stringify(product || {}) %>;
    let currentImages = <%- JSON.stringify(typeof initialImages !== 'undefined' ? initialImages : []) %>;
    let currentImgIndex = 0;
    // Normalize server-side data for client-side consistency
    const normalizeUnit = (s) => {
      if (!s) return "";
      let v = s.toString().trim();
      if (/^\d+$/.test(v)) return v + " GB";
      if (v.toLowerCase().endsWith("gb")) return v.slice(0, -2).trim() + " GB";
      return v;
    };

    if (product.variants) {
      product.variants = product.variants.map(v => ({
        ...v,
        color: (v.color || "").trim(),
        storage: normalizeUnit(v.storage),
        ram: normalizeUnit(v.ram)
      }));
    }
    const serverVariants = product.variants || [];
    const wishlistedKeys = <%- JSON.stringify(wishlistedIds || []) %>;

    let qty = 1;
    let maxStock = <%= (defaultVariant ? defaultVariant.stock : product.stock) || 10 %>;
    maxStock = Math.min(10, maxStock); // Global cap of 10

    function checkCurrentWishlist() {
        const selectedColor = document.getElementById('selectedColor')?.textContent?.trim() || "";
        const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim() || "";
        const selectedRam = document.getElementById('selectedRam')?.textContent?.trim() || "";
        const normalize = (val) => String(val || '').toLowerCase().replace(/\s+/g, "").replace(/gb$/i, "").trim();
        const productId = '<%= product._id %>';
        const key = `${productId}_${normalize(selectedColor)}_${normalize(selectedStorage)}_${normalize(selectedRam)}`;
        return wishlistedKeys.includes(key);
    }
    let wishlisted = checkCurrentWishlist();

    // Set initial wishlist state
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('wishlistBtn');
        if (btn && wishlisted) {
            btn.classList.add('active');
            btn.style.color = 'var(--danger)';
            btn.querySelector('svg').setAttribute('fill', 'currentColor');
        }
    });

    // ── GALLERY ───────────────────────────────────────────────────────────────
    function changeImg(index) {
      if (!currentImages || currentImages.length === 0) return;
      currentImgIndex = index;
      document.getElementById('mainImg').src = currentImages[index];
      const thumbs = document.querySelectorAll('#galleryThumbnails .gallery-thumb');
      thumbs.forEach((t, i) => {
        if (i === index) t.classList.add('active');
        else t.classList.remove('active');
      });
    }

    function prevImage(e) {
      if (e) e.stopPropagation();
      if (!currentImages || currentImages.length === 0) return;
      let newIndex = currentImgIndex - 1;
      if (newIndex < 0) newIndex = currentImages.length - 1;
      changeImg(newIndex);
    }

    function nextImage(e) {
      if (e) e.stopPropagation();
      if (!currentImages || currentImages.length === 0) return;
      let newIndex = currentImgIndex + 1;
      if (newIndex >= currentImages.length) newIndex = 0;
      changeImg(newIndex);
    }

    // ── FULLSCREEN CAROUSEL ───────────────────────────────────────────────────
    function openFsCarousel() {
        if (!currentImages || currentImages.length === 0) return;
        const modal = document.getElementById('fsCarouselModal');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            fsChangeImg(currentImgIndex);
        }
    }

    function closeFsCarousel() {
        const modal = document.getElementById('fsCarouselModal');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }
    }

    function fsChangeImg(index) {
        if (!currentImages || currentImages.length === 0) return;
        currentImgIndex = index;
        document.getElementById('fsMainImg').src = currentImages[index];
        
        // Sync main page image
        document.getElementById('mainImg').src = currentImages[index];
        const thumbs = document.querySelectorAll('#galleryThumbnails .gallery-thumb');
        thumbs.forEach((t, i) => {
            if (i === index) t.classList.add('active');
            else t.classList.remove('active');
        });

        // Update Dots
        const dotsContainer = document.getElementById('fsDotsContainer');
        if (dotsContainer) {
            dotsContainer.innerHTML = '';
            currentImages.forEach((img, i) => {
                const dot = document.createElement('div');
                dot.style.width = '8px';
                dot.style.height = '8px';
                dot.style.borderRadius = '50%';
                dot.style.cursor = 'pointer';
                dot.style.transition = 'background 0.3s, transform 0.3s';
                if (i === index) {
                    dot.style.background = 'var(--accent)';
                    dot.style.transform = 'scale(1.3)';
                } else {
                    dot.style.background = 'rgba(255,255,255,0.3)';
                }
                dot.onclick = (e) => { e.stopPropagation(); fsChangeImg(i); };
                dotsContainer.appendChild(dot);
            });
        }
    }

    function fsPrevImage(e) {
        if (e) e.stopPropagation();
        if (!currentImages || currentImages.length === 0) return;
        let newIndex = currentImgIndex - 1;
        if (newIndex < 0) newIndex = currentImages.length - 1;
        fsChangeImg(newIndex);
    }

    function fsNextImage(e) {
        if (e) e.stopPropagation();
        if (!currentImages || currentImages.length === 0) return;
        let newIndex = currentImgIndex + 1;
        if (newIndex >= currentImages.length) newIndex = 0;
        fsChangeImg(newIndex);
    }

    // Keyboard navigation for fullscreen carousel
    document.addEventListener('keydown', (e) => {
        const modal = document.getElementById('fsCarouselModal');
        if (modal && modal.style.display === 'flex') {
            if (e.key === 'Escape') closeFsCarousel();
            if (e.key === 'ArrowLeft') fsPrevImage();
            if (e.key === 'ArrowRight') fsNextImage();
        }
    });

    // ── TABS ──────────────────────────────────────────────────────────────────
    function switchTab(btn, tabId) {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
      if (typeof btn === 'string') {
        document.querySelectorAll('.tab-btn').forEach(b => { if (b.getAttribute('onclick') && b.getAttribute('onclick').includes(btn)) b.classList.add('active'); });
        tabId = btn;
      } else {
        btn.classList.add('active');
      }
      const el = document.getElementById('tab-' + tabId);
      if (el) el.style.display = 'block';
    }

    // ── VARIANT SELECTORS ─────────────────────────────────────────────────────
    function selectColor(el, name) {
      document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedColor').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
        const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();
        const match = serverVariants.find(v => v.color === name && v.storage === selectedStorage && v.ram === selectedRam);

        if (!match) {
          const altVariant = serverVariants.find(v => v.color === name);
          if (altVariant) {
            if (document.getElementById('selectedStorage')) {
              document.getElementById('selectedStorage').textContent = altVariant.storage;
              document.querySelectorAll('#storagePills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.storage);
              });
            }
            if (document.getElementById('selectedRam')) {
              document.getElementById('selectedRam').textContent = altVariant.ram;
              document.querySelectorAll('#ramPills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.ram);
              });
            }
          }
        }
      }

      updateVariantDisplay();
    }

    function selectStorage(el, name) {
      document.querySelectorAll('#storagePills .variant-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedStorage').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
        const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();
        const match = serverVariants.find(v => v.storage === name && v.color === selectedColor && v.ram === selectedRam);

        if (!match) {
          const altVariant = serverVariants.find(v => v.storage === name);
          if (altVariant) {
            if (document.getElementById('selectedColor')) {
              document.getElementById('selectedColor').textContent = altVariant.color;
              document.querySelectorAll('.color-swatch').forEach(s => {
                s.classList.toggle('active', s.getAttribute('title') === altVariant.color);
              });
            }
            if (document.getElementById('selectedRam')) {
              document.getElementById('selectedRam').textContent = altVariant.ram;
              document.querySelectorAll('#ramPills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.ram);
              });
            }
          }
        }
      }

      updateVariantDisplay();
      showToast('info', 'Variant selected', `${name} selected`);
    }

    function selectRam(el, name) {
      document.querySelectorAll('#ramPills .variant-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedRam').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
        const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
        const match = serverVariants.find(v => v.ram === name && v.color === selectedColor && v.storage === selectedStorage);

        if (!match) {
          const altVariant = serverVariants.find(v => v.ram === name);
          if (altVariant) {
            if (document.getElementById('selectedColor')) {
              document.getElementById('selectedColor').textContent = altVariant.color;
              document.querySelectorAll('.color-swatch').forEach(s => {
                s.classList.toggle('active', s.getAttribute('title') === altVariant.color);
              });
            }
            if (document.getElementById('selectedStorage')) {
              document.getElementById('selectedStorage').textContent = altVariant.storage;
              document.querySelectorAll('#storagePills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.storage);
              });
            }
          }
        }
      }

      updateVariantDisplay();
      showToast('info', 'Variant selected', `${name} RAM selected`);
    }

    function updateVariantDisplay() {
      const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
      const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
      const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();

      if (!selectedStorage || !selectedColor || !serverVariants.length) return;

      const match = serverVariants.find(v => v.storage === selectedStorage && v.color === selectedColor && (!selectedRam || v.ram === selectedRam));

      // Storage: active if ANY variant exists with selected color + this storage (regardless of RAM)
      document.querySelectorAll('#storagePills .variant-pill').forEach(pill => {
        const s = pill.textContent.trim();
        const exists = serverVariants.find(v => v.color === selectedColor && v.storage === s && !v.isDeleted);
        const existsDeleted = serverVariants.find(v => v.color === selectedColor && v.storage === s);
        if (!exists) {
          pill.classList.add('disabled');
          pill.title = existsDeleted ? 'Unlisted' : 'Not available in this color';
        } else {
          pill.classList.remove('disabled');
          pill.title = '';
        }
      });
 
      // RAM: active if ANY variant exists with selected color + selected storage + this RAM
      document.querySelectorAll('#ramPills .variant-pill').forEach(pill => {
        const r = pill.textContent.trim();
        const exists = serverVariants.find(v => v.color === selectedColor && v.storage === selectedStorage && v.ram === r && !v.isDeleted);
        const existsDeleted = serverVariants.find(v => v.color === selectedColor && v.storage === selectedStorage && v.ram === r);
        if (!exists) {
          pill.classList.add('disabled');
          pill.title = existsDeleted ? 'Unlisted' : 'Not available in this combination';
        } else {
          pill.classList.remove('disabled');
          pill.title = '';
        }
      });
 
      // Color swatches: active if ANY variant exists with this color + selected storage (regardless of RAM)
      document.querySelectorAll('.color-swatch').forEach(swatch => {
        const c = swatch.getAttribute('title');
        const exists = serverVariants.find(v => v.color === c && v.storage === selectedStorage && !v.isDeleted);
        const existsDeleted = serverVariants.find(v => v.color === c && v.storage === selectedStorage);
        if (!exists) {
          swatch.style.opacity = '0.3';
          swatch.title = existsDeleted ? `${c} (Unlisted)` : c;
        } else {
          swatch.style.opacity = '1';
          swatch.title = c;
        }
      });

      if (match) {
        // Calculate discounted price
        let finalPrice = match.price;
        let originalPrice = match.price;
        let hasOffer = false;

        if (product.bestOffer || product.hasOffer) {
            const offer = product.bestOffer || { discountType: 'percentage', discountValue: 0 }; // fallback
            hasOffer = true;
            let discount = 0;
            if (offer.discountType === 'percentage') {
                discount = (match.price * offer.discountValue) / 100;
            } else {
                discount = offer.discountValue;
            }

            // Apply cap if defined
            if (offer.maxDiscountAmount && discount > offer.maxDiscountAmount) {
                discount = offer.maxDiscountAmount;
            }

            // Safety net: Max 95% discount
            const maxSafety = match.price * 0.95;
            discount = Math.min(discount, maxSafety);

            finalPrice = Math.floor(Math.max(1, match.price - discount));
            
            // If it's a 0% offer but product.hasOffer was true (maybe it was just discountedPrice set), 
            // we should still respect the discountedPrice if we don't have bestOffer details.
            // But bestOffer should be there.
        }

        // Update price
        const priceEl = document.getElementById('productPrice');
        const originalPriceEl = document.getElementById('originalPrice');
        
        if (priceEl) priceEl.textContent = `₹${finalPrice.toLocaleString()}`;
        if (originalPriceEl) {
            if (hasOffer) {
                originalPriceEl.textContent = `₹${originalPrice.toLocaleString()}`;
                originalPriceEl.style.display = 'inline';
            } else {
                originalPriceEl.style.display = 'none';
            }
        }

        const stickyPriceEl = document.getElementById('stickyPrice');
        if (stickyPriceEl) stickyPriceEl.textContent = `₹${finalPrice.toLocaleString()}`;

        // Update stock badge
        const badge = document.getElementById('stockStatusBadge');

        // Manage buy buttons based on stock
        const actionBtns = [
          ...document.querySelectorAll('.btn-primary[onclick="addToCart()"]'), // add to cart
          ...document.querySelectorAll('.btn-secondary[onclick="buyNow()"]') // buy now (using click handler)
        ];

        if (match.stock > 0 && !match.isDeleted) {
          if (badge) {
            badge.innerHTML = `● IN STOCK`;
            badge.style.color = 'var(--success)';
          }

          // Update Stock Warning
          const stockWarningContainer = document.getElementById('stockWarningContainer');
          const stockWarningText = document.getElementById('stockWarningText');
          if (stockWarningContainer && stockWarningText) {
            const isLowStock = match.stock <= 5;
            stockWarningContainer.style.display = 'flex';
            stockWarningContainer.style.background = isLowStock ? 'rgba(239, 68, 68, 0.06)' : 'rgba(34, 197, 94, 0.06)';
            stockWarningContainer.style.borderColor = isLowStock ? 'rgba(239, 68, 68, 0.2)' : 'rgba(34, 197, 94, 0.2)';
            stockWarningText.style.color = isLowStock ? 'var(--danger)' : 'var(--success)';
            stockWarningContainer.querySelector('svg').style.stroke = isLowStock ? 'var(--danger)' : 'var(--success)';
            stockWarningText.textContent = isLowStock 
              ? `Hurry! Only ${match.stock} left in stock — order soon` 
              : `${match.stock} units currently available`;
          }

          actionBtns.forEach(btn => {
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.cursor = 'pointer';
            if (btn.classList.contains('btn-primary')) btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> Add to Cart';
          });

          // Sync maxStock and Qty
          maxStock = Math.min(10, match.stock);
          if (qty > maxStock) {
            qty = Math.max(1, maxStock);
            document.getElementById('qtyDisplay').textContent = qty;
          }
        } else {
          if (badge) {
            badge.innerHTML = match.isDeleted ? `● UNAVAILABLE` : `● OUT OF STOCK`;
            badge.style.color = 'var(--danger)';
          }

          // Hide stock warning if out of stock (since button says it)
          const stockWarningContainer = document.getElementById('stockWarningContainer');
          if (stockWarningContainer) stockWarningContainer.style.display = 'none';

          actionBtns.forEach(btn => {
            btn.disabled = true;
            btn.style.opacity = '0.5';
            btn.style.cursor = 'not-allowed';
            if (btn.classList.contains('btn-primary')) btn.innerHTML = match.isDeleted ? 'Unavailable' : 'Out of Stock';
          });

          maxStock = 0;
          qty = 1;
          document.getElementById('qtyDisplay').textContent = qty;
        }

        // Update images dynamically
        let imagesToDisplay = match.images && match.images.length > 0 ? match.images : [];
        if (imagesToDisplay && imagesToDisplay.length > 0) {
          currentImages = imagesToDisplay;
          currentImgIndex = 0;
          const mainImg = document.getElementById('mainImg');
          if (mainImg) mainImg.src = imagesToDisplay[0];

          const thumbsContainer = document.getElementById('galleryThumbnails');
          if (thumbsContainer) {
            thumbsContainer.innerHTML = '';
            imagesToDisplay.forEach((img, index) => {
              thumbsContainer.innerHTML += `
            <div class="gallery-thumb ${index === 0 ? 'active' : ''}" onclick="changeImg(${index})">
              <img src="${img}" alt="${product.name}">
            </div>
          `;
            });
          }
        }

        // ── UPDATE WISHLIST BUTTON ──
        wishlisted = checkCurrentWishlist();
        const wlBtn = document.getElementById('wishlistBtn');
        if (wlBtn) {
            wlBtn.classList.toggle('active', wishlisted);
            wlBtn.style.color = wishlisted ? 'var(--danger)' : 'var(--t2)';
            const heartSvg = wlBtn.querySelector('svg');
            if (heartSvg) heartSvg.setAttribute('fill', wishlisted ? 'currentColor' : 'none');
        }
      } else {
        const badge = document.getElementById('stockStatusBadge');
        if (badge) {
          badge.innerHTML = `● UNAVAILABLE`;
          badge.style.color = 'var(--t3)';
        }
      }
    }

    // ── QUANTITY ──────────────────────────────────────────────────────────────
    function adjustQty(delta) {
      if (maxStock <= 0) return;
      qty = Math.max(1, Math.min(maxStock, qty + delta));
      document.getElementById('qtyDisplay').textContent = qty;
    }

    // ── CART + WISHLIST ───────────────────────────────────────────────────────
    async function addToCart() {
      const storageBase = document.getElementById('selectedStorage')?.textContent?.trim() || '';
      const colorBase = document.getElementById('selectedColor')?.textContent?.trim() || '';
      const ramBase = document.getElementById('selectedRam')?.textContent?.trim() || '';
      
      const variant = {
        storage: storageBase,
        color: colorBase,
        ram: ramBase
      };
      
      const productId = product._id;

      const btn = (typeof event !== 'undefined' && event ? event.currentTarget : null) || document.querySelector('.btn-primary[onclick="addToCart()"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Adding...';
      btn.disabled = true;

      try {
        const response = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ productId, variant, qty })
        });

        const data = await response.json();

        if (data.success) {
          const variantStr = [variant.color, variant.storage, variant.ram].filter(Boolean).join(' / ');
          showToast('success', 'Added to cart', `${product.name} ${variantStr ? '· ' + variantStr : ''} × ${qty}`);
          const badge = document.getElementById('cart-badge');
          if (badge && data.cartCount !== undefined) {
            badge.textContent = data.cartCount;
            badge.classList.remove('hidden');
          }
          btn.innerHTML = 'In Cart ✓';
          setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 2000);
        } else {
          showToast('error', 'Failed to add', data.message || 'Something went wrong');
          btn.innerHTML = originalText;
          btn.disabled = false;
          if (data.message && data.message.toLowerCase().includes('login')) {
            setTimeout(() => window.location.href = '/auth/login', 1500);
          }
        }
      } catch (err) {
        console.error(err);
        showToast('error', 'Error', 'Failed to communicate with server');
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

