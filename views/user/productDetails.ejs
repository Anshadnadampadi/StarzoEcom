            badge.classList.remove('hidden');
          }
        } else {
          showToast('error', 'Failed to add', data.message || 'Something went wrong');
        }
      } catch (err) {
        console.error(err);
        showToast('error', 'Error', 'Failed to communicate with server');
      }
    }

    async function toggleWishlist() {
      const storageBase = document.getElementById('selectedStorage')?.textContent?.trim() || '';
      const colorBase = document.getElementById('selectedColor')?.textContent?.trim() || '';
      const ramBase = document.getElementById('selectedRam')?.textContent?.trim() || '';
      const productId = product._id;

      try {
        const response = await fetch('/wishlist/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
              productId, 
              color: colorBase, 
              storage: storageBase, 
              ram: ramBase 
          })
        });

        const data = await response.json();

            if (data.success) {
                wishlisted = data.added;
                
                // Update local keys list
                const normalize = (val) => String(val || '').toLowerCase().replace(/\s+/g, "").replace(/gb$/i, "").trim();
                const key = `${productId}_${normalize(colorBase)}_${normalize(storageBase)}_${normalize(ramBase)}`;
                if (wishlisted) {
                    if (!wishlistedKeys.includes(key)) wishlistedKeys.push(key);
                } else {
                    const idx = wishlistedKeys.indexOf(key);
                    if (idx > -1) wishlistedKeys.splice(idx, 1);
                }

                const btn = document.getElementById('wishlistBtn');
            if (btn) {
                btn.classList.toggle('active', wishlisted);
                btn.style.color = wishlisted ? 'var(--danger)' : 'var(--t2)';
                btn.querySelector('svg').setAttribute('fill', wishlisted ? 'currentColor' : 'none');
            }
            
            showToast(wishlisted ? 'success' : 'info', data.message, product.name);
            
