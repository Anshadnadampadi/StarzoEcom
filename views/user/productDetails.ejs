  <!-- ═══════════════════════════════════════════════════════════ JAVASCRIPT -->
  <script>
    // ── DATA ──────────────────────────────────────────────────────────────────
    const product = <%- JSON.stringify(product || {}) %>;
    // Normalize server-side data for client-side consistency
    const normalizeUnit = (s) => {
      if (!s) return "";
      let v = s.toString().trim();
      if (/^\d+$/.test(v)) return v + " GB";
      if (v.toLowerCase().endsWith("gb")) return v.slice(0, -2).trim() + " GB";
      return v;
    };

    if (product.variants) {
      product.variants = product.variants.map(v => ({
        ...v,
        color: (v.color || "").trim(),
        storage: normalizeUnit(v.storage),
        ram: normalizeUnit(v.ram)
      }));
    }
    const serverVariants = product.variants || [];

    let qty = 1;
    let wishlisted = <%= locals.isWishlisted ? 'true' : 'false' %>;

    // Set initial wishlist state
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('wishlistBtn');
        if (btn && wishlisted) {
            btn.classList.add('active');
            btn.style.color = 'var(--danger)';
            btn.querySelector('svg').setAttribute('fill', 'currentColor');
        }
    });

    // ── GALLERY ───────────────────────────────────────────────────────────────
    function changeImg(el, url) {
      document.getElementById('mainImg').src = url;
      document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
    }

    // ── TABS ──────────────────────────────────────────────────────────────────
    function switchTab(btn, tabId) {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
      if (typeof btn === 'string') {
        document.querySelectorAll('.tab-btn').forEach(b => { if (b.getAttribute('onclick') && b.getAttribute('onclick').includes(btn)) b.classList.add('active'); });
        tabId = btn;
      } else {
        btn.classList.add('active');
      }
      const el = document.getElementById('tab-' + tabId);
      if (el) el.style.display = 'block';
    }

    // ── VARIANT SELECTORS ─────────────────────────────────────────────────────
    function selectColor(el, name) {
      document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedColor').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
        const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();
        const match = serverVariants.find(v => v.color === name && v.storage === selectedStorage && v.ram === selectedRam);

        if (!match) {
          const altVariant = serverVariants.find(v => v.color === name);
          if (altVariant) {
            if (document.getElementById('selectedStorage')) {
              document.getElementById('selectedStorage').textContent = altVariant.storage;
              document.querySelectorAll('#storagePills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.storage);
              });
            }
            if (document.getElementById('selectedRam')) {
              document.getElementById('selectedRam').textContent = altVariant.ram;
              document.querySelectorAll('#ramPills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.ram);
              });
            }
          }
        }
      }

      updateVariantDisplay();
    }

    function selectStorage(el, name) {
      document.querySelectorAll('#storagePills .variant-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedStorage').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
        const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();
        const match = serverVariants.find(v => v.storage === name && v.color === selectedColor && v.ram === selectedRam);

        if (!match) {
          const altVariant = serverVariants.find(v => v.storage === name);
          if (altVariant) {
            if (document.getElementById('selectedColor')) {
              document.getElementById('selectedColor').textContent = altVariant.color;
              document.querySelectorAll('.color-swatch').forEach(s => {
                s.classList.toggle('active', s.getAttribute('title') === altVariant.color);
              });
            }
            if (document.getElementById('selectedRam')) {
              document.getElementById('selectedRam').textContent = altVariant.ram;
              document.querySelectorAll('#ramPills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.ram);
              });
            }
          }
        }
      }

      updateVariantDisplay();
      showToast('info', 'Variant selected', `${name} selected`);
    }

    function selectRam(el, name) {
      document.querySelectorAll('#ramPills .variant-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      document.getElementById('selectedRam').textContent = name;

      if (serverVariants && serverVariants.length) {
        const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
        const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
        const match = serverVariants.find(v => v.ram === name && v.color === selectedColor && v.storage === selectedStorage);

        if (!match) {
          const altVariant = serverVariants.find(v => v.ram === name);
          if (altVariant) {
            if (document.getElementById('selectedColor')) {
              document.getElementById('selectedColor').textContent = altVariant.color;
              document.querySelectorAll('.color-swatch').forEach(s => {
                s.classList.toggle('active', s.getAttribute('title') === altVariant.color);
              });
            }
            if (document.getElementById('selectedStorage')) {
              document.getElementById('selectedStorage').textContent = altVariant.storage;
              document.querySelectorAll('#storagePills .variant-pill').forEach(p => {
                p.classList.toggle('active', p.textContent.trim() === altVariant.storage);
              });
            }
          }
        }
      }

      updateVariantDisplay();
      showToast('info', 'Variant selected', `${name} RAM selected`);
    }

    function updateVariantDisplay() {
      const selectedStorage = document.getElementById('selectedStorage')?.textContent?.trim();
      const selectedColor = document.getElementById('selectedColor')?.textContent?.trim();
      const selectedRam = document.getElementById('selectedRam')?.textContent?.trim();

      if (!selectedStorage || !selectedColor || !serverVariants.length) return;

      const match = serverVariants.find(v => v.storage === selectedStorage && v.color === selectedColor && (!selectedRam || v.ram === selectedRam));

      // Disable unavailable pills/swatches — cascading filter approach
      // Storage: enabled if ANY variant exists with selected color + this storage (regardless of RAM)
      document.querySelectorAll('#storagePills .variant-pill').forEach(pill => {
        const s = pill.textContent.trim();
        const exists = serverVariants.find(v => v.color === selectedColor && v.storage === s);
        if (!exists) {
          pill.classList.add('disabled');
          pill.title = 'Not available in this color';
        } else {
          pill.classList.remove('disabled');
          pill.title = '';
        }
      });

      // RAM: enabled if ANY variant exists with selected color + selected storage + this RAM
      document.querySelectorAll('#ramPills .variant-pill').forEach(pill => {
        const r = pill.textContent.trim();
        const exists = serverVariants.find(v => v.color === selectedColor && v.storage === selectedStorage && v.ram === r);
        if (!exists) {
          pill.classList.add('disabled');
          pill.title = 'Not available in this combination';
        } else {
          pill.classList.remove('disabled');
          pill.title = '';
        }
      });

      // Color swatches: enabled if ANY variant exists with this color + selected storage (regardless of RAM)
      document.querySelectorAll('.color-swatch').forEach(swatch => {
        const c = swatch.getAttribute('title');
        const exists = serverVariants.find(v => v.color === c && v.storage === selectedStorage);
        if (!exists) {
          swatch.style.opacity = '0.3';
        } else {
          swatch.style.opacity = '1';
        }
      });

      if (match) {
        // Update price
        const formattedPrice = `₹${match.price.toLocaleString()}`;
        const priceEl = document.getElementById('productPrice');
        if (priceEl) priceEl.textContent = formattedPrice;

        const stickyPriceEl = document.getElementById('stickyPrice');
        if (stickyPriceEl) stickyPriceEl.textContent = formattedPrice;

        // Update stock badge
        const badge = document.getElementById('stockStatusBadge');

        // Manage buy buttons based on stock
        const actionBtns = [
          ...document.querySelectorAll('.btn-primary[onclick="addToCart()"]'), // add to cart
          ...document.querySelectorAll('.btn-secondary[onclick="buyNow()"]') // buy now (using click handler)
        ];

        if (match.stock > 0) {
          if (badge) {
            badge.innerHTML = `● IN STOCK`;
            badge.style.color = 'var(--success)';
          }
          actionBtns.forEach(btn => {
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.cursor = 'pointer';
            if (btn.classList.contains('btn-primary')) btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg> Add to Cart';
          });
        } else {
          if (badge) {
            badge.innerHTML = `● OUT OF STOCK`;
            badge.style.color = 'var(--danger)';
          }
          actionBtns.forEach(btn => {
            btn.disabled = true;
            btn.style.opacity = '0.5';
            btn.style.cursor = 'not-allowed';
            if (btn.classList.contains('btn-primary')) btn.innerHTML = 'Out of Stock';
          });
        }

        // Update images dynamically
        let imagesToDisplay = match.images && match.images.length > 0 ? match.images : [];
        if (imagesToDisplay && imagesToDisplay.length > 0) {
          const mainImg = document.getElementById('mainImg');
          if (mainImg) mainImg.src = imagesToDisplay[0];

          const thumbsContainer = document.getElementById('galleryThumbnails');
          if (thumbsContainer) {
            thumbsContainer.innerHTML = '';
            imagesToDisplay.forEach((img, index) => {
              thumbsContainer.innerHTML += `
            <div class="gallery-thumb ${index === 0 ? 'active' : ''}" onclick="changeImg(this,'${img}')">
              <img src="${img}" alt="${product.name}">
            </div>
          `;
            });
          }
        }
      } else {
        const badge = document.getElementById('stockStatusBadge');
        if (badge) {
          badge.innerHTML = `● UNAVAILABLE`;
          badge.style.color = 'var(--t3)';
        }
      }
    }

    // ── QUANTITY ──────────────────────────────────────────────────────────────
    function adjustQty(delta) {
      qty = Math.max(1, Math.min(10, qty + delta));
      document.getElementById('qtyDisplay').textContent = qty;
    }

    // ── CART + WISHLIST ───────────────────────────────────────────────────────
    async function addToCart() {
      const storageBase = document.getElementById('selectedStorage')?.textContent?.trim() || '';
      const colorBase = document.getElementById('selectedColor')?.textContent?.trim() || '';
      const ramBase = document.getElementById('selectedRam')?.textContent?.trim() || '';
      const variant = storageBase && colorBase ? `${storageBase} ${colorBase} ${ramBase}`.trim() : '';
      const productId = product._id;

      const btn = (typeof event !== 'undefined' && event ? event.currentTarget : null) || document.querySelector('.btn-primary[onclick="addToCart()"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = 'Adding...';
      btn.disabled = true;

      try {
        const response = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ productId, variant, qty })
        });

        const data = await response.json();

        if (data.success) {
          showToast('success', 'Added to cart', `${product.name} ${variant ? '· ' + variant : ''} × ${qty}`);
          const badge = document.getElementById('cart-badge');
          if (badge && data.cartCount !== undefined) {
            badge.textContent = data.cartCount;
            badge.classList.remove('hidden');
          }
          btn.innerHTML = 'In Cart ✓';
          setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 2000);
        } else {
          showToast('error', 'Failed to add', data.message || 'Something went wrong');
          btn.innerHTML = originalText;
          btn.disabled = false;
          if (data.message && data.message.toLowerCase().includes('login')) {
            setTimeout(() => window.location.href = '/auth/login', 1500);
          }
        }
      } catch (err) {
        console.error(err);
        showToast('error', 'Error', 'Failed to communicate with server');
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

    async function quickAdd(productId, name) {
      try {
        const response = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ productId, variant: '', qty: 1 })
        });
        const data = await response.json();
        if (data.success) {
          showToast('success', 'Added to cart', name);
          const badge = document.getElementById('cart-badge');
          if (badge && data.cartCount !== undefined) {
            badge.textContent = data.cartCount;
            badge.classList.remove('hidden');
          }
        } else {
          showToast('error', 'Failed to add', data.message || 'Something went wrong');
        }
      } catch (err) {
        console.error(err);
        showToast('error', 'Error', 'Failed to communicate with server');
      }
    }

    async function toggleWishlist() {
      const storageBase = document.getElementById('selectedStorage')?.textContent?.trim() || '';
      const colorBase = document.getElementById('selectedColor')?.textContent?.trim() || '';
      const ramBase = document.getElementById('selectedRam')?.textContent?.trim() || '';
      const productId = product._id;

      try {
        const response = await fetch('/wishlist/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
              productId, 
              color: colorBase, 
              storage: storageBase, 
              ram: ramBase 
          })
        });

        const data = await response.json();

        if (data.success) {
            wishlisted = data.added;
            const btn = document.getElementById('wishlistBtn');
            if (btn) {
                btn.classList.toggle('active', wishlisted);
                btn.style.color = wishlisted ? 'var(--danger)' : 'var(--t2)';
                btn.querySelector('svg').setAttribute('fill', wishlisted ? 'currentColor' : 'none');
            }
            
            showToast(wishlisted ? 'success' : 'info', data.message, product.name);
            
            // Update Navigation Badge
            const badge = document.getElementById('wishlist-badge');
            if (badge && data.wishlistCount !== undefined) {
                badge.textContent = data.wishlistCount;
                badge.classList.toggle('hidden', data.wishlistCount === 0);
            }
        } else {
            showToast('error', 'Operation Failed', data.message);
            if (data.message && data.message.toLowerCase().includes('login')) {
                setTimeout(() => window.location.href = '/auth/login', 1500);
            }
        }
      } catch (err) {
        console.error(err);
        showToast('error', 'Sync Error', 'Unable to reach the vault servers');
      }
    }

    // ── DELIVERY CHECK ────────────────────────────────────────────────────────
    function checkDelivery() {
      const pin = document.getElementById('pincodeInput').value;
      const res = document.getElementById('deliveryResult');
      if (pin.length < 6) { showToast('error', 'Invalid PIN', 'Please enter a 6-digit PIN code.'); return; }
      res.style.display = 'flex';
      res.style.alignItems = 'center';
      res.style.gap = '8px';
      res.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> <span style="color:var(--success);font-weight:600;">Free delivery</span> <span style="color:var(--t2);">to ${pin} by <strong style="color:var(--t1);">Tomorrow</strong></span>`;
    }

    // ── STICKY BAR ────────────────────────────────────────────────────────────
    window.addEventListener('scroll', () => {
      const bar = document.getElementById('stickyBar');
      if (bar) bar.classList.toggle('visible', window.scrollY > 600);
    });

    // ── TOAST ─────────────────────────────────────────────────────────────────
    function showToast(type, title, msg) {
      window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: msg || title, type: type } }));
    }

    // ── IMAGE ZOOM ───────────────────────────────────────────────────────────
    const mainGallery = document.getElementById('mainGallery');
    const mainImg = document.getElementById('mainImg');

    if (mainGallery && mainImg) {
      mainGallery.addEventListener('mousemove', (e) => {
        const rect = mainGallery.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const xPercent = (x / rect.width) * 100;
        const yPercent = (y / rect.height) * 100;

        mainImg.style.transformOrigin = `${xPercent}% ${yPercent}%`;
      });

      mainGallery.addEventListener('mouseleave', () => {
        mainImg.style.transformOrigin = 'center center';
      });
    }

    // ── INIT ──────────────────────────────────────────────────────────────────
    updateVariantDisplay();
  </script>