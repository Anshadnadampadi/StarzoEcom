<style>
  :root {
    --bg: #000;
    --surface: #0d0d0d;
    --card: #111;
    --elevated: #1a1a1a;
    --border: #222;
    --accent: #ff6a00;
    --accent-h: #e05800;
    --accent-s: rgba(255, 106, 0, .1);
    --t1: #fff;
    --t2: #888;
    --t3: #444;
    --success: #22c55e;
    --danger: #ef4444;
  }

  .font-syne {
    font-family: 'Syne', sans-serif;
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }

  /* :: SIDEBAR :: */
  .sidebar-section {
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
    margin-bottom: 24px;
  }

  .sidebar-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--t1);
    margin-bottom: 16px;
  }

  /* Filter checkboxes */
  .filter-lbl {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--t2);
    cursor: pointer;
    transition: color .2s;
    margin-bottom: 12px;
  }

  .filter-lbl:hover,
  .filter-lbl.active {
    color: var(--t1);
  }

  .filter-box {
    width: 16px;
    height: 16px;
    border: 1px solid var(--t3);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
    background: transparent;
  }

  .filter-lbl input {
    display: none;
  }

  .filter-lbl input:checked+.filter-box {
    background: var(--accent);
    border-color: var(--accent);
  }

  .filter-lbl input:checked+.filter-box::after {
    content: '✓';
    color: #000;
    font-size: 10px;
    font-weight: 900;
  }

  /* :: PRODUCT GRID :: */
  .grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  @media (max-width: 1024px) {
    .grid-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid-container {
      grid-template-columns: repeat(1, 1fr);
    }
  }

  /* Inputs */
  .input-dark {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 12px 14px;
    color: var(--t1);
    font-size: 13px;
    transition: border-color .2s;
    outline: none;
    border-radius: 0;
  }

  .input-dark:focus {
    border-color: var(--accent);
  }

  .input-dark::placeholder {
    color: var(--t3);
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 40px;
  }

  .page-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--t2);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all .2s;
    cursor: pointer;
  }

  .page-link:hover {
    border-color: var(--t1);
    color: var(--t1);
  }

  .page-link.active {
    background: var(--t1);
    color: #000;
    border-color: var(--t1);
    font-weight: 700;
  }
</style>

<main style="padding:40px 0;">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-8 flex flex-col lg:flex-row gap-8 lg:gap-16 items-start">

      <!-- LEFT SIDEBAR -->
      <aside class="w-full lg:w-[260px] flex-shrink-0 lg:sticky lg:top-[100px] hidden lg:block">

        <!-- Search focus -->
        <div class="sidebar-section">
          <div class="sidebar-title">Search</div>
          <div style="position:relative;display:flex;">
            <input type="text" id="searchInput" class="input-dark" placeholder="Name, Model, SKU..."
              value="<%= searchQuery || '' %>">
            <svg id="searchIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--t3)"
              stroke-width="2"
              style="position:absolute;right:12px;top:50%;transform:translateY(-50%);pointer-events:none;">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.35-4.35" />
            </svg>
            <button id="clearSearchBtn" onclick="clearSearch()"
              style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:var(--t2);cursor:pointer;display:none;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Categories -->
        <div class="sidebar-section">
          <div class="sidebar-title">Categories</div>
          <div>


            <!-- All -->
            <label class="filter-lbl category-item">
              <input type="checkbox" class="category-filter" value="all" id="allCategory">
              <div class="filter-box"></div>
              All Collections
            </label>

            <% if (locals.categories) { %>
              <% categories.forEach(c=> { %>
                <label class="filter-lbl category-item">
                  <input type="checkbox" class="category-filter" value="<%= c._id %>"
                    <%=selectedCategories?.includes(c._id.toString()) ? 'checked' : '' %>
                  >
                  <div class="filter-box"></div>
                  <%= c.name %>
                </label>
              <% }) %>
            <% } %>

          </div>
        </div>
        <!-- Brands -->
        <div class="sidebar-section">
          <div class="sidebar-title">Brands</div>
          <div>
            <% if (locals.brands) { %>
              <% brands.forEach(b=> { %>
                <label class="filter-lbl brand-item" data-brand="<%= b %>">
                  <input type="checkbox" <%=selectedBrand && selectedBrand.includes(b) ? 'checked' : '' %>
                  onchange="applyFilters()">
                  <div class="filter-box"></div>
                  <%= b %>
                </label>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Price Range -->
        <div class="sidebar-section">
          <div class="sidebar-title">Price Range</div>
          <div>
            <label class="filter-lbl price-item" data-price="">
              <input type="radio" name="price" <%=!selectedPrice ? 'checked' : '' %> onchange="applyFilters()">
              <div class="filter-box"></div>
              Any Price
            </label>
            <label class="filter-lbl price-item" data-price="0-10000">
              <input type="radio" name="price" <%=selectedPrice==='0-10000' ? 'checked' : '' %>
              onchange="applyFilters()">
              <div class="filter-box"></div>
              Under ₹10,000
            </label>
            <label class="filter-lbl price-item" data-price="10000-50000">
              <input type="radio" name="price" <%=selectedPrice==='10000-50000' ? 'checked' : '' %>
              onchange="applyFilters()">
              <div class="filter-box"></div>
              ₹10,000 - ₹50,000
            </label>
            <label class="filter-lbl price-item" data-price="50000-100000">
              <input type="radio" name="price" <%=selectedPrice==='50000-100000' ? 'checked' : '' %>
              onchange="applyFilters()">
              <div class="filter-box"></div>
              ₹50,000 - ₹1,00,000
            </label>
            <label class="filter-lbl price-item" data-price="100000-">
              <input type="radio" name="price" <%=selectedPrice==='100000-' ? 'checked' : '' %>
              onchange="applyFilters()">
              <div class="filter-box"></div>
              Over ₹1,00,000
            </label>
          </div>
        </div>

        <!-- Apply btn for mobile usually, but since desktop sticky: -->
        <button onclick="applyFilters()"
          style="width:100%;background:var(--t1);color:#000;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;letter-spacing:.1em;text-transform:uppercase;padding:14px;border:none;cursor:pointer;transition:background .2s;"
          onmouseover="this.style.background='var(--accent)'" onmouseout="this.style.background='var(--t1)'">
          Apply Filters
        </button>
      </aside>

      <!-- RIGHT CONTENT -->
      <div class="flex-1 w-full">

        <!-- Title & Sort -->
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-8">
          <div>
            <h1 class="font-syne" style="font-size:36px;font-weight:800;line-height:1.1;margin-bottom:8px;">The
              Collection</h1>
            <p style="font-size:13px;color:var(--t2);">Showing <span class="font-mono text-white" id="currentCount">
                <%= products.length %>
              </span> models match your criteria.</p>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span
              style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--t3);">Sort
              By</span>
            <select id="sortSelect" class="input-dark" style="width:160px;padding:10px 14px;cursor:pointer;"
              onchange="applyFilters()">
              <option value="newest" <%=selectedSort==='newest' ? 'selected' : '' %>>Newest Arrivals</option>
              <option value="priceLow" <%=selectedSort==='priceLow' ? 'selected' : '' %>>Price: Low to High</option>
              <option value="priceHigh" <%=selectedSort==='priceHigh' ? 'selected' : '' %>>Price: High to Low</option>
              <option value="aToZ" <%=selectedSort==='aToZ' ? 'selected' : '' %>>Name: A to Z</option>
              <option value="zToA" <%=selectedSort==='zToA' ? 'selected' : '' %>>Name: Z to A</option>
            </select>
          </div>
        </div>

        <!-- Grid -->
        <div class="grid-container" id="productContainer">
          <!-- Initial SSR Render -->
          <% products.forEach(product=> { %>
             <%- include('../partials/product-card', { 
                 product: product
             }) %>
          <% }) %>

              <% if (products.length===0) { %>
                <div style="grid-column:1/-1;padding:80px 20px;text-align:center;">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--t3)" stroke-width="1.5"
                    style="margin:0 auto 20px;">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                  </svg>
                  <h3 class="font-syne" style="font-size:18px;font-weight:700;color:var(--t1);margin-bottom:8px;">No
                    products found</h3>
                  <p style="font-size:13px;color:var(--t2);">Try adjusting your search or filters to find what you're
                    looking for.</p>
                </div>
                <% } %>
        </div>

        <!-- Pagination Container (Rendered Server Side/Updated Client Side) -->
        <div class="pagination" id="pagination">
          <%- pagination %>
        </div>

      </div>
    </div>
  </main>

  <template id="product-template">
    <div class="bg-black-card group relative overflow-hidden transition-all duration-300 border border-transparent hover:border-white/5 h-full flex flex-col">
        <!-- Image block -->
        <div class="aspect-square bg-black overflow-hidden relative cursor-pointer img-link">
            <img src="" alt="" class="w-full h-full object-contain p-8 lg:p-12 block transition-transform duration-500 group-hover:scale-110" loading="lazy">
            
            <!-- Badges -->
            <div class="absolute top-4 left-4 flex flex-col gap-2">
                <span class="bg-accent text-black text-[9px] font-black px-2 py-0.5 tracking-widest uppercase badge-new" style="display:none;">NEW</span>
                <span class="bg-status-success text-black text-[9px] font-black px-2 py-0.5 tracking-widest uppercase badge-offer" style="display:none;">OFFER</span>
            </div>

            <!-- Quick actions -->
            <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-10">
                <button type="button" class="w-full bg-accent text-black font-black py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-white transition-colors quick-add-btn">
                    QUICK ADD
                </button>
                <button type="button" disabled class="w-full bg-white/20 text-white/50 font-black py-4 text-[10px] tracking-[0.2em] uppercase cursor-not-allowed out-of-stock-btn" style="display:none;">
                    OUT OF STOCK
                </button>
            </div>

            <!-- Wishlist Toggle -->
            <button class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 text-white/50 transition-all duration-300 hover:text-white p-2 wishlist-btn">
                <svg class="w-5 h-5 drop-shadow-md" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
            </button>
        </div>

        <!-- Details -->
        <div class="p-6 flex-grow flex flex-col">
            <p class="text-white/30 text-[9px] uppercase font-black tracking-[0.2em] mb-2 brand-name"></p>
            <h3 class="text-white font-bold text-sm leading-snug mb-3 line-clamp-2 h-10 group-hover:text-accent transition-colors">
                <a href="" class="product-link"></a>
            </h3>
            
            <!-- Ratings -->
            <div class="flex items-center gap-1 mb-4">
                <div class="flex items-center star-container">
                    <svg class="w-2.5 h-2.5 star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    <svg class="w-2.5 h-2.5 star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    <svg class="w-2.5 h-2.5 star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    <svg class="w-2.5 h-2.5 star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    <svg class="w-2.5 h-2.5 star-icon" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                </div>
                <span class="text-white/20 text-[9px] font-bold ml-1 tracking-wider review-count-text"></span>
            </div>

            <div class="mt-auto flex items-center justify-between">
                <div class="flex flex-col price-container">
                    <span class="text-white/30 text-[10px] line-through font-mono orig-price" style="display:none;"></span>
                    <span class="text-white font-mono font-black text-base italic current-price"></span>
                </div>
                <span class="text-status-danger text-[8px] font-black uppercase tracking-widest out-of-stock-label" style="display:none;">Out of Stock</span>
            </div>
        </div>
    </div>
  </template>





  <script>
    const allCheckbox = document.getElementById("allCategory");
    const categoryCheckboxes = document.querySelectorAll(".category-filter");

    categoryCheckboxes.forEach(cb => {
      cb.addEventListener("change", () => {

        if (cb.value === "all" && cb.checked) {
          categoryCheckboxes.forEach(c => {
            if (c.value !== "all") c.checked = false;
          });
        } else {
          allCheckbox.checked = false;
        }

        applyFilters(); // ✅ NO reload
      });
    });
    function showToast(type, title, msg) {
      window.dispatchEvent(new CustomEvent('show-toast', { 
        detail: { message: msg, type: type } 
      }));
    }

    // State Management
    let currentPage = 1;

    function getSelectedCategory() {
      const selected = [];

      document.querySelectorAll('.category-filter:checked').forEach(cb => {
        if (cb.value !== "all") {
          selected.push(cb.value);
        }
      });

      return selected;
    }

    function getSelectedBrands() {
      const brands = [];
      document.querySelectorAll('.brand-item input:checked').forEach(e => {
        brands.push(e.closest('label').dataset.brand);
      });
      return brands;
    }

    function getSelectedPrice() {
      const el = document.querySelector('.price-item input:checked');
      return el ? el.closest('label').dataset.price : '';
    }

    function clearSearch() {
      document.getElementById("searchInput").value = "";
      document.getElementById("clearSearchBtn").style.display = 'none';
      document.getElementById("searchIcon").style.display = 'block';
      loadProducts(1);
    }

    async function loadProducts(page = 1) {
      currentPage = page;
      const container = document.getElementById("productContainer");

      // Create loading state that matches Street-Luxury
      container.innerHTML = `
      <div style="grid-column:1/-1;padding:100px 0;display:flex;justify-content:center;">
        <div style="width:24px;height:24px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;"></div>
      </div>
      <style>@keyframes spin { to { transform:rotate(360deg); } }</style>
    `;

      const search = document.getElementById("searchInput").value;
      const brand = getSelectedBrands().join(",");
      const price = getSelectedPrice();
      const sort = document.getElementById("sortSelect").value;

      const params = new URLSearchParams({ page, search, brand, price, sort });
      
      const categoriesList = getSelectedCategory();
      if (categoriesList.length > 0) {
        categoriesList.forEach(c => params.append("category", c));
      }

      // Update browser URL silently
      if (!window.isPopState) {
        window.history.pushState({ page, search, category: categoriesList, brand, price, sort }, '', `/products?${params}`);
      }
      window.isPopState = false;

      try {
        const res = await fetch(`/products?${params}`, { headers: { "Accept": "application/json" } });
        const data = await res.json();
        
        document.getElementById("currentCount").innerText = data.currentCount;
        renderProducts(data.products, data.wishlistedIds);

        const paginationContainer = document.getElementById("pagination");
        paginationContainer.innerHTML = data.pagination;

      } catch (err) {
        console.error(err);
        container.innerHTML = `<div style="grid-column:1/-1;padding:40px;color:var(--danger);text-align:center;">Failed to load products.</div>`;
      }
    }

    function renderProducts(products, wishlistedIds = []) {
      const container = document.getElementById("productContainer");
      container.innerHTML = "";

      if (products.length === 0) {
        container.innerHTML = `
        <div style="grid-column:1/-1;padding:80px 20px;text-align:center;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--t3)" stroke-width="1.5" style="margin:0 auto 20px;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <h3 class="font-syne" style="font-size:18px;font-weight:700;color:var(--t1);margin-bottom:8px;">No products found</h3>
          <p style="font-size:13px;color:var(--t2);">Try adjusting your search or filters to find what you're looking for.</p>
        </div>
      `;
        return;
      }

      const template = document.getElementById("product-template");

      products.forEach(p => {
        const node = template.content.cloneNode(true);
        
        const variant = p.variants && p.variants.length > 0 ? p.variants[0] : {};
        const imageUrl = (variant && variant.images && variant.images.length > 0) ? variant.images[0] : '/images/placeholder.jpg';
        
        // Price logic
        const basePrice = variant.price || (p.price || 0);
        const hasOffer = p.hasOffer || false;
        const discountedPrice = p.discountedPrice || basePrice;
        
        const pStock = typeof variant.stock !== 'undefined' ? variant.stock : (p.stock || 0);
        const isOutOfStock = pStock <= 0;

        const normalize = (val) => String(val || '').toLowerCase().replace(/\s+/g, "").replace(/gb$/i, "").trim();
        const wishlistKey = `${p._id}_${normalize(variant.color)}_${normalize(variant.storage)}_${normalize(variant.ram)}`;
        const isWishlisted = wishlistedIds.includes(wishlistKey);

        // Populate Template
        const imgLink = node.querySelector('.img-link');
        imgLink.onclick = () => window.location.href = `/products/${p._id}`;
        
        node.querySelector("img").src = imageUrl;
        node.querySelector("img").alt = p.name;
        
        // Badges
        if (p.isNew) node.querySelector('.badge-new').style.display = 'block';
        if (hasOffer) {
            const offerBadge = node.querySelector('.badge-offer');
            if (p.bestOffer) {
                offerBadge.textContent = p.bestOffer.discountType === 'percentage' 
                    ? `${p.bestOffer.discountValue}% OFF` 
                    : `₹${p.bestOffer.discountValue.toLocaleString()} OFF`;
            }
            offerBadge.style.display = 'block';
        }

        // Details
        node.querySelector(".brand-name").textContent = p.brand;
        const productLink = node.querySelector(".product-link");
        productLink.textContent = p.name;
        productLink.href = `/products/${p._id}`;

        // Prices
        if (hasOffer) {
            const origPriceEl = node.querySelector(".orig-price");
            origPriceEl.textContent = "₹" + basePrice.toLocaleString('en-IN');
            origPriceEl.style.display = 'block';
        }
        node.querySelector(".current-price").textContent = "₹" + discountedPrice.toLocaleString('en-IN');

        // Ratings
        const avgRating = Math.round(p.averageRating || 0);
        const revCount = p.reviewCount || 0;
        const starIcons = node.querySelectorAll('.star-icon');
        starIcons.forEach((star, idx) => {
            if (idx < avgRating) {
                star.classList.add('text-accent');
                star.classList.remove('text-white/10');
            } else {
                star.classList.add('text-white/10');
                star.classList.remove('text-accent');
            }
        });
        node.querySelector(".review-count-text").textContent = `(${revCount})`;

        // Stock actions
        if (isOutOfStock) {
            node.querySelector('.quick-add-btn').style.display = 'none';
            node.querySelector('.out-of-stock-btn').style.display = 'block';
            node.querySelector('.out-of-stock-label').style.display = 'block';
        } else {
            const quickAddBtn = node.querySelector('.quick-add-btn');
            quickAddBtn.onclick = (e) => { 
                e.stopPropagation(); 
                if (typeof addToCartFromCard === 'function') {
                    addToCartFromCard(p._id, p.name); 
                } else {
                   // Fallback for simple Quick Add
                   fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId: p._id, variant: '', qty: 1 })
                    }).then(res => res.json()).then(data => {
                        if (data.success) {
                            showToast('success', 'Success', 'Added to Cart');
                        } else {
                            showToast('error', 'Error', data.message || 'Failed to add');
                        }
                    });
                }
            };
        }

        // Wishlist
        const fav = node.querySelector('.wishlist-btn');
        const favSvg = fav.querySelector('svg');
        if (isWishlisted) {
            fav.classList.add('opacity-100', 'text-status-danger');
            fav.classList.remove('opacity-0', 'text-white/50');
            favSvg.setAttribute('fill', 'currentColor');
        }
        fav.onclick = (e) => { 
            e.stopPropagation(); 
            toggleWishlist(p._id, { 
                button: fav,
                color: variant.color || "",
                storage: variant.storage || "",
                ram: variant.ram || ""
            }); 
        };

        container.appendChild(node);
      });
    }

    function applyFilters() {
      loadProducts(1);
    }

    let searchTimer;
    document.getElementById("searchInput").addEventListener("input", (e) => {
      if (e.target.value.length > 0) {
        document.getElementById("clearSearchBtn").style.display = 'block';
        document.getElementById("searchIcon").style.display = 'none';
      } else {
        document.getElementById("clearSearchBtn").style.display = 'none';
        document.getElementById("searchIcon").style.display = 'block';
      }
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => loadProducts(1), 500);
    });

    // Setup pagination on initial load
    document.addEventListener('DOMContentLoaded', () => {
      const searchVal = document.getElementById("searchInput").value;
      if (searchVal.length > 0) {
        document.getElementById("clearSearchBtn").style.display = 'block';
        document.getElementById("searchIcon").style.display = 'none';
      }

      // Handle back/forward buttons
      window.addEventListener('popstate', (e) => {
        if (e.state) {
          window.isPopState = true;
          loadProducts(e.state.page || 1);
        }
      });

      /* CHANGE THIS: 
         Only trigger loadProducts(1) if the product container is empty 
         or if you specifically need to sync the client-side state.
      */
      const productContainer = document.getElementById("productContainer");
      if (!productContainer || productContainer.children.length === 0) {
        loadProducts(1);
      }
    });

  </script>