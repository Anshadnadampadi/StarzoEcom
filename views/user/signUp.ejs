<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Starzo - Signup</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
body {
    background: #f4f6f9;
}

.signup-card {
    max-width: 420px;
    margin: 60px auto;
    padding: 35px;
    border-radius: 15px;
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.error-text {
    font-size: 13px;
    color: red;
}

.password-wrapper {
    position: relative;
}

.toggle-password {
    position: absolute;
    right: 12px;
    top: 38px;
    cursor: pointer;
    font-size: 14px;
    color: #666;
}

.divider {
    text-align: center;
    margin: 20px 0;
    position: relative;
}

.divider::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 100%;
    height: 1px;
    background: #ddd;
}

.divider span {
    background: white;
    padding: 0 15px;
    position: relative;
    font-size: 14px;
    color: #888;
}

.google-btn {
    border: 1px solid #ddd;
    height: 48px;
    border-radius: 10px;
    font-weight: 500;
    background: #fff;
}

.google-btn:hover {
    background-color: #f8f9fa;
}
</style>
</head>

<body>

<div class="signup-card">
    <h4 class="text-center mb-3">Create your Account</h4>

    <form id="signupForm" method="post" action="/auth/signup">

        <!-- Full Name -->
        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="name"  class="form-control" id="name">
            <div id="nameError" class="error-text"></div>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="text" name="email" class="form-control" id="email">
            <div id="emailError" class="error-text"></div>
        </div>

        <!-- Password -->
        <div class="mb-3 password-wrapper">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" id="password">
            <span class="toggle-password" onclick="togglePassword('password')">👁</span>
            <div id="passwordError" class="error-text"></div>
        </div>

        <!-- Confirm Password -->
        <div class="mb-3 password-wrapper">
            <label class="form-label">Confirm Password</label>
            <input type="password"  class="form-control" id="confirmPassword">
            <span class="toggle-password" onclick="togglePassword('confirmPassword')">👁</span>
            <div id="confirmPasswordError" class="error-text"></div>
        </div>

        <button type="submit" class="btn btn-primary w-100">Sign Up</button>

        <!-- Divider -->
        <div class="divider">
            <span>OR</span>
        </div>

        <!-- Google Signup Button -->
       <button type="button" onclick="window.location.href='/auth/google'" class="btn google-btn w-100 mb-3" aria-label="Sign up with Google">
                <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" width="18" class="me-2">
                Sign up with Google
            </button>

        <div class="text-center mt-3">
            <small>Already have an account? <a href="/auth/login">Login</a></small>
        </div>

    </form>
</div>

<script>

// VALIDATION FUNCTIONS

function validateName(name) {
    return /^[A-Za-z ]{3,30}$/.test(name);
}

function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

function validatePassword(password) {
    return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/.test(password);
}

// INLINE VALIDATION

document.getElementById("name").addEventListener("input", function() {
    document.getElementById("nameError").textContent =
        validateName(this.value.trim()) ? "" : "Name must be 3-30 letters only.";
});

document.getElementById("email").addEventListener("input", function() {
    document.getElementById("emailError").textContent =
        validateEmail(this.value.trim()) ? "" : "Enter a valid email address.";
});

document.getElementById("password").addEventListener("input", function() {
    document.getElementById("passwordError").textContent =
        validatePassword(this.value) ? "" :
        "Password must contain uppercase, lowercase, number & special character.";
});

document.getElementById("confirmPassword").addEventListener("input", function() {
    const password = document.getElementById("password").value;
    document.getElementById("confirmPasswordError").textContent =
        this.value === password ? "" : "Passwords do not match.";
});

// SUBMIT
document.getElementById("signupForm").addEventListener("submit", function(e) {
    
    const name = document.getElementById("name").value.trim();
    const email = document.getElementById("email").value.trim();
    const password = document.getElementById("password").value;
    const confirmPassword = document.getElementById("confirmPassword").value;
    
    if (!validateName(name) ||
    !validateEmail(email) ||
    !validatePassword(password) ||
    password !== confirmPassword) {
        alert("Please fix the errors before submitting.");
        e.preventDefault();
        return false;
    }else{
      
        return true
    }
    
});

// PASSWORD TOGGLE

function togglePassword(id) {
    const input = document.getElementById(id);
    input.type = input.type === "password" ? "text" : "password";
}



const params = new URLSearchParams(window.location.search);
const msg = params.get("msg");

if(msg){
Swal.fire({
  toast: true,
  position: "top-end",
  icon: "error",
  title: msg,
  showConfirmButton: false,
  timer: 3000
});
}


</script>

</body>
</html>
