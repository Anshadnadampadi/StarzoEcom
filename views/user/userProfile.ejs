<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile – Starzo</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
    rel="stylesheet" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Material Icons -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <!-- SweetAlert2 -->

  <style>
    /* ━━━━━━━━━━━━━━━━━ RESET & ROOT ━━━━━━━━━━━━━━━━━ */
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --brand: #1a1aff;
      --brand-hover: #0000d4;
      --brand-light: rgba(26, 26, 255, .07);
      --brand-glow: rgba(26, 26, 255, .18);
      --bg-page: #f2f2f8;
      --bg-card: #ffffff;
      --bg-subtle: #f8f8fc;
      --border: #e6e6f0;
      --border-focus: #1a1aff;
      --text-900: #0d0d1e;
      --text-600: #3a3a5c;
      --text-400: #6e6e96;
      --text-200: #adadcc;
      --green: #16c47f;
      --amber: #f59e0b;
      --red: #f43f5e;
      --gold: #f59e0b;
      --radius-xs: 6px;
      --radius-sm: 10px;
      --radius-md: 14px;
      --radius-lg: 20px;
      --radius-xl: 26px;
      --shadow-sm: 0 1px 4px rgba(13, 13, 30, .06);
      --shadow-md: 0 4px 24px rgba(13, 13, 30, .09);
      --shadow-lg: 0 12px 40px rgba(13, 13, 30, .12);
      --shadow-brand: 0 4px 20px rgba(26, 26, 255, .30);
      --nav-h: 60px;
      --ease: cubic-bezier(.4, 0, .2, 1);
    }

    html {
      font-size: 15px;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-page);
      color: var(--text-900);
      min-height: 100vh;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
      background: none;
    }

    input,
    textarea,
    select {
      font-family: inherit;
    }

    /* ━━━━━━━━━━━━━━━━━ TOP NAV ━━━━━━━━━━━━━━━━━ */
    .topnav {
      position: sticky;
      top: 0;
      z-index: 200;
      height: var(--nav-h);
      background: #fff;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 32px;
      gap: 0;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
      margin-right: 40px;
    }

    .nav-logo-icon {
      width: 30px;
      height: 30px;
      background: var(--brand);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 800;
      font-size: 15px;
      box-shadow: var(--shadow-brand);
    }

    .nav-logo-text {
      font-size: 17px;
      font-weight: 800;
      color: var(--text-900);
      letter-spacing: -0.4px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
      flex: 1;
    }

    .nav-link {
      padding: 7px 14px;
      border-radius: var(--radius-xs);
      font-size: 13.5px;
      font-weight: 500;
      color: var(--text-400);
      transition: background .18s var(--ease), color .18s var(--ease);
    }

    .nav-link:hover {
      background: var(--bg-subtle);
      color: var(--text-900);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-left: auto;
    }

    .nav-icon-btn {
      width: 36px;
      height: 36px;
      border-radius: 9999px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-400);
      transition: background .15s, color .15s;
    }

    .nav-icon-btn:hover {
      background: var(--bg-subtle);
      color: var(--text-900);
    }

    .nav-icon-btn .material-icons-round {
      font-size: 20px;
    }

    .nav-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border);
      cursor: pointer;
      transition: border-color .15s;
    }

    .nav-avatar:hover {
      border-color: var(--brand);
    }

    /* ━━━━━━━━━━━━━━━━━ PAGE LAYOUT ━━━━━━━━━━━━━━━━━ */
    .page-wrapper {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 20px 60px;
      animation: fadeUp .4s var(--ease) both;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .page-grid {
      display: grid;
      grid-template-columns: 228px 1fr;
      gap: 22px;
      align-items: start;
    }


    /* ━━━━━━━━━━━━━━━━━ MAIN CONTENT ━━━━━━━━━━━━━━━━━ */
    .main-content {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .content-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }

    /* ━━━━━━━━━━━━━━━━━ CARD HEADER ━━━━━━━━━━━━━━━━━ */
    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 28px 16px;
      border-bottom: 1px solid var(--border);
    }

    .card-header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .card-title {
      font-size: 15.5px;
      font-weight: 700;
      color: var(--text-900);
      letter-spacing: -0.2px;
    }

    .premium-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: linear-gradient(135deg, #fff7e6 0%, #ffefc0 100%);
      border: 1px solid #f6c84a;
      color: #b45309;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 9999px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .premium-badge .material-icons-round {
      font-size: 11px;
      color: var(--gold);
    }

    .btn-edit-profile {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--bg-subtle);
      border: 1.5px solid var(--border);
      color: var(--text-600);
      font-size: 12.5px;
      font-weight: 600;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      transition: all .18s var(--ease);
    }

    .btn-edit-profile:hover {
      background: var(--brand);
      border-color: var(--brand);
      color: #fff;
      box-shadow: var(--shadow-brand);
    }

    .btn-edit-profile .material-icons-round {
      font-size: 14px;
    }

    /* ━━━━━━━━━━━━━━━━━ CARD BODY ━━━━━━━━━━━━━━━━━ */
    .card-body {
      padding: 24px 28px;
    }

    /* ━━━━━━━━━━━━━━━━━ PHOTO SECTION ━━━━━━━━━━━━━━━━━ */
    .photo-section {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
    }

    .avatar-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .avatar-ring {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      padding: 2px;
      background: linear-gradient(135deg, var(--brand), #6060ff);
      box-shadow: 0 3px 14px var(--brand-glow);
    }

    .avatar-inner {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      border: 2.5px solid white;
    }

    .avatar-inner img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .avatar-online {
      position: absolute;
      bottom: 3px;
      right: 3px;
      width: 13px;
      height: 13px;
      background: var(--green);
      border: 2.5px solid white;
      border-radius: 50%;
    }

    .photo-meta {
      flex: 1;
    }

    .photo-label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-900);
      margin-bottom: 4px;
    }

    .photo-hint {
      font-size: 12px;
      color: var(--text-400);
      line-height: 1.55;
      margin-bottom: 12px;
    }

    .photo-actions {
      display: flex;
      align-items: center;
      gap: 0;
    }

    .btn-change {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--brand);
      color: #fff;
      font-size: 12.5px;
      font-weight: 600;
      padding: 7px 16px;
      border-radius: var(--radius-xs);
      box-shadow: var(--shadow-brand);
      transition: all .18s var(--ease);
    }

    .btn-change:hover {
      background: var(--brand-hover);
      transform: translateY(-1px);
    }

    .btn-change .material-icons-round {
      font-size: 13px;
    }

    .photo-sep {
      width: 1px;
      height: 20px;
      background: var(--border);
      margin: 0 12px;
    }

    .btn-remove-photo {
      font-size: 12.5px;
      font-weight: 500;
      color: var(--text-400);
      padding: 4px 2px;
      transition: color .15s;
    }

    .btn-remove-photo:hover {
      color: var(--red);
    }

    /* ━━━━━━━━━━━━━━━━━ FIELD GRID ━━━━━━━━━━━━━━━━━ */
    .field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 32px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-400);
      letter-spacing: 0.02em;
    }

    .field-label .material-icons-round {
      font-size: 14px;
      color: var(--text-200);
    }

    .field-value {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-900);
      line-height: 1.4;
    }

    /* ━━━━━━━━━━━━━━━━━ SECURITY CARD ━━━━━━━━━━━━━━━━━ */
    .security-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .security-info {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .security-icon-wrap {
      width: 40px;
      height: 40px;
      border-radius: var(--radius-sm);
      background: var(--bg-subtle);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .security-icon-wrap .material-icons-round {
      font-size: 19px;
      color: var(--text-400);
    }

    .security-label {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-900);
      margin-bottom: 2px;
    }

    .security-meta {
      font-size: 12px;
      color: var(--text-400);
    }

    .btn-change-pw {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--bg-subtle);
      border: 1.5px solid var(--border);
      color: var(--text-600);
      font-size: 12.5px;
      font-weight: 600;
      padding: 8px 16px;
      border-radius: var(--radius-sm);
      white-space: nowrap;
      transition: all .18s var(--ease);
      flex-shrink: 0;
    }

    .btn-change-pw:hover {
      border-color: var(--brand);
      color: var(--brand);
      background: var(--brand-light);
    }

    /* ━━━━━━━━━━━━━━━━━ REFER & EARN CARD ━━━━━━━━━━━━━━━━━ */
    .referral-body {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: start;
    }

    .referral-left-title {
      font-size: 15.5px;
      font-weight: 700;
      color: var(--text-900);
      margin-bottom: 6px;
    }

    .referral-left-desc {
      font-size: 13px;
      color: var(--text-400);
      line-height: 1.6;
      margin-bottom: 18px;
      max-width: 380px;
    }

    .referral-code-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-200);
      margin-bottom: 6px;
    }

    .referral-code-box {
      display: flex;
      align-items: center;
      gap: 0;
      background: var(--bg-subtle);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      overflow: hidden;
      width: fit-content;
      margin-bottom: 14px;
    }

    .referral-code {
      padding: 9px 16px;
      font-size: 14.5px;
      font-weight: 700;
      color: var(--brand);
      letter-spacing: 0.06em;
    }

    .btn-copy-code {
      padding: 0 12px;
      border-left: 1.5px solid var(--border);
      height: 100%;
      min-height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-400);
      transition: background .15s, color .15s;
    }

    .btn-copy-code:hover {
      background: #eeeef8;
      color: var(--brand);
    }

    .btn-copy-code .material-icons-round {
      font-size: 16px;
    }

    .btn-share {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      width: 100%;
      max-width: 224px;
      background: var(--brand);
      color: #fff;
      font-size: 13.5px;
      font-weight: 700;
      padding: 11px 24px;
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-brand);
      letter-spacing: 0.01em;
      transition: all .18s var(--ease);
    }

    .btn-share:hover {
      background: var(--brand-hover);
      transform: translateY(-1px);
      box-shadow: 0 6px 26px rgba(26, 26, 255, .38);
    }

    .btn-share .material-icons-round {
      font-size: 16px;
    }

    .referral-stats {
      display: flex;
      flex-direction: column;
      gap: 12px;
      flex-shrink: 0;
    }

    .stat-pill {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-subtle);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 18px;
      min-width: 160px;
    }

    .stat-pill-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .stat-pill-icon.blue {
      background: rgba(26, 26, 255, .1);
      color: var(--brand);
    }

    .stat-pill-icon.amber {
      background: rgba(245, 158, 11, .12);
      color: var(--amber);
    }

    .stat-pill-icon .material-icons-round {
      font-size: 18px;
    }

    .stat-pill-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-400);
      margin-bottom: 2px;
    }

    .stat-pill-value {
      font-size: 20px;
      font-weight: 800;
      color: var(--text-900);
      letter-spacing: -0.5px;
      line-height: 1;
    }

    /* ━━━━━━━━━━━━━━━━━ BOTTOM ACTIONS ━━━━━━━━━━━━━━━━━ */
    .bottom-actions {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 10px;
      padding: 16px 28px 20px;
      border-top: 1px solid var(--border);
    }



    /* ━━━━━━━━━━━━━━━━━ MODALS ━━━━━━━━━━━━━━━━━ */
    .pw-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(13, 13, 30, .45);
      backdrop-filter: blur(3px);
      z-index: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s var(--ease);
    }

    .pw-modal-backdrop.open {
      opacity: 1;
      pointer-events: all;
    }

    .pw-modal {
      background: #fff;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      width: 100%;
      max-width: 440px;
      padding: 32px;
      transform: translateY(20px) scale(.97);
      transition: transform .28s var(--ease);
    }

    .pw-modal-backdrop.open .pw-modal {
      transform: translateY(0) scale(1);
    }

    .modal-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 22px;
    }

    .modal-title {
      font-size: 17px;
      font-weight: 700;
      color: var(--text-900);
    }

    .modal-subtitle {
      font-size: 13px;
      color: var(--text-400);
      margin-top: 4px;
    }

    .modal-close {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: var(--bg-subtle);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-400);
      flex-shrink: 0;
      transition: background .15s;
    }

    .modal-close:hover {
      background: #e8e8f4;
      color: var(--text-900);
    }

    .modal-close .material-icons-round {
      font-size: 17px;
    }

    .modal-field {
      margin-bottom: 16px;
    }

    .modal-label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-400);
      letter-spacing: 0.03em;
      margin-bottom: 7px;
    }

    .modal-input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 14px;
      color: var(--text-900);
      background: var(--bg-subtle);
      outline: none;
      transition: border-color .15s, box-shadow .15s;
    }

    .modal-input:focus {
      border-color: var(--border-focus);
      background: #fff;
      box-shadow: 0 0 0 3.5px rgba(26, 26, 255, .10);
    }

    .modal-input::placeholder {
      color: var(--text-200);
    }

    .password-input-wrap {
      position: relative;
    }

    .password-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-200);
      cursor: pointer;
      display: flex;
      transition: color .15s;
    }

    .password-toggle:hover {
      color: var(--text-400);
    }

    .password-toggle .material-icons-round {
      font-size: 18px;
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 24px;
    }

    .btn-modal-cancel {
      padding: 9px 20px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 13.5px;
      font-weight: 600;
      color: var(--text-600);
      background: transparent;
      transition: background .15s;
    }

    .btn-modal-cancel:hover {
      background: var(--bg-subtle);
    }

    .btn-modal-save {
      padding: 9px 22px;
      background: var(--brand);
      border-radius: var(--radius-sm);
      font-size: 13.5px;
      font-weight: 700;
      color: #fff;
      box-shadow: var(--shadow-brand);
      transition: all .18s;
    }

    .btn-modal-save:hover {
      background: var(--brand-hover);
      transform: translateY(-1px);
    }

    /* ━━━━━━━━━━━━━━━━━ TOAST ━━━━━━━━━━━━━━━━━ */
    .toast {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%) translateY(16px);
      background: var(--text-900);
      color: #fff;
      padding: 12px 22px;
      border-radius: var(--radius-md);
      font-size: 13.5px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 9px;
      box-shadow: var(--shadow-lg);
      opacity: 0;
      pointer-events: none;
      transition: all .3s var(--ease);
      z-index: 999;
      white-space: nowrap;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .toast .material-icons-round {
      font-size: 17px;
      color: var(--green);
    }

    /* ━━━━━━━━━━━━━━━━━ STRENGTH BAR ━━━━━━━━━━━━━━━━━ */
    .strength-row {
      display: flex;
      gap: 6px;
      margin-top: 8px;
    }

    .strength-seg {
      flex: 1;
      height: 3px;
      border-radius: 9999px;
      background: var(--border);
      transition: background .25s;
    }

    .strength-seg.filled-weak {
      background: var(--red);
    }

    .strength-seg.filled-mid {
      background: var(--amber);
    }

    .strength-seg.filled-strong {
      background: var(--green);
    }

    .strength-label {
      font-size: 11px;
      color: var(--text-200);
      margin-top: 5px;
    }

    /* ━━━━━━━━━━━━━━━━━ RESPONSIVE ━━━━━━━━━━━━━━━━━ */
    @media (max-width: 768px) {
      .page-grid {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
      }

      .field-grid {
        grid-template-columns: 1fr;
      }

      .referral-body {
        grid-template-columns: 1fr;
      }

      .topnav .nav-links {
        display: none;
      }
    }

    /* ━━━━━━━━━━━━━━━━━ STAGGER ANIMATIONS ━━━━━━━━━━━━━━━━━ */
    .content-card:nth-child(1) {
      animation: fadeUp .4s var(--ease) .05s both;
    }

    .content-card:nth-child(2) {
      animation: fadeUp .4s var(--ease) .12s both;
    }

    .content-card:nth-child(3) {
      animation: fadeUp .4s var(--ease) .19s both;
    }

    .sidebar {
      animation: fadeUp .4s var(--ease) both;
    }

    /* file input hidden */
    #photoInput {
      display: none;
    }
  </style>
</head>

<body>

  <!-- ════════════════ TOP NAV ════════════════ -->
  <nav class="topnav">
    <div class="nav-logo">
      <div class="nav-logo-icon">S</div>
      <span class="nav-logo-text">Starzo</span>
    </div>

    <div class="nav-links">
      <a class="nav-link" href="#">Latest Flagships</a>
      <a class="nav-link" href="#">Budget Phones</a>
      <a class="nav-link" href="#">Accessories</a>
    </div>

    <div class="nav-actions">
      <button class="nav-icon-btn" title="Search">
        <span class="material-icons-round">search</span>
      </button>
      <button class="nav-icon-btn" title="Cart" style="position:relative">
        <span class="material-icons-round">shopping_bag</span>
        <span
          style="position:absolute;top:5px;right:5px;width:8px;height:8px;background:var(--brand);border-radius:50%;border:2px solid #fff;"></span>
      </button>
      <img src="<%= user && (user.profileImage || user.avatar) ? (user.profileImage || user.avatar) : '/images/default-avatar.png' %>" alt="User" class="nav-avatar" title="My Profile" />
    </div>
  </nav>

  <!-- hidden file input -->
  <input type="file" id="photoInput" accept="image/*" onchange="previewPhoto(event)" />

  <!-- ════════════════ PAGE ════════════════ -->
  <div class="page-wrapper">
    <div class="page-grid">

      <%-include('./partials/sidebar',{currentPath:'/profile'})%>

        <!-- ╔══════════════ MAIN CONTENT ══════════════╗ -->
        <main class="main-content">

          <!-- ── Card 1: Profile Information ── -->
          <div class="content-card">

            <div class="card-header">
              <div class="card-header-left">
                <span class="card-title">Profile Information</span>
               
              </div>
              <a href="/editProfile" class="btn-edit-profile">
                <span class="material-icons-round">edit</span>
                Edit Profile
              </a>
            </div>

            <div class="card-body">

              <!-- Photo row -->
              <div class="photo-section">
                <div class="avatar-wrap">
                  <div class="avatar-ring">
                    <div class="avatar-inner">
                      <img id="mainAvatar"
                        src="<%= user && (user.profileImage || user.avatar) ? (user.profileImage || user.avatar) : '/images/default-avatar.png' %>"
                        alt="<%= user ? user.name : '' %>" />
                    </div>
                  </div>
                  <div class="avatar-online" title="Online"></div>
                </div>

                <div class="photo-meta">
                  <div class="photo-label">Profile Photo</div>
                 
                  <div class="photo-hint">
                    This will be<br />
                    displayed on<br />
                    your profile and<br />
                    reviews.
                  </div>
                  <div class="photo-actions">
                    <button class="btn-change" onclick="document.getElementById('photoInput').click()">
                      <span class="material-icons-round">photo_camera</span>
                      Change Photo
                    </button>
                    <div class="photo-sep"></div>
                    <button class="btn-remove-photo" onclick="removeAvatar()">Remove</button>
                  </div>
                </div>
              </div>

              <!-- Info fields -->
              <div class="field-grid">

                <div class="field">
                  <div class="field-label">
                    <span class="material-icons-round">person_outline</span>
                    Full Name
                  </div>
                  <div class="field-value" id="displayFullName">
                    <%= user ? user.name : '' %>
                  </div>
                </div>

                <div class="field">
                  <div class="field-label">
                    <span class="material-icons-round">mail_outline</span>
                    Email Address
                  </div>
                  <div class="field-value" id="displayEmail">
                    <%= user ? user.email : '' %>
                  </div>
                </div>

                <div class="field">
                  <div class="field-label">
                    <span class="material-icons-round">smartphone</span>
                    Phone Number
                  </div>
                  <div class="field-value" id="displayPhone">
                    <%= user && user.phone ? user.phone : '' %>
                  </div>
                </div>

                <div class="field">
                  <div class="field-label">
                    <span class="material-icons-round">cake</span>
                    Date of Birth
                  </div>
                  <div class="field-value" id="displayDob">
                    <%= user && user.dob ? user.dob.toISOString().split('T')[0] : '' %>
                  </div>
                </div>

              </div>

            </div>

          </div>

          <!-- ── Card 2: Security ── -->
          <div class="content-card">

            <div class="card-header">
              <span class="card-title">Security</span>
            </div>

            <div class="card-body">
              <div class="security-row">
                <div class="security-info">
                  <div class="security-icon-wrap">
                    <span class="material-icons-round">lock_outline</span>
                  </div>
                  <div>
                    <div class="security-label">Password</div>
                    <div class="security-meta">Last changed 3 months ago</div>
                  </div>
                </div>
                <button class="btn-change-pw" onclick="openPasswordModal()">
                  Change Password
                </button>
              </div>
            </div>

          </div>

          <!-- ── Card 3: Refer & Earn ── -->
          <div class="content-card">

            <div class="card-header">
              <span class="card-title">Refer &amp; Earn</span>
            </div>

            <div class="card-body">
              <div class="referral-body">

                <!-- Left -->
                <div>
                  <div class="referral-left-title">Share the Tech, Get Rewards!</div>
                  <p class="referral-left-desc">
                    Invite your friends to Zyrox. When they make their first smartphone
                    purchase using your code, you both get $50 in wallet credits.
                  </p>

                  <div class="referral-code-label">Your Referral Code</div>
                  <div class="referral-code-box">
                    <span class="referral-code" id="refCode">ALEX-TECH-123</span>
                    <button class="btn-copy-code" onclick="copyCode()" title="Copy code">
                      <span class="material-icons-round">content_copy</span>
                    </button>
                  </div>

                  <button class="btn-share" onclick="shareCode()">
                    <span class="material-icons-round">share</span>
                    Share Now
                  </button>
                </div>

                <!-- Right stats -->
                <div class="referral-stats">

                  <div class="stat-pill">
                    <div class="stat-pill-icon blue">
                      <span class="material-icons-round">group_add</span>
                    </div>
                    <div>
                      <div class="stat-pill-label">Total Referrals</div>
                      <div class="stat-pill-value">12</div>
                    </div>
                  </div>

                  <div class="stat-pill">
                    <div class="stat-pill-icon amber">
                      <span class="material-icons-round">monetization_on</span>
                    </div>
                    <div>
                      <div class="stat-pill-label">Earnings Earned</div>
                      <div class="stat-pill-value">$600</div>
                    </div>
                  </div>

                </div>

              </div>
            </div>

          </div>

        </main>

    </div>
  </div>


  <!-- ════════════════ CHANGE PASSWORD MODAL ════════════════ -->
  <div class="pw-modal-backdrop" id="passwordModal" onclick="closeOnBackdrop(event, 'passwordModal')">
    <div class="pw-modal">
      <div class="modal-header">
        <div>
          <div  class="modal-title">Change Password</div>
          <div class="modal-subtitle">Choose a strong, unique password</div>
        </div>
        <button class="modal-close" onclick="closeModal('passwordModal')">
          <span class="material-icons-round">close</span>
        </button>
      </div>

      <div class="modal-field">
        <label class="modal-label" for="currentPw">Current Password</label>
        <div class="password-input-wrap">
          <input class="modal-input" id="currentPw" type="password" placeholder="Enter current password" />
          <span class="password-toggle" onclick="togglePw('currentPw', this)">
            <span class="material-icons-round">visibility_off</span>
          </span>
        </div>
      </div>

      <div class="modal-field">
        <label class="modal-label" for="newPw">New Password</label>
        <div class="password-input-wrap">
          <input class="modal-input" id="newPw" type="password" placeholder="Min. 8 characters"
            oninput="checkStrength(this.value)" />
          <span class="password-toggle" onclick="togglePw('newPw', this)">
            <span class="material-icons-round">visibility_off</span>
          </span>
        </div>
        <div class="strength-row" id="strengthRow">
          <div class="strength-seg" id="s1"></div>
          <div class="strength-seg" id="s2"></div>
          <div class="strength-seg" id="s3"></div>
          <div class="strength-seg" id="s4"></div>
        </div>
        <div class="strength-label" id="strengthLabel">Enter a password</div>
      </div>

      <div class="modal-field">
        <label class="modal-label" for="confirmPw">Confirm New Password</label>
        <div class="password-input-wrap">
          <input class="modal-input" id="confirmPw" type="password" placeholder="Repeat new password" />
          <span class="password-toggle" onclick="togglePw('confirmPw', this)">
            <span class="material-icons-round">visibility_off</span>
          </span>
        </div>
      </div>

      <div class="modal-actions">
        <button class="btn-modal-cancel" onclick="closeModal('passwordModal')">Cancel</button>
        <button class="btn-modal-save" onclick="applyPassword()">Update Password</button>
      </div>
    </div>
  </div>

  <!-- ════════════════ TOAST ════════════════ -->
  <div class="toast" id="toast">
    <span class="material-icons-round">check_circle</span>
    <span id="toastMsg">Profile updated!</span>
  </div>
  

  <!-- ════════════════ SCRIPTS ════════════════ -->
  <script>

/* ── Sidebar tab switch ── */
function showTab(el) {
  document.querySelectorAll('.sidebar-item')
    .forEach(i => i.classList.remove('active'));
  el.classList.add('active');
}

/* ── Photo preview ── */
function previewPhoto(e) {

  const file = e.target.files[0];
  if (!file) return;

  const allowedTypes = ["image/png", "image/jpeg", "image/jpg", "image/webp", "image/gif"];

  if (!allowedTypes.includes(file.type)) {
    toast("Only PNG, JPG, WEBP or GIF images are allowed", false);
    e.target.value = "";
    return;
  }

  if (file.size > 2 * 1024 * 1024) {
    toast("File size must be under 2MB", false);
    e.target.value = "";
    return;
  }

  const reader = new FileReader();

  reader.onload = function (ev) {
    document.getElementById("mainAvatar").src = ev.target.result;
    const navAv = document.querySelector(".nav-avatar");
    if (navAv) navAv.src = ev.target.result;
  };

  reader.readAsDataURL(file);

  const formData = new FormData();
  formData.append("profileImage", file);

  fetch("/upload-profile", {
    method: "POST",
    body: formData
  })
    .then(r => r.json())
    .then(result => {
      if (!result.success) {
        throw new Error(result.message || "Unable to upload image");
      }

      if (result.imageUrl) {
        document.getElementById("mainAvatar").src = result.imageUrl;
        const navAv = document.querySelector(".nav-avatar");
        if (navAv) navAv.src = result.imageUrl;
      }

      toast("Profile photo updated!");
      e.target.value = "";
    })
    .catch(err => {
      console.error(err);
      toast(err.message || "Image upload failed", false);
      e.target.value = "";
    });
}


/* ── Modal open ── */
function openPasswordModal() {
  document.getElementById('passwordModal').classList.add('open');
  document.body.style.overflow = "hidden";
}

/* ── Modal close ── */
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  document.body.style.overflow = "auto";
}

/* ── Close when clicking outside ── */
function closeOnBackdrop(e, id) {
  if (e.target.id === id) closeModal(id);
}


/* ── Esc key closes modal ── */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.pw-modal-backdrop.open')
      .forEach(m => m.classList.remove('open'));
  }
});


/* ── Apply password ── */
function applyPassword() {

  const cur = document.getElementById('currentPw').value;
  const nw = document.getElementById('newPw').value;
  const conf = document.getElementById('confirmPw').value;

  if (!cur) {
    toast('Enter your current password', false);
    return;
  }

  if (nw.length < 8) {
    toast('Password must be at least 8 characters', false);
    return;
  }

  if (nw !== conf) {
    toast("Passwords don't match", false);
    return;
  }

  fetch('/profile/password', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      currentPw: cur,
      newPw: nw,
      confirmPw: conf
    })
  })
  .then(r => r.json())
  .then(result => {

    if (result.success) {

      closeModal('passwordModal');

      toast('Password updated!');

      document.getElementById('currentPw').value = '';
      document.getElementById('newPw').value = '';
      document.getElementById('confirmPw').value = '';

    } else {

      toast(result.message || 'Unable to change password', false);

    }

  })
  .catch(err => {

    console.error(err);
    toast('Network error', false);

  });

}


/* ── Password strength ── */
function checkStrength(pw) {

  const s1 = document.getElementById('s1');
  const s2 = document.getElementById('s2');
  const s3 = document.getElementById('s3');
  const s4 = document.getElementById('s4');

  const label = document.getElementById('strengthLabel');

  const bars = [s1, s2, s3, s4];

  bars.forEach(b => b.className = "strength-seg");

  let score = 0;

  if (pw.length >= 8) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;

  let colorClass = "filled-weak";
  let labelText = "Weak";

  if (score === 2) {
    colorClass = "filled-mid";
    labelText = "Fair";
  }

  if (score === 3) {
    colorClass = "filled-strong";
    labelText = "Good";
  }

  if (score === 4) {
    colorClass = "filled-strong";
    labelText = "Strong";
  }

  for (let i = 0; i < score; i++) {
    bars[i].classList.add(colorClass);
  }

  label.textContent = labelText;

}


/* ── Toggle password ── */
function togglePw(inputId, iconEl) {

  const inp = document.getElementById(inputId);
  const icon = iconEl.querySelector('.material-icons-round');

  if (inp.type === 'password') {

    inp.type = 'text';
    icon.textContent = 'visibility';

  } else {

    inp.type = 'password';
    icon.textContent = 'visibility_off';

  }

}


/* ── Copy referral code ── */
function copyCode() {

  const code = document.getElementById('refCode').textContent;

  if (navigator.clipboard) {

    navigator.clipboard.writeText(code)
      .then(() => toast('Referral code copied!'));

  } else {

    toast('Code: ' + code);

  }

}


/* ── Share code ── */
function shareCode() {

  const code = document.getElementById('refCode').textContent;

  if (navigator.share) {

    navigator.share({
      title: 'Join Starzo!',
      text: `Use my referral code ${code}`,
      url: window.location.origin
    });

  } else {

    copyCode();

  }

}


/* ── Toast ── */
function toast(msg, ok = true) {

  const t = document.getElementById('toast');
  const ic = t.querySelector('.material-icons-round');
  const tx = document.getElementById('toastMsg');

  ic.style.color = ok ? 'var(--green)' : 'var(--amber)';
  ic.textContent = ok ? 'check_circle' : 'warning';

  tx.textContent = msg;

  t.classList.add('show');

  setTimeout(() => {
    t.classList.remove('show');
  }, 3000);

}
function showToast(message, type = "error") {

Toastify({
    text: message,
    duration: 3000,
    gravity: "top",
    position: "right",
    backgroundColor: type === "error" ? "#ff4d4f" : "#28a745",
    stopOnFocus: true
}).showToast();

}



const msg = "<%= msg %>";

if(msg && msg !== "null"){

    const toast = document.getElementById("toast");
    const toastMsg = document.getElementById("toastMsg");

    toastMsg.innerText = msg;

    toast.classList.add("show");

    setTimeout(()=>{
        toast.classList.remove("show");
    },3000);

}
console.log("<%= msg %>");

</script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

</body>

</html>
