<%- contentFor('body') %>

<style>
    .wallet-container {
        font-family: 'Inter', sans-serif;
        background-color: #050505;
        color: #ffffff;
        min-height: 100vh;
    }

    .display-heading {
        font-family: 'Outfit', sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: #ffffff;
    }

    .balance-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 3.5rem;
        margin-bottom: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .balance-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255, 106, 0, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .label-xs {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.25em;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        display: block;
        font-family: 'Outfit', sans-serif;
    }

    .balance-amount {
        font-size: 4.5rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        color: #ffffff;
        font-family: 'Outfit', sans-serif;
    }

    .btn-add-money {
        background-color: #ff6a00;
        color: #000000;
        padding: 1.2rem 2.8rem;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: none;
        cursor: pointer;
        font-family: 'Outfit', sans-serif;
        box-shadow: 0 10px 30px rgba(255, 106, 0, 0.2);
    }

    .btn-add-money:hover {
        background-color: #ffffff;
        color: #000000;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(255, 255, 255, 0.1);
    }

    .transaction-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 2rem;
    }

    .transaction-table th {
        text-align: left;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.4);
        padding: 2.2rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        font-family: 'Outfit', sans-serif;
    }

    .transaction-table td {
        padding: 2.2rem 0;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.6);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-weight: 500;
    }

    .transaction-table tr:hover td {
        color: #ffffff;
        background: rgba(255, 255, 255, 0.01);
    }

    .status-success {
        color: #10b981;
        font-weight: 900;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-family: 'Outfit', sans-serif;
    }

    .status-success::before {
        content: '';
        width: 6px;
        height: 6px;
        background-color: #10b981;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 12px #10b981;
    }

    .amount-credit {
        color: #10b981;
        font-weight: 900;
        font-size: 15px;
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.01em;
    }

    .amount-debit {
        color: #ef4444;
        font-weight: 900;
        font-size: 15px;
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.01em;
    }

    .order-link {
        color: #ff6a00;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 106, 0, 0.3);
        font-weight: 800;
        padding-bottom: 2px;
        transition: all 0.3s ease;
        font-family: 'Outfit', sans-serif;
    }

    .order-link:hover {
        color: #ffffff;
        border-bottom-color: #ffffff;
    }

    .mono-id {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 600;
    }

    /* Custom Scrollbar for dark theme */
    .custom-scrollbar::-webkit-scrollbar {
        height: 4px;
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #ff6a00;
    }
</style>

<div class="wallet-container py-24 relative overflow-hidden" x-data="walletManager()">
    <!-- Ambient Gloom -->
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-accent/5 to-transparent pointer-events-none"></div>

    <div class="max-w-screen-xl mx-auto px-6 lg:px-8 relative z-10">
        
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            
            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <%- include('../partials/account-sidebar', { activeTab: 'wallet' }) %>
            </div>

            <!-- Content Area -->
            <div class="lg:col-span-3">
                
                <div class="mb-16">
                    <h1 class="display-heading text-6xl mb-4">My <span class="text-accent italic">Wallet.</span></h1>
                    <p class="text-[10px] font-black text-white/30 uppercase tracking-[0.4em]">Integrated Credit protocol & Transaction history</p>
                </div>

                <!-- Balance Section -->
                <div class="balance-card">
                    <div class="space-y-2">
                        <span class="label-xs">Active Liquidity</span>
                        <div class="balance-amount">₹<%= (wallet ? wallet.balance : 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></div>
                    </div>
                    <button @click="openTopupModal" class="btn-add-money">Top Up Wallet</button>
                </div>

                <!-- History Section -->
                <div class="mt-20">
                    <div class="flex items-center justify-between border-b border-white/5 pb-10 mb-10">
                        <h2 class="display-heading text-3xl">Transaction <span class="text-accent italic">History.</span></h2>
                        <span class="text-[9px] font-black text-white/20 uppercase tracking-[0.3em]"><%= (wallet ? wallet.transactions.length : 0) %> Events Logged</span>
                    </div>
                    
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="transaction-table">
                            <thead>
                                <tr>
                                    <th>Date & Time</th>
                                    <th>Transaction ID</th>
                                    <th>Order ID</th>
                                    <th>Process Abstract</th>
                                    <th>Status</th>
                                    <th style="text-align: right;">Magnitude</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>
                                    <% wallet.transactions.forEach(tx => { %>
                                        <tr class="group">
                                            <td class="whitespace-nowrap">
                                                <div class="text-white font-bold text-xs uppercase tracking-wide"><%= new Date(tx.timestamp).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                                                <div class="text-white/20 text-[9px] mt-1 font-mono uppercase font-semibold"><%= new Date(tx.timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }) %></div>
                                            </td>
                                            <td class="mono-id text-[10px] text-white/30 uppercase">
                                                <%= tx.txnId || 'N/A' %>
                                            </td>
                                            <td>
                                                <% if (tx.orderId) { %>
                                                    <a href="/account/orders/<%= tx.orderId %>" class="order-link">#<%= tx.orderId.split('-')[1] || tx.orderId %></a>
                                                <% } else { %>
                                                    <span class="text-white/10">—</span>
                                                <% } %>
                                            </td>
                                            <td class="max-w-xs truncate font-medium">
                                                <%= tx.description %>
                                            </td>
                                            <td>
                                                <span class="status-success">Success</span>
                                            </td>
                                            <td style="text-align: right;" class="<%= tx.type === 'credit' ? 'amount-credit' : 'amount-debit' %>">
                                                <%= tx.type === 'credit' ? '+' : '-' %>₹<%= tx.amount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="py-24 text-center">
                                            <p class="text-white/10 text-[10px] font-black uppercase tracking-[0.4em] border border-dashed border-white/5 py-16">System idle. No activity sequences detected.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Top-up Modal (iOS Glassmorphism Redesign) -->
    <div x-show="showModal" 
         x-cloak 
         class="fixed inset-0 z-[100] flex items-center justify-center p-6 select-none"
         x-transition:enter="transition duration-300 ease-out"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition duration-200 ease-in"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0">
        
        <!-- Drastic Backdrop -->
        <div class="absolute inset-0 bg-black/60 backdrop-blur-[20px]" @click="if(!isProcessing) showModal = false"></div>
        
        <!-- Modal Container -->
        <div class="w-full max-w-[340px] bg-white/[0.08] backdrop-blur-[30px] border border-white/10 rounded-[24px] shadow-2xl relative z-10 overflow-hidden flex flex-col"
             x-show="showModal"
             x-transition:enter="transition cubic-bezier(0.34, 1.56, 0.64, 1) duration-500 transform"
             x-transition:enter-start="opacity-0 scale-110 translate-y-4"
             x-transition:enter-end="opacity-100 scale-100 translate-y-0"
             x-transition:leave="transition ease-in duration-200 transform"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 scale-95">
            
            <!-- Content Section -->
            <div class="p-8 space-y-8 text-center">
                <div class="space-y-2">
                    <h3 class="display-heading text-2xl tracking-tighter">Top Up <span class="text-accent italic">Credits.</span></h3>
                    <p class="text-[10px] font-medium text-white/40 uppercase tracking-widest">Protocol Upgrade Sequence</p>
                </div>

                <!-- Input Zone -->
                <div class="space-y-4">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-accent/10 blur-xl opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
                        <input type="number" 
                               x-model="topupAmount" 
                               class="relative w-full bg-white/[0.03] border border-white/10 text-white rounded-xl px-4 py-6 text-center font-display font-black text-4xl focus:outline-none focus:border-accent/40 transition-all placeholder:text-white/5" 
                               placeholder="0">
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 text-white/10 font-black text-xl">₹</span>
                    </div>
                    <p class="text-[9px] text-white/20 font-bold uppercase tracking-widest">Minimum Sequence: ₹100.00</p>
                </div>

                <!-- Quick Select -->
                <div class="grid grid-cols-3 gap-2">
                    <template x-for="amt in [500, 1000, 5000]">
                        <button @click="topupAmount = amt" 
                                class="py-3 rounded-lg border border-white/5 bg-white/5 text-[10px] font-black uppercase text-white/50 hover:bg-white/10 hover:border-white/20 transition-all active:scale-95" 
                                x-text="'₹' + amt"></button>
                    </template>
                </div>
            </div>

            <!-- Action Grid (iOS Style) -->
            <div class="flex border-t border-white/10">
                <button @click="showModal = false" 
                        :disabled="isProcessing"
                        class="flex-1 py-5 text-[11px] font-black uppercase tracking-widest text-white/40 hover:bg-white/[0.02] transition-colors border-r border-white/10 disabled:opacity-30">
                    Dismiss
                </button>
                <button @click="initiateTopup" 
                        :disabled="isProcessing || topupAmount < 100" 
                        class="flex-1 py-5 text-[11px] font-black uppercase tracking-widest text-accent hover:bg-accent/5 transition-colors disabled:opacity-30 flex items-center justify-center gap-2">
                    <span x-show="!isProcessing">Initialize</span>
                    <svg x-show="isProcessing" class="animate-spin h-3.5 w-3.5" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    <span x-show="isProcessing">Active...</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    function walletManager() {
        return {
            showModal: false,
            topupAmount: '',
            isProcessing: false,
            razorpayKey: '<%= razorpayKeyId %>',

            openTopupModal() {
                this.topupAmount = '';
                this.showModal = true;
            },

            async initiateTopup() {
                if (this.topupAmount < 100) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Minimum sequence of ₹100 required.', type: 'error' } }));
                    return;
                }

                this.isProcessing = true;
                try {
                    const res = await fetch('/account/wallet/topup/create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount: this.topupAmount })
                    });
                    const data = await res.json();

                    if (data.success) {
                        this.openRazorpay(data.razorpayOrder);
                    } else {
                        throw new Error(data.message);
                    }
                } catch (err) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: err.message, type: 'error' } }));
                    this.isProcessing = false;
                }
            },

            openRazorpay(order) {
                const options = {
                    key: this.razorpayKey,
                    amount: order.amount,
                    currency: order.currency,
                    name: "STARZO MOBILES",
                    description: "Wallet Protocol Upgrade",
                    order_id: order.id,
                    handler: async (response) => {
                        await this.verifyTopup(response);
                    },
                    modal: {
                        ondismiss: () => { this.isProcessing = false; }
                    },
                    theme: { color: "#ff6a00" }
                };
                const rzp = new Razorpay(options);
                rzp.open();
            },

            async verifyTopup(razorpayResponse) {
                try {
                    const res = await fetch('/account/wallet/topup/verify', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            ...razorpayResponse,
                            amount: this.topupAmount
                        })
                    });
                    const data = await res.json();

                    if (data.success) {
                        window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: 'Wallet protocol upgraded successfully.', type: 'success' } }));
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        throw new Error(data.message);
                    }
                } catch (err) {
                    window.dispatchEvent(new CustomEvent('show-toast', { detail: { message: err.message, type: 'error' } }));
                    this.isProcessing = false;
                }
            }
        }
    }
</script>
