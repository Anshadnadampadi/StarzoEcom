<%- contentFor('body') %>

<style>
    .wallet-container {
        font-family: 'Inter', sans-serif;
        background-color: #050505;
        color: #ffffff;
        min-height: 100vh;
    }

    .display-heading {
        font-family: 'Outfit', sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        color: #ffffff;
    }

    .balance-card {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 3.5rem;
        margin-bottom: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .balance-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255, 106, 0, 0.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .label-xs {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.25em;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        display: block;
        font-family: 'Outfit', sans-serif;
    }

    .balance-amount {
        font-size: 4.5rem;
        font-weight: 900;
        letter-spacing: -0.03em;
        color: #ffffff;
        font-family: 'Outfit', sans-serif;
    }

    .btn-add-money {
        background-color: #ff6a00;
        color: #000000;
        padding: 1.2rem 2.8rem;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: none;
        cursor: pointer;
        font-family: 'Outfit', sans-serif;
        box-shadow: 0 10px 30px rgba(255, 106, 0, 0.2);
    }

    .btn-add-money:hover {
        background-color: #ffffff;
        color: #000000;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(255, 255, 255, 0.1);
    }

    .transaction-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 2rem;
    }

    .transaction-table th {
        text-align: left;
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.4);
        padding: 2.2rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        font-family: 'Outfit', sans-serif;
    }

    .transaction-table td {
        padding: 2.2rem 0;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.6);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-weight: 500;
    }

    .transaction-table tr:hover td {
        color: #ffffff;
        background: rgba(255, 255, 255, 0.01);
    }

    .status-success {
        color: #10b981;
        font-weight: 900;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-family: 'Outfit', sans-serif;
    }

    .status-success::before {
        content: '';
        width: 6px;
        height: 6px;
        background-color: #10b981;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 12px #10b981;
    }

    .status-pending {
        color: #f59e0b;
        font-weight: 900; font-size: 9px; text-transform: uppercase; letter-spacing: 0.15em;
        display: flex; align-items: center; gap: 0.6rem; font-family: 'Outfit', sans-serif;
    }
    .status-pending::before {
        content: ''; width: 6px; height: 6px; background-color: #f59e0b; border-radius: 50%; 
        display: inline-block; box-shadow: 0 0 12px #f59e0b;
    }

    .status-failed {
        color: #ef4444;
        font-weight: 900; font-size: 9px; text-transform: uppercase; letter-spacing: 0.15em;
        display: flex; align-items: center; gap: 0.6rem; font-family: 'Outfit', sans-serif;
    }
    .status-failed::before {
        content: ''; width: 6px; height: 6px; background-color: #ef4444; border-radius: 50%; 
        display: inline-block; box-shadow: 0 0 12px #ef4444;
    }

    .amount-credit {
        color: #10b981;
        font-weight: 900;
        font-size: 15px;
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.01em;
    }

    .amount-debit {
        color: #ef4444;
        font-weight: 900;
        font-size: 15px;
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.01em;
    }

    .order-link {
        color: #ff6a00;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 106, 0, 0.3);
        font-weight: 800;
        padding-bottom: 2px;
        transition: all 0.3s ease;
        font-family: 'Outfit', sans-serif;
    }

    .order-link:hover {
        color: #ffffff;
        border-bottom-color: #ffffff;
    }

    .mono-id {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 600;
    }

    /* x-cloak: hide until Alpine initialises */
    [x-cloak] { display: none !important; }

    /* Modal overlay — only positioning, z-index. Display managed by Alpine */
    .topup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 99999;
        align-items: center;
        justify-content: center;
    }

    /* Custom Scrollbar for dark theme */
    .custom-scrollbar::-webkit-scrollbar {
        height: 4px;
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #ff6a00;
    }
</style>

<div class="wallet-container py-24 relative overflow-hidden" x-data="walletManager()">
    <!-- Ambient Gloom -->
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-accent/5 to-transparent pointer-events-none"></div>

    <div class="max-w-screen-xl mx-auto px-6 lg:px-8 relative z-10">
        
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            
            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <%- include('../partials/account-sidebar', { activeTab: 'wallet' }) %>
            </div>

            <!-- Content Area -->
            <div class="lg:col-span-3">
                
                <div class="mb-16">
                    <h1 class="display-heading text-6xl mb-4">My <span class="text-accent italic">Wallet.</span></h1>
                    <p class="text-[10px] font-black text-white/30 uppercase tracking-[0.4em]">Integrated Credit protocol & Transaction history</p>
                </div>

                <!-- Balance Section -->
                <div class="balance-card">
                    <div class="space-y-2">
                        <span class="label-xs">Active Liquidity</span>
                        <div class="balance-amount">₹<%= (wallet ? wallet.balance : 0).toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></div>
                    </div>
                    <button @click="window.dispatchEvent(new CustomEvent('open-topup-modal'))" class="btn-add-money">Top Up Wallet</button>
                </div>

                <!-- History Section -->
                <div class="mt-20">
                    <div class="flex items-center justify-between border-b border-white/5 pb-10 mb-10">
                        <h2 class="display-heading text-3xl">Transaction <span class="text-accent italic">History.</span></h2>
                        <span class="text-[9px] font-black text-white/20 uppercase tracking-[0.3em]"><%= (wallet ? wallet.transactions.length : 0) %> Events Logged</span>
                    </div>
                    
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="transaction-table">
                            <thead>
                                <tr>
                                    <th>Date & Time</th>
                                    <th>Transaction ID</th>
                                    <th>Order ID</th>
                                    <th>Process Abstract</th>
                                    <th>Status</th>
                                    <th style="text-align: right;">Magnitude</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>
                                    <% wallet.transactions.forEach(tx => { %>
                                        <tr class="group">
                                            <td class="whitespace-nowrap">
                                                <div class="text-white font-bold text-xs uppercase tracking-wide"><%= new Date(tx.timestamp).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                                                <div class="text-white/20 text-[9px] mt-1 font-mono uppercase font-semibold"><%= new Date(tx.timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }) %></div>
                                            </td>
                                            <td class="mono-id text-[10px] text-white/30 uppercase">
                                                <%= tx.txnId || 'N/A' %>
                                            </td>
                                            <td>
                                                <% if (tx.orderId) { %>
                                                    <a href="/account/orders/<%= tx.orderId %>" class="order-link">#<%= tx.orderId.split('-')[1] || tx.orderId %></a>
                                                <% } else { %>
                                                    <span class="text-white/10">—</span>
                                                <% } %>
                                            </td>
                                            <td class="max-w-xs truncate font-medium">
                                                <%= tx.description %>
                                            </td>
                                            <td>
                                                <span class="<%= 
                                                    tx.status === 'Success' ? 'status-success' : 
                                                    tx.status === 'Pending' ? 'status-pending' : 'status-failed' 
                                                %>">
                                                    <%= tx.status || 'Success' %>
                                                </span>
                                            </td>
                                            <td style="text-align: right;" class="<%= tx.type === 'credit' ? 'amount-credit' : 'amount-debit' %>">
                                                <%= tx.type === 'credit' ? '+' : '-' %>₹<%= tx.amount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="py-24 text-center">
                                            <p class="text-white/10 text-[10px] font-black uppercase tracking-[0.4em] border border-dashed border-white/5 py-16">System idle. No activity sequences detected.</p>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    // Expose Razorpay key for the global top-up modal in main layout
    window.__RZPKEY__ = '<%= razorpayKeyId %>';

    function walletManager() {
        return {};
    }
</script>
